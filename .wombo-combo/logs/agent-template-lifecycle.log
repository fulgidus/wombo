ents,\n  queuedAgents,\n  isWaveComplete,\n  type WaveState,\n  type AgentState,\n} from \"../lib/state.js\";\nimport {\n  createWorktree,\n  installDeps,\n  featureBranchName,\n  worktreePath,\n  worktreeReady,\n  removeWorktree,\n  log as wtLog,\n} from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport {\n  launchHeadless,\n  retryHeadless,\n  launchInteractive,\n  retryInteractive,\n  isProcessRunning,\n} from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";\nimport { runBuild } from \"../lib/verifier.js\";\nimport { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\nimport {\n  printDashboard,\n  printFeatureSelection,\n  printAgentUpdate,\n} from \"../lib/ui.js\";\nimport { WomboTUI } from \"../lib/tui.js\";"},"output":"Edit applied successfully.\n\nLSP errors detected in this file, please fix:\n<diagnostics file=\"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/launch.ts\">\nERROR [59:10] Module '\"../lib/templates.js\"' has no exported member 'ensureAgentDefinition'.\n</diagnostics>","title":"src/commands/launch.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/init.ts":[],"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/launch.ts":[{"range":{"start":{"line":58,"character":9},"end":{"line":58,"character":30}},"message":"Module '\"../lib/templates.js\"' has no exported member 'ensureAgentDefinition'.","severity":1,"code":2305,"source":"typescript"},{"range":{"start":{"line":21,"character":2},"end":{"line":21,"character":11}},"message":"'loadState' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":46,"character":2},"end":{"line":46,"character":18}},"message":"'retryInteractive' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":58,"character":0},"end":{"line":58,"charac