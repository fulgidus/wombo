{"type":"tool_use","timestamp":1773245121477,"sessionID":"ses_3225b064fffe2278ZpH9B8kavM","part":{"id":"prt_cdda5425f001GQsO0C2AoqKEIi","sessionID":"ses_3225b064fffe2278ZpH9B8kavM","messageID":"msg_cdda52b2f0016t63s6SSBnV9n6","type":"tool","callID":"toolu_01JeTePLPZES7f2zpRj7uHB5","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/prompt.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/prompt.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * prompt.ts — Generate agent prompts from feature specs.\n3:  *\n4:  * Responsibilities:\n5:  *   - Transform a Feature into a structured prompt for the agent\n6:  *   - Include feature spec, subtasks, constraints, forbidden items, references\n7:  *   - Generate the build command and success criteria\n8:  *   - All project-specific values come from config (no hardcoded Astro references)\n9:  */\n10: \n11: import type { Feature, Subtask } from \"./features.js\";\n12: import { formatDuration, parseDurationMinutes } from \"./features.js\";\n13: import type { WomboConfig } from \"../config.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Prompt Generation\n17: // ---------------------------------------------------------------------------\n18: \n19: /**\n20:  * Generate the full prompt for an autonomous agent working on a feature.\n21:  */\n22: export function generatePrompt(\n23:   feature: Feature,\n24:   baseBranch: string,\n25:   config: WomboConfig\n26: ): string {\n27:   const sections: string[] = [];\n28: \n29:   // Header\n30:   sections.push(`# Feature Implementation: ${feature.title}`);\n31:   sections.push(`**Feature ID:** \\`${feature.id}\\``);\n32:   sections.push(`**Branch:** \\`${config.git.branchPrefix}${feature.id}\\``);\n33:   sections.push(`**Base:** \\`${baseBranch}\\``);\n34:   sections.push(\n35:     `**Estimated Effort:** ${formatDuration(parseDurationMinutes(feature.effort))}`\n36:   );\n37:   sections.push(\n38:     `**Difficulty:** ${feature.difficulty} | **Priority:** ${feature.priority}`\n39:   );\n40: \n41:   // Description\n42:   sections.push(`\\n## Description\\n`);\n43:   sections.push(feature.description.trim());\n44: \n45:   // Subtasks\n46:   if (feature.subtasks.length > 0) {\n47:     sections.push(`\\n## Subtasks\\n`);\n48:     sections.push(\n49:       \"Complete these in order. Mark each done with a commit when finished.\\n\"\n50:     );\n51:     for (let i = 0; i < feature.subtasks.length; i++) {\n52:       sections.push(formatSubtask(feature.subtasks[i], i + 1, 0));\n53:     }\n54:   }\n55: \n56:   // Constraints\n57:   if (feature.constraints.length > 0) {\n58:     sections.push(`\\n## Constraints\\n`);\n59:     sections.push(\n60:       \"You MUST follow these constraints. Violating any is a failure.\\n\"\n61:     );\n62:     for (const c of feature.constraints) {\n63:       sections.push(`- ${c}`);\n64:     }\n65:   }\n66: \n67:   // Forbidden\n68:   if (feature.forbidden.length > 0) {\n69:     sections.push(`\\n## Forbidden\\n`);\n70:     sections.push(\n71:       \"You MUST NOT do any of the following. Violating any is a failure.\\n\"\n72:     );\n73:     for (const f of feature.forbidden) {\n74:       sections.push(`- ${f}`);\n75:     }\n76:   }\n77: \n78:   // References (files to explore)\n79:   if (feature.references.length > 0) {\n80:     sections.push(`\\n## Key Files to Explore\\n`);\n81:     sections.push(\n82:       \"Start by reading these files to understand the current state:\\n\"\n83:     );\n84:     for (const r of feature.references) {\n85:       sections.push(`- \\`${r}\\``);\n86:     }\n87:   }\n88: \n89:   // Notes\n90:   if (feature.notes.length > 0) {\n91:     sections.push(`\\n## Planning Notes\\n`);\n92:     for (const n of feature.notes) {\n93:       sections.push(`- ${n}`);\n94:     }\n95:   }\n96: \n97:   // Build verification — uses config, no hardcoded Astro command\n98:   sections.push(`\\n## Build Verification\\n`);\n99:   sections.push(\n100:     \"After completing all changes, run the build to verify everything works:\\n\"\n101:   );\n102:   sections.push(\"```bash\");\n103:   sections.push(config.build.command);\n104:   sections.push(\"```\\n\");\n105:   sections.push(\n106:     \"If the build fails, fix the errors before considering the task complete.\"\n107:   );\n108: \n109:   // Commit guidelines\n110:   sections.push(`\\n## Commit Guidelines\\n`);\n111:   sections.push(\"- Use conventional commits: `feat(scope):`, `fix(scope):`, `refactor(scope):`, `docs(scope):`\");\n112:   sections.push(`- Scope should be: \\`${feature.id}\\` or a relevant module name`);\n113:   sections.push(\"- Commit after each logical unit of work (roughly per subtask)\");\n114:   sections.push(\"- Do NOT squash all changes into one commit\");\n115:   sections.push(\"- Do NOT push to remote -- the orchestrator handles that\");\n116:   sections.push(`- Do NOT modify \\`${config.featuresFile}\\` -- the orchestrator handles that`);\n117: \n118:   // Final instruction\n119:   sections.push(`\\n## Execution\\n`);\n120:   sections.push(\"1. Read the key files listed above to understand the codebase\");\n121:   sections.push(\"2. Create a plan (use the TodoWrite tool)\");\n122:   sections.push(\"3. Implement each subtask, committing as you go\");\n123:   sections.push(`4. Run \\`${config.build.command}\\` to verify`);\n124:   sections.push(\"5. If the build passes, you are done\");\n125:   sections.push(\"6. If the build fails, fix the errors and re-run until it passes\");\n126: \n127:   return sections.join(\"\\n\");\n128: }\n129: \n130: // ---------------------------------------------------------------------------\n131: // Subtask Formatting\n132: // ---------------------------------------------------------------------------\n133: \n134: function formatSubtask(\n135:   subtask: Subtask,\n136:   index: number,\n137:   depth: number\n138: ): string {\n139:   const indent = \"  \".repeat(depth);\n140:   const lines: string[] = [];\n141: \n142:   lines.push(\n143:     `${indent}${index}. **${subtask.title}** (\\`${subtask.id}\\`, ${formatDuration(parseDurationMinutes(subtask.effort))})`\n144:   );\n145:   lines.push(`${indent}   ${subtask.description.trim()}`);\n146: \n147:   if (subtask.constraints.length > 0) {\n148:     for (const c of subtask.constraints) {\n149:       lines.push(`${indent}   - Constraint: ${c}`);\n150:     }\n151:   }\n152:   if (subtask.forbidden.length > 0) {\n153:     for (const f of subtask.forbidden) {\n154:       lines.push(`${indent}   - Forbidden: ${f}`);\n155:     }\n156:   }\n157:   if (subtask.references.length > 0) {\n158:     lines.push(\n159:       `${indent}   - Files: ${subtask.references.map((r) => `\\`${r}\\``).join(\", \")}`\n160:     );\n161:   }\n162:   if (subtask.depends_on.length > 0) {\n163:     lines.push(\n164:       `${indent}   - Depends on: ${subtask.depends_on.map((d) => `\\`${d}\\``).join(\", \")}`\n165:     );\n166:   }\n167: \n168:   // Nested subtasks\n169:   if (subtask.subtasks.length > 0) {\n170:     for (let i = 0; i < subtask.subtasks.length; i++) {\n171:       lines.push(formatSubtask(subtask.subtasks[i], i + 1, depth + 1));\n172:     }\n173:   }\n174: \n175:   return lines.join(\"\\n\");\n176: }\n\n(End of file - total 176 lines)\n</content>","title":"src/lib/prompt.ts","metadata":{"preview":"/**\n * prompt.ts — Generate agent prompts from feature specs.\n *\n * Responsibilities:\n *   - Transform a Feature into a structured prompt for the agent\n *   - Include feature spec, subtasks, constraints, forbidden items, references\n *   - Generate the build command and success criteria\n *   - All project-specific values come from config (no hardcoded Astro references)\n */\n\nimport type { Feature, Subtask } from \"./features.js\";\nimport { formatDuration, parseDurationMinutes } from \"./features.js\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Prompt Generation\n// ---------------------------------------------------------------------------\n\n/**\n * Generate the full prompt for an autonomous agent working on a feature.","truncated":false,"loaded":[]},"time":{"start":1773245121469,"end":1773245121476}}}}
