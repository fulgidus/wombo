{"type":"tool_use","timestamp":1773245113669,"sessionID":"ses_3225b064fffe2278ZpH9B8kavM","part":{"id":"prt_cdda524720014UZ8yfYlKphH4f","sessionID":"ses_3225b064fffe2278ZpH9B8kavM","messageID":"msg_cdda5156b001NSsLzHVjNO2Ciu","type":"tool","callID":"toolu_014ePeNqMfpFXJycyNwa3X3G","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/init.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/init.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * init.ts — Interactive guided setup for wombo.json.\n3:  *\n4:  * Usage: wombo init [--force]\n5:  *\n6:  * Walks the user through every config section, showing defaults and\n7:  * accepting overrides.  Press Enter on any prompt to keep the default.\n8:  */\n9: \n10: import { existsSync, writeFileSync, readFileSync } from \"node:fs\";\n11: import { resolve } from \"node:path\";\n12: import { createInterface } from \"node:readline\";\n13: import { CONFIG_FILE, DEFAULT_CONFIG, type WomboConfig } from \"../config.js\";\n14: import { FEATURES_TEMPLATE_PATH } from \"../lib/features.js\";\n15: \n16: export interface InitOptions {\n17:   projectRoot: string;\n18:   force?: boolean;\n19: }\n20: \n21: // ---------------------------------------------------------------------------\n22: // Prompt helper — reads one line at a time from stdin\n23: // ---------------------------------------------------------------------------\n24: \n25: class Prompter {\n26:   private lines: AsyncIterableIterator<string>;\n27:   private done = false;\n28:   private rl: ReturnType<typeof createInterface>;\n29: \n30:   constructor() {\n31:     this.rl = createInterface({ input: process.stdin, output: process.stdout, terminal: process.stdin.isTTY ?? false });\n32:     this.lines = this.rl[Symbol.asyncIterator]();\n33:   }\n34: \n35:   /** Read one line from stdin after printing the prompt. */\n36:   private async ask(prompt: string): Promise<string> {\n37:     if (this.done) return \"\";\n38:     process.stdout.write(prompt);\n39:     const result = await this.lines.next();\n40:     if (result.done) {\n41:       this.done = true;\n42:       return \"\";\n43:     }\n44:     return result.value.trim();\n45:   }\n46: \n47:   async string(label: string, defaultVal: string): Promise<string> {\n48:     const answer = await this.ask(`  ${label} [${defaultVal}]: `);\n49:     return answer || defaultVal;\n50:   }\n51: \n52:   async number(label: string, defaultVal: number): Promise<number> {\n53:     const answer = await this.ask(`  ${label} [${defaultVal}]: `);\n54:     if (!answer) return defaultVal;\n55:     const n = parseInt(answer, 10);\n56:     return isNaN(n) ? defaultVal : n;\n57:   }\n58: \n59:   async stringOrNull(label: string, defaultVal: string | null): Promise<string | null> {\n60:     const display = defaultVal ?? \"auto-detect\";\n61:     const answer = await this.ask(`  ${label} [${display}]: `);\n62:     if (!answer) return defaultVal;\n63:     if (answer.toLowerCase() === \"null\" || answer.toLowerCase() === \"auto\") return null;\n64:     return answer;\n65:   }\n66: \n67:   async stringList(label: string, defaultVal: string[]): Promise<string[]> {\n68:     const display = defaultVal.join(\", \");\n69:     const answer = await this.ask(`  ${label} [${display}]: `);\n70:     if (!answer) return defaultVal;\n71:     return answer.split(\",\").map((s) => s.trim()).filter(Boolean);\n72:   }\n73: \n74:   close(): void {\n75:     this.rl.close();\n76:   }\n77: }\n78: \n79: // ---------------------------------------------------------------------------\n80: // Section printer\n81: // ---------------------------------------------------------------------------\n82: \n83: function section(title: string): void {\n84:   console.log(`\\n--- ${title} ${\"─\".repeat(Math.max(0, 56 - title.length))}`);\n85: }\n86: \n87: // ---------------------------------------------------------------------------\n88: // Command\n89: // ---------------------------------------------------------------------------\n90: \n91: export async function cmdInit(opts: InitOptions): Promise<void> {\n92:   const configPath = resolve(opts.projectRoot, CONFIG_FILE);\n93: \n94:   if (existsSync(configPath) && !opts.force) {\n95:     console.error(\n96:       `${CONFIG_FILE} already exists. Use --force to overwrite.`\n97:     );\n98:     process.exit(1);\n99:   }\n100: \n101:   console.log(`\\nWombo — Project Setup`);\n102:   console.log(`Configuring ${CONFIG_FILE} for ${opts.projectRoot}`);\n103:   console.log(`Press Enter to accept the default shown in [brackets].\\n`);\n104: \n105:   const p = new Prompter();\n106: \n107:   try {\n108:     const cfg: WomboConfig = structuredClone(DEFAULT_CONFIG);\n109: \n110:     // -- General ----------------------------------------------------------\n111:     section(\"General\");\n112:     cfg.featuresFile = await p.string(\"Features YAML file\", cfg.featuresFile);\n113:     cfg.baseBranch = await p.string(\"Base branch\", cfg.baseBranch);\n114: \n115:     // -- Build ------------------------------------------------------------\n116:     section(\"Build\");\n117:     cfg.build.command = await p.string(\"Build command\", cfg.build.command);\n118:     cfg.build.timeout = await p.number(\"Build timeout (ms)\", cfg.build.timeout);\n119:     cfg.build.artifactDir = await p.string(\"Artifact directory\", cfg.build.artifactDir);\n120: \n121:     // -- Install ----------------------------------------------------------\n122:     section(\"Install\");\n123:     cfg.install.command = await p.string(\"Install command\", cfg.install.command);\n124:     cfg.install.timeout = await p.number(\"Install timeout (ms)\", cfg.install.timeout);\n125: \n126:     // -- Git --------------------------------------------------------------\n127:     section(\"Git\");\n128:     cfg.git.branchPrefix = await p.string(\"Branch prefix\", cfg.git.branchPrefix);\n129:     cfg.git.worktreePrefix = await p.string(\"Worktree prefix\", cfg.git.worktreePrefix);\n130:     cfg.git.remote = await p.string(\"Remote name\", cfg.git.remote);\n131:     cfg.git.mergeStrategy = await p.string(\"Merge strategy flag\", cfg.git.mergeStrategy);\n132: \n133:     // -- Agent ------------------------------------------------------------\n134:     section(\"Agent\");\n135:     cfg.agent.bin = await p.stringOrNull(\"Agent binary path (or 'auto')\", cfg.agent.bin);\n136:     cfg.agent.name = await p.string(\"Agent name\", cfg.agent.name);\n137:     cfg.agent.configFiles = await p.stringList(\n138:       \"Config files to copy (comma-sep)\",\n139:       cfg.agent.configFiles\n140:     );\n141:     cfg.agent.tmuxPrefix = await p.string(\"tmux session prefix\", cfg.agent.tmuxPrefix);\n142: \n143:     // -- Defaults ---------------------------------------------------------\n144:     section(\"Runtime Defaults\");\n145:     cfg.defaults.maxConcurrent = await p.number(\"Max concurrent agents\", cfg.defaults.maxConcurrent);\n146:     cfg.defaults.maxRetries = await p.number(\"Max retries per agent\", cfg.defaults.maxRetries);\n147: \n148:     // -- Write config ------------------------------------------------------\n149:     console.log(`\\n${\"─\".repeat(60)}`);\n150:     const json = JSON.stringify(cfg, null, 2) + \"\\n\";\n151:     writeFileSync(configPath, json, \"utf-8\");\n152:     console.log(`\\nCreated ${CONFIG_FILE}`);\n153: \n154:     // -- Create features file from template -------------------------------\n155:     const featuresPath = resolve(opts.projectRoot, cfg.featuresFile);\n156:     if (existsSync(featuresPath) && !opts.force) {\n157:       console.log(`${cfg.featuresFile} already exists, skipping.`);\n158:     } else {\n159:       const template = readFileSync(FEATURES_TEMPLATE_PATH, \"utf-8\");\n160:       const now = new Date().toISOString();\n161:       const content = template\n162:         .replace(/created_at:\\s*\".*?\"/, `created_at: \"${now}\"`)\n163:         .replace(/updated_at:\\s*\".*?\"/, `updated_at: \"${now}\"`);\n164:       writeFileSync(featuresPath, content, \"utf-8\");\n165:       console.log(`Created ${cfg.featuresFile} from template.`);\n166:     }\n167: \n168:     console.log(`\\nYou're all set! Run 'wombo help' to see available commands.\\n`);\n169:   } finally {\n170:     p.close();\n171:   }\n172: }\n\n(End of file - total 172 lines)\n</content>","title":"src/commands/init.ts","metadata":{"preview":"/**\n * init.ts — Interactive guided setup for wombo.json.\n *\n * Usage: wombo init [--force]\n *\n * Walks the user through every config section, showing defaults and\n * accepting overrides.  Press Enter on any prompt to keep the default.\n */\n\nimport { existsSync, writeFileSync, readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport { CONFIG_FILE, DEFAULT_CONFIG, type WomboConfig } from \"../config.js\";\nimport { FEATURES_TEMPLATE_PATH } from \"../lib/features.js\";\n\nexport interface InitOptions {\n  projectRoot: string;\n  force?: boolean;\n}\n","truncated":false,"loaded":[]},"time":{"start":1773245113659,"end":1773245113667}}}}
{"type":"tool_use","timestamp":1773245113927,"sessionID":"ses_3225b064fffe2278ZpH9B8kavM","part":{"id":"prt_cdda5253e001XreJ8eo5K7u2oK","sessionID":"ses_3225b064fffe2278ZpH9B8kavM","messageID":"msg_cdda5156b001NSsLzHVjNO2Ciu","type":"tool","callID":"toolu_016rGRBoDtennx9ieSvoYTov","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import type { WomboConfig } from \"../config.js\";\n19: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n20: import { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";\n21: import {\n22:   loadState,\n23:   saveState,\n24:   createWaveState,\n25:   createAgentState,\n26:   updateAgent,\n27:   activeAgents,\n28:   queuedAgents,\n29:   isWaveComplete,\n30:   type WaveState,\n31:   type AgentState,\n32: } from \"../lib/state.js\";\n33: import {\n34:   createWorktree,\n35:   installDeps,\n36:   featureBranchName,\n37:   worktreePath,\n38:   worktreeReady,\n39:   removeWorktree,\n40:   log as wtLog,\n41: } from \"../lib/worktree.js\";\n42: import { generatePrompt } from \"../lib/prompt.js\";\n43: import {\n44:   launchHeadless,\n45:   retryHeadless,\n46:   launchInteractive,\n47:   retryInteractive,\n48:   isProcessRunning,\n49: } from \"../lib/launcher.js\";\n50: import { ProcessMonitor } from \"../lib/monitor.js\";\n51: import { runBuild } from \"../lib/verifier.js\";\n52: import { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\n53: import {\n54:   printDashboard,\n55:   printFeatureSelection,\n56:   printAgentUpdate,\n57: } from \"../lib/ui.js\";\n58: import { WomboTUI } from \"../lib/tui.js\";\n59: \n60: // ---------------------------------------------------------------------------\n61: // Types\n62: // ---------------------------------------------------------------------------\n63: \n64: export interface LaunchCommandOptions {\n65:   projectRoot: string;\n66:   config: WomboConfig;\n67:   // Selection\n68:   topPriority?: number;\n69:   quickestWins?: number;\n70:   priority?: Priority;\n71:   difficulty?: Difficulty;\n72:   features?: string[];\n73:   allReady?: boolean;\n74:   // Launch\n75:   maxConcurrent: number;\n76:   model?: string;\n77:   interactive: boolean;\n78:   dryRun: boolean;\n79:   baseBranch: string;\n80:   maxRetries: number;\n81:   noTui: boolean;\n82:   autoPush: boolean;\n83: }\n84: \n85: // ---------------------------------------------------------------------------\n86: // Shared Helpers (exported for resume.ts and others)\n87: // ---------------------------------------------------------------------------\n88: \n89: /**\n90:  * Launch a single agent in headless mode.\n91:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n92:  */\n93: export async function launchSingleHeadless(\n94:   projectRoot: string,\n95:   state: WaveState,\n96:   agent: AgentState,\n97:   feature: Feature,\n98:   monitor: ProcessMonitor,\n99:   config: WomboConfig,\n100:   model?: string\n101: ): Promise<void> {\n102:   updateAgent(state, agent.feature_id, {\n103:     status: \"installing\",\n104:     started_at: new Date().toISOString(),\n105:     activity: \"setting up worktree...\",\n106:   });\n107:   saveState(projectRoot, state);\n108: \n109:   try {\n110:     // Skip worktree setup if already ready (resume case)\n111:     if (worktreeReady(agent.worktree)) {\n112:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n113:     } else {\n114:       // Create worktree (async — doesn't block other agents)\n115:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n116: \n117:       // Install dependencies (async)\n118:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n119:       await installDeps(agent.worktree, feature.id, config);\n120:     }\n121: \n122:     // Generate prompt\n123:     const prompt = generatePrompt(feature, state.base_branch, config);\n124: \n125:     // Launch agent\n126:     wtLog(agent.feature_id, \"launching agent...\");\n127:     const result = launchHeadless({\n128:       worktreePath: agent.worktree,\n129:       featureId: feature.id,\n130:       prompt,\n131:       model,\n132:       config,\n133:     });\n134: \n135:     updateAgent(state, agent.feature_id, {\n136:       status: \"running\",\n137:       pid: result.pid,\n138:       activity: \"starting...\",\n139:     });\n140:     saveState(projectRoot, state);\n141: \n142:     monitor.addProcess(feature.id, result.process);\n143:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n144:   } catch (err: any) {\n145:     updateAgent(state, agent.feature_id, {\n146:       status: \"failed\",\n147:       error: err.message,\n148:       activity: null,\n149:       completed_at: new Date().toISOString(),\n150:     });\n151:     saveState(projectRoot, state);\n152:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n153:   }\n154: }\n155: \n156: /**\n157:  * Handle build verification after agent completion.\n158:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n159:  *\n160:  * ASYNC — runs build and merge without blocking the event loop.\n161:  */\n162: export async function handleBuildVerification(\n163:   projectRoot: string,\n164:   state: WaveState,\n165:   agent: AgentState,\n166:   feature: Feature,\n167:   config: WomboConfig,\n168:   model?: string,\n169:   monitor?: ProcessMonitor\n170: ): Promise<void> {\n171:   try {\n172:     printAgentUpdate(agent, \"verifying build...\");\n173: \n174:     const buildResult = await runBuild(agent.worktree, config);\n175: \n176:     if (buildResult.passed) {\n177:       updateAgent(state, agent.feature_id, {\n178:         status: \"verified\",\n179:         build_passed: true,\n180:         build_output: null,\n181:       });\n182:       saveState(projectRoot, state);\n183:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n184: \n185:       // Auto-merge: merge verified branch into base immediately\n186:       printAgentUpdate(agent, \"auto-merging...\");\n187:       try {\n188:         const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n189: \n190:         if (mergeResult.success) {\n191:           updateAgent(state, agent.feature_id, {\n192:             status: \"merged\",\n193:             completed_at: new Date().toISOString(),\n194:           });\n195:           saveState(projectRoot, state);\n196:           printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n197: \n198:           // Clean up worktree after successful merge\n199:           try {\n200:             removeWorktree(projectRoot, agent.worktree, false);\n201:             printAgentUpdate(agent, \"worktree removed\");\n202:           } catch {\n203:             // Not critical — worktree cleanup is best-effort\n204:           }\n205:         } else {\n206:           // Merge failed (conflicts, etc.) — leave as verified for manual resolution\n207:           printAgentUpdate(agent, `AUTO-MERGE FAILED: ${mergeResult.error}`);\n208:         }\n209:       } catch (mergeErr: any) {\n210:         printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n211:       }\n212:     } else {\n213:       if (agent.retries < agent.max_retries) {\n214:         updateAgent(state, agent.feature_id, {\n215:           status: \"retry\",\n216:           retries: agent.retries + 1,\n217:           build_passed: false,\n218:           build_output: buildResult.errorSummary,\n219:         });\n220:         saveState(projectRoot, state);\n221:         printAgentUpdate(\n222:           agent,\n223:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n224:         );\n225: \n226:         // Retry with build errors\n227:         if (agent.session_id) {\n228:           const retryResult = retryHeadless({\n229:             worktreePath: agent.worktree,\n230:             featureId: agent.feature_id,\n231:             sessionId: agent.session_id,\n232:             buildErrors: buildResult.errorSummary,\n233:             model,\n234:             config,\n235:           });\n236: \n237:           updateAgent(state, agent.feature_id, {\n238:             status: \"running\",\n239:             pid: retryResult.pid,\n240:           });\n241:           saveState(projectRoot, state);\n242: \n243:           // Add retry process to monitor so events are tracked\n244:           if (monitor) {\n245:             monitor.addProcess(agent.feature_id, retryResult.process);\n246:           }\n247:         }\n248:       } else {\n249:         updateAgent(state, agent.feature_id, {\n250:           status: \"failed\",\n251:           build_passed: false,\n252:           build_output: buildResult.errorSummary,\n253:           error: `Build failed after ${agent.max_retries} retries`,\n254:           completed_at: new Date().toISOString(),\n255:         });\n256:         saveState(projectRoot, state);\n257:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n258:       }\n259:     }\n260:   } catch (err: any) {\n261:     // Catch-all — never let build verification crash the process\n262:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n263:     updateAgent(state, agent.feature_id, {\n264:       status: \"failed\",\n265:       error: `Build verification error: ${err.message}`,\n266:       completed_at: new Date().toISOString(),\n267:     });\n268:     saveState(projectRoot, state);\n269:   }\n270: }\n271: \n272: /**\n273:  * Handle retry of a failed agent (error-based, not build-based).\n274:  */\n275: export function handleRetry(\n276:   projectRoot: string,\n277:   state: WaveState,\n278:   agent: AgentState,\n279:   monitor: ProcessMonitor,\n280:   config: WomboConfig,\n281:   model?: string\n282: ): void {\n283:   if (!agent.session_id || !agent.error) return;\n284: \n285:   const retryResult = retryHeadless({\n286:     worktreePath: agent.worktree,\n287:     featureId: agent.feature_id,\n288:     sessionId: agent.session_id,\n289:     buildErrors: agent.error,\n290:     model,\n291:     config,\n292:   });\n293: \n294:   updateAgent(state, agent.feature_id, {\n295:     status: \"running\",\n296:     pid: retryResult.pid,\n297:   });\n298:   saveState(projectRoot, state);\n299: \n300:   monitor.addProcess(agent.feature_id, retryResult.process);\n301: }\n302: \n303: /**\n304:  * Launch the next queued agent if capacity allows.\n305:  */\n306: export function launchNextQueued(\n307:   projectRoot: string,\n308:   state: WaveState,\n309:   featureMap: Map<string, Feature>,\n310:   monitor: ProcessMonitor,\n311:   config: WomboConfig,\n312:   model?: string\n313: ): void {\n314:   const active = activeAgents(state);\n315:   const queued = queuedAgents(state);\n316: \n317:   if (active.length < state.max_concurrent && queued.length > 0) {\n318:     const next = queued[0];\n319:     const feature = featureMap.get(next.feature_id);\n320:     if (feature) {\n321:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n322:     }\n323:   }\n324: }\n325: \n326: // ---------------------------------------------------------------------------\n327: // Headless Wave Launch\n328: // ---------------------------------------------------------------------------\n329: \n330: async function launchWaveHeadless(\n331:   projectRoot: string,\n332:   state: WaveState,\n333:   features: Feature[],\n334:   opts: LaunchCommandOptions\n335: ): Promise<void> {\n336:   const { config, model } = opts;\n337:   const featureMap = new Map(features.map((f) => [f.id, f]));\n338: \n339:   const monitor = new ProcessMonitor(projectRoot, {\n340:     onSessionId: (featureId, sessionId) => {\n341:       updateAgent(state, featureId, { session_id: sessionId });\n342:       saveState(projectRoot, state);\n343:     },\n344:     onComplete: (featureId) => {\n345:       updateAgent(state, featureId, {\n346:         status: \"completed\",\n347:         completed_at: new Date().toISOString(),\n348:       });\n349:       saveState(projectRoot, state);\n350: \n351:       // Run build verification — fire-and-forget\n352:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n353:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n354:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n355:         .catch((err) => {\n356:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n357:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n358:         });\n359:     },\n360:     onError: (featureId, error) => {\n361:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n362:       if (agent.retries < agent.max_retries) {\n363:         updateAgent(state, featureId, {\n364:           status: \"retry\",\n365:           retries: agent.retries + 1,\n366:           error,\n367:         });\n368:         saveState(projectRoot, state);\n369: \n370:         // Retry\n371:         handleRetry(projectRoot, state, agent, monitor, config, model);\n372:       } else {\n373:         updateAgent(state, featureId, {\n374:           status: \"failed\",\n375:           error,\n376:           completed_at: new Date().toISOString(),\n377:         });\n378:         saveState(projectRoot, state);\n379:       }\n380: \n381:       // Try to launch next queued agent\n382:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n383:     },\n384:     onOutput: (_featureId, _data) => {\n385:       // Raw output — logged to file by ProcessMonitor\n386:     },\n387:     onActivity: (featureId, activity) => {\n388:       updateAgent(state, featureId, {\n389:         activity,\n390:         activity_updated_at: new Date().toISOString(),\n391:       });\n392:       // Don't save to disk on every activity — too frequent.\n393:     },\n394:   });\n395: \n396:   // Create the TUI — it will auto-refresh and show activity from the monitor\n397:   const tuiRef = { current: null as WomboTUI | null };\n398:   const startTUI = () => {\n399:     tuiRef.current = new WomboTUI({\n400:       state,\n401:       monitor,\n402:       projectRoot,\n403:       interactive: false,\n404:       config,\n405:       onQuit: () => {\n406:         // Same as SIGINT — save state and exit\n407:         for (const agent of state.agents) {\n408:           if (agent.status === \"running\") {\n409:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n410:           }\n411:         }\n412:         monitor.killAll();\n413:         saveState(projectRoot, state);\n414:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n415:         process.exit(0);\n416:       },\n417:     });\n418:     tuiRef.current.start();\n419:   };\n420: \n421:   // Handle graceful shutdown\n422:   process.on(\"SIGINT\", () => {\n423:     if (tuiRef.current) tuiRef.current.stop();\n424:     for (const agent of state.agents) {\n425:       if (agent.status === \"running\") {\n426:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n427:       }\n428:     }\n429:     monitor.killAll();\n430:     saveState(projectRoot, state);\n431:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n432:     process.exit(0);\n433:   });\n434: \n435:   // Launch initial batch — set up worktrees in parallel\n436:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n437:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n438: \n439:   await Promise.all(\n440:     tolaunch.map((agent) =>\n441:       launchSingleHeadless(\n442:         projectRoot,\n443:         state,\n444:         agent,\n445:         featureMap.get(agent.feature_id)!,\n446:         monitor,\n447:         config,\n448:         model\n449:       )\n450:     )\n451:   );\n452: \n453:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n454: \n455:   // Start the TUI dashboard (or skip if --no-tui)\n456:   if (opts.noTui) {\n457:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n458:     printDashboard(state);\n459:   } else {\n460:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n461:     startTUI();\n462:   }\n463: \n464:   // Background monitoring loop — checks for dead processes and launches queued\n465:   const POLL_INTERVAL = 5000;\n466:   let dashboardCounter = 0;\n467:   while (!isWaveComplete(state)) {\n468:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n469: \n470:     // Check for completed processes that weren't caught by event handlers\n471:     for (const agent of state.agents) {\n472:       if (\n473:         agent.status === \"running\" &&\n474:         agent.pid &&\n475:         !isProcessRunning(agent.pid) &&\n476:         !monitor.isRunning(agent.feature_id)\n477:       ) {\n478:         // Process exited but we didn't get a callback\n479:         updateAgent(state, agent.feature_id, {\n480:           status: \"completed\",\n481:           completed_at: new Date().toISOString(),\n482:           activity: \"done\",\n483:         });\n484:         saveState(projectRoot, state);\n485:         try {\n486:           await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n487:         } catch (err: any) {\n488:           wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n489:         }\n490:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n491:       }\n492:     }\n493: \n494:     // Persist state periodically\n495:     saveState(projectRoot, state);\n496: \n497:     // Update TUI state reference (or print dashboard in --no-tui mode)\n498:     if (tuiRef.current) {\n499:       tuiRef.current.updateState(state);\n500:     } else if (opts.noTui) {\n501:       dashboardCounter++;\n502:       if (dashboardCounter % 3 === 0) {\n503:         printDashboard(state);\n504: \n505:         // Auto-push base branch if requested\n506:         if (opts.autoPush) {\n507:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n508:           if (anyMerged) {\n509:             await pushBaseBranch(projectRoot, state.base_branch, config);\n510:           } else {\n511:             console.log(\"No branches were merged — skipping push.\");\n512:           }\n513:         }\n514:       }\n515:     }\n516:   }\n517: \n518:   // Wave complete — tear down TUI and show final summary\n519:   if (tuiRef.current) tuiRef.current.stop();\n520:   printDashboard(state);\n521: \n522:   // Auto-push base branch if requested\n523:   if (opts.autoPush) {\n524:     await pushBaseBranch(projectRoot, state.base_branch, config);\n525:   }\n526: \n527:   console.log(\"Wave complete.\");\n528: }\n529: \n530: // ---------------------------------------------------------------------------\n531: // Interactive Wave Launch\n532: // ---------------------------------------------------------------------------\n533: \n534: async function launchWaveInteractive(\n535:   projectRoot: string,\n536:   state: WaveState,\n537:   features: Feature[],\n538:   opts: LaunchCommandOptions\n539: ): Promise<void> {\n540:   const { config, model } = opts;\n541:   const featureMap = new Map(features.map((f) => [f.id, f]));\n542: \n543:   // Show dashboard immediately\n544:   printDashboard(state);\n545: \n546:   // Launch initial batch in tmux — parallelize setup\n547:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n548:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n549: \n550:   await Promise.all(\n551:     tolaunch.map(async (agent) => {\n552:       updateAgent(state, agent.feature_id, {\n553:         status: \"installing\",\n554:         started_at: new Date().toISOString(),\n555:         activity: \"setting up worktree...\",\n556:       });\n557:       saveState(projectRoot, state);\n558: \n559:       try {\n560:         if (worktreeReady(agent.worktree)) {\n561:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n562:         } else {\n563:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n564:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n565:           await installDeps(agent.worktree, agent.feature_id, config);\n566:         }\n567: \n568:         const prompt = generatePrompt(\n569:           featureMap.get(agent.feature_id)!,\n570:           state.base_branch,\n571:           config\n572:         );\n573: \n574:         wtLog(agent.feature_id, \"launching tmux session...\");\n575:         const result = launchInteractive({\n576:           worktreePath: agent.worktree,\n577:           featureId: agent.feature_id,\n578:           prompt,\n579:           model,\n580:           interactive: true,\n581:           config,\n582:         });\n583: \n584:         updateAgent(state, agent.feature_id, {\n585:           status: \"running\",\n586:           pid: result.pid,\n587:           activity: \"tmux session active\",\n588:         });\n589:         saveState(projectRoot, state);\n590:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n591:       } catch (err: any) {\n592:         updateAgent(state, agent.feature_id, {\n593:           status: \"failed\",\n594:           error: err.message,\n595:           activity: null,\n596:           completed_at: new Date().toISOString(),\n597:         });\n598:         saveState(projectRoot, state);\n599:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n600:       }\n601:     })\n602:   );\n603: \n604:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n605:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n606:   console.log(\"  tmux ls                                                  # list sessions\");\n607:   console.log(\"  wombo status                                             # check status\");\n608:   console.log(\"  wombo verify                                             # verify builds\");\n609:   console.log(\"  wombo merge                                              # merge verified\");\n610:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n611: \n612:   printDashboard(state);\n613: }\n614: \n615: // ---------------------------------------------------------------------------\n616: // Main Command\n617: // ---------------------------------------------------------------------------\n618: \n619: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n620:   const { projectRoot, config } = opts;\n621: \n622:   console.log(\"\\n--- Wombo: Launch ---\\n\");\n623: \n624:   // Load features\n625:   const data = loadFeatures(projectRoot, config);\n626: \n627:   // Build selection options\n628:   const selOpts: SelectionOptions = {};\n629:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n630:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n631:   if (opts.priority) selOpts.priority = opts.priority;\n632:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n633:   if (opts.features) selOpts.featureIds = opts.features;\n634:   if (opts.allReady) selOpts.allReady = true;\n635: \n636:   // Select features\n637:   const selected = selectFeatures(data, selOpts);\n638: \n639:   if (selected.length === 0) {\n640:     console.error(\n641:       \"No features matched the selection criteria. Use --all-ready to see all available.\"\n642:     );\n643:     process.exit(1);\n644:   }\n645: \n646:   // Show selection\n647:   printFeatureSelection(\n648:     selected.map((f) => ({\n649:       id: f.id,\n650:       title: f.title,\n651:       priority: f.priority,\n652:       difficulty: f.difficulty,\n653:       effort: f.effort,\n654:     }))\n655:   );\n656: \n657:   if (opts.dryRun) {\n658:     console.log(\"Dry run — not launching agents.\");\n659:     return;\n660:   }\n661: \n662:   // Create wave state\n663:   const state = createWaveState({\n664:     baseBranch: opts.baseBranch,\n665:     maxConcurrent: opts.maxConcurrent,\n666:     model: opts.model ?? null,\n667:     interactive: opts.interactive,\n668:   });\n669: \n670:   // Create agent entries for all selected features\n671:   for (const feature of selected) {\n672:     const branch = featureBranchName(feature.id, config);\n673:     const wtPath = worktreePath(projectRoot, feature.id, config);\n674:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n675:     // Set effort estimate from feature spec\n676:     const effortMinutes = parseDurationMinutes(feature.effort);\n677:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n678:     state.agents.push(agent);\n679:   }\n680: \n681:   saveState(projectRoot, state);\n682:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n683: \n684:   // Launch agents up to max_concurrent\n685:   if (opts.interactive) {\n686:     await launchWaveInteractive(projectRoot, state, selected, opts);\n687:   } else {\n688:     await launchWaveHeadless(projectRoot, state, selected, opts);\n689:   }\n690: }\n\n(End of file - total 690 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\nimport { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773245113918,"end":1773245113926}}}}
{"type":"tool_use","timestamp":1773245114690,"sessionID":"ses_3225b064fffe2278ZpH9B8kavM","part":{"id":"prt_cdda5263f001eAlRBKSSK8WPKU","sessionID":"ses_3225b064fffe2278ZpH9B8kavM","messageID":"msg_cdda5156b001NSsLzHVjNO2Ciu","type":"tool","callID":"toolu_01FNgxCxAzuLyoGBkR8JmMq8","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/worktree.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/worktree.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * worktree.ts — Git worktree lifecycle management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Create feature branches from a base branch\n6:  *   - Create git worktrees for each feature branch\n7:  *   - Run install command in worktrees\n8:  *   - List and remove worktrees\n9:  *   - Copy agent config files into worktrees\n10:  *\n11:  * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n12:  * to allow true parallelism with Promise.all.\n13:  */\n14: \n15: import { exec, execSync } from \"node:child_process\";\n16: import { existsSync, cpSync, statSync } from \"node:fs\";\n17: import { resolve, dirname } from \"node:path\";\n18: import type { WomboConfig } from \"../config.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface WorktreeInfo {\n25:   path: string;\n26:   branch: string;\n27:   head: string;\n28:   bare: boolean;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Diagnostic Logger\n33: // ---------------------------------------------------------------------------\n34: \n35: function ts(): string {\n36:   return new Date().toISOString().slice(11, 19); // HH:MM:SS\n37: }\n38: \n39: export function log(featureId: string, msg: string): void {\n40:   console.log(`  [${ts()}] ${featureId}: ${msg}`);\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // Async Command Runner\n45: // ---------------------------------------------------------------------------\n46: \n47: /**\n48:  * Run a command asynchronously. Returns stdout on success, throws on failure.\n49:  */\n50: function runAsync(\n51:   cmd: string,\n52:   opts?: { cwd?: string; timeoutMs?: number }\n53: ): Promise<string> {\n54:   return new Promise((resolve, reject) => {\n55:     exec(\n56:       cmd,\n57:       {\n58:         cwd: opts?.cwd,\n59:         encoding: \"utf-8\",\n60:         timeout: opts?.timeoutMs ?? 0,\n61:         maxBuffer: 10 * 1024 * 1024,\n62:       },\n63:       (error, stdout, stderr) => {\n64:         if (error) {\n65:           const errMsg = stderr?.trim() || stdout?.trim() || error.message;\n66:           reject(new Error(`Command failed: ${cmd}\\n${errMsg}`));\n67:         } else {\n68:           resolve((stdout ?? \"\").trim());\n69:         }\n70:       }\n71:     );\n72:   });\n73: }\n74: \n75: /**\n76:  * Synchronous run — only for quick, non-blocking operations.\n77:  */\n78: function runSync(\n79:   cmd: string,\n80:   opts?: { cwd?: string; silent?: boolean; timeoutMs?: number }\n81: ): string {\n82:   try {\n83:     return execSync(cmd, {\n84:       cwd: opts?.cwd,\n85:       encoding: \"utf-8\",\n86:       stdio: opts?.silent ? \"pipe\" : [\"pipe\", \"pipe\", \"pipe\"],\n87:       timeout: opts?.timeoutMs,\n88:       maxBuffer: 10 * 1024 * 1024,\n89:     }).trim();\n90:   } catch (err: any) {\n91:     const stderr = err.stderr?.toString().trim() || \"\";\n92:     const stdout = err.stdout?.toString().trim() || \"\";\n93:     throw new Error(\n94:       `Command failed: ${cmd}\\n${stderr || stdout || err.message}`\n95:     );\n96:   }\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Branch Management\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Create a feature branch from the base branch. If it already exists, reset it.\n105:  */\n106: async function createBranch(\n107:   projectRoot: string,\n108:   branchName: string,\n109:   baseBranch: string\n110: ): Promise<void> {\n111:   const existing = await runAsync(\n112:     `git branch --list \"${branchName}\"`,\n113:     { cwd: projectRoot }\n114:   );\n115:   if (existing.trim()) {\n116:     try {\n117:       await runAsync(`git branch -D \"${branchName}\"`, { cwd: projectRoot });\n118:     } catch {\n119:       // May fail if checked out in a worktree\n120:     }\n121:   }\n122:   await runAsync(`git branch \"${branchName}\" \"${baseBranch}\"`, {\n123:     cwd: projectRoot,\n124:   });\n125: }\n126: \n127: /**\n128:  * Generate the branch name for a feature using config prefix.\n129:  */\n130: export function featureBranchName(\n131:   featureId: string,\n132:   config: WomboConfig\n133: ): string {\n134:   return `${config.git.branchPrefix}${featureId}`;\n135: }\n136: \n137: /**\n138:  * Generate the worktree path for a feature (sibling directory to project root).\n139:  */\n140: export function worktreePath(\n141:   projectRoot: string,\n142:   featureId: string,\n143:   config: WomboConfig\n144: ): string {\n145:   const parentDir = dirname(projectRoot);\n146:   return resolve(parentDir, `${config.git.worktreePrefix}${featureId}`);\n147: }\n148: \n149: // ---------------------------------------------------------------------------\n150: // Worktree Lifecycle (async)\n151: // ---------------------------------------------------------------------------\n152: \n153: /**\n154:  * Create a git worktree for a feature branch.\n155:  * Returns the absolute path to the worktree.\n156:  */\n157: export async function createWorktree(\n158:   projectRoot: string,\n159:   featureId: string,\n160:   baseBranch: string,\n161:   config: WomboConfig\n162: ): Promise<string> {\n163:   const branch = featureBranchName(featureId, config);\n164:   const wtPath = worktreePath(projectRoot, featureId, config);\n165: \n166:   // Create the branch if it doesn't exist\n167:   log(featureId, \"creating branch...\");\n168:   await createBranch(projectRoot, branch, baseBranch);\n169: \n170:   // Remove existing worktree if present\n171:   if (existsSync(wtPath)) {\n172:     log(featureId, \"removing old worktree...\");\n173:     try {\n174:       await runAsync(`git worktree remove --force \"${wtPath}\"`, {\n175:         cwd: projectRoot,\n176:       });\n177:     } catch {\n178:       await runAsync(`rm -rf \"${wtPath}\"`);\n179:       await runAsync(`git worktree prune`, { cwd: projectRoot });\n180:     }\n181:   }\n182: \n183:   // Create the worktree\n184:   log(featureId, \"creating worktree...\");\n185:   await runAsync(`git worktree add \"${wtPath}\" \"${branch}\"`, {\n186:     cwd: projectRoot,\n187:   });\n188: \n189:   // Copy agent config files into worktree\n190:   for (const configFile of config.agent.configFiles) {\n191:     const srcPath = resolve(projectRoot, configFile);\n192:     if (!existsSync(srcPath)) continue;\n193: \n194:     const destPath = resolve(wtPath, configFile);\n195:     try {\n196:       const stat = statSync(srcPath);\n197:       if (stat.isDirectory()) {\n198:         cpSync(srcPath, destPath, { recursive: true });\n199:       } else {\n200:         cpSync(srcPath, destPath);\n201:       }\n202:     } catch {\n203:       // Non-critical — best effort\n204:     }\n205:   }\n206: \n207:   log(featureId, \"worktree ready\");\n208:   return wtPath;\n209: }\n210: \n211: /**\n212:  * Install dependencies in a worktree.\n213:  */\n214: export async function installDeps(\n215:   wtPath: string,\n216:   featureId: string,\n217:   config: WomboConfig\n218: ): Promise<void> {\n219:   log(featureId, `running ${config.install.command}...`);\n220:   const start = Date.now();\n221:   await runAsync(config.install.command, {\n222:     cwd: wtPath,\n223:     timeoutMs: config.install.timeout,\n224:   });\n225:   const elapsed = ((Date.now() - start) / 1000).toFixed(1);\n226:   log(featureId, `install done (${elapsed}s)`);\n227: }\n228: \n229: /**\n230:  * Check if a worktree already exists and has node_modules.\n231:  */\n232: export function worktreeReady(wtPath: string): boolean {\n233:   return (\n234:     existsSync(wtPath) &&\n235:     existsSync(resolve(wtPath, \"node_modules\"))\n236:   );\n237: }\n238: \n239: // ---------------------------------------------------------------------------\n240: // Worktree Listing / Cleanup (sync)\n241: // ---------------------------------------------------------------------------\n242: \n243: /**\n244:  * List all git worktrees.\n245:  */\n246: export function listWorktrees(projectRoot: string): WorktreeInfo[] {\n247:   const output = runSync(\"git worktree list --porcelain\", {\n248:     cwd: projectRoot,\n249:     silent: true,\n250:   });\n251:   if (!output) return [];\n252: \n253:   const worktrees: WorktreeInfo[] = [];\n254:   let current: Partial<WorktreeInfo> = {};\n255: \n256:   for (const line of output.split(\"\\n\")) {\n257:     if (line.startsWith(\"worktree \")) {\n258:       if (current.path) worktrees.push(current as WorktreeInfo);\n259:       current = { path: line.slice(9), bare: false };\n260:     } else if (line.startsWith(\"HEAD \")) {\n261:       current.head = line.slice(5);\n262:     } else if (line.startsWith(\"branch \")) {\n263:       current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n264:     } else if (line === \"bare\") {\n265:       current.bare = true;\n266:     } else if (line === \"\" && current.path) {\n267:       worktrees.push(current as WorktreeInfo);\n268:       current = {};\n269:     }\n270:   }\n271:   if (current.path) worktrees.push(current as WorktreeInfo);\n272: \n273:   return worktrees;\n274: }\n275: \n276: /**\n277:  * List only wombo-related worktrees.\n278:  */\n279: export function listWomboWorktrees(\n280:   projectRoot: string,\n281:   config: WomboConfig\n282: ): WorktreeInfo[] {\n283:   return listWorktrees(projectRoot).filter((wt) =>\n284:     wt.path.includes(config.git.worktreePrefix)\n285:   );\n286: }\n287: \n288: /**\n289:  * Remove a worktree and optionally delete its branch.\n290:  */\n291: export function removeWorktree(\n292:   projectRoot: string,\n293:   wtPath: string,\n294:   deleteBranchToo: boolean = true\n295: ): void {\n296:   const worktrees = listWorktrees(projectRoot);\n297:   const wt = worktrees.find((w) => w.path === wtPath);\n298: \n299:   try {\n300:     runSync(`git worktree remove --force \"${wtPath}\"`, { cwd: projectRoot });\n301:   } catch {\n302:     if (existsSync(wtPath)) {\n303:       runSync(`rm -rf \"${wtPath}\"`);\n304:     }\n305:     runSync(\"git worktree prune\", { cwd: projectRoot });\n306:   }\n307: \n308:   if (deleteBranchToo && wt?.branch) {\n309:     try {\n310:       runSync(`git branch -D \"${wt.branch}\"`, {\n311:         cwd: projectRoot,\n312:         silent: true,\n313:       });\n314:     } catch {\n315:       // Branch may have been merged or already deleted\n316:     }\n317:   }\n318: }\n319: \n320: /**\n321:  * Remove all wombo-related worktrees and prune.\n322:  */\n323: export function cleanupAllWorktrees(\n324:   projectRoot: string,\n325:   config: WomboConfig\n326: ): number {\n327:   const womboWorktrees = listWomboWorktrees(projectRoot, config);\n328:   let removed = 0;\n329:   for (const wt of womboWorktrees) {\n330:     try {\n331:       removeWorktree(projectRoot, wt.path, false);\n332:       removed++;\n333:     } catch (err: any) {\n334:       console.error(`Failed to remove worktree ${wt.path}: ${err.message}`);\n335:     }\n336:   }\n337:   runSync(\"git worktree prune\", { cwd: projectRoot });\n338:   return removed;\n339: }\n\n(End of file - total 339 lines)\n</content>","title":"src/lib/worktree.ts","metadata":{"preview":"/**\n * worktree.ts — Git worktree lifecycle management.\n *\n * Responsibilities:\n *   - Create feature branches from a base branch\n *   - Create git worktrees for each feature branch\n *   - Run install command in worktrees\n *   - List and remove worktrees\n *   - Copy agent config files into worktrees\n *\n * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n * to allow true parallelism with Promise.all.\n */\n\nimport { exec, execSync } from \"node:child_process\";\nimport { existsSync, cpSync, statSync } from \"node:fs\";\nimport { resolve, dirname } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773245114685,"end":1773245114689}}}}
{"type":"tool_use","timestamp":1773245114963,"sessionID":"ses_3225b064fffe2278ZpH9B8kavM","part":{"id":"prt_cdda5293f001KYGcsGZNQmf6yA","sessionID":"ses_3225b064fffe2278ZpH9B8kavM","messageID":"msg_cdda5156b001NSsLzHVjNO2Ciu","type":"tool","callID":"toolu_01RSspvQHUZf5vPoTbg6JXLf","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at the target project root (the repo being orchestrated).\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: \n11: // ---------------------------------------------------------------------------\n12: // Types\n13: // ---------------------------------------------------------------------------\n14: \n15: export interface WomboConfig {\n16:   /** Path to the features YAML file relative to project root */\n17:   featuresFile: string;\n18:   /** Base branch to create feature branches from */\n19:   baseBranch: string;\n20:   /** Build configuration */\n21:   build: {\n22:     /** Build command to run in worktrees */\n23:     command: string;\n24:     /** Build timeout in milliseconds */\n25:     timeout: number;\n26:     /** Build artifact directory (for quick \"did it build?\" checks) */\n27:     artifactDir: string;\n28:   };\n29:   /** Install configuration */\n30:   install: {\n31:     /** Install command to run in worktrees */\n32:     command: string;\n33:     /** Install timeout in milliseconds */\n34:     timeout: number;\n35:   };\n36:   /** Git configuration */\n37:   git: {\n38:     /** Branch name prefix for feature branches */\n39:     branchPrefix: string;\n40:     /** Worktree directory name prefix */\n41:     worktreePrefix: string;\n42:     /** Git remote name */\n43:     remote: string;\n44:     /** Merge strategy flag */\n45:     mergeStrategy: string;\n46:   };\n47:   /** Agent configuration */\n48:   agent: {\n49:     /** Path to agent binary (null = auto-detect) */\n50:     bin: string | null;\n51:     /** Agent name to pass via --agent flag */\n52:     name: string;\n53:     /** Config files/dirs to copy into worktrees */\n54:     configFiles: string[];\n55:     /** tmux session name prefix */\n56:     tmuxPrefix: string;\n57:   };\n58:   /** Default runtime values */\n59:   defaults: {\n60:     /** Max concurrent agents */\n61:     maxConcurrent: number;\n62:     /** Max retries per agent */\n63:     maxRetries: number;\n64:   };\n65: }\n66: \n67: // ---------------------------------------------------------------------------\n68: // Defaults\n69: // ---------------------------------------------------------------------------\n70: \n71: export const DEFAULT_CONFIG: WomboConfig = {\n72:   featuresFile: \".features.yml\",\n73:   baseBranch: \"develop\",\n74:   build: {\n75:     command: \"bun run build\",\n76:     timeout: 300_000,\n77:     artifactDir: \"dist\",\n78:   },\n79:   install: {\n80:     command: \"bun install\",\n81:     timeout: 120_000,\n82:   },\n83:   git: {\n84:     branchPrefix: \"feature/\",\n85:     worktreePrefix: \"wombo-\",\n86:     remote: \"origin\",\n87:     mergeStrategy: \"--no-ff\",\n88:   },\n89:   agent: {\n90:     bin: null,\n91:     name: \"wave-worker\",\n92:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\", \"agent/\"],\n93:     tmuxPrefix: \"wombo\",\n94:   },\n95:   defaults: {\n96:     maxConcurrent: 6,\n97:     maxRetries: 2,\n98:   },\n99: };\n100: \n101: // ---------------------------------------------------------------------------\n102: // Config File Name\n103: // ---------------------------------------------------------------------------\n104: \n105: export const CONFIG_FILE = \"wombo.json\";\n106: \n107: // ---------------------------------------------------------------------------\n108: // Loader\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Deep-merge source into target. Only merges plain objects, not arrays.\n113:  */\n114: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n115:   const result = { ...target };\n116:   for (const key of Object.keys(source) as (keyof T)[]) {\n117:     const srcVal = source[key];\n118:     const tgtVal = target[key];\n119:     if (\n120:       srcVal !== undefined &&\n121:       srcVal !== null &&\n122:       typeof srcVal === \"object\" &&\n123:       !Array.isArray(srcVal) &&\n124:       typeof tgtVal === \"object\" &&\n125:       !Array.isArray(tgtVal) &&\n126:       tgtVal !== null\n127:     ) {\n128:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n129:     } else if (srcVal !== undefined) {\n130:       result[key] = srcVal as T[keyof T];\n131:     }\n132:   }\n133:   return result;\n134: }\n135: \n136: /**\n137:  * Load wombo.json from the given project root and merge with defaults.\n138:  * Returns the full config. If no config file exists, returns defaults.\n139:  */\n140: export function loadConfig(projectRoot: string): WomboConfig {\n141:   const configPath = resolve(projectRoot, CONFIG_FILE);\n142: \n143:   if (!existsSync(configPath)) {\n144:     return { ...DEFAULT_CONFIG };\n145:   }\n146: \n147:   try {\n148:     const raw = readFileSync(configPath, \"utf-8\");\n149:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n150:     return deepMerge(DEFAULT_CONFIG, partial);\n151:   } catch (err: any) {\n152:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n153:   }\n154: }\n155: \n156: /**\n157:  * Resolve the agent binary path. Priority:\n158:  *   1. config.agent.bin (explicit)\n159:  *   2. OPENCODE_BIN env var\n160:  *   3. ~/.opencode/bin/opencode (default install location)\n161:  */\n162: export function resolveAgentBin(config: WomboConfig): string {\n163:   if (config.agent.bin) return config.agent.bin;\n164:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n165:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n166: }\n167: \n168: /**\n169:  * Validate the config for obvious issues. Throws on error.\n170:  */\n171: export function validateConfig(config: WomboConfig): void {\n172:   if (!config.featuresFile) {\n173:     throw new Error(\"config.featuresFile must be a non-empty string\");\n174:   }\n175:   if (!config.baseBranch) {\n176:     throw new Error(\"config.baseBranch must be a non-empty string\");\n177:   }\n178:   if (!config.build.command) {\n179:     throw new Error(\"config.build.command must be a non-empty string\");\n180:   }\n181:   if (!config.install.command) {\n182:     throw new Error(\"config.install.command must be a non-empty string\");\n183:   }\n184:   if (!config.git.branchPrefix) {\n185:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n186:   }\n187:   if (!config.git.worktreePrefix) {\n188:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n189:   }\n190:   if (config.defaults.maxConcurrent < 1) {\n191:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n192:   }\n193:   if (config.defaults.maxRetries < 0) {\n194:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n195:   }\n196: }\n197: \n198: /**\n199:  * Generate the default wombo.json content string (for `wombo init`).\n200:  */\n201: export function generateDefaultConfig(): string {\n202:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n203: }\n\n(End of file - total 203 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at the target project root (the repo being orchestrated).\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface WomboConfig {\n  /** Path to the features YAML file relative to project root */\n  featuresFile: string;\n  /** Base branch to create feature branches from */\n  baseBranch: string;\n  /** Build configuration */","truncated":false,"loaded":[]},"time":{"start":1773245114960,"end":1773245114962}}}}
{"type":"text","timestamp":1773245115157,"sessionID":"ses_3225b064fffe2278ZpH9B8kavM","part":{"id":"prt_cdda52129001JwWpzqTjRlvlZR","sessionID":"ses_3225b064fffe2278ZpH9B8kavM","messageID":"msg_cdda5156b001NSsLzHVjNO2Ciu","type":"text","text":"Now let me explore the key source files I need to understand and modify:","time":{"start":1773245115157,"end":1773245115157}}}
{"type":"tool_use","timestamp":1773245115161,"sessionID":"ses_3225b064fffe2278ZpH9B8kavM","part":{"id":"prt_cdda52ad7001lHHdRmtzNEuR16","sessionID":"ses_3225b064fffe2278ZpH9B8kavM","messageID":"msg_cdda5156b001NSsLzHVjNO2Ciu","type":"tool","callID":"toolu_01W92vK1rHgnJR6srqPbyDgc","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/features.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/features.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features.ts — Parse features YAML and provide feature selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the features file with full type safety\n6:  *   - Parse ISO 8601 durations into comparable minutes\n7:  *   - Filter features by status, priority, difficulty, dependency readiness\n8:  *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n9:  *   - Resolve dependency graphs to determine which features are ready to start\n10:  *   - Write-back capability for feature management commands\n11:  */\n12: \n13: import { readFileSync, writeFileSync, existsSync } from \"node:fs\";\n14: import { resolve, dirname, join } from \"node:path\";\n15: import { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Template path (resolved relative to this source file)\n21: // ---------------------------------------------------------------------------\n22: \n23: export const FEATURES_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \".features.yml\");\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export type FeatureStatus =\n30:   | \"backlog\"\n31:   | \"planned\"\n32:   | \"in_progress\"\n33:   | \"blocked\"\n34:   | \"in_review\"\n35:   | \"done\"\n36:   | \"cancelled\";\n37: \n38: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n39: \n40: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n41: \n42: export interface Subtask {\n43:   id: string;\n44:   title: string;\n45:   description: string;\n46:   status: FeatureStatus;\n47:   completion: number;\n48:   difficulty: Difficulty;\n49:   priority: Priority;\n50:   depends_on: string[];\n51:   effort: string;\n52:   started_at: string | null;\n53:   ended_at: string | null;\n54:   constraints: string[];\n55:   forbidden: string[];\n56:   references: string[];\n57:   notes: string[];\n58:   subtasks: Subtask[];\n59: }\n60: \n61: export interface Feature {\n62:   id: string;\n63:   title: string;\n64:   description: string;\n65:   status: FeatureStatus;\n66:   completion: number;\n67:   difficulty: Difficulty;\n68:   priority: Priority;\n69:   depends_on: string[];\n70:   effort: string;\n71:   started_at: string | null;\n72:   ended_at: string | null;\n73:   constraints: string[];\n74:   forbidden: string[];\n75:   references: string[];\n76:   notes: string[];\n77:   subtasks: Subtask[];\n78: }\n79: \n80: export interface FeaturesFile {\n81:   version: string;\n82:   meta: {\n83:     created_at: string;\n84:     updated_at: string;\n85:     project: string;\n86:     generator: string;\n87:     maintainer: string;\n88:   };\n89:   features: Feature[];\n90:   archive: Feature[];\n91: }\n92: \n93: // Priority ordering (lower = more important)\n94: const PRIORITY_ORDER: Record<Priority, number> = {\n95:   critical: 0,\n96:   high: 1,\n97:   medium: 2,\n98:   low: 3,\n99:   wishlist: 4,\n100: };\n101: \n102: // Difficulty ordering (lower = easier)\n103: const DIFFICULTY_ORDER: Record<Difficulty, number> = {\n104:   trivial: 0,\n105:   easy: 1,\n106:   medium: 2,\n107:   hard: 3,\n108:   very_hard: 4,\n109: };\n110: \n111: // ---------------------------------------------------------------------------\n112: // ISO 8601 Duration Parser\n113: // ---------------------------------------------------------------------------\n114: \n115: /**\n116:  * Parse an ISO 8601 duration string into total minutes.\n117:  * Supports: P[nD][T[nH][nM][nS]]\n118:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n119:  */\n120: export function parseDurationMinutes(iso: string): number {\n121:   const match = iso.match(\n122:     /^P(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n123:   );\n124:   if (!match) return Infinity; // unparseable -> sort to end\n125:   const days = parseInt(match[1] || \"0\", 10);\n126:   const hours = parseInt(match[2] || \"0\", 10);\n127:   const minutes = parseInt(match[3] || \"0\", 10);\n128:   const seconds = parseInt(match[4] || \"0\", 10);\n129:   return days * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n130: }\n131: \n132: /**\n133:  * Format minutes into a human-readable string.\n134:  */\n135: export function formatDuration(minutes: number): string {\n136:   if (minutes === Infinity) return \"unknown\";\n137:   if (minutes < 60) return `${minutes}m`;\n138:   const h = Math.floor(minutes / 60);\n139:   const m = minutes % 60;\n140:   if (h >= 24) {\n141:     const d = Math.floor(h / 24);\n142:     const rh = h % 24;\n143:     if (rh === 0 && m === 0) return `${d}d`;\n144:     if (m === 0) return `${d}d ${rh}h`;\n145:     return `${d}d ${rh}h ${m}m`;\n146:   }\n147:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n148: }\n149: \n150: // ---------------------------------------------------------------------------\n151: // Features File Existence Guard\n152: // ---------------------------------------------------------------------------\n153: \n154: /**\n155:  * Prompt the user with a yes/no question via stdin.\n156:  */\n157: function promptYesNo(question: string): Promise<boolean> {\n158:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n159:   return new Promise((resolve) => {\n160:     rl.question(question, (answer) => {\n161:       rl.close();\n162:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n163:     });\n164:   });\n165: }\n166: \n167: /**\n168:  * Ensure the features file exists before any command that needs it.\n169:  * If the file is missing, prompt the user to generate one from the template.\n170:  */\n171: export async function ensureFeaturesFile(\n172:   projectRoot: string,\n173:   config: WomboConfig\n174: ): Promise<void> {\n175:   const filePath = resolve(projectRoot, config.featuresFile);\n176: \n177:   if (existsSync(filePath)) return;\n178: \n179:   console.log(`\\nFeatures file not found: ${config.featuresFile}`);\n180: \n181:   const generate = await promptYesNo(\n182:     \"Generate a new features file from template? (y/N): \"\n183:   );\n184: \n185:   if (!generate) {\n186:     console.error(\n187:       `Cannot proceed without a features file. Create one manually or run again and accept the prompt.`\n188:     );\n189:     process.exit(1);\n190:   }\n191: \n192:   // Read template, update timestamps, write to project root\n193:   const template = readFileSync(FEATURES_TEMPLATE_PATH, \"utf-8\");\n194:   const now = new Date().toISOString();\n195:   const content = template\n196:     .replace(/created_at:\\s*\".*?\"/, `created_at: \"${now}\"`)\n197:     .replace(/updated_at:\\s*\".*?\"/, `updated_at: \"${now}\"`);\n198: \n199:   writeFileSync(filePath, content, \"utf-8\");\n200:   console.log(`Created ${config.featuresFile} from template.\\n`);\n201: }\n202: \n203: // ---------------------------------------------------------------------------\n204: // Loader\n205: // ---------------------------------------------------------------------------\n206: \n207: /**\n208:  * Load and parse the features YAML file from the project root.\n209:  * Uses config.featuresFile for the file path.\n210:  */\n211: export function loadFeatures(\n212:   projectRoot: string,\n213:   config: WomboConfig\n214: ): FeaturesFile {\n215:   const filePath = resolve(projectRoot, config.featuresFile);\n216:   const raw = readFileSync(filePath, \"utf-8\");\n217:   const parsed = parseYaml(raw) as FeaturesFile;\n218: \n219:   // Normalize: ensure top-level arrays are never null/undefined (YAML parses\n220:   // empty keys as null).\n221:   parsed.features = parsed.features ?? [];\n222:   parsed.archive = parsed.archive ?? [];\n223: \n224:   for (const f of [...parsed.features, ...parsed.archive]) {\n225:     normalizeFeature(f);\n226:   }\n227: \n228:   return parsed;\n229: }\n230: \n231: /**\n232:  * Save the features file back to disk (for management commands).\n233:  */\n234: export function saveFeatures(\n235:   projectRoot: string,\n236:   config: WomboConfig,\n237:   data: FeaturesFile\n238: ): void {\n239:   const filePath = resolve(projectRoot, config.featuresFile);\n240:   data.meta.updated_at = new Date().toISOString();\n241:   const yaml = stringifyYaml(data, {\n242:     lineWidth: 120,\n243:     defaultKeyType: \"PLAIN\",\n244:     defaultStringType: \"PLAIN\",\n245:   });\n246:   writeFileSync(filePath, yaml, \"utf-8\");\n247: }\n248: \n249: function normalizeFeature(f: Feature | Subtask): void {\n250:   f.depends_on = f.depends_on ?? [];\n251:   f.constraints = f.constraints ?? [];\n252:   f.forbidden = f.forbidden ?? [];\n253:   f.references = f.references ?? [];\n254:   f.notes = f.notes ?? [];\n255:   f.subtasks = f.subtasks ?? [];\n256:   for (const s of f.subtasks) {\n257:     normalizeFeature(s);\n258:   }\n259: }\n260: \n261: // ---------------------------------------------------------------------------\n262: // Dependency Resolution\n263: // ---------------------------------------------------------------------------\n264: \n265: /**\n266:  * Get all feature IDs that are done (status === \"done\" or completion === 100).\n267:  */\n268: function getDoneIds(features: Feature[], archive: Feature[]): Set<string> {\n269:   const done = new Set<string>();\n270:   const collectDone = (items: (Feature | Subtask)[]) => {\n271:     for (const item of items) {\n272:       if (item.status === \"done\" || item.completion === 100) {\n273:         done.add(item.id);\n274:       }\n275:       if (item.subtasks?.length) {\n276:         collectDone(item.subtasks);\n277:       }\n278:     }\n279:   };\n280:   collectDone(features);\n281:   collectDone(archive);\n282:   return done;\n283: }\n284: \n285: /**\n286:  * Check if a feature's dependencies are all satisfied.\n287:  */\n288: export function areDependenciesMet(\n289:   feature: Feature,\n290:   doneIds: Set<string>\n291: ): boolean {\n292:   return feature.depends_on.every((dep) => doneIds.has(dep));\n293: }\n294: \n295: /**\n296:  * Get all features that are ready to start (backlog + deps met).\n297:  */\n298: export function getReadyFeatures(data: FeaturesFile): Feature[] {\n299:   const doneIds = getDoneIds(data.features, data.archive);\n300:   return data.features.filter(\n301:     (f) =>\n302:       f.status === \"backlog\" &&\n303:       f.completion === 0 &&\n304:       areDependenciesMet(f, doneIds)\n305:   );\n306: }\n307: \n308: /**\n309:  * Get done IDs (exported for use in selection error messages).\n310:  */\n311: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n312:   return getDoneIds(data.features, data.archive);\n313: }\n314: \n315: // ---------------------------------------------------------------------------\n316: // Selection Strategies\n317: // ---------------------------------------------------------------------------\n318: \n319: export interface SelectionOptions {\n320:   /** Select top N by priority (highest priority first, then lowest effort) */\n321:   topPriority?: number;\n322:   /** Select N quickest wins (lowest effort first) */\n323:   quickestWins?: number;\n324:   /** Select all features matching this priority level */\n325:   priority?: Priority;\n326:   /** Select all features matching this difficulty level */\n327:   difficulty?: Difficulty;\n328:   /** Select specific feature IDs (comma-separated) */\n329:   featureIds?: string[];\n330:   /** Select all ready features */\n331:   allReady?: boolean;\n332: }\n333: \n334: /**\n335:  * Select features based on the given strategy.\n336:  * Always filters to only ready features (backlog + deps met) first.\n337:  */\n338: export function selectFeatures(\n339:   data: FeaturesFile,\n340:   options: SelectionOptions\n341: ): Feature[] {\n342:   const ready = getReadyFeatures(data);\n343: \n344:   if (options.allReady) {\n345:     return sortByPriorityThenEffort(ready);\n346:   }\n347: \n348:   if (options.featureIds?.length) {\n349:     const idSet = new Set(options.featureIds);\n350:     const selected = ready.filter((f) => idSet.has(f.id));\n351:     const missing = options.featureIds.filter(\n352:       (id) => !selected.find((f) => f.id === id)\n353:     );\n354:     if (missing.length) {\n355:       const allIds = data.features.map((f) => f.id);\n356:       const doneIds = getDoneIds(data.features, data.archive);\n357:       for (const m of missing) {\n358:         if (!allIds.includes(m)) {\n359:           console.error(`  Feature \"${m}\" does not exist in the features file`);\n360:         } else {\n361:           const feat = data.features.find((f) => f.id === m)!;\n362:           console.error(\n363:             `  Feature \"${m}\" is not ready (status: ${feat.status}, deps met: ${areDependenciesMet(feat, doneIds)})`\n364:           );\n365:         }\n366:       }\n367:     }\n368:     return sortByPriorityThenEffort(selected);\n369:   }\n370: \n371:   if (options.priority) {\n372:     return sortByPriorityThenEffort(\n373:       ready.filter((f) => f.priority === options.priority)\n374:     );\n375:   }\n376: \n377:   if (options.difficulty) {\n378:     return sortByEffort(ready.filter((f) => f.difficulty === options.difficulty));\n379:   }\n380: \n381:   if (options.topPriority) {\n382:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n383:   }\n384: \n385:   if (options.quickestWins) {\n386:     return sortByEffort(ready).slice(0, options.quickestWins);\n387:   }\n388: \n389:   // Default: return all ready, sorted by priority\n390:   return sortByPriorityThenEffort(ready);\n391: }\n392: \n393: // ---------------------------------------------------------------------------\n394: // Sorting Helpers\n395: // ---------------------------------------------------------------------------\n396: \n397: function sortByPriorityThenEffort(features: Feature[]): Feature[] {\n398:   return [...features].sort((a, b) => {\n399:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n400:     if (pDiff !== 0) return pDiff;\n401:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n402:   });\n403: }\n404: \n405: function sortByEffort(features: Feature[]): Feature[] {\n406:   return [...features].sort(\n407:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n408:   );\n409: }\n410: \n411: // ---------------------------------------------------------------------------\n412: // Utility Exports\n413: // ---------------------------------------------------------------------------\n414: \n415: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n416: \n417: /**\n418:  * Get a compact summary of a feature for display.\n419:  */\n420: export function featureSummary(f: Feature): string {\n421:   const effort = formatDuration(parseDurationMinutes(f.effort));\n422:   return `[${f.priority}/${f.difficulty}] ${f.id} -- ${f.title} (${effort})`;\n423: }\n424: \n425: /**\n426:  * Recursively search a list of features (and their subtasks) for a matching ID.\n427:  */\n428: function findInList(features: Feature[], id: string): Feature | undefined {\n429:   for (const f of features) {\n430:     if (f.id === id) return f;\n431:     if (f.subtasks?.length) {\n432:       const found = findInList(f.subtasks, id);\n433:       if (found) return found;\n434:     }\n435:   }\n436:   return undefined;\n437: }\n438: \n439: /**\n440:  * Find a feature or subtask by ID across active features, their subtasks\n441:  * (recursively), and the archive list.\n442:  */\n443: export function findFeatureById(\n444:   data: FeaturesFile,\n445:   id: string\n446: ): Feature | undefined {\n447:   return (\n448:     findInList(data.features, id) ??\n449:     (data.archive ? findInList(data.archive, id) : undefined)\n450:   );\n451: }\n452: \n453: /**\n454:  * Create a blank feature with all required fields initialized.\n455:  */\n456: export function createBlankFeature(\n457:   id: string,\n458:   title: string,\n459:   description: string = \"\",\n460:   opts?: {\n461:     priority?: Priority;\n462:     difficulty?: Difficulty;\n463:     effort?: string;\n464:   }\n465: ): Feature {\n466:   return {\n467:     id,\n468:     title,\n469:     description,\n470:     status: \"backlog\",\n471:     completion: 0,\n472:     difficulty: opts?.difficulty ?? \"medium\",\n473:     priority: opts?.priority ?? \"medium\",\n474:     depends_on: [],\n475:     effort: opts?.effort ?? \"PT1H\",\n476:     started_at: null,\n477:     ended_at: null,\n478:     constraints: [],\n479:     forbidden: [],\n480:     references: [],\n481:     notes: [],\n482:     subtasks: [],\n483:   };\n484: }\n485: \n486: /**\n487:  * Get all feature IDs (active + archive), useful for validation.\n488:  */\n489: export function allFeatureIds(data: FeaturesFile): string[] {\n490:   const ids: string[] = [];\n491:   const collect = (items: (Feature | Subtask)[]) => {\n492:     for (const item of items) {\n493:       ids.push(item.id);\n494:       if (item.subtasks?.length) collect(item.subtasks);\n495:     }\n496:   };\n497:   collect(data.features);\n498:   collect(data.archive ?? []);\n499:   return ids;\n500: }\n\n(End of file - total 500 lines)\n</content>","title":"src/lib/features.ts","metadata":{"preview":"/**\n * features.ts — Parse features YAML and provide feature selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the features file with full type safety\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter features by status, priority, difficulty, dependency readiness\n *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which features are ready to start\n *   - Write-back capability for feature management commands\n */\n\nimport { readFileSync, writeFileSync, existsSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Template path (resolved relative to this source file)","truncated":false,"loaded":[]},"time":{"start":1773245115156,"end":1773245115160}}}}
