{"type":"tool_use","timestamp":1773245221077,"sessionID":"ses_3225b064fffe2278ZpH9B8kavM","part":{"id":"prt_cdda6c809001BLKKHhVYgdXWp6","sessionID":"ses_3225b064fffe2278ZpH9B8kavM","messageID":"msg_cdda6b28f0014tsL24lNLzb23q","type":"tool","callID":"toolu_01SEm8AY7bgFM3gyXE6qeyc9","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/init.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/init.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * init.ts — Interactive guided setup for wombo.json.\n3:  *\n4:  * Usage: wombo init [--force]\n5:  *\n6:  * Walks the user through every config section, showing defaults and\n7:  * accepting overrides.  Press Enter on any prompt to keep the default.\n8:  */\n9: \n10: import { existsSync, writeFileSync, readFileSync } from \"node:fs\";\n11: import { resolve } from \"node:path\";\n12: import { createInterface } from \"node:readline\";\n13: import { CONFIG_FILE, DEFAULT_CONFIG, type WomboConfig } from \"../config.js\";\n14: import { FEATURES_TEMPLATE_PATH } from \"../lib/features.js\";\n15: \n16: export interface InitOptions {\n17:   projectRoot: string;\n18:   force?: boolean;\n19: }\n20: \n21: // ---------------------------------------------------------------------------\n22: // Prompt helper — reads one line at a time from stdin\n23: // ---------------------------------------------------------------------------\n24: \n25: class Prompter {\n26:   private lines: AsyncIterableIterator<string>;\n27:   private done = false;\n28:   private rl: ReturnType<typeof createInterface>;\n29: \n30:   constructor() {\n31:     this.rl = createInterface({ input: process.stdin, output: process.stdout, terminal: process.stdin.isTTY ?? false });\n32:     this.lines = this.rl[Symbol.asyncIterator]();\n33:   }\n34: \n35:   /** Read one line from stdin after printing the prompt. */\n36:   private async ask(prompt: string): Promise<string> {\n37:     if (this.done) return \"\";\n38:     process.stdout.write(prompt);\n39:     const result = await this.lines.next();\n40:     if (result.done) {\n41:       this.done = true;\n42:       return \"\";\n43:     }\n44:     return result.value.trim();\n45:   }\n46: \n47:   async string(label: string, defaultVal: string): Promise<string> {\n48:     const answer = await this.ask(`  ${label} [${defaultVal}]: `);\n49:     return answer || defaultVal;\n50:   }\n51: \n52:   async number(label: string, defaultVal: number): Promise<number> {\n53:     const answer = await this.ask(`  ${label} [${defaultVal}]: `);\n54:     if (!answer) return defaultVal;\n55:     const n = parseInt(answer, 10);\n56:     return isNaN(n) ? defaultVal : n;\n57:   }\n58: \n59:   async stringOrNull(label: string, defaultVal: string | null): Promise<string | null> {\n60:     const display = defaultVal ?? \"auto-detect\";\n61:     const answer = await this.ask(`  ${label} [${display}]: `);\n62:     if (!answer) return defaultVal;\n63:     if (answer.toLowerCase() === \"null\" || answer.toLowerCase() === \"auto\") return null;\n64:     return answer;\n65:   }\n66: \n67:   async stringList(label: string, defaultVal: string[]): Promise<string[]> {\n68:     const display = defaultVal.join(\", \");\n69:     const answer = await this.ask(`  ${label} [${display}]: `);\n70:     if (!answer) return defaultVal;\n71:     return answer.split(\",\").map((s) => s.trim()).filter(Boolean);\n72:   }\n73: \n74:   close(): void {\n75:     this.rl.close();\n76:   }\n77: }\n78: \n79: // ---------------------------------------------------------------------------\n80: // Section printer\n81: // ---------------------------------------------------------------------------\n82: \n83: function section(title: string): void {\n84:   console.log(`\\n--- ${title} ${\"─\".repeat(Math.max(0, 56 - title.length))}`);\n85: }\n86: \n87: // ---------------------------------------------------------------------------\n88: // Command\n89: // ---------------------------------------------------------------------------\n90: \n91: export async function cmdInit(opts: InitOptions): Promise<void> {\n92:   const configPath = resolve(opts.projectRoot, CONFIG_FILE);\n93: \n94:   if (existsSync(configPath) && !opts.force) {\n95:     console.error(\n96:       `${CONFIG_FILE} already exists. Use --force to overwrite.`\n97:     );\n98:     process.exit(1);\n99:   }\n100: \n101:   console.log(`\\nWombo — Project Setup`);\n102:   console.log(`Configuring ${CONFIG_FILE} for ${opts.projectRoot}`);\n103:   console.log(`Press Enter to accept the default shown in [brackets].\\n`);\n104: \n105:   const p = new Prompter();\n106: \n107:   try {\n108:     const cfg: WomboConfig = structuredClone(DEFAULT_CONFIG);\n109: \n110:     // -- General ----------------------------------------------------------\n111:     section(\"General\");\n112:     cfg.featuresFile = await p.string(\"Features YAML file\", cfg.featuresFile);\n113:     cfg.baseBranch = await p.string(\"Base branch\", cfg.baseBranch);\n114: \n115:     // -- Build ------------------------------------------------------------\n116:     section(\"Build\");\n117:     cfg.build.command = await p.string(\"Build command\", cfg.build.command);\n118:     cfg.build.timeout = await p.number(\"Build timeout (ms)\", cfg.build.timeout);\n119:     cfg.build.artifactDir = await p.string(\"Artifact directory\", cfg.build.artifactDir);\n120: \n121:     // -- Install ----------------------------------------------------------\n122:     section(\"Install\");\n123:     cfg.install.command = await p.string(\"Install command\", cfg.install.command);\n124:     cfg.install.timeout = await p.number(\"Install timeout (ms)\", cfg.install.timeout);\n125: \n126:     // -- Git --------------------------------------------------------------\n127:     section(\"Git\");\n128:     cfg.git.branchPrefix = await p.string(\"Branch prefix\", cfg.git.branchPrefix);\n129:     cfg.git.worktreePrefix = await p.string(\"Worktree prefix\", cfg.git.worktreePrefix);\n130:     cfg.git.remote = await p.string(\"Remote name\", cfg.git.remote);\n131:     cfg.git.mergeStrategy = await p.string(\"Merge strategy flag\", cfg.git.mergeStrategy);\n132: \n133:     // -- Agent ------------------------------------------------------------\n134:     section(\"Agent\");\n135:     cfg.agent.bin = await p.stringOrNull(\"Agent binary path (or 'auto')\", cfg.agent.bin);\n136:     cfg.agent.name = await p.string(\"Agent name\", cfg.agent.name);\n137:     cfg.agent.configFiles = await p.stringList(\n138:       \"Config files to copy (comma-sep)\",\n139:       cfg.agent.configFiles\n140:     );\n141:     cfg.agent.tmuxPrefix = await p.string(\"tmux session prefix\", cfg.agent.tmuxPrefix);\n142: \n143:     // -- Defaults ---------------------------------------------------------\n144:     section(\"Runtime Defaults\");\n145:     cfg.defaults.maxConcurrent = await p.number(\"Max concurrent agents\", cfg.defaults.maxConcurrent);\n146:     cfg.defaults.maxRetries = await p.number(\"Max retries per agent\", cfg.defaults.maxRetries);\n147: \n148:     // -- Write config ------------------------------------------------------\n149:     console.log(`\\n${\"─\".repeat(60)}`);\n150:     const json = JSON.stringify(cfg, null, 2) + \"\\n\";\n151:     writeFileSync(configPath, json, \"utf-8\");\n152:     console.log(`\\nCreated ${CONFIG_FILE}`);\n153: \n154:     // -- Create features file from template -------------------------------\n155:     const featuresPath = resolve(opts.projectRoot, cfg.featuresFile);\n156:     if (existsSync(featuresPath) && !opts.force) {\n157:       console.log(`${cfg.featuresFile} already exists, skipping.`);\n158:     } else {\n159:       const template = readFileSync(FEATURES_TEMPLATE_PATH, \"utf-8\");\n160:       const now = new Date().toISOString();\n161:       const content = template\n162:         .replace(/created_at:\\s*\".*?\"/, `created_at: \"${now}\"`)\n163:         .replace(/updated_at:\\s*\".*?\"/, `updated_at: \"${now}\"`);\n164:       writeFileSync(featuresPath, content, \"utf-8\");\n165:       console.log(`Created ${cfg.featuresFile} from template.`);\n166:     }\n167: \n168:     console.log(`\\nYou're all set! Run 'wombo help' to see available commands.\\n`);\n169:   } finally {\n170:     p.close();\n171:   }\n172: }\n\n(End of file - total 172 lines)\n</content>","title":"src/commands/init.ts","metadata":{"preview":"/**\n * init.ts — Interactive guided setup for wombo.json.\n *\n * Usage: wombo init [--force]\n *\n * Walks the user through every config section, showing defaults and\n * accepting overrides.  Press Enter on any prompt to keep the default.\n */\n\nimport { existsSync, writeFileSync, readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport { CONFIG_FILE, DEFAULT_CONFIG, type WomboConfig } from \"../config.js\";\nimport { FEATURES_TEMPLATE_PATH } from \"../lib/features.js\";\n\nexport interface InitOptions {\n  projectRoot: string;\n  force?: boolean;\n}\n","truncated":false,"loaded":[]},"time":{"start":1773245221072,"end":1773245221076}}}}
