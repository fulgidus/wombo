{"type":"tool_use","timestamp":1773245274344,"sessionID":"ses_3225b064fffe2278ZpH9B8kavM","part":{"id":"prt_cdda79732001e7RZDMMhNPhm76","sessionID":"ses_3225b064fffe2278ZpH9B8kavM","messageID":"msg_cdda7841e001d7jL8VnpwuHGSl","type":"tool","callID":"toolu_01CKSuFZH3yiwt6DzajrRwT1","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/launch.ts","offset":1,"limit":60},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import type { WomboConfig } from \"../config.js\";\n19: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n20: import { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";\n21: import {\n22:   loadState,\n23:   saveState,\n24:   createWaveState,\n25:   createAgentState,\n26:   updateAgent,\n27:   activeAgents,\n28:   queuedAgents,\n29:   isWaveComplete,\n30:   type WaveState,\n31:   type AgentState,\n32: } from \"../lib/state.js\";\n33: import {\n34:   createWorktree,\n35:   installDeps,\n36:   featureBranchName,\n37:   worktreePath,\n38:   worktreeReady,\n39:   removeWorktree,\n40:   log as wtLog,\n41: } from \"../lib/worktree.js\";\n42: import { generatePrompt } from \"../lib/prompt.js\";\n43: import {\n44:   launchHeadless,\n45:   retryHeadless,\n46:   launchInteractive,\n47:   retryInteractive,\n48:   isProcessRunning,\n49: } from \"../lib/launcher.js\";\n50: import { ProcessMonitor } from \"../lib/monitor.js\";\n51: import { runBuild } from \"../lib/verifier.js\";\n52: import { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\n53: import {\n54:   printDashboard,\n55:   printFeatureSelection,\n56:   printAgentUpdate,\n57: } from \"../lib/ui.js\";\n58: import { WomboTUI } from \"../lib/tui.js\";\n59: \n60: // ---------------------------------------------------------------------------\n\n(Showing lines 1-60 of 690. Use offset=61 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\nimport { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";","truncated":true,"loaded":[]},"time":{"start":1773245274334,"end":1773245274343}}}}
