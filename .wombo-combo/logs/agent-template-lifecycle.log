{"type":"tool_use","timestamp":1773246677858,"sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","part":{"id":"prt_cddbd02eb0013yBSbyy70HPzJF","sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","messageID":"msg_cddbcefd30016cpb3KtSunA7lc","type":"tool","callID":"toolu_012JNNnU1sQtgFdQCYQ27S5B","tool":"glob","state":{"status":"completed","input":{"pattern":"src/lib/templates.ts"},"output":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/templates.ts","title":"","metadata":{"count":1,"truncated":false},"time":{"start":1773246677852,"end":1773246677858}}}}
{"type":"tool_use","timestamp":1773246678318,"sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","part":{"id":"prt_cddbd0361001YASW5MolOgpxUS","sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","messageID":"msg_cddbcefd30016cpb3KtSunA7lc","type":"tool","callID":"toolu_01Qf5HGXDS1dmicCD7KEbTgg","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/features.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/features.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features.ts — Parse features YAML and provide feature selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the features file with full type safety\n6:  *   - Parse ISO 8601 durations into comparable minutes\n7:  *   - Filter features by status, priority, difficulty, dependency readiness\n8:  *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n9:  *   - Resolve dependency graphs to determine which features are ready to start\n10:  *   - Write-back capability for feature management commands\n11:  */\n12: \n13: import { readFileSync, writeFileSync, existsSync } from \"node:fs\";\n14: import { resolve, dirname, join } from \"node:path\";\n15: import { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Template path (resolved relative to this source file)\n21: // ---------------------------------------------------------------------------\n22: \n23: export const FEATURES_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \".features.yml\");\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export type FeatureStatus =\n30:   | \"backlog\"\n31:   | \"planned\"\n32:   | \"in_progress\"\n33:   | \"blocked\"\n34:   | \"in_review\"\n35:   | \"done\"\n36:   | \"cancelled\";\n37: \n38: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n39: \n40: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n41: \n42: export interface Subtask {\n43:   id: string;\n44:   title: string;\n45:   description: string;\n46:   status: FeatureStatus;\n47:   completion: number;\n48:   difficulty: Difficulty;\n49:   priority: Priority;\n50:   depends_on: string[];\n51:   effort: string;\n52:   started_at: string | null;\n53:   ended_at: string | null;\n54:   constraints: string[];\n55:   forbidden: string[];\n56:   references: string[];\n57:   notes: string[];\n58:   subtasks: Subtask[];\n59: }\n60: \n61: export interface Feature {\n62:   id: string;\n63:   title: string;\n64:   description: string;\n65:   status: FeatureStatus;\n66:   completion: number;\n67:   difficulty: Difficulty;\n68:   priority: Priority;\n69:   depends_on: string[];\n70:   effort: string;\n71:   started_at: string | null;\n72:   ended_at: string | null;\n73:   constraints: string[];\n74:   forbidden: string[];\n75:   references: string[];\n76:   notes: string[];\n77:   subtasks: Subtask[];\n78: }\n79: \n80: export interface FeaturesFile {\n81:   version: string;\n82:   meta: {\n83:     created_at: string;\n84:     updated_at: string;\n85:     project: string;\n86:     generator: string;\n87:     maintainer: string;\n88:   };\n89:   features: Feature[];\n90:   archive: Feature[];\n91: }\n92: \n93: // Priority ordering (lower = more important)\n94: const PRIORITY_ORDER: Record<Priority, number> = {\n95:   critical: 0,\n96:   high: 1,\n97:   medium: 2,\n98:   low: 3,\n99:   wishlist: 4,\n100: };\n101: \n102: // Difficulty ordering (lower = easier)\n103: const DIFFICULTY_ORDER: Record<Difficulty, number> = {\n104:   trivial: 0,\n105:   easy: 1,\n106:   medium: 2,\n107:   hard: 3,\n108:   very_hard: 4,\n109: };\n110: \n111: // ---------------------------------------------------------------------------\n112: // ISO 8601 Duration Parser\n113: // ---------------------------------------------------------------------------\n114: \n115: /**\n116:  * Parse an ISO 8601 duration string into total minutes.\n117:  * Supports: P[nD][T[nH][nM][nS]]\n118:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n119:  */\n120: export function parseDurationMinutes(iso: string): number {\n121:   const match = iso.match(\n122:     /^P(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n123:   );\n124:   if (!match) return Infinity; // unparseable -> sort to end\n125:   const days = parseInt(match[1] || \"0\", 10);\n126:   const hours = parseInt(match[2] || \"0\", 10);\n127:   const minutes = parseInt(match[3] || \"0\", 10);\n128:   const seconds = parseInt(match[4] || \"0\", 10);\n129:   return days * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n130: }\n131: \n132: /**\n133:  * Format minutes into a human-readable string.\n134:  */\n135: export function formatDuration(minutes: number): string {\n136:   if (minutes === Infinity) return \"unknown\";\n137:   if (minutes < 60) return `${minutes}m`;\n138:   const h = Math.floor(minutes / 60);\n139:   const m = minutes % 60;\n140:   if (h >= 24) {\n141:     const d = Math.floor(h / 24);\n142:     const rh = h % 24;\n143:     if (rh === 0 && m === 0) return `${d}d`;\n144:     if (m === 0) return `${d}d ${rh}h`;\n145:     return `${d}d ${rh}h ${m}m`;\n146:   }\n147:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n148: }\n149: \n150: // ---------------------------------------------------------------------------\n151: // Features File Existence Guard\n152: // ---------------------------------------------------------------------------\n153: \n154: /**\n155:  * Prompt the user with a yes/no question via stdin.\n156:  */\n157: function promptYesNo(question: string): Promise<boolean> {\n158:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n159:   return new Promise((resolve) => {\n160:     rl.question(question, (answer) => {\n161:       rl.close();\n162:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n163:     });\n164:   });\n165: }\n166: \n167: /**\n168:  * Ensure the features file exists before any command that needs it.\n169:  * If the file is missing, prompt the user to generate one from the template.\n170:  */\n171: export async function ensureFeaturesFile(\n172:   projectRoot: string,\n173:   config: WomboConfig\n174: ): Promise<void> {\n175:   const filePath = resolve(projectRoot, config.featuresFile);\n176: \n177:   if (existsSync(filePath)) return;\n178: \n179:   console.log(`\\nFeatures file not found: ${config.featuresFile}`);\n180: \n181:   const generate = await promptYesNo(\n182:     \"Generate a new features file from template? (y/N): \"\n183:   );\n184: \n185:   if (!generate) {\n186:     console.error(\n187:       `Cannot proceed without a features file. Create one manually or run again and accept the prompt.`\n188:     );\n189:     process.exit(1);\n190:   }\n191: \n192:   // Read template, update timestamps, write to project root\n193:   const template = readFileSync(FEATURES_TEMPLATE_PATH, \"utf-8\");\n194:   const now = new Date().toISOString();\n195:   const content = template\n196:     .replace(/created_at:\\s*\".*?\"/, `created_at: \"${now}\"`)\n197:     .replace(/updated_at:\\s*\".*?\"/, `updated_at: \"${now}\"`);\n198: \n199:   writeFileSync(filePath, content, \"utf-8\");\n200:   console.log(`Created ${config.featuresFile} from template.\\n`);\n201: }\n202: \n203: // ---------------------------------------------------------------------------\n204: // Loader\n205: // ---------------------------------------------------------------------------\n206: \n207: /**\n208:  * Load and parse the features YAML file from the project root.\n209:  * Uses config.featuresFile for the file path.\n210:  */\n211: export function loadFeatures(\n212:   projectRoot: string,\n213:   config: WomboConfig\n214: ): FeaturesFile {\n215:   const filePath = resolve(projectRoot, config.featuresFile);\n216:   const raw = readFileSync(filePath, \"utf-8\");\n217:   const parsed = parseYaml(raw) as FeaturesFile;\n218: \n219:   // Normalize: ensure top-level arrays are never null/undefined (YAML parses\n220:   // empty keys as null).\n221:   parsed.features = parsed.features ?? [];\n222:   parsed.archive = parsed.archive ?? [];\n223: \n224:   for (const f of [...parsed.features, ...parsed.archive]) {\n225:     normalizeFeature(f);\n226:   }\n227: \n228:   return parsed;\n229: }\n230: \n231: /**\n232:  * Save the features file back to disk (for management commands).\n233:  */\n234: export function saveFeatures(\n235:   projectRoot: string,\n236:   config: WomboConfig,\n237:   data: FeaturesFile\n238: ): void {\n239:   const filePath = resolve(projectRoot, config.featuresFile);\n240:   data.meta.updated_at = new Date().toISOString();\n241:   const yaml = stringifyYaml(data, {\n242:     lineWidth: 120,\n243:     defaultKeyType: \"PLAIN\",\n244:     defaultStringType: \"PLAIN\",\n245:   });\n246:   writeFileSync(filePath, yaml, \"utf-8\");\n247: }\n248: \n249: function normalizeFeature(f: Feature | Subtask): void {\n250:   f.depends_on = f.depends_on ?? [];\n251:   f.constraints = f.constraints ?? [];\n252:   f.forbidden = f.forbidden ?? [];\n253:   f.references = f.references ?? [];\n254:   f.notes = f.notes ?? [];\n255:   f.subtasks = f.subtasks ?? [];\n256:   for (const s of f.subtasks) {\n257:     normalizeFeature(s);\n258:   }\n259: }\n260: \n261: // ---------------------------------------------------------------------------\n262: // Dependency Resolution\n263: // ---------------------------------------------------------------------------\n264: \n265: /**\n266:  * Get all feature IDs that are done (status === \"done\" or completion === 100).\n267:  */\n268: function getDoneIds(features: Feature[], archive: Feature[]): Set<string> {\n269:   const done = new Set<string>();\n270:   const collectDone = (items: (Feature | Subtask)[]) => {\n271:     for (const item of items) {\n272:       if (item.status === \"done\" || item.completion === 100) {\n273:         done.add(item.id);\n274:       }\n275:       if (item.subtasks?.length) {\n276:         collectDone(item.subtasks);\n277:       }\n278:     }\n279:   };\n280:   collectDone(features);\n281:   collectDone(archive);\n282:   return done;\n283: }\n284: \n285: /**\n286:  * Check if a feature's dependencies are all satisfied.\n287:  */\n288: export function areDependenciesMet(\n289:   feature: Feature,\n290:   doneIds: Set<string>\n291: ): boolean {\n292:   return feature.depends_on.every((dep) => doneIds.has(dep));\n293: }\n294: \n295: /**\n296:  * Get all features that are ready to start (backlog + deps met).\n297:  */\n298: export function getReadyFeatures(data: FeaturesFile): Feature[] {\n299:   const doneIds = getDoneIds(data.features, data.archive);\n300:   return data.features.filter(\n301:     (f) =>\n302:       f.status === \"backlog\" &&\n303:       f.completion === 0 &&\n304:       areDependenciesMet(f, doneIds)\n305:   );\n306: }\n307: \n308: /**\n309:  * Get done IDs (exported for use in selection error messages).\n310:  */\n311: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n312:   return getDoneIds(data.features, data.archive);\n313: }\n314: \n315: // ---------------------------------------------------------------------------\n316: // Selection Strategies\n317: // ---------------------------------------------------------------------------\n318: \n319: export interface SelectionOptions {\n320:   /** Select top N by priority (highest priority first, then lowest effort) */\n321:   topPriority?: number;\n322:   /** Select N quickest wins (lowest effort first) */\n323:   quickestWins?: number;\n324:   /** Select all features matching this priority level */\n325:   priority?: Priority;\n326:   /** Select all features matching this difficulty level */\n327:   difficulty?: Difficulty;\n328:   /** Select specific feature IDs (comma-separated) */\n329:   featureIds?: string[];\n330:   /** Select all ready features */\n331:   allReady?: boolean;\n332: }\n333: \n334: /**\n335:  * Select features based on the given strategy.\n336:  * Always filters to only ready features (backlog + deps met) first.\n337:  */\n338: export function selectFeatures(\n339:   data: FeaturesFile,\n340:   options: SelectionOptions\n341: ): Feature[] {\n342:   const ready = getReadyFeatures(data);\n343: \n344:   if (options.allReady) {\n345:     return sortByPriorityThenEffort(ready);\n346:   }\n347: \n348:   if (options.featureIds?.length) {\n349:     const idSet = new Set(options.featureIds);\n350:     const selected = ready.filter((f) => idSet.has(f.id));\n351:     const missing = options.featureIds.filter(\n352:       (id) => !selected.find((f) => f.id === id)\n353:     );\n354:     if (missing.length) {\n355:       const allIds = data.features.map((f) => f.id);\n356:       const doneIds = getDoneIds(data.features, data.archive);\n357:       for (const m of missing) {\n358:         if (!allIds.includes(m)) {\n359:           console.error(`  Feature \"${m}\" does not exist in the features file`);\n360:         } else {\n361:           const feat = data.features.find((f) => f.id === m)!;\n362:           console.error(\n363:             `  Feature \"${m}\" is not ready (status: ${feat.status}, deps met: ${areDependenciesMet(feat, doneIds)})`\n364:           );\n365:         }\n366:       }\n367:     }\n368:     return sortByPriorityThenEffort(selected);\n369:   }\n370: \n371:   if (options.priority) {\n372:     return sortByPriorityThenEffort(\n373:       ready.filter((f) => f.priority === options.priority)\n374:     );\n375:   }\n376: \n377:   if (options.difficulty) {\n378:     return sortByEffort(ready.filter((f) => f.difficulty === options.difficulty));\n379:   }\n380: \n381:   if (options.topPriority) {\n382:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n383:   }\n384: \n385:   if (options.quickestWins) {\n386:     return sortByEffort(ready).slice(0, options.quickestWins);\n387:   }\n388: \n389:   // Default: return all ready, sorted by priority\n390:   return sortByPriorityThenEffort(ready);\n391: }\n392: \n393: // ---------------------------------------------------------------------------\n394: // Sorting Helpers\n395: // ---------------------------------------------------------------------------\n396: \n397: function sortByPriorityThenEffort(features: Feature[]): Feature[] {\n398:   return [...features].sort((a, b) => {\n399:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n400:     if (pDiff !== 0) return pDiff;\n401:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n402:   });\n403: }\n404: \n405: function sortByEffort(features: Feature[]): Feature[] {\n406:   return [...features].sort(\n407:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n408:   );\n409: }\n410: \n411: // ---------------------------------------------------------------------------\n412: // Utility Exports\n413: // ---------------------------------------------------------------------------\n414: \n415: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n416: \n417: /**\n418:  * Get a compact summary of a feature for display.\n419:  */\n420: export function featureSummary(f: Feature): string {\n421:   const effort = formatDuration(parseDurationMinutes(f.effort));\n422:   return `[${f.priority}/${f.difficulty}] ${f.id} -- ${f.title} (${effort})`;\n423: }\n424: \n425: /**\n426:  * Recursively search a list of features (and their subtasks) for a matching ID.\n427:  */\n428: function findInList(features: Feature[], id: string): Feature | undefined {\n429:   for (const f of features) {\n430:     if (f.id === id) return f;\n431:     if (f.subtasks?.length) {\n432:       const found = findInList(f.subtasks, id);\n433:       if (found) return found;\n434:     }\n435:   }\n436:   return undefined;\n437: }\n438: \n439: /**\n440:  * Find a feature or subtask by ID across active features, their subtasks\n441:  * (recursively), and the archive list.\n442:  */\n443: export function findFeatureById(\n444:   data: FeaturesFile,\n445:   id: string\n446: ): Feature | undefined {\n447:   return (\n448:     findInList(data.features, id) ??\n449:     (data.archive ? findInList(data.archive, id) : undefined)\n450:   );\n451: }\n452: \n453: /**\n454:  * Create a blank feature with all required fields initialized.\n455:  */\n456: export function createBlankFeature(\n457:   id: string,\n458:   title: string,\n459:   description: string = \"\",\n460:   opts?: {\n461:     priority?: Priority;\n462:     difficulty?: Difficulty;\n463:     effort?: string;\n464:   }\n465: ): Feature {\n466:   return {\n467:     id,\n468:     title,\n469:     description,\n470:     status: \"backlog\",\n471:     completion: 0,\n472:     difficulty: opts?.difficulty ?? \"medium\",\n473:     priority: opts?.priority ?? \"medium\",\n474:     depends_on: [],\n475:     effort: opts?.effort ?? \"PT1H\",\n476:     started_at: null,\n477:     ended_at: null,\n478:     constraints: [],\n479:     forbidden: [],\n480:     references: [],\n481:     notes: [],\n482:     subtasks: [],\n483:   };\n484: }\n485: \n486: /**\n487:  * Get all feature IDs (active + archive), useful for validation.\n488:  */\n489: export function allFeatureIds(data: FeaturesFile): string[] {\n490:   const ids: string[] = [];\n491:   const collect = (items: (Feature | Subtask)[]) => {\n492:     for (const item of items) {\n493:       ids.push(item.id);\n494:       if (item.subtasks?.length) collect(item.subtasks);\n495:     }\n496:   };\n497:   collect(data.features);\n498:   collect(data.archive ?? []);\n499:   return ids;\n500: }\n\n(End of file - total 500 lines)\n</content>","title":"src/lib/features.ts","metadata":{"preview":"/**\n * features.ts — Parse features YAML and provide feature selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the features file with full type safety\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter features by status, priority, difficulty, dependency readiness\n *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which features are ready to start\n *   - Write-back capability for feature management commands\n */\n\nimport { readFileSync, writeFileSync, existsSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Template path (resolved relative to this source file)","truncated":false,"loaded":[]},"time":{"start":1773246678314,"end":1773246678317}}}}
{"type":"tool_use","timestamp":1773246678470,"sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","part":{"id":"prt_cddbd052b001zrDaxQATj1ob2u","sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","messageID":"msg_cddbcefd30016cpb3KtSunA7lc","type":"tool","callID":"toolu_01RLugMR61xNvwQwVznzJKLR","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo cleanup\n21:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n22:  *   wombo features add <id> <title> [options]\n23:  *   wombo features set-status <feature-id> <status>\n24:  *   wombo features check\n25:  *   wombo features archive [feature-id] [--dry-run]\n26:  *   wombo features show <feature-id>\n27:  *   wombo help\n28:  */\n29: \n30: import { resolve } from \"node:path\";\n31: import { existsSync, readFileSync } from \"node:fs\";\n32: import { loadConfig, validateConfig } from \"./config.js\";\n33: import { loadState, saveState } from \"./lib/state.js\";\n34: \n35: // ---------------------------------------------------------------------------\n36: // Dev-mode guard: warn if running the global binary inside the wombo repo\n37: // ---------------------------------------------------------------------------\n38: \n39: function checkDevModeGuard(): void {\n40:   const cwd = process.cwd();\n41:   const pkgPath = resolve(cwd, \"package.json\");\n42: \n43:   // Are we inside the wombo repo?\n44:   if (!existsSync(pkgPath)) return;\n45: \n46:   let pkgName: string | undefined;\n47:   try {\n48:     const raw = readFileSync(pkgPath, \"utf-8\");\n49:     pkgName = JSON.parse(raw).name;\n50:   } catch {\n51:     return;\n52:   }\n53:   if (pkgName !== \"wombo\") return;\n54: \n55:   // We're in the wombo repo. Is the source being run from a different location?\n56:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n57:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n58:   // we're running the globally installed binary.\n59:   const sourceDir = resolve(import.meta.dir);\n60:   const projectSrc = resolve(cwd, \"src\");\n61: \n62:   if (!sourceDir.startsWith(projectSrc)) {\n63:     console.warn(\n64:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n65:       \"inside the wombo repo.\\n\" +\n66:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n67:       \"  See AGENTS.md for details.\\n\"\n68:     );\n69:   }\n70: }\n71: \n72: import { cmdInit } from \"./commands/init.js\";\n73: import { cmdLaunch } from \"./commands/launch.js\";\n74: import { cmdResume } from \"./commands/resume.js\";\n75: import { cmdStatus } from \"./commands/status.js\";\n76: import { cmdVerify } from \"./commands/verify.js\";\n77: import { cmdMerge } from \"./commands/merge.js\";\n78: import { cmdRetry } from \"./commands/retry.js\";\n79: import { cmdCleanup } from \"./commands/cleanup.js\";\n80: import { cmdUpgrade } from \"./commands/upgrade.js\";\n81: import { cmdFeaturesList } from \"./commands/features/list.js\";\n82: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n83: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n84: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n85: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n86: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n87: \n88: import { ensureFeaturesFile } from \"./lib/features.js\";\n89: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n90: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n91: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n92: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n93: \n94: // ---------------------------------------------------------------------------\n95: // Types\n96: // ---------------------------------------------------------------------------\n97: \n98: interface CLIArgs {\n99:   command: string;\n100:   subcommand?: string;\n101:   // Selection options (launch)\n102:   topPriority?: number;\n103:   quickestWins?: number;\n104:   priority?: Priority;\n105:   difficulty?: Difficulty;\n106:   features?: string[];\n107:   allReady?: boolean;\n108:   // Launch / runtime options\n109:   maxConcurrent?: number;\n110:   model?: string;\n111:   interactive: boolean;\n112:   dryRun: boolean;\n113:   baseBranch?: string;\n114:   maxRetries?: number;\n115:   noTui: boolean;\n116:   autoPush: boolean;\n117:   // General\n118:   featureId?: string;\n119:   force: boolean;\n120:   // Output format\n121:   outputFmt: OutputFormat;\n122:   // Upgrade options\n123:   checkOnly: boolean;\n124:   version?: string;\n125:   // Features subcommand extras\n126:   status?: string;\n127:   ready?: boolean;\n128:   includeArchive?: boolean;\n129:   title?: string;\n130:   description?: string;\n131:   effort?: string;\n132:   dependsOn?: string[];\n133:   // Compact output\n134:   fields?: string[];\n135: }\n136: \n137: // ---------------------------------------------------------------------------\n138: // Arg Parsing\n139: // ---------------------------------------------------------------------------\n140: \n141: function parseArgs(argv: string[]): CLIArgs {\n142:   const args = argv.slice(2); // skip 'bun' and script path\n143:   const result: CLIArgs = {\n144:     command: args[0] || \"help\",\n145:     interactive: false,\n146:     dryRun: false,\n147:     noTui: false,\n148:     autoPush: false,\n149:     force: false,\n150:     checkOnly: false,\n151:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n152:   };\n153: \n154:   // If the first arg is \"features\", treat the second positional as the subcommand\n155:   let startIdx = 1;\n156:   if (result.command === \"features\") {\n157:     result.subcommand = args[1] || \"list\";\n158:     startIdx = 2;\n159:   }\n160: \n161:   for (let i = startIdx; i < args.length; i++) {\n162:     const arg = args[i];\n163:     switch (arg) {\n164:       // --- Selection options ---\n165:       case \"--top-priority\":\n166:         result.topPriority = parseInt(args[++i], 10);\n167:         break;\n168:       case \"--quickest-wins\":\n169:         result.quickestWins = parseInt(args[++i], 10);\n170:         break;\n171:       case \"--priority\":\n172:         result.priority = args[++i] as Priority;\n173:         break;\n174:       case \"--difficulty\":\n175:         result.difficulty = args[++i] as Difficulty;\n176:         break;\n177:       case \"--features\":\n178:         result.features = args[++i].split(\",\").map((s) => s.trim());\n179:         break;\n180:       case \"--all-ready\":\n181:         result.allReady = true;\n182:         break;\n183: \n184:       // --- Launch / runtime options ---\n185:       case \"--max-concurrent\":\n186:         result.maxConcurrent = parseInt(args[++i], 10);\n187:         break;\n188:       case \"--model\":\n189:       case \"-m\":\n190:         result.model = args[++i];\n191:         break;\n192:       case \"--interactive\":\n193:         result.interactive = true;\n194:         break;\n195:       case \"--dry-run\":\n196:         result.dryRun = true;\n197:         break;\n198:       case \"--no-tui\":\n199:         result.noTui = true;\n200:         break;\n201:       case \"--auto-push\":\n202:         result.autoPush = true;\n203:         break;\n204:       case \"--base-branch\":\n205:         result.baseBranch = args[++i];\n206:         break;\n207:       case \"--max-retries\":\n208:         result.maxRetries = parseInt(args[++i], 10);\n209:         break;\n210: \n211:       // --- General flags ---\n212:       case \"--force\":\n213:         result.force = true;\n214:         break;\n215:       case \"--check\":\n216:         result.checkOnly = true;\n217:         break;\n218:       case \"--version\":\n219:         result.version = args[++i];\n220:         break;\n221:       case \"--output\":\n222:       case \"-o\":\n223:         result.outputFmt = resolveOutputFormat(args[++i]);\n224:         break;\n225: \n226:       // --- Features subcommand options ---\n227:       case \"--status\":\n228:         result.status = args[++i];\n229:         break;\n230:       case \"--ready\":\n231:         result.ready = true;\n232:         break;\n233:       case \"--include-archive\":\n234:         result.includeArchive = true;\n235:         break;\n236:       case \"--title\":\n237:         result.title = args[++i];\n238:         break;\n239:       case \"--description\":\n240:       case \"--desc\":\n241:         result.description = args[++i];\n242:         break;\n243:       case \"--effort\":\n244:         result.effort = args[++i];\n245:         break;\n246:       case \"--depends-on\":\n247:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n248:         break;\n249:       case \"--fields\":\n250:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n251:         break;\n252: \n253:       // --- Positional (feature-id, title for add, etc.) ---\n254:       default:\n255:         if (!arg.startsWith(\"-\")) {\n256:           if (!result.featureId) {\n257:             result.featureId = arg;\n258:           } else if (!result.title) {\n259:             result.title = arg;\n260:           }\n261:         }\n262:         break;\n263:     }\n264:   }\n265: \n266:   return result;\n267: }\n268: \n269: // ---------------------------------------------------------------------------\n270: // Help\n271: // ---------------------------------------------------------------------------\n272: \n273: function cmdHelp(): void {\n274:   console.log(`\n275: Wombo — AI Agent Orchestration System\n276: \n277:   WOMBO COMBO! Parallel feature development with AI agents.\n278: \n279: Commands:\n280:   init           Generate wombo.json config in the current project\n281:   launch         Launch a wave of agents to implement features\n282:   resume         Resume a previously stopped wave\n283:   status         Show the status of the current wave\n284:   verify         Run build verification on completed agents\n285:   merge          Merge verified branches into the base branch\n286:   retry          Retry a failed agent\n287:   cleanup        Remove all wave worktrees and tmux sessions\n288:   features       Manage .features.yml (see below)\n289:   upgrade        Check for updates and upgrade wombo\n290:   describe       Emit JSON schema of a command (for AI agents)\n291:   help           Show this help\n292: \n293: Features Subcommands:\n294:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n295:   features add <id> <title> [options]\n296:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n297:   features set-status <id> <status>\n298:                            Change a feature's status\n299:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n300:   features archive [id]    Move done/cancelled to archive (--dry-run)\n301:   features show <id>       Show feature details\n302: \n303: Selection Options (for launch):\n304:   --top-priority N         Select top N features by priority\n305:   --quickest-wins N        Select N features with lowest effort\n306:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n307:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n308:   --features \"id1,id2\"     Select specific features by ID\n309:   --all-ready              Select all features whose dependencies are met\n310: \n311: Launch Options:\n312:   --max-concurrent N       Max agents running in parallel (default: from config)\n313:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n314:   --interactive            Use tmux TUI mode instead of headless\n315:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n316:   --auto-push              Push base branch to remote after all merges complete\n317:   --dry-run                Show what would be launched without launching\n318:   --base-branch <branch>   Base branch (default: from config)\n319:   --max-retries N          Max retries per agent (default: from config)\n320: \n321: General:\n322:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n323:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n324:   -o <fmt>                 Alias for --output\n325:   --dry-run                Show what would happen without performing the action\n326:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n327: \n328: Upgrade Options:\n329:   --check                  Only check for updates, don't install\n330:   --version <tag>          Install a specific version (e.g., v0.1.0)\n331: \n332: Examples:\n333:   wombo init\n334:   wombo launch --quickest-wins 3\n335:   wombo launch --priority high --interactive\n336:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n337:   wombo resume\n338:   wombo status\n339:   wombo verify\n340:   wombo merge\n341:   wombo retry auth-flow\n342:   wombo cleanup\n343:   wombo features list --status ready --priority high\n344:   wombo features list --fields id,status,priority --output json\n345:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n346:   wombo features set-status my-feature in-progress\n347:   wombo features check\n348:   wombo features archive --dry-run\n349:   wombo features show my-feature\n350:   wombo describe                           # list all commands as JSON\n351:   wombo describe launch                    # describe a specific command\n352:   wombo describe features add              # describe a subcommand\n353: `);\n354: }\n355: \n356: // ---------------------------------------------------------------------------\n357: // Main\n358: // ---------------------------------------------------------------------------\n359: \n360: async function main(): Promise<void> {\n361:   checkDevModeGuard();\n362: \n363:   const PROJECT_ROOT = resolve(process.cwd());\n364:   const args = parseArgs(process.argv);\n365: \n366:   // -----------------------------------------------------------------------\n367:   // Input validation at the CLI boundary\n368:   // -----------------------------------------------------------------------\n369:   if (args.featureId) {\n370:     assertValid(validateId(args.featureId, \"feature ID\"));\n371:   }\n372:   if (args.title) {\n373:     assertValid(validateText(args.title, \"title\"));\n374:   }\n375:   if (args.description) {\n376:     assertValid(validateText(args.description, \"description\"));\n377:   }\n378:   if (args.baseBranch) {\n379:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n380:   }\n381:   if (args.effort) {\n382:     assertValid(validateDuration(args.effort, \"effort\"));\n383:   }\n384:   if (args.features) {\n385:     for (const fid of args.features) {\n386:       assertValid(validateId(fid, \"feature ID in --features\"));\n387:     }\n388:   }\n389:   if (args.dependsOn) {\n390:     for (const dep of args.dependsOn) {\n391:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n392:     }\n393:   }\n394: \n395:   // Commands that don't need config loading\n396:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n397:     cmdHelp();\n398:     return;\n399:   }\n400: \n401:   if (args.command === \"describe\") {\n402:     // Schema introspection: `wombo describe [command]`\n403:     if (!args.featureId) {\n404:       // No command specified — list all commands\n405:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n406:     } else {\n407:       // Describe a specific command. Handle compound names: \"features list\"\n408:       const cmdName = args.title\n409:         ? `${args.featureId} ${args.title}`\n410:         : args.featureId;\n411:       const def = findCommandDef(cmdName);\n412:       if (!def) {\n413:         console.error(`Unknown command: \"${cmdName}\"`);\n414:         console.error(\"Run 'wombo describe' to list all commands.\");\n415:         process.exit(1);\n416:         return;\n417:       }\n418:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n419:     }\n420:     return;\n421:   }\n422: \n423:   if (args.command === \"init\") {\n424:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n425:     return;\n426:   }\n427: \n428:   if (args.command === \"upgrade\") {\n429:     await cmdUpgrade({\n430:       force: args.force,\n431:       version: args.version,\n432:       checkOnly: args.checkOnly,\n433:     });\n434:     return;\n435:   }\n436: \n437:   // Everything else requires config\n438:   const config = loadConfig(PROJECT_ROOT);\n439:   validateConfig(config);\n440: \n441:   // Commands that operate on the features file — ensure it exists first\n442:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n443:   if (needsFeatures.has(args.command)) {\n444:     await ensureFeaturesFile(PROJECT_ROOT, config);\n445:   }\n446: \n447:   switch (args.command) {\n448:     case \"launch\":\n449:       await cmdLaunch({\n450:         projectRoot: PROJECT_ROOT,\n451:         config,\n452:         topPriority: args.topPriority,\n453:         quickestWins: args.quickestWins,\n454:         priority: args.priority,\n455:         difficulty: args.difficulty,\n456:         features: args.features,\n457:         allReady: args.allReady,\n458:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n459:         model: args.model,\n460:         interactive: args.interactive,\n461:         dryRun: args.dryRun,\n462:         baseBranch: args.baseBranch ?? config.baseBranch,\n463:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n464:         noTui: args.noTui,\n465:         autoPush: args.autoPush,\n466:       });\n467:       break;\n468: \n469:     case \"resume\":\n470:       await cmdResume({\n471:         projectRoot: PROJECT_ROOT,\n472:         config,\n473:         maxConcurrent: args.maxConcurrent,\n474:         model: args.model,\n475:         interactive: args.interactive,\n476:         noTui: args.noTui,\n477:         autoPush: args.autoPush,\n478:         baseBranch: args.baseBranch,\n479:         maxRetries: args.maxRetries,\n480:       });\n481:       break;\n482: \n483:     case \"status\":\n484:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n485:       break;\n486: \n487:     case \"verify\":\n488:       await cmdVerify({\n489:         projectRoot: PROJECT_ROOT,\n490:         config,\n491:         featureId: args.featureId,\n492:         model: args.model,\n493:         maxRetries: args.maxRetries,\n494:       });\n495:       break;\n496: \n497:     case \"merge\":\n498:       await cmdMerge({\n499:         projectRoot: PROJECT_ROOT,\n500:         config,\n501:         featureId: args.featureId,\n502:         autoPush: args.autoPush,\n503:         dryRun: args.dryRun,\n504:       });\n505:       break;\n506: \n507:     case \"retry\": {\n508:       if (!args.featureId) {\n509:         console.error(\"Usage: wombo retry <feature-id>\");\n510:         process.exit(1);\n511:         return;\n512:       }\n513:       await cmdRetry({\n514:         projectRoot: PROJECT_ROOT,\n515:         config,\n516:         featureId: args.featureId,\n517:         model: args.model,\n518:         interactive: args.interactive,\n519:         dryRun: args.dryRun,\n520:       });\n521:       break;\n522:     }\n523: \n524:     case \"cleanup\":\n525:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n526:       break;\n527: \n528:     case \"features\":\n529:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n530:       break;\n531: \n532:     default:\n533:       console.error(`Unknown command: ${args.command}`);\n534:       cmdHelp();\n535:       process.exit(1);\n536:       return;\n537:   }\n538: }\n539: \n540: // ---------------------------------------------------------------------------\n541: // Features Subcommand Router\n542: // ---------------------------------------------------------------------------\n543: \n544: async function handleFeaturesSubcommand(\n545:   args: CLIArgs,\n546:   projectRoot: string,\n547:   config: import(\"./config.js\").WomboConfig\n548: ): Promise<void> {\n549:   switch (args.subcommand) {\n550:     case \"list\":\n551:     case \"ls\":\n552:       await cmdFeaturesList({\n553:         projectRoot,\n554:         config,\n555:         status: args.status as FeatureStatus | undefined,\n556:         priority: args.priority,\n557:         difficulty: args.difficulty,\n558:         ready: args.ready,\n559:         includeArchive: args.includeArchive,\n560:         outputFmt: args.outputFmt,\n561:         fields: args.fields,\n562:       });\n563:       break;\n564: \n565:     case \"add\": {\n566:       if (!args.featureId || !args.title) {\n567:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n568:         process.exit(1);\n569:         return;\n570:       }\n571:       await cmdFeaturesAdd({\n572:         projectRoot,\n573:         config,\n574:         id: args.featureId,\n575:         title: args.title,\n576:         description: args.description,\n577:         priority: args.priority,\n578:         difficulty: args.difficulty,\n579:         effort: args.effort,\n580:         dependsOn: args.dependsOn,\n581:         outputFmt: args.outputFmt,\n582:         dryRun: args.dryRun,\n583:       });\n584:       break;\n585:     }\n586: \n587:     case \"set-status\": {\n588:       if (!args.featureId || !args.title) {\n589:         // title holds the second positional arg (the status value)\n590:         // If not provided via positional, check --status flag\n591:         const newStatus = args.title || args.status;\n592:         if (!args.featureId || !newStatus) {\n593:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n594:           process.exit(1);\n595:           return;\n596:         }\n597:         await cmdFeaturesSetStatus({\n598:           projectRoot,\n599:           config,\n600:           featureId: args.featureId,\n601:           newStatus,\n602:           outputFmt: args.outputFmt,\n603:           dryRun: args.dryRun,\n604:         });\n605:       } else {\n606:         await cmdFeaturesSetStatus({\n607:           projectRoot,\n608:           config,\n609:           featureId: args.featureId,\n610:           newStatus: args.title, // second positional = new status\n611:           outputFmt: args.outputFmt,\n612:           dryRun: args.dryRun,\n613:         });\n614:       }\n615:       break;\n616:     }\n617: \n618:     case \"check\":\n619:     case \"validate\":\n620:       await cmdFeaturesCheck({ projectRoot, config });\n621:       break;\n622: \n623:     case \"archive\":\n624:       await cmdFeaturesArchive({\n625:         projectRoot,\n626:         config,\n627:         featureId: args.featureId,\n628:         dryRun: args.dryRun,\n629:       });\n630:       break;\n631: \n632:     case \"show\": {\n633:       if (!args.featureId) {\n634:         console.error(\"Usage: wombo features show <feature-id>\");\n635:         process.exit(1);\n636:         return;\n637:       }\n638:       await cmdFeaturesShow({\n639:         projectRoot,\n640:         config,\n641:         featureId: args.featureId,\n642:         outputFmt: args.outputFmt,\n643:         fields: args.fields,\n644:       });\n645:       break;\n646:     }\n647: \n648:     case \"help\":\n649:     case \"--help\":\n650:     case \"-h\":\n651:       cmdHelp();\n652:       break;\n653: \n654:     default:\n655:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n656:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n657:       process.exit(1);\n658:       return;\n659:   }\n660: }\n661: \n662: // ---------------------------------------------------------------------------\n663: // Error Handlers & Entry\n664: // ---------------------------------------------------------------------------\n665: \n666: // Global error handlers — prevent silent crashes\n667: process.on(\"uncaughtException\", (err) => {\n668:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n669:   console.error(err.stack);\n670:   try {\n671:     const state = loadState(process.cwd());\n672:     if (state) saveState(process.cwd(), state);\n673:   } catch {}\n674:   process.exit(1);\n675: });\n676: \n677: process.on(\"unhandledRejection\", (reason: any) => {\n678:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n679:   if (reason?.stack) console.error(reason.stack);\n680:   try {\n681:     const state = loadState(process.cwd());\n682:     if (state) saveState(process.cwd(), state);\n683:   } catch {}\n684:   process.exit(1);\n685: });\n686: \n687: main().catch((err) => {\n688:   console.error(\"Fatal error:\", err.message);\n689:   process.exit(1);\n690: });\n\n(End of file - total 690 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo cleanup","truncated":false,"loaded":[]},"time":{"start":1773246678466,"end":1773246678469}}}}
