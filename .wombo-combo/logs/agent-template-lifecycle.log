{"type":"tool_use","timestamp":1773246671574,"sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","part":{"id":"prt_cddbce82e001CraKN11igA1b28","sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","messageID":"msg_cddbcdd08001ds8m7HrcSI46fq","type":"tool","callID":"toolu_01116ZNv3KtHaPguQK17q3fi","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/config.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/config.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n3:  *\n4:  * The config file lives at the target project root (the repo being orchestrated).\n5:  * All values have sensible defaults so minimal config works out of the box.\n6:  */\n7: \n8: import { readFileSync, existsSync } from \"node:fs\";\n9: import { resolve } from \"node:path\";\n10: \n11: // ---------------------------------------------------------------------------\n12: // Types\n13: // ---------------------------------------------------------------------------\n14: \n15: export interface WomboConfig {\n16:   /** Path to the features YAML file relative to project root */\n17:   featuresFile: string;\n18:   /** Base branch to create feature branches from */\n19:   baseBranch: string;\n20:   /** Build configuration */\n21:   build: {\n22:     /** Build command to run in worktrees */\n23:     command: string;\n24:     /** Build timeout in milliseconds */\n25:     timeout: number;\n26:     /** Build artifact directory (for quick \"did it build?\" checks) */\n27:     artifactDir: string;\n28:   };\n29:   /** Install configuration */\n30:   install: {\n31:     /** Install command to run in worktrees */\n32:     command: string;\n33:     /** Install timeout in milliseconds */\n34:     timeout: number;\n35:   };\n36:   /** Git configuration */\n37:   git: {\n38:     /** Branch name prefix for feature branches */\n39:     branchPrefix: string;\n40:     /** Worktree directory name prefix */\n41:     worktreePrefix: string;\n42:     /** Git remote name */\n43:     remote: string;\n44:     /** Merge strategy flag */\n45:     mergeStrategy: string;\n46:   };\n47:   /** Agent configuration */\n48:   agent: {\n49:     /** Path to agent binary (null = auto-detect) */\n50:     bin: string | null;\n51:     /** Agent name to pass via --agent flag */\n52:     name: string;\n53:     /** Config files/dirs to copy into worktrees */\n54:     configFiles: string[];\n55:     /** tmux session name prefix */\n56:     tmuxPrefix: string;\n57:   };\n58:   /** Default runtime values */\n59:   defaults: {\n60:     /** Max concurrent agents */\n61:     maxConcurrent: number;\n62:     /** Max retries per agent */\n63:     maxRetries: number;\n64:   };\n65: }\n66: \n67: // ---------------------------------------------------------------------------\n68: // Defaults\n69: // ---------------------------------------------------------------------------\n70: \n71: export const DEFAULT_CONFIG: WomboConfig = {\n72:   featuresFile: \".features.yml\",\n73:   baseBranch: \"develop\",\n74:   build: {\n75:     command: \"bun run build\",\n76:     timeout: 300_000,\n77:     artifactDir: \"dist\",\n78:   },\n79:   install: {\n80:     command: \"bun install\",\n81:     timeout: 120_000,\n82:   },\n83:   git: {\n84:     branchPrefix: \"feature/\",\n85:     worktreePrefix: \"wombo-\",\n86:     remote: \"origin\",\n87:     mergeStrategy: \"--no-ff\",\n88:   },\n89:   agent: {\n90:     bin: null,\n91:     name: \"wave-worker\",\n92:     configFiles: [\".opencode/\", \"opencode.json\", \"AGENTS.md\", \"agent/\"],\n93:     tmuxPrefix: \"wombo\",\n94:   },\n95:   defaults: {\n96:     maxConcurrent: 6,\n97:     maxRetries: 2,\n98:   },\n99: };\n100: \n101: // ---------------------------------------------------------------------------\n102: // Config File Name\n103: // ---------------------------------------------------------------------------\n104: \n105: export const CONFIG_FILE = \"wombo.json\";\n106: \n107: // ---------------------------------------------------------------------------\n108: // Loader\n109: // ---------------------------------------------------------------------------\n110: \n111: /**\n112:  * Deep-merge source into target. Only merges plain objects, not arrays.\n113:  */\n114: function deepMerge<T extends Record<string, any>>(target: T, source: Partial<T>): T {\n115:   const result = { ...target };\n116:   for (const key of Object.keys(source) as (keyof T)[]) {\n117:     const srcVal = source[key];\n118:     const tgtVal = target[key];\n119:     if (\n120:       srcVal !== undefined &&\n121:       srcVal !== null &&\n122:       typeof srcVal === \"object\" &&\n123:       !Array.isArray(srcVal) &&\n124:       typeof tgtVal === \"object\" &&\n125:       !Array.isArray(tgtVal) &&\n126:       tgtVal !== null\n127:     ) {\n128:       result[key] = deepMerge(tgtVal as any, srcVal as any);\n129:     } else if (srcVal !== undefined) {\n130:       result[key] = srcVal as T[keyof T];\n131:     }\n132:   }\n133:   return result;\n134: }\n135: \n136: /**\n137:  * Load wombo.json from the given project root and merge with defaults.\n138:  * Returns the full config. If no config file exists, returns defaults.\n139:  */\n140: export function loadConfig(projectRoot: string): WomboConfig {\n141:   const configPath = resolve(projectRoot, CONFIG_FILE);\n142: \n143:   if (!existsSync(configPath)) {\n144:     return { ...DEFAULT_CONFIG };\n145:   }\n146: \n147:   try {\n148:     const raw = readFileSync(configPath, \"utf-8\");\n149:     const partial = JSON.parse(raw) as Partial<WomboConfig>;\n150:     return deepMerge(DEFAULT_CONFIG, partial);\n151:   } catch (err: any) {\n152:     throw new Error(`Failed to load ${CONFIG_FILE}: ${err.message}`);\n153:   }\n154: }\n155: \n156: /**\n157:  * Resolve the agent binary path. Priority:\n158:  *   1. config.agent.bin (explicit)\n159:  *   2. OPENCODE_BIN env var\n160:  *   3. ~/.opencode/bin/opencode (default install location)\n161:  */\n162: export function resolveAgentBin(config: WomboConfig): string {\n163:   if (config.agent.bin) return config.agent.bin;\n164:   if (process.env.OPENCODE_BIN) return process.env.OPENCODE_BIN;\n165:   return resolve(process.env.HOME || \"~\", \".opencode/bin/opencode\");\n166: }\n167: \n168: /**\n169:  * Validate the config for obvious issues. Throws on error.\n170:  */\n171: export function validateConfig(config: WomboConfig): void {\n172:   if (!config.featuresFile) {\n173:     throw new Error(\"config.featuresFile must be a non-empty string\");\n174:   }\n175:   if (!config.baseBranch) {\n176:     throw new Error(\"config.baseBranch must be a non-empty string\");\n177:   }\n178:   if (!config.build.command) {\n179:     throw new Error(\"config.build.command must be a non-empty string\");\n180:   }\n181:   if (!config.install.command) {\n182:     throw new Error(\"config.install.command must be a non-empty string\");\n183:   }\n184:   if (!config.git.branchPrefix) {\n185:     throw new Error(\"config.git.branchPrefix must be a non-empty string\");\n186:   }\n187:   if (!config.git.worktreePrefix) {\n188:     throw new Error(\"config.git.worktreePrefix must be a non-empty string\");\n189:   }\n190:   if (config.defaults.maxConcurrent < 1) {\n191:     throw new Error(\"config.defaults.maxConcurrent must be >= 1\");\n192:   }\n193:   if (config.defaults.maxRetries < 0) {\n194:     throw new Error(\"config.defaults.maxRetries must be >= 0\");\n195:   }\n196: }\n197: \n198: /**\n199:  * Generate the default wombo.json content string (for `wombo init`).\n200:  */\n201: export function generateDefaultConfig(): string {\n202:   return JSON.stringify(DEFAULT_CONFIG, null, 2) + \"\\n\";\n203: }\n\n(End of file - total 203 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"/**\n * config.ts — Load wombo.json, merge with defaults, validate, expose typed config.\n *\n * The config file lives at the target project root (the repo being orchestrated).\n * All values have sensible defaults so minimal config works out of the box.\n */\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface WomboConfig {\n  /** Path to the features YAML file relative to project root */\n  featuresFile: string;\n  /** Base branch to create feature branches from */\n  baseBranch: string;\n  /** Build configuration */","truncated":false,"loaded":[]},"time":{"start":1773246671570,"end":1773246671573}}}}
{"type":"tool_use","timestamp":1773246672007,"sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","part":{"id":"prt_cddbcead30019Q7jA30M1sJO2p","sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","messageID":"msg_cddbcdd08001ds8m7HrcSI46fq","type":"tool","callID":"toolu_01FPhCHBwiVpwQ6pzw4CRd8u","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/init.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/init.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * init.ts — Interactive guided setup for wombo.json.\n3:  *\n4:  * Usage: wombo init [--force]\n5:  *\n6:  * Walks the user through every config section, showing defaults and\n7:  * accepting overrides.  Press Enter on any prompt to keep the default.\n8:  */\n9: \n10: import { existsSync, writeFileSync, readFileSync, mkdirSync } from \"node:fs\";\n11: import { resolve } from \"node:path\";\n12: import { createInterface } from \"node:readline\";\n13: import { CONFIG_FILE, DEFAULT_CONFIG, type WomboConfig } from \"../config.js\";\n14: import { FEATURES_TEMPLATE_PATH } from \"../lib/features.js\";\n15: import { AGENT_TEMPLATE_PATH } from \"../lib/templates.js\";\n16: \n17: export interface InitOptions {\n18:   projectRoot: string;\n19:   force?: boolean;\n20: }\n21: \n22: // ---------------------------------------------------------------------------\n23: // Prompt helper — reads one line at a time from stdin\n24: // ---------------------------------------------------------------------------\n25: \n26: class Prompter {\n27:   private lines: AsyncIterableIterator<string>;\n28:   private done = false;\n29:   private rl: ReturnType<typeof createInterface>;\n30: \n31:   constructor() {\n32:     this.rl = createInterface({ input: process.stdin, output: process.stdout, terminal: process.stdin.isTTY ?? false });\n33:     this.lines = this.rl[Symbol.asyncIterator]();\n34:   }\n35: \n36:   /** Read one line from stdin after printing the prompt. */\n37:   private async ask(prompt: string): Promise<string> {\n38:     if (this.done) return \"\";\n39:     process.stdout.write(prompt);\n40:     const result = await this.lines.next();\n41:     if (result.done) {\n42:       this.done = true;\n43:       return \"\";\n44:     }\n45:     return result.value.trim();\n46:   }\n47: \n48:   async string(label: string, defaultVal: string): Promise<string> {\n49:     const answer = await this.ask(`  ${label} [${defaultVal}]: `);\n50:     return answer || defaultVal;\n51:   }\n52: \n53:   async number(label: string, defaultVal: number): Promise<number> {\n54:     const answer = await this.ask(`  ${label} [${defaultVal}]: `);\n55:     if (!answer) return defaultVal;\n56:     const n = parseInt(answer, 10);\n57:     return isNaN(n) ? defaultVal : n;\n58:   }\n59: \n60:   async stringOrNull(label: string, defaultVal: string | null): Promise<string | null> {\n61:     const display = defaultVal ?? \"auto-detect\";\n62:     const answer = await this.ask(`  ${label} [${display}]: `);\n63:     if (!answer) return defaultVal;\n64:     if (answer.toLowerCase() === \"null\" || answer.toLowerCase() === \"auto\") return null;\n65:     return answer;\n66:   }\n67: \n68:   async stringList(label: string, defaultVal: string[]): Promise<string[]> {\n69:     const display = defaultVal.join(\", \");\n70:     const answer = await this.ask(`  ${label} [${display}]: `);\n71:     if (!answer) return defaultVal;\n72:     return answer.split(\",\").map((s) => s.trim()).filter(Boolean);\n73:   }\n74: \n75:   async yesNo(label: string, defaultVal: boolean): Promise<boolean> {\n76:     const display = defaultVal ? \"Y/n\" : \"y/N\";\n77:     const answer = await this.ask(`  ${label} [${display}]: `);\n78:     if (!answer) return defaultVal;\n79:     return answer.toLowerCase().startsWith(\"y\");\n80:   }\n81: \n82:   close(): void {\n83:     this.rl.close();\n84:   }\n85: }\n86: \n87: // ---------------------------------------------------------------------------\n88: // Section printer\n89: // ---------------------------------------------------------------------------\n90: \n91: function section(title: string): void {\n92:   console.log(`\\n--- ${title} ${\"─\".repeat(Math.max(0, 56 - title.length))}`);\n93: }\n94: \n95: // ---------------------------------------------------------------------------\n96: // Command\n97: // ---------------------------------------------------------------------------\n98: \n99: export async function cmdInit(opts: InitOptions): Promise<void> {\n100:   const configPath = resolve(opts.projectRoot, CONFIG_FILE);\n101: \n102:   if (existsSync(configPath) && !opts.force) {\n103:     console.error(\n104:       `${CONFIG_FILE} already exists. Use --force to overwrite.`\n105:     );\n106:     process.exit(1);\n107:   }\n108: \n109:   console.log(`\\nWombo — Project Setup`);\n110:   console.log(`Configuring ${CONFIG_FILE} for ${opts.projectRoot}`);\n111:   console.log(`Press Enter to accept the default shown in [brackets].\\n`);\n112: \n113:   const p = new Prompter();\n114: \n115:   try {\n116:     const cfg: WomboConfig = structuredClone(DEFAULT_CONFIG);\n117: \n118:     // -- General ----------------------------------------------------------\n119:     section(\"General\");\n120:     cfg.featuresFile = await p.string(\"Features YAML file\", cfg.featuresFile);\n121:     cfg.baseBranch = await p.string(\"Base branch\", cfg.baseBranch);\n122: \n123:     // -- Build ------------------------------------------------------------\n124:     section(\"Build\");\n125:     cfg.build.command = await p.string(\"Build command\", cfg.build.command);\n126:     cfg.build.timeout = await p.number(\"Build timeout (ms)\", cfg.build.timeout);\n127:     cfg.build.artifactDir = await p.string(\"Artifact directory\", cfg.build.artifactDir);\n128: \n129:     // -- Install ----------------------------------------------------------\n130:     section(\"Install\");\n131:     cfg.install.command = await p.string(\"Install command\", cfg.install.command);\n132:     cfg.install.timeout = await p.number(\"Install timeout (ms)\", cfg.install.timeout);\n133: \n134:     // -- Git --------------------------------------------------------------\n135:     section(\"Git\");\n136:     cfg.git.branchPrefix = await p.string(\"Branch prefix\", cfg.git.branchPrefix);\n137:     cfg.git.worktreePrefix = await p.string(\"Worktree prefix\", cfg.git.worktreePrefix);\n138:     cfg.git.remote = await p.string(\"Remote name\", cfg.git.remote);\n139:     cfg.git.mergeStrategy = await p.string(\"Merge strategy flag\", cfg.git.mergeStrategy);\n140: \n141:     // -- Agent ------------------------------------------------------------\n142:     section(\"Agent\");\n143:     cfg.agent.bin = await p.stringOrNull(\"Agent binary path (or 'auto')\", cfg.agent.bin);\n144:     cfg.agent.name = await p.string(\"Agent name\", cfg.agent.name);\n145:     cfg.agent.configFiles = await p.stringList(\n146:       \"Config files to copy (comma-sep)\",\n147:       cfg.agent.configFiles\n148:     );\n149:     cfg.agent.tmuxPrefix = await p.string(\"tmux session prefix\", cfg.agent.tmuxPrefix);\n150: \n151:     // -- Defaults ---------------------------------------------------------\n152:     section(\"Runtime Defaults\");\n153:     cfg.defaults.maxConcurrent = await p.number(\"Max concurrent agents\", cfg.defaults.maxConcurrent);\n154:     cfg.defaults.maxRetries = await p.number(\"Max retries per agent\", cfg.defaults.maxRetries);\n155: \n156:     // -- Write config ------------------------------------------------------\n157:     console.log(`\\n${\"─\".repeat(60)}`);\n158:     const json = JSON.stringify(cfg, null, 2) + \"\\n\";\n159:     writeFileSync(configPath, json, \"utf-8\");\n160:     console.log(`\\nCreated ${CONFIG_FILE}`);\n161: \n162:     // -- Create features file from template -------------------------------\n163:     const featuresPath = resolve(opts.projectRoot, cfg.featuresFile);\n164:     if (existsSync(featuresPath) && !opts.force) {\n165:       console.log(`${cfg.featuresFile} already exists, skipping.`);\n166:     } else {\n167:       const template = readFileSync(FEATURES_TEMPLATE_PATH, \"utf-8\");\n168:       const now = new Date().toISOString();\n169:       const content = template\n170:         .replace(/created_at:\\s*\".*?\"/, `created_at: \"${now}\"`)\n171:         .replace(/updated_at:\\s*\".*?\"/, `updated_at: \"${now}\"`);\n172:       writeFileSync(featuresPath, content, \"utf-8\");\n173:       console.log(`Created ${cfg.featuresFile} from template.`);\n174:     }\n175: \n176:     // -- Install agent definition template --------------------------------\n177:     const agentDir = resolve(opts.projectRoot, \"agent\");\n178:     const agentDefPath = resolve(agentDir, `${cfg.agent.name}.md`);\n179: \n180:     let installAgent = true;\n181:     if (existsSync(agentDefPath) && !opts.force) {\n182:       installAgent = await p.yesNo(\n183:         `agent/${cfg.agent.name}.md already exists. Overwrite?`,\n184:         false\n185:       );\n186:     }\n187: \n188:     if (installAgent) {\n189:       mkdirSync(agentDir, { recursive: true });\n190:       const agentTemplate = readFileSync(AGENT_TEMPLATE_PATH, \"utf-8\");\n191:       writeFileSync(agentDefPath, agentTemplate, \"utf-8\");\n192:       console.log(`Created agent/${cfg.agent.name}.md from template.`);\n193:     } else {\n194:       console.log(`agent/${cfg.agent.name}.md already exists, skipping.`);\n195:     }\n196: \n197:     // Ensure agent/ is in configFiles\n198:     if (!cfg.agent.configFiles.includes(\"agent/\")) {\n199:       cfg.agent.configFiles.push(\"agent/\");\n200:       // Re-write config with updated configFiles\n201:       const updatedJson = JSON.stringify(cfg, null, 2) + \"\\n\";\n202:       writeFileSync(configPath, updatedJson, \"utf-8\");\n203:       console.log(`Added agent/ to configFiles in ${CONFIG_FILE}.`);\n204:     }\n205: \n206:     console.log(`\\nYou're all set! Run 'wombo help' to see available commands.\\n`);\n207:   } finally {\n208:     p.close();\n209:   }\n210: }\n\n(End of file - total 210 lines)\n</content>","title":"src/commands/init.ts","metadata":{"preview":"/**\n * init.ts — Interactive guided setup for wombo.json.\n *\n * Usage: wombo init [--force]\n *\n * Walks the user through every config section, showing defaults and\n * accepting overrides.  Press Enter on any prompt to keep the default.\n */\n\nimport { existsSync, writeFileSync, readFileSync, mkdirSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport { CONFIG_FILE, DEFAULT_CONFIG, type WomboConfig } from \"../config.js\";\nimport { FEATURES_TEMPLATE_PATH } from \"../lib/features.js\";\nimport { AGENT_TEMPLATE_PATH } from \"../lib/templates.js\";\n\nexport interface InitOptions {\n  projectRoot: string;\n  force?: boolean;\n}","truncated":false,"loaded":[]},"time":{"start":1773246672003,"end":1773246672006}}}}
{"type":"tool_use","timestamp":1773246672424,"sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","part":{"id":"prt_cddbcec840016iUppqRik0zVyC","sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","messageID":"msg_cddbcdd08001ds8m7HrcSI46fq","type":"tool","callID":"toolu_01XmTnze3VXfV4b41oejUPJE","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import type { WomboConfig } from \"../config.js\";\n19: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n20: import { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";\n21: import {\n22:   loadState,\n23:   saveState,\n24:   createWaveState,\n25:   createAgentState,\n26:   updateAgent,\n27:   activeAgents,\n28:   queuedAgents,\n29:   isWaveComplete,\n30:   type WaveState,\n31:   type AgentState,\n32: } from \"../lib/state.js\";\n33: import {\n34:   createWorktree,\n35:   installDeps,\n36:   featureBranchName,\n37:   worktreePath,\n38:   worktreeReady,\n39:   removeWorktree,\n40:   log as wtLog,\n41: } from \"../lib/worktree.js\";\n42: import { generatePrompt } from \"../lib/prompt.js\";\n43: import {\n44:   launchHeadless,\n45:   retryHeadless,\n46:   launchInteractive,\n47:   retryInteractive,\n48:   isProcessRunning,\n49: } from \"../lib/launcher.js\";\n50: import { ProcessMonitor } from \"../lib/monitor.js\";\n51: import { runBuild } from \"../lib/verifier.js\";\n52: import { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\n53: import {\n54:   printDashboard,\n55:   printFeatureSelection,\n56:   printAgentUpdate,\n57: } from \"../lib/ui.js\";\n58: import { WomboTUI } from \"../lib/tui.js\";\n59: import { ensureAgentDefinition } from \"../lib/templates.js\";\n60: \n61: // ---------------------------------------------------------------------------\n62: // Types\n63: // ---------------------------------------------------------------------------\n64: \n65: export interface LaunchCommandOptions {\n66:   projectRoot: string;\n67:   config: WomboConfig;\n68:   // Selection\n69:   topPriority?: number;\n70:   quickestWins?: number;\n71:   priority?: Priority;\n72:   difficulty?: Difficulty;\n73:   features?: string[];\n74:   allReady?: boolean;\n75:   // Launch\n76:   maxConcurrent: number;\n77:   model?: string;\n78:   interactive: boolean;\n79:   dryRun: boolean;\n80:   baseBranch: string;\n81:   maxRetries: number;\n82:   noTui: boolean;\n83:   autoPush: boolean;\n84: }\n85: \n86: // ---------------------------------------------------------------------------\n87: // Shared Helpers (exported for resume.ts and others)\n88: // ---------------------------------------------------------------------------\n89: \n90: /**\n91:  * Launch a single agent in headless mode.\n92:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n93:  */\n94: export async function launchSingleHeadless(\n95:   projectRoot: string,\n96:   state: WaveState,\n97:   agent: AgentState,\n98:   feature: Feature,\n99:   monitor: ProcessMonitor,\n100:   config: WomboConfig,\n101:   model?: string\n102: ): Promise<void> {\n103:   updateAgent(state, agent.feature_id, {\n104:     status: \"installing\",\n105:     started_at: new Date().toISOString(),\n106:     activity: \"setting up worktree...\",\n107:   });\n108:   saveState(projectRoot, state);\n109: \n110:   try {\n111:     // Skip worktree setup if already ready (resume case)\n112:     if (worktreeReady(agent.worktree)) {\n113:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n114:     } else {\n115:       // Create worktree (async — doesn't block other agents)\n116:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n117: \n118:       // Install dependencies (async)\n119:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n120:       await installDeps(agent.worktree, feature.id, config);\n121:     }\n122: \n123:     // Generate prompt\n124:     const prompt = generatePrompt(feature, state.base_branch, config);\n125: \n126:     // Launch agent\n127:     wtLog(agent.feature_id, \"launching agent...\");\n128:     const result = launchHeadless({\n129:       worktreePath: agent.worktree,\n130:       featureId: feature.id,\n131:       prompt,\n132:       model,\n133:       config,\n134:     });\n135: \n136:     updateAgent(state, agent.feature_id, {\n137:       status: \"running\",\n138:       pid: result.pid,\n139:       activity: \"starting...\",\n140:     });\n141:     saveState(projectRoot, state);\n142: \n143:     monitor.addProcess(feature.id, result.process);\n144:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n145:   } catch (err: any) {\n146:     updateAgent(state, agent.feature_id, {\n147:       status: \"failed\",\n148:       error: err.message,\n149:       activity: null,\n150:       completed_at: new Date().toISOString(),\n151:     });\n152:     saveState(projectRoot, state);\n153:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n154:   }\n155: }\n156: \n157: /**\n158:  * Handle build verification after agent completion.\n159:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n160:  *\n161:  * ASYNC — runs build and merge without blocking the event loop.\n162:  */\n163: export async function handleBuildVerification(\n164:   projectRoot: string,\n165:   state: WaveState,\n166:   agent: AgentState,\n167:   feature: Feature,\n168:   config: WomboConfig,\n169:   model?: string,\n170:   monitor?: ProcessMonitor\n171: ): Promise<void> {\n172:   try {\n173:     printAgentUpdate(agent, \"verifying build...\");\n174: \n175:     const buildResult = await runBuild(agent.worktree, config);\n176: \n177:     if (buildResult.passed) {\n178:       updateAgent(state, agent.feature_id, {\n179:         status: \"verified\",\n180:         build_passed: true,\n181:         build_output: null,\n182:       });\n183:       saveState(projectRoot, state);\n184:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n185: \n186:       // Auto-merge: merge verified branch into base immediately\n187:       printAgentUpdate(agent, \"auto-merging...\");\n188:       try {\n189:         const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n190: \n191:         if (mergeResult.success) {\n192:           updateAgent(state, agent.feature_id, {\n193:             status: \"merged\",\n194:             completed_at: new Date().toISOString(),\n195:           });\n196:           saveState(projectRoot, state);\n197:           printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n198: \n199:           // Clean up worktree after successful merge\n200:           try {\n201:             removeWorktree(projectRoot, agent.worktree, false);\n202:             printAgentUpdate(agent, \"worktree removed\");\n203:           } catch {\n204:             // Not critical — worktree cleanup is best-effort\n205:           }\n206:         } else {\n207:           // Merge failed (conflicts, etc.) — leave as verified for manual resolution\n208:           printAgentUpdate(agent, `AUTO-MERGE FAILED: ${mergeResult.error}`);\n209:         }\n210:       } catch (mergeErr: any) {\n211:         printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n212:       }\n213:     } else {\n214:       if (agent.retries < agent.max_retries) {\n215:         updateAgent(state, agent.feature_id, {\n216:           status: \"retry\",\n217:           retries: agent.retries + 1,\n218:           build_passed: false,\n219:           build_output: buildResult.errorSummary,\n220:         });\n221:         saveState(projectRoot, state);\n222:         printAgentUpdate(\n223:           agent,\n224:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n225:         );\n226: \n227:         // Retry with build errors\n228:         if (agent.session_id) {\n229:           const retryResult = retryHeadless({\n230:             worktreePath: agent.worktree,\n231:             featureId: agent.feature_id,\n232:             sessionId: agent.session_id,\n233:             buildErrors: buildResult.errorSummary,\n234:             model,\n235:             config,\n236:           });\n237: \n238:           updateAgent(state, agent.feature_id, {\n239:             status: \"running\",\n240:             pid: retryResult.pid,\n241:           });\n242:           saveState(projectRoot, state);\n243: \n244:           // Add retry process to monitor so events are tracked\n245:           if (monitor) {\n246:             monitor.addProcess(agent.feature_id, retryResult.process);\n247:           }\n248:         }\n249:       } else {\n250:         updateAgent(state, agent.feature_id, {\n251:           status: \"failed\",\n252:           build_passed: false,\n253:           build_output: buildResult.errorSummary,\n254:           error: `Build failed after ${agent.max_retries} retries`,\n255:           completed_at: new Date().toISOString(),\n256:         });\n257:         saveState(projectRoot, state);\n258:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n259:       }\n260:     }\n261:   } catch (err: any) {\n262:     // Catch-all — never let build verification crash the process\n263:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n264:     updateAgent(state, agent.feature_id, {\n265:       status: \"failed\",\n266:       error: `Build verification error: ${err.message}`,\n267:       completed_at: new Date().toISOString(),\n268:     });\n269:     saveState(projectRoot, state);\n270:   }\n271: }\n272: \n273: /**\n274:  * Handle retry of a failed agent (error-based, not build-based).\n275:  */\n276: export function handleRetry(\n277:   projectRoot: string,\n278:   state: WaveState,\n279:   agent: AgentState,\n280:   monitor: ProcessMonitor,\n281:   config: WomboConfig,\n282:   model?: string\n283: ): void {\n284:   if (!agent.session_id || !agent.error) return;\n285: \n286:   const retryResult = retryHeadless({\n287:     worktreePath: agent.worktree,\n288:     featureId: agent.feature_id,\n289:     sessionId: agent.session_id,\n290:     buildErrors: agent.error,\n291:     model,\n292:     config,\n293:   });\n294: \n295:   updateAgent(state, agent.feature_id, {\n296:     status: \"running\",\n297:     pid: retryResult.pid,\n298:   });\n299:   saveState(projectRoot, state);\n300: \n301:   monitor.addProcess(agent.feature_id, retryResult.process);\n302: }\n303: \n304: /**\n305:  * Launch the next queued agent if capacity allows.\n306:  */\n307: export function launchNextQueued(\n308:   projectRoot: string,\n309:   state: WaveState,\n310:   featureMap: Map<string, Feature>,\n311:   monitor: ProcessMonitor,\n312:   config: WomboConfig,\n313:   model?: string\n314: ): void {\n315:   const active = activeAgents(state);\n316:   const queued = queuedAgents(state);\n317: \n318:   if (active.length < state.max_concurrent && queued.length > 0) {\n319:     const next = queued[0];\n320:     const feature = featureMap.get(next.feature_id);\n321:     if (feature) {\n322:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n323:     }\n324:   }\n325: }\n326: \n327: // ---------------------------------------------------------------------------\n328: // Headless Wave Launch\n329: // ---------------------------------------------------------------------------\n330: \n331: async function launchWaveHeadless(\n332:   projectRoot: string,\n333:   state: WaveState,\n334:   features: Feature[],\n335:   opts: LaunchCommandOptions\n336: ): Promise<void> {\n337:   const { config, model } = opts;\n338:   const featureMap = new Map(features.map((f) => [f.id, f]));\n339: \n340:   const monitor = new ProcessMonitor(projectRoot, {\n341:     onSessionId: (featureId, sessionId) => {\n342:       updateAgent(state, featureId, { session_id: sessionId });\n343:       saveState(projectRoot, state);\n344:     },\n345:     onComplete: (featureId) => {\n346:       updateAgent(state, featureId, {\n347:         status: \"completed\",\n348:         completed_at: new Date().toISOString(),\n349:       });\n350:       saveState(projectRoot, state);\n351: \n352:       // Run build verification — fire-and-forget\n353:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n354:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n355:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n356:         .catch((err) => {\n357:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n358:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n359:         });\n360:     },\n361:     onError: (featureId, error) => {\n362:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n363:       if (agent.retries < agent.max_retries) {\n364:         updateAgent(state, featureId, {\n365:           status: \"retry\",\n366:           retries: agent.retries + 1,\n367:           error,\n368:         });\n369:         saveState(projectRoot, state);\n370: \n371:         // Retry\n372:         handleRetry(projectRoot, state, agent, monitor, config, model);\n373:       } else {\n374:         updateAgent(state, featureId, {\n375:           status: \"failed\",\n376:           error,\n377:           completed_at: new Date().toISOString(),\n378:         });\n379:         saveState(projectRoot, state);\n380:       }\n381: \n382:       // Try to launch next queued agent\n383:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n384:     },\n385:     onOutput: (_featureId, _data) => {\n386:       // Raw output — logged to file by ProcessMonitor\n387:     },\n388:     onActivity: (featureId, activity) => {\n389:       updateAgent(state, featureId, {\n390:         activity,\n391:         activity_updated_at: new Date().toISOString(),\n392:       });\n393:       // Don't save to disk on every activity — too frequent.\n394:     },\n395:   });\n396: \n397:   // Create the TUI — it will auto-refresh and show activity from the monitor\n398:   const tuiRef = { current: null as WomboTUI | null };\n399:   const startTUI = () => {\n400:     tuiRef.current = new WomboTUI({\n401:       state,\n402:       monitor,\n403:       projectRoot,\n404:       interactive: false,\n405:       config,\n406:       onQuit: () => {\n407:         // Same as SIGINT — save state and exit\n408:         for (const agent of state.agents) {\n409:           if (agent.status === \"running\") {\n410:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n411:           }\n412:         }\n413:         monitor.killAll();\n414:         saveState(projectRoot, state);\n415:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n416:         process.exit(0);\n417:       },\n418:     });\n419:     tuiRef.current.start();\n420:   };\n421: \n422:   // Handle graceful shutdown\n423:   process.on(\"SIGINT\", () => {\n424:     if (tuiRef.current) tuiRef.current.stop();\n425:     for (const agent of state.agents) {\n426:       if (agent.status === \"running\") {\n427:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n428:       }\n429:     }\n430:     monitor.killAll();\n431:     saveState(projectRoot, state);\n432:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n433:     process.exit(0);\n434:   });\n435: \n436:   // Launch initial batch — set up worktrees in parallel\n437:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n438:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n439: \n440:   await Promise.all(\n441:     tolaunch.map((agent) =>\n442:       launchSingleHeadless(\n443:         projectRoot,\n444:         state,\n445:         agent,\n446:         featureMap.get(agent.feature_id)!,\n447:         monitor,\n448:         config,\n449:         model\n450:       )\n451:     )\n452:   );\n453: \n454:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n455: \n456:   // Start the TUI dashboard (or skip if --no-tui)\n457:   if (opts.noTui) {\n458:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n459:     printDashboard(state);\n460:   } else {\n461:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n462:     startTUI();\n463:   }\n464: \n465:   // Background monitoring loop — checks for dead processes and launches queued\n466:   const POLL_INTERVAL = 5000;\n467:   let dashboardCounter = 0;\n468:   while (!isWaveComplete(state)) {\n469:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n470: \n471:     // Check for completed processes that weren't caught by event handlers\n472:     for (const agent of state.agents) {\n473:       if (\n474:         agent.status === \"running\" &&\n475:         agent.pid &&\n476:         !isProcessRunning(agent.pid) &&\n477:         !monitor.isRunning(agent.feature_id)\n478:       ) {\n479:         // Process exited but we didn't get a callback\n480:         updateAgent(state, agent.feature_id, {\n481:           status: \"completed\",\n482:           completed_at: new Date().toISOString(),\n483:           activity: \"done\",\n484:         });\n485:         saveState(projectRoot, state);\n486:         try {\n487:           await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n488:         } catch (err: any) {\n489:           wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n490:         }\n491:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n492:       }\n493:     }\n494: \n495:     // Persist state periodically\n496:     saveState(projectRoot, state);\n497: \n498:     // Update TUI state reference (or print dashboard in --no-tui mode)\n499:     if (tuiRef.current) {\n500:       tuiRef.current.updateState(state);\n501:     } else if (opts.noTui) {\n502:       dashboardCounter++;\n503:       if (dashboardCounter % 3 === 0) {\n504:         printDashboard(state);\n505: \n506:         // Auto-push base branch if requested\n507:         if (opts.autoPush) {\n508:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n509:           if (anyMerged) {\n510:             await pushBaseBranch(projectRoot, state.base_branch, config);\n511:           } else {\n512:             console.log(\"No branches were merged — skipping push.\");\n513:           }\n514:         }\n515:       }\n516:     }\n517:   }\n518: \n519:   // Wave complete — tear down TUI and show final summary\n520:   if (tuiRef.current) tuiRef.current.stop();\n521:   printDashboard(state);\n522: \n523:   // Auto-push base branch if requested\n524:   if (opts.autoPush) {\n525:     await pushBaseBranch(projectRoot, state.base_branch, config);\n526:   }\n527: \n528:   console.log(\"Wave complete.\");\n529: }\n530: \n531: // ---------------------------------------------------------------------------\n532: // Interactive Wave Launch\n533: // ---------------------------------------------------------------------------\n534: \n535: async function launchWaveInteractive(\n536:   projectRoot: string,\n537:   state: WaveState,\n538:   features: Feature[],\n539:   opts: LaunchCommandOptions\n540: ): Promise<void> {\n541:   const { config, model } = opts;\n542:   const featureMap = new Map(features.map((f) => [f.id, f]));\n543: \n544:   // Show dashboard immediately\n545:   printDashboard(state);\n546: \n547:   // Launch initial batch in tmux — parallelize setup\n548:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n549:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n550: \n551:   await Promise.all(\n552:     tolaunch.map(async (agent) => {\n553:       updateAgent(state, agent.feature_id, {\n554:         status: \"installing\",\n555:         started_at: new Date().toISOString(),\n556:         activity: \"setting up worktree...\",\n557:       });\n558:       saveState(projectRoot, state);\n559: \n560:       try {\n561:         if (worktreeReady(agent.worktree)) {\n562:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n563:         } else {\n564:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n565:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n566:           await installDeps(agent.worktree, agent.feature_id, config);\n567:         }\n568: \n569:         const prompt = generatePrompt(\n570:           featureMap.get(agent.feature_id)!,\n571:           state.base_branch,\n572:           config\n573:         );\n574: \n575:         wtLog(agent.feature_id, \"launching tmux session...\");\n576:         const result = launchInteractive({\n577:           worktreePath: agent.worktree,\n578:           featureId: agent.feature_id,\n579:           prompt,\n580:           model,\n581:           interactive: true,\n582:           config,\n583:         });\n584: \n585:         updateAgent(state, agent.feature_id, {\n586:           status: \"running\",\n587:           pid: result.pid,\n588:           activity: \"tmux session active\",\n589:         });\n590:         saveState(projectRoot, state);\n591:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n592:       } catch (err: any) {\n593:         updateAgent(state, agent.feature_id, {\n594:           status: \"failed\",\n595:           error: err.message,\n596:           activity: null,\n597:           completed_at: new Date().toISOString(),\n598:         });\n599:         saveState(projectRoot, state);\n600:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n601:       }\n602:     })\n603:   );\n604: \n605:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n606:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n607:   console.log(\"  tmux ls                                                  # list sessions\");\n608:   console.log(\"  wombo status                                             # check status\");\n609:   console.log(\"  wombo verify                                             # verify builds\");\n610:   console.log(\"  wombo merge                                              # merge verified\");\n611:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n612: \n613:   printDashboard(state);\n614: }\n615: \n616: // ---------------------------------------------------------------------------\n617: // Main Command\n618: // ---------------------------------------------------------------------------\n619: \n620: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n621:   const { projectRoot, config } = opts;\n622: \n623:   console.log(\"\\n--- Wombo: Launch ---\\n\");\n624: \n625:   // Ensure agent definition exists — reinstall from template if missing\n626:   ensureAgentDefinition(projectRoot, config);\n627: \n628:   // Load features\n629:   const data = loadFeatures(projectRoot, config);\n630: \n631:   // Build selection options\n632:   const selOpts: SelectionOptions = {};\n633:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n634:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n635:   if (opts.priority) selOpts.priority = opts.priority;\n636:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n637:   if (opts.features) selOpts.featureIds = opts.features;\n638:   if (opts.allReady) selOpts.allReady = true;\n639: \n640:   // Select features\n641:   const selected = selectFeatures(data, selOpts);\n642: \n643:   if (selected.length === 0) {\n644:     console.error(\n645:       \"No features matched the selection criteria. Use --all-ready to see all available.\"\n646:     );\n647:     process.exit(1);\n648:   }\n649: \n650:   // Show selection\n651:   printFeatureSelection(\n652:     selected.map((f) => ({\n653:       id: f.id,\n654:       title: f.title,\n655:       priority: f.priority,\n656:       difficulty: f.difficulty,\n657:       effort: f.effort,\n658:     }))\n659:   );\n660: \n661:   if (opts.dryRun) {\n662:     console.log(\"Dry run — not launching agents.\");\n663:     return;\n664:   }\n665: \n666:   // Create wave state\n667:   const state = createWaveState({\n668:     baseBranch: opts.baseBranch,\n669:     maxConcurrent: opts.maxConcurrent,\n670:     model: opts.model ?? null,\n671:     interactive: opts.interactive,\n672:   });\n673: \n674:   // Create agent entries for all selected features\n675:   for (const feature of selected) {\n676:     const branch = featureBranchName(feature.id, config);\n677:     const wtPath = worktreePath(projectRoot, feature.id, config);\n678:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n679:     // Set effort estimate from feature spec\n680:     const effortMinutes = parseDurationMinutes(feature.effort);\n681:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n682:     state.agents.push(agent);\n683:   }\n684: \n685:   saveState(projectRoot, state);\n686:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n687: \n688:   // Launch agents up to max_concurrent\n689:   if (opts.interactive) {\n690:     await launchWaveInteractive(projectRoot, state, selected, opts);\n691:   } else {\n692:     await launchWaveHeadless(projectRoot, state, selected, opts);\n693:   }\n694: }\n\n(End of file - total 694 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\nimport { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773246672415,"end":1773246672422}}}}
{"type":"text","timestamp":1773246672825,"sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","part":{"id":"prt_cddbce82d00199VKTxACYDGvPO","sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","messageID":"msg_cddbcdd08001ds8m7HrcSI46fq","type":"text","text":"Now let me read the key source files to understand the implementation patterns:","time":{"start":1773246672825,"end":1773246672825}}}
{"type":"tool_use","timestamp":1773246672827,"sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","part":{"id":"prt_cddbcee200018dYi1uUDxbplKY","sessionID":"ses_3224353d0ffe1yyNC1L6qxZ8jx","messageID":"msg_cddbcdd08001ds8m7HrcSI46fq","type":"tool","callID":"toolu_01GKaZhHjrKoboB5mxogMDoD","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/worktree.ts"},"output":"<path>/home/fulgidus/Documents/wombo-agent-template-lifecycle/src/lib/worktree.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * worktree.ts — Git worktree lifecycle management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Create feature branches from a base branch\n6:  *   - Create git worktrees for each feature branch\n7:  *   - Run install command in worktrees\n8:  *   - List and remove worktrees\n9:  *   - Copy agent config files into worktrees\n10:  *\n11:  * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n12:  * to allow true parallelism with Promise.all.\n13:  */\n14: \n15: import { exec, execSync } from \"node:child_process\";\n16: import { existsSync, cpSync, statSync } from \"node:fs\";\n17: import { resolve, dirname } from \"node:path\";\n18: import type { WomboConfig } from \"../config.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface WorktreeInfo {\n25:   path: string;\n26:   branch: string;\n27:   head: string;\n28:   bare: boolean;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Diagnostic Logger\n33: // ---------------------------------------------------------------------------\n34: \n35: function ts(): string {\n36:   return new Date().toISOString().slice(11, 19); // HH:MM:SS\n37: }\n38: \n39: export function log(featureId: string, msg: string): void {\n40:   console.log(`  [${ts()}] ${featureId}: ${msg}`);\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // Async Command Runner\n45: // ---------------------------------------------------------------------------\n46: \n47: /**\n48:  * Run a command asynchronously. Returns stdout on success, throws on failure.\n49:  */\n50: function runAsync(\n51:   cmd: string,\n52:   opts?: { cwd?: string; timeoutMs?: number }\n53: ): Promise<string> {\n54:   return new Promise((resolve, reject) => {\n55:     exec(\n56:       cmd,\n57:       {\n58:         cwd: opts?.cwd,\n59:         encoding: \"utf-8\",\n60:         timeout: opts?.timeoutMs ?? 0,\n61:         maxBuffer: 10 * 1024 * 1024,\n62:       },\n63:       (error, stdout, stderr) => {\n64:         if (error) {\n65:           const errMsg = stderr?.trim() || stdout?.trim() || error.message;\n66:           reject(new Error(`Command failed: ${cmd}\\n${errMsg}`));\n67:         } else {\n68:           resolve((stdout ?? \"\").trim());\n69:         }\n70:       }\n71:     );\n72:   });\n73: }\n74: \n75: /**\n76:  * Synchronous run — only for quick, non-blocking operations.\n77:  */\n78: function runSync(\n79:   cmd: string,\n80:   opts?: { cwd?: string; silent?: boolean; timeoutMs?: number }\n81: ): string {\n82:   try {\n83:     return execSync(cmd, {\n84:       cwd: opts?.cwd,\n85:       encoding: \"utf-8\",\n86:       stdio: opts?.silent ? \"pipe\" : [\"pipe\", \"pipe\", \"pipe\"],\n87:       timeout: opts?.timeoutMs,\n88:       maxBuffer: 10 * 1024 * 1024,\n89:     }).trim();\n90:   } catch (err: any) {\n91:     const stderr = err.stderr?.toString().trim() || \"\";\n92:     const stdout = err.stdout?.toString().trim() || \"\";\n93:     throw new Error(\n94:       `Command failed: ${cmd}\\n${stderr || stdout || err.message}`\n95:     );\n96:   }\n97: }\n98: \n99: // ---------------------------------------------------------------------------\n100: // Branch Management\n101: // ---------------------------------------------------------------------------\n102: \n103: /**\n104:  * Create a feature branch from the base branch. If it already exists, reset it.\n105:  */\n106: async function createBranch(\n107:   projectRoot: string,\n108:   branchName: string,\n109:   baseBranch: string\n110: ): Promise<void> {\n111:   const existing = await runAsync(\n112:     `git branch --list \"${branchName}\"`,\n113:     { cwd: projectRoot }\n114:   );\n115:   if (existing.trim()) {\n116:     try {\n117:       await runAsync(`git branch -D \"${branchName}\"`, { cwd: projectRoot });\n118:     } catch {\n119:       // May fail if checked out in a worktree\n120:     }\n121:   }\n122:   await runAsync(`git branch \"${branchName}\" \"${baseBranch}\"`, {\n123:     cwd: projectRoot,\n124:   });\n125: }\n126: \n127: /**\n128:  * Generate the branch name for a feature using config prefix.\n129:  */\n130: export function featureBranchName(\n131:   featureId: string,\n132:   config: WomboConfig\n133: ): string {\n134:   return `${config.git.branchPrefix}${featureId}`;\n135: }\n136: \n137: /**\n138:  * Generate the worktree path for a feature (sibling directory to project root).\n139:  */\n140: export function worktreePath(\n141:   projectRoot: string,\n142:   featureId: string,\n143:   config: WomboConfig\n144: ): string {\n145:   const parentDir = dirname(projectRoot);\n146:   return resolve(parentDir, `${config.git.worktreePrefix}${featureId}`);\n147: }\n148: \n149: // ---------------------------------------------------------------------------\n150: // Worktree Lifecycle (async)\n151: // ---------------------------------------------------------------------------\n152: \n153: /**\n154:  * Create a git worktree for a feature branch.\n155:  * Returns the absolute path to the worktree.\n156:  */\n157: export async function createWorktree(\n158:   projectRoot: string,\n159:   featureId: string,\n160:   baseBranch: string,\n161:   config: WomboConfig\n162: ): Promise<string> {\n163:   const branch = featureBranchName(featureId, config);\n164:   const wtPath = worktreePath(projectRoot, featureId, config);\n165: \n166:   // Create the branch if it doesn't exist\n167:   log(featureId, \"creating branch...\");\n168:   await createBranch(projectRoot, branch, baseBranch);\n169: \n170:   // Remove existing worktree if present\n171:   if (existsSync(wtPath)) {\n172:     log(featureId, \"removing old worktree...\");\n173:     try {\n174:       await runAsync(`git worktree remove --force \"${wtPath}\"`, {\n175:         cwd: projectRoot,\n176:       });\n177:     } catch {\n178:       await runAsync(`rm -rf \"${wtPath}\"`);\n179:       await runAsync(`git worktree prune`, { cwd: projectRoot });\n180:     }\n181:   }\n182: \n183:   // Create the worktree\n184:   log(featureId, \"creating worktree...\");\n185:   await runAsync(`git worktree add \"${wtPath}\" \"${branch}\"`, {\n186:     cwd: projectRoot,\n187:   });\n188: \n189:   // Copy agent config files into worktree\n190:   for (const configFile of config.agent.configFiles) {\n191:     const srcPath = resolve(projectRoot, configFile);\n192:     if (!existsSync(srcPath)) continue;\n193: \n194:     const destPath = resolve(wtPath, configFile);\n195:     try {\n196:       const stat = statSync(srcPath);\n197:       if (stat.isDirectory()) {\n198:         cpSync(srcPath, destPath, { recursive: true });\n199:       } else {\n200:         cpSync(srcPath, destPath);\n201:       }\n202:     } catch {\n203:       // Non-critical — best effort\n204:     }\n205:   }\n206: \n207:   // Verify all config files were copied successfully\n208:   verifyConfigFiles(projectRoot, wtPath, featureId, config);\n209: \n210:   log(featureId, \"worktree ready\");\n211:   return wtPath;\n212: }\n213: \n214: // ---------------------------------------------------------------------------\n215: // Config File Verification\n216: // ---------------------------------------------------------------------------\n217: \n218: /**\n219:  * Verify that all expected config files were copied into the worktree.\n220:  * Logs a warning for any that are missing. This is a safety net on top\n221:  * of the best-effort cpSync logic in createWorktree.\n222:  */\n223: function verifyConfigFiles(\n224:   projectRoot: string,\n225:   wtPath: string,\n226:   featureId: string,\n227:   config: WomboConfig\n228: ): void {\n229:   const missing: string[] = [];\n230: \n231:   for (const configFile of config.agent.configFiles) {\n232:     const srcPath = resolve(projectRoot, configFile);\n233:     const destPath = resolve(wtPath, configFile);\n234: \n235:     // Only check files/dirs that exist in the source project\n236:     if (!existsSync(srcPath)) continue;\n237: \n238:     if (!existsSync(destPath)) {\n239:       missing.push(configFile);\n240:     }\n241:   }\n242: \n243:   if (missing.length > 0) {\n244:     log(\n245:       featureId,\n246:       `\\x1b[33mWARNING\\x1b[0m: config files missing in worktree: ${missing.join(\", \")}`\n247:     );\n248:   }\n249: }\n250: \n251: /**\n252:  * Install dependencies in a worktree.\n253:  */\n254: export async function installDeps(\n255:   wtPath: string,\n256:   featureId: string,\n257:   config: WomboConfig\n258: ): Promise<void> {\n259:   log(featureId, `running ${config.install.command}...`);\n260:   const start = Date.now();\n261:   await runAsync(config.install.command, {\n262:     cwd: wtPath,\n263:     timeoutMs: config.install.timeout,\n264:   });\n265:   const elapsed = ((Date.now() - start) / 1000).toFixed(1);\n266:   log(featureId, `install done (${elapsed}s)`);\n267: }\n268: \n269: /**\n270:  * Check if a worktree already exists and has node_modules.\n271:  */\n272: export function worktreeReady(wtPath: string): boolean {\n273:   return (\n274:     existsSync(wtPath) &&\n275:     existsSync(resolve(wtPath, \"node_modules\"))\n276:   );\n277: }\n278: \n279: // ---------------------------------------------------------------------------\n280: // Worktree Listing / Cleanup (sync)\n281: // ---------------------------------------------------------------------------\n282: \n283: /**\n284:  * List all git worktrees.\n285:  */\n286: export function listWorktrees(projectRoot: string): WorktreeInfo[] {\n287:   const output = runSync(\"git worktree list --porcelain\", {\n288:     cwd: projectRoot,\n289:     silent: true,\n290:   });\n291:   if (!output) return [];\n292: \n293:   const worktrees: WorktreeInfo[] = [];\n294:   let current: Partial<WorktreeInfo> = {};\n295: \n296:   for (const line of output.split(\"\\n\")) {\n297:     if (line.startsWith(\"worktree \")) {\n298:       if (current.path) worktrees.push(current as WorktreeInfo);\n299:       current = { path: line.slice(9), bare: false };\n300:     } else if (line.startsWith(\"HEAD \")) {\n301:       current.head = line.slice(5);\n302:     } else if (line.startsWith(\"branch \")) {\n303:       current.branch = line.slice(7).replace(\"refs/heads/\", \"\");\n304:     } else if (line === \"bare\") {\n305:       current.bare = true;\n306:     } else if (line === \"\" && current.path) {\n307:       worktrees.push(current as WorktreeInfo);\n308:       current = {};\n309:     }\n310:   }\n311:   if (current.path) worktrees.push(current as WorktreeInfo);\n312: \n313:   return worktrees;\n314: }\n315: \n316: /**\n317:  * List only wombo-related worktrees.\n318:  */\n319: export function listWomboWorktrees(\n320:   projectRoot: string,\n321:   config: WomboConfig\n322: ): WorktreeInfo[] {\n323:   return listWorktrees(projectRoot).filter((wt) =>\n324:     wt.path.includes(config.git.worktreePrefix)\n325:   );\n326: }\n327: \n328: /**\n329:  * Remove a worktree and optionally delete its branch.\n330:  */\n331: export function removeWorktree(\n332:   projectRoot: string,\n333:   wtPath: string,\n334:   deleteBranchToo: boolean = true\n335: ): void {\n336:   const worktrees = listWorktrees(projectRoot);\n337:   const wt = worktrees.find((w) => w.path === wtPath);\n338: \n339:   try {\n340:     runSync(`git worktree remove --force \"${wtPath}\"`, { cwd: projectRoot });\n341:   } catch {\n342:     if (existsSync(wtPath)) {\n343:       runSync(`rm -rf \"${wtPath}\"`);\n344:     }\n345:     runSync(\"git worktree prune\", { cwd: projectRoot });\n346:   }\n347: \n348:   if (deleteBranchToo && wt?.branch) {\n349:     try {\n350:       runSync(`git branch -D \"${wt.branch}\"`, {\n351:         cwd: projectRoot,\n352:         silent: true,\n353:       });\n354:     } catch {\n355:       // Branch may have been merged or already deleted\n356:     }\n357:   }\n358: }\n359: \n360: /**\n361:  * Remove all wombo-related worktrees and prune.\n362:  */\n363: export function cleanupAllWorktrees(\n364:   projectRoot: string,\n365:   config: WomboConfig\n366: ): number {\n367:   const womboWorktrees = listWomboWorktrees(projectRoot, config);\n368:   let removed = 0;\n369:   for (const wt of womboWorktrees) {\n370:     try {\n371:       removeWorktree(projectRoot, wt.path, false);\n372:       removed++;\n373:     } catch (err: any) {\n374:       console.error(`Failed to remove worktree ${wt.path}: ${err.message}`);\n375:     }\n376:   }\n377:   runSync(\"git worktree prune\", { cwd: projectRoot });\n378:   return removed;\n379: }\n\n(End of file - total 379 lines)\n</content>","title":"src/lib/worktree.ts","metadata":{"preview":"/**\n * worktree.ts — Git worktree lifecycle management.\n *\n * Responsibilities:\n *   - Create feature branches from a base branch\n *   - Create git worktrees for each feature branch\n *   - Run install command in worktrees\n *   - List and remove worktrees\n *   - Copy agent config files into worktrees\n *\n * IMPORTANT: Heavy operations (createWorktree, installDeps) are async\n * to allow true parallelism with Promise.all.\n */\n\nimport { exec, execSync } from \"node:child_process\";\nimport { existsSync, cpSync, statSync } from \"node:fs\";\nimport { resolve, dirname } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773246672823,"end":1773246672827}}}}
