{"type":"tool_use","timestamp":1773246665659,"sessionID":"ses_3224353f9ffe48zNky1jQ0HMD4","part":{"id":"prt_cddbcd121001DXU1roswUr2hrk","sessionID":"ses_3224353f9ffe48zNky1jQ0HMD4","messageID":"msg_cddbcc484001PW26YxhAuOrLKA","type":"tool","callID":"toolu_015gobqugQ7eBCsXEWbVqmgg","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-ux-polish/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-ux-polish/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import type { WomboConfig } from \"../config.js\";\n19: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n20: import { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";\n21: import {\n22:   loadState,\n23:   saveState,\n24:   createWaveState,\n25:   createAgentState,\n26:   updateAgent,\n27:   activeAgents,\n28:   queuedAgents,\n29:   isWaveComplete,\n30:   type WaveState,\n31:   type AgentState,\n32: } from \"../lib/state.js\";\n33: import {\n34:   createWorktree,\n35:   installDeps,\n36:   featureBranchName,\n37:   worktreePath,\n38:   worktreeReady,\n39:   removeWorktree,\n40:   log as wtLog,\n41: } from \"../lib/worktree.js\";\n42: import { generatePrompt } from \"../lib/prompt.js\";\n43: import {\n44:   launchHeadless,\n45:   retryHeadless,\n46:   launchInteractive,\n47:   retryInteractive,\n48:   isProcessRunning,\n49: } from \"../lib/launcher.js\";\n50: import { ProcessMonitor } from \"../lib/monitor.js\";\n51: import { runBuild } from \"../lib/verifier.js\";\n52: import { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\n53: import {\n54:   printDashboard,\n55:   printFeatureSelection,\n56:   printAgentUpdate,\n57: } from \"../lib/ui.js\";\n58: import { WomboTUI } from \"../lib/tui.js\";\n59: \n60: // ---------------------------------------------------------------------------\n61: // Types\n62: // ---------------------------------------------------------------------------\n63: \n64: export interface LaunchCommandOptions {\n65:   projectRoot: string;\n66:   config: WomboConfig;\n67:   // Selection\n68:   topPriority?: number;\n69:   quickestWins?: number;\n70:   priority?: Priority;\n71:   difficulty?: Difficulty;\n72:   features?: string[];\n73:   allReady?: boolean;\n74:   // Launch\n75:   maxConcurrent: number;\n76:   model?: string;\n77:   interactive: boolean;\n78:   dryRun: boolean;\n79:   baseBranch: string;\n80:   maxRetries: number;\n81:   noTui: boolean;\n82:   autoPush: boolean;\n83: }\n84: \n85: // ---------------------------------------------------------------------------\n86: // Shared Helpers (exported for resume.ts and others)\n87: // ---------------------------------------------------------------------------\n88: \n89: /**\n90:  * Launch a single agent in headless mode.\n91:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n92:  */\n93: export async function launchSingleHeadless(\n94:   projectRoot: string,\n95:   state: WaveState,\n96:   agent: AgentState,\n97:   feature: Feature,\n98:   monitor: ProcessMonitor,\n99:   config: WomboConfig,\n100:   model?: string\n101: ): Promise<void> {\n102:   updateAgent(state, agent.feature_id, {\n103:     status: \"installing\",\n104:     started_at: new Date().toISOString(),\n105:     activity: \"setting up worktree...\",\n106:   });\n107:   saveState(projectRoot, state);\n108: \n109:   try {\n110:     // Skip worktree setup if already ready (resume case)\n111:     if (worktreeReady(agent.worktree)) {\n112:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n113:     } else {\n114:       // Create worktree (async — doesn't block other agents)\n115:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n116: \n117:       // Install dependencies (async)\n118:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n119:       await installDeps(agent.worktree, feature.id, config);\n120:     }\n121: \n122:     // Generate prompt\n123:     const prompt = generatePrompt(feature, state.base_branch, config);\n124: \n125:     // Launch agent\n126:     wtLog(agent.feature_id, \"launching agent...\");\n127:     const result = launchHeadless({\n128:       worktreePath: agent.worktree,\n129:       featureId: feature.id,\n130:       prompt,\n131:       model,\n132:       config,\n133:     });\n134: \n135:     updateAgent(state, agent.feature_id, {\n136:       status: \"running\",\n137:       pid: result.pid,\n138:       activity: \"starting...\",\n139:     });\n140:     saveState(projectRoot, state);\n141: \n142:     monitor.addProcess(feature.id, result.process);\n143:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n144:   } catch (err: any) {\n145:     updateAgent(state, agent.feature_id, {\n146:       status: \"failed\",\n147:       error: err.message,\n148:       activity: null,\n149:       completed_at: new Date().toISOString(),\n150:     });\n151:     saveState(projectRoot, state);\n152:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n153:   }\n154: }\n155: \n156: /**\n157:  * Handle build verification after agent completion.\n158:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n159:  *\n160:  * ASYNC — runs build and merge without blocking the event loop.\n161:  */\n162: export async function handleBuildVerification(\n163:   projectRoot: string,\n164:   state: WaveState,\n165:   agent: AgentState,\n166:   feature: Feature,\n167:   config: WomboConfig,\n168:   model?: string,\n169:   monitor?: ProcessMonitor\n170: ): Promise<void> {\n171:   try {\n172:     printAgentUpdate(agent, \"verifying build...\");\n173: \n174:     const buildResult = await runBuild(agent.worktree, config);\n175: \n176:     if (buildResult.passed) {\n177:       updateAgent(state, agent.feature_id, {\n178:         status: \"verified\",\n179:         build_passed: true,\n180:         build_output: null,\n181:       });\n182:       saveState(projectRoot, state);\n183:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n184: \n185:       // Auto-merge: merge verified branch into base immediately\n186:       printAgentUpdate(agent, \"auto-merging...\");\n187:       try {\n188:         const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n189: \n190:         if (mergeResult.success) {\n191:           updateAgent(state, agent.feature_id, {\n192:             status: \"merged\",\n193:             completed_at: new Date().toISOString(),\n194:           });\n195:           saveState(projectRoot, state);\n196:           printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n197: \n198:           // Clean up worktree after successful merge\n199:           try {\n200:             removeWorktree(projectRoot, agent.worktree, false);\n201:             printAgentUpdate(agent, \"worktree removed\");\n202:           } catch {\n203:             // Not critical — worktree cleanup is best-effort\n204:           }\n205:         } else {\n206:           // Merge failed (conflicts, etc.) — leave as verified for manual resolution\n207:           printAgentUpdate(agent, `AUTO-MERGE FAILED: ${mergeResult.error}`);\n208:         }\n209:       } catch (mergeErr: any) {\n210:         printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n211:       }\n212:     } else {\n213:       if (agent.retries < agent.max_retries) {\n214:         updateAgent(state, agent.feature_id, {\n215:           status: \"retry\",\n216:           retries: agent.retries + 1,\n217:           build_passed: false,\n218:           build_output: buildResult.errorSummary,\n219:         });\n220:         saveState(projectRoot, state);\n221:         printAgentUpdate(\n222:           agent,\n223:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n224:         );\n225: \n226:         // Retry with build errors\n227:         if (agent.session_id) {\n228:           const retryResult = retryHeadless({\n229:             worktreePath: agent.worktree,\n230:             featureId: agent.feature_id,\n231:             sessionId: agent.session_id,\n232:             buildErrors: buildResult.errorSummary,\n233:             model,\n234:             config,\n235:           });\n236: \n237:           updateAgent(state, agent.feature_id, {\n238:             status: \"running\",\n239:             pid: retryResult.pid,\n240:           });\n241:           saveState(projectRoot, state);\n242: \n243:           // Add retry process to monitor so events are tracked\n244:           if (monitor) {\n245:             monitor.addProcess(agent.feature_id, retryResult.process);\n246:           }\n247:         }\n248:       } else {\n249:         updateAgent(state, agent.feature_id, {\n250:           status: \"failed\",\n251:           build_passed: false,\n252:           build_output: buildResult.errorSummary,\n253:           error: `Build failed after ${agent.max_retries} retries`,\n254:           completed_at: new Date().toISOString(),\n255:         });\n256:         saveState(projectRoot, state);\n257:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n258:       }\n259:     }\n260:   } catch (err: any) {\n261:     // Catch-all — never let build verification crash the process\n262:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n263:     updateAgent(state, agent.feature_id, {\n264:       status: \"failed\",\n265:       error: `Build verification error: ${err.message}`,\n266:       completed_at: new Date().toISOString(),\n267:     });\n268:     saveState(projectRoot, state);\n269:   }\n270: }\n271: \n272: /**\n273:  * Handle retry of a failed agent (error-based, not build-based).\n274:  */\n275: export function handleRetry(\n276:   projectRoot: string,\n277:   state: WaveState,\n278:   agent: AgentState,\n279:   monitor: ProcessMonitor,\n280:   config: WomboConfig,\n281:   model?: string\n282: ): void {\n283:   if (!agent.session_id || !agent.error) return;\n284: \n285:   const retryResult = retryHeadless({\n286:     worktreePath: agent.worktree,\n287:     featureId: agent.feature_id,\n288:     sessionId: agent.session_id,\n289:     buildErrors: agent.error,\n290:     model,\n291:     config,\n292:   });\n293: \n294:   updateAgent(state, agent.feature_id, {\n295:     status: \"running\",\n296:     pid: retryResult.pid,\n297:   });\n298:   saveState(projectRoot, state);\n299: \n300:   monitor.addProcess(agent.feature_id, retryResult.process);\n301: }\n302: \n303: /**\n304:  * Launch the next queued agent if capacity allows.\n305:  */\n306: export function launchNextQueued(\n307:   projectRoot: string,\n308:   state: WaveState,\n309:   featureMap: Map<string, Feature>,\n310:   monitor: ProcessMonitor,\n311:   config: WomboConfig,\n312:   model?: string\n313: ): void {\n314:   const active = activeAgents(state);\n315:   const queued = queuedAgents(state);\n316: \n317:   if (active.length < state.max_concurrent && queued.length > 0) {\n318:     const next = queued[0];\n319:     const feature = featureMap.get(next.feature_id);\n320:     if (feature) {\n321:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n322:     }\n323:   }\n324: }\n325: \n326: // ---------------------------------------------------------------------------\n327: // Headless Wave Launch\n328: // ---------------------------------------------------------------------------\n329: \n330: async function launchWaveHeadless(\n331:   projectRoot: string,\n332:   state: WaveState,\n333:   features: Feature[],\n334:   opts: LaunchCommandOptions\n335: ): Promise<void> {\n336:   const { config, model } = opts;\n337:   const featureMap = new Map(features.map((f) => [f.id, f]));\n338: \n339:   const monitor = new ProcessMonitor(projectRoot, {\n340:     onSessionId: (featureId, sessionId) => {\n341:       updateAgent(state, featureId, { session_id: sessionId });\n342:       saveState(projectRoot, state);\n343:     },\n344:     onComplete: (featureId) => {\n345:       updateAgent(state, featureId, {\n346:         status: \"completed\",\n347:         completed_at: new Date().toISOString(),\n348:       });\n349:       saveState(projectRoot, state);\n350: \n351:       // Run build verification — fire-and-forget\n352:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n353:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n354:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n355:         .catch((err) => {\n356:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n357:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n358:         });\n359:     },\n360:     onError: (featureId, error) => {\n361:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n362:       if (agent.retries < agent.max_retries) {\n363:         updateAgent(state, featureId, {\n364:           status: \"retry\",\n365:           retries: agent.retries + 1,\n366:           error,\n367:         });\n368:         saveState(projectRoot, state);\n369: \n370:         // Retry\n371:         handleRetry(projectRoot, state, agent, monitor, config, model);\n372:       } else {\n373:         updateAgent(state, featureId, {\n374:           status: \"failed\",\n375:           error,\n376:           completed_at: new Date().toISOString(),\n377:         });\n378:         saveState(projectRoot, state);\n379:       }\n380: \n381:       // Try to launch next queued agent\n382:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n383:     },\n384:     onOutput: (_featureId, _data) => {\n385:       // Raw output — logged to file by ProcessMonitor\n386:     },\n387:     onActivity: (featureId, activity) => {\n388:       updateAgent(state, featureId, {\n389:         activity,\n390:         activity_updated_at: new Date().toISOString(),\n391:       });\n392:       // Don't save to disk on every activity — too frequent.\n393:     },\n394:   });\n395: \n396:   // Create the TUI — it will auto-refresh and show activity from the monitor\n397:   const tuiRef = { current: null as WomboTUI | null };\n398:   const startTUI = () => {\n399:     tuiRef.current = new WomboTUI({\n400:       state,\n401:       monitor,\n402:       projectRoot,\n403:       interactive: false,\n404:       config,\n405:       onQuit: () => {\n406:         // Same as SIGINT — save state and exit\n407:         for (const agent of state.agents) {\n408:           if (agent.status === \"running\") {\n409:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n410:           }\n411:         }\n412:         monitor.killAll();\n413:         saveState(projectRoot, state);\n414:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n415:         process.exit(0);\n416:       },\n417:     });\n418:     tuiRef.current.start();\n419:   };\n420: \n421:   // Handle graceful shutdown\n422:   process.on(\"SIGINT\", () => {\n423:     if (tuiRef.current) tuiRef.current.stop();\n424:     for (const agent of state.agents) {\n425:       if (agent.status === \"running\") {\n426:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n427:       }\n428:     }\n429:     monitor.killAll();\n430:     saveState(projectRoot, state);\n431:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n432:     process.exit(0);\n433:   });\n434: \n435:   // Launch initial batch — set up worktrees in parallel\n436:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n437:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n438: \n439:   await Promise.all(\n440:     tolaunch.map((agent) =>\n441:       launchSingleHeadless(\n442:         projectRoot,\n443:         state,\n444:         agent,\n445:         featureMap.get(agent.feature_id)!,\n446:         monitor,\n447:         config,\n448:         model\n449:       )\n450:     )\n451:   );\n452: \n453:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n454: \n455:   // Start the TUI dashboard (or skip if --no-tui)\n456:   if (opts.noTui) {\n457:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n458:     printDashboard(state);\n459:   } else {\n460:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n461:     startTUI();\n462:   }\n463: \n464:   // Background monitoring loop — checks for dead processes and launches queued\n465:   const POLL_INTERVAL = 5000;\n466:   let dashboardCounter = 0;\n467:   while (!isWaveComplete(state)) {\n468:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n469: \n470:     // Check for completed processes that weren't caught by event handlers\n471:     for (const agent of state.agents) {\n472:       if (\n473:         agent.status === \"running\" &&\n474:         agent.pid &&\n475:         !isProcessRunning(agent.pid) &&\n476:         !monitor.isRunning(agent.feature_id)\n477:       ) {\n478:         // Process exited but we didn't get a callback\n479:         updateAgent(state, agent.feature_id, {\n480:           status: \"completed\",\n481:           completed_at: new Date().toISOString(),\n482:           activity: \"done\",\n483:         });\n484:         saveState(projectRoot, state);\n485:         try {\n486:           await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n487:         } catch (err: any) {\n488:           wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n489:         }\n490:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n491:       }\n492:     }\n493: \n494:     // Persist state periodically\n495:     saveState(projectRoot, state);\n496: \n497:     // Update TUI state reference (or print dashboard in --no-tui mode)\n498:     if (tuiRef.current) {\n499:       tuiRef.current.updateState(state);\n500:     } else if (opts.noTui) {\n501:       dashboardCounter++;\n502:       if (dashboardCounter % 3 === 0) {\n503:         printDashboard(state);\n504: \n505:         // Auto-push base branch if requested\n506:         if (opts.autoPush) {\n507:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n508:           if (anyMerged) {\n509:             await pushBaseBranch(projectRoot, state.base_branch, config);\n510:           } else {\n511:             console.log(\"No branches were merged — skipping push.\");\n512:           }\n513:         }\n514:       }\n515:     }\n516:   }\n517: \n518:   // Wave complete — tear down TUI and show final summary\n519:   if (tuiRef.current) tuiRef.current.stop();\n520:   printDashboard(state);\n521: \n522:   // Auto-push base branch if requested\n523:   if (opts.autoPush) {\n524:     await pushBaseBranch(projectRoot, state.base_branch, config);\n525:   }\n526: \n527:   console.log(\"Wave complete.\");\n528: }\n529: \n530: // ---------------------------------------------------------------------------\n531: // Interactive Wave Launch\n532: // ---------------------------------------------------------------------------\n533: \n534: async function launchWaveInteractive(\n535:   projectRoot: string,\n536:   state: WaveState,\n537:   features: Feature[],\n538:   opts: LaunchCommandOptions\n539: ): Promise<void> {\n540:   const { config, model } = opts;\n541:   const featureMap = new Map(features.map((f) => [f.id, f]));\n542: \n543:   // Show dashboard immediately\n544:   printDashboard(state);\n545: \n546:   // Launch initial batch in tmux — parallelize setup\n547:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n548:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n549: \n550:   await Promise.all(\n551:     tolaunch.map(async (agent) => {\n552:       updateAgent(state, agent.feature_id, {\n553:         status: \"installing\",\n554:         started_at: new Date().toISOString(),\n555:         activity: \"setting up worktree...\",\n556:       });\n557:       saveState(projectRoot, state);\n558: \n559:       try {\n560:         if (worktreeReady(agent.worktree)) {\n561:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n562:         } else {\n563:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n564:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n565:           await installDeps(agent.worktree, agent.feature_id, config);\n566:         }\n567: \n568:         const prompt = generatePrompt(\n569:           featureMap.get(agent.feature_id)!,\n570:           state.base_branch,\n571:           config\n572:         );\n573: \n574:         wtLog(agent.feature_id, \"launching tmux session...\");\n575:         const result = launchInteractive({\n576:           worktreePath: agent.worktree,\n577:           featureId: agent.feature_id,\n578:           prompt,\n579:           model,\n580:           interactive: true,\n581:           config,\n582:         });\n583: \n584:         updateAgent(state, agent.feature_id, {\n585:           status: \"running\",\n586:           pid: result.pid,\n587:           activity: \"tmux session active\",\n588:         });\n589:         saveState(projectRoot, state);\n590:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n591:       } catch (err: any) {\n592:         updateAgent(state, agent.feature_id, {\n593:           status: \"failed\",\n594:           error: err.message,\n595:           activity: null,\n596:           completed_at: new Date().toISOString(),\n597:         });\n598:         saveState(projectRoot, state);\n599:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n600:       }\n601:     })\n602:   );\n603: \n604:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n605:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n606:   console.log(\"  tmux ls                                                  # list sessions\");\n607:   console.log(\"  wombo status                                             # check status\");\n608:   console.log(\"  wombo verify                                             # verify builds\");\n609:   console.log(\"  wombo merge                                              # merge verified\");\n610:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n611: \n612:   printDashboard(state);\n613: }\n614: \n615: // ---------------------------------------------------------------------------\n616: // Main Command\n617: // ---------------------------------------------------------------------------\n618: \n619: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n620:   const { projectRoot, config } = opts;\n621: \n622:   console.log(\"\\n--- Wombo: Launch ---\\n\");\n623: \n624:   // Load features\n625:   const data = loadFeatures(projectRoot, config);\n626: \n627:   // Build selection options\n628:   const selOpts: SelectionOptions = {};\n629:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n630:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n631:   if (opts.priority) selOpts.priority = opts.priority;\n632:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n633:   if (opts.features) selOpts.featureIds = opts.features;\n634:   if (opts.allReady) selOpts.allReady = true;\n635: \n636:   // Select features\n637:   const selected = selectFeatures(data, selOpts);\n638: \n639:   if (selected.length === 0) {\n640:     if (opts.allReady) {\n641:       console.error(\n642:         \"No launchable features found. All features may be done, cancelled, or have unmet dependencies.\"\n643:       );\n644:     } else {\n645:       console.error(\n646:         \"No features matched the selection criteria. Use --all-ready to see all available.\"\n647:       );\n648:     }\n649:     process.exit(1);\n650:   }\n651: \n652:   // Show selection\n653:   printFeatureSelection(\n654:     selected.map((f) => ({\n655:       id: f.id,\n656:       title: f.title,\n657:       priority: f.priority,\n658:       difficulty: f.difficulty,\n659:       effort: f.effort,\n660:     }))\n661:   );\n662: \n663:   if (opts.dryRun) {\n664:     console.log(\"Dry run — not launching agents.\");\n665:     return;\n666:   }\n667: \n668:   // Create wave state\n669:   const state = createWaveState({\n670:     baseBranch: opts.baseBranch,\n671:     maxConcurrent: opts.maxConcurrent,\n672:     model: opts.model ?? null,\n673:     interactive: opts.interactive,\n674:   });\n675: \n676:   // Create agent entries for all selected features\n677:   for (const feature of selected) {\n678:     const branch = featureBranchName(feature.id, config);\n679:     const wtPath = worktreePath(projectRoot, feature.id, config);\n680:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n681:     // Set effort estimate from feature spec\n682:     const effortMinutes = parseDurationMinutes(feature.effort);\n683:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n684:     state.agents.push(agent);\n685:   }\n686: \n687:   saveState(projectRoot, state);\n688:   console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n689: \n690:   // Launch agents up to max_concurrent\n691:   if (opts.interactive) {\n692:     await launchWaveInteractive(projectRoot, state, selected, opts);\n693:   } else {\n694:     await launchWaveHeadless(projectRoot, state, selected, opts);\n695:   }\n696: }\n\n(End of file - total 696 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\nimport { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773246665655,"end":1773246665658}}}}
