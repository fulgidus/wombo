{"type":"tool_use","timestamp":1773246661728,"sessionID":"ses_3224353f9ffe48zNky1jQ0HMD4","part":{"id":"prt_cddbcc35d001NMUsTUq33T6V5W","sessionID":"ses_3224353f9ffe48zNky1jQ0HMD4","messageID":"msg_cddbcac3f001OxX7V00slfVlYd","type":"tool","callID":"toolu_01RCDwhM2ftMgyZcSADp3p37","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-ux-polish/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-ux-polish/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo cleanup\n21:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n22:  *   wombo features add <id> <title> [options]\n23:  *   wombo features set-status <feature-id> <status>\n24:  *   wombo features check\n25:  *   wombo features archive [feature-id] [--dry-run]\n26:  *   wombo features show <feature-id>\n27:  *   wombo help\n28:  *   wombo --version\n29:  */\n30: \n31: import { resolve } from \"node:path\";\n32: import { existsSync, readFileSync } from \"node:fs\";\n33: import { loadConfig, validateConfig } from \"./config.js\";\n34: import { loadState, saveState } from \"./lib/state.js\";\n35: \n36: // ---------------------------------------------------------------------------\n37: // Dev-mode guard: warn if running the global binary inside the wombo repo\n38: // ---------------------------------------------------------------------------\n39: \n40: function checkDevModeGuard(): void {\n41:   const cwd = process.cwd();\n42:   const pkgPath = resolve(cwd, \"package.json\");\n43: \n44:   // Are we inside the wombo repo?\n45:   if (!existsSync(pkgPath)) return;\n46: \n47:   let pkgName: string | undefined;\n48:   try {\n49:     const raw = readFileSync(pkgPath, \"utf-8\");\n50:     pkgName = JSON.parse(raw).name;\n51:   } catch {\n52:     return;\n53:   }\n54:   if (pkgName !== \"wombo\") return;\n55: \n56:   // We're in the wombo repo. Is the source being run from a different location?\n57:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n58:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n59:   // we're running the globally installed binary.\n60:   const sourceDir = resolve(import.meta.dir);\n61:   const projectSrc = resolve(cwd, \"src\");\n62: \n63:   if (!sourceDir.startsWith(projectSrc)) {\n64:     console.warn(\n65:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n66:       \"inside the wombo repo.\\n\" +\n67:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n68:       \"  See AGENTS.md for details.\\n\"\n69:     );\n70:   }\n71: }\n72: \n73: import { cmdInit } from \"./commands/init.js\";\n74: import { cmdLaunch } from \"./commands/launch.js\";\n75: import { cmdResume } from \"./commands/resume.js\";\n76: import { cmdStatus } from \"./commands/status.js\";\n77: import { cmdVerify } from \"./commands/verify.js\";\n78: import { cmdMerge } from \"./commands/merge.js\";\n79: import { cmdRetry } from \"./commands/retry.js\";\n80: import { cmdCleanup } from \"./commands/cleanup.js\";\n81: import { cmdUpgrade } from \"./commands/upgrade.js\";\n82: import { cmdFeaturesList } from \"./commands/features/list.js\";\n83: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n84: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n85: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n86: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n87: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n88: \n89: import { ensureFeaturesFile } from \"./lib/features.js\";\n90: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n91: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n92: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n93: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n94: \n95: // ---------------------------------------------------------------------------\n96: // Types\n97: // ---------------------------------------------------------------------------\n98: \n99: interface CLIArgs {\n100:   command: string;\n101:   subcommand?: string;\n102:   // Selection options (launch)\n103:   topPriority?: number;\n104:   quickestWins?: number;\n105:   priority?: Priority;\n106:   difficulty?: Difficulty;\n107:   features?: string[];\n108:   allReady?: boolean;\n109:   // Launch / runtime options\n110:   maxConcurrent?: number;\n111:   model?: string;\n112:   interactive: boolean;\n113:   dryRun: boolean;\n114:   baseBranch?: string;\n115:   maxRetries?: number;\n116:   noTui: boolean;\n117:   autoPush: boolean;\n118:   // General\n119:   featureId?: string;\n120:   force: boolean;\n121:   // Output format\n122:   outputFmt: OutputFormat;\n123:   // Upgrade options\n124:   checkOnly: boolean;\n125:   version?: string;\n126:   // Features subcommand extras\n127:   status?: string;\n128:   ready?: boolean;\n129:   includeArchive?: boolean;\n130:   title?: string;\n131:   description?: string;\n132:   effort?: string;\n133:   dependsOn?: string[];\n134:   // Compact output\n135:   fields?: string[];\n136: }\n137: \n138: // ---------------------------------------------------------------------------\n139: // Arg Parsing\n140: // ---------------------------------------------------------------------------\n141: \n142: function parseArgs(argv: string[]): CLIArgs {\n143:   const args = argv.slice(2); // skip 'bun' and script path\n144:   const result: CLIArgs = {\n145:     command: args[0] || \"help\",\n146:     interactive: false,\n147:     dryRun: false,\n148:     noTui: false,\n149:     autoPush: false,\n150:     force: false,\n151:     checkOnly: false,\n152:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n153:   };\n154: \n155:   // If the first arg is \"features\", treat the second positional as the subcommand\n156:   let startIdx = 1;\n157:   if (result.command === \"features\") {\n158:     result.subcommand = args[1] || \"list\";\n159:     startIdx = 2;\n160:   }\n161: \n162:   for (let i = startIdx; i < args.length; i++) {\n163:     const arg = args[i];\n164:     switch (arg) {\n165:       // --- Selection options ---\n166:       case \"--top-priority\":\n167:         result.topPriority = parseInt(args[++i], 10);\n168:         break;\n169:       case \"--quickest-wins\":\n170:         result.quickestWins = parseInt(args[++i], 10);\n171:         break;\n172:       case \"--priority\":\n173:         result.priority = args[++i] as Priority;\n174:         break;\n175:       case \"--difficulty\":\n176:         result.difficulty = args[++i] as Difficulty;\n177:         break;\n178:       case \"--features\":\n179:         result.features = args[++i].split(\",\").map((s) => s.trim());\n180:         break;\n181:       case \"--all-ready\":\n182:         result.allReady = true;\n183:         break;\n184: \n185:       // --- Launch / runtime options ---\n186:       case \"--max-concurrent\":\n187:         result.maxConcurrent = parseInt(args[++i], 10);\n188:         break;\n189:       case \"--model\":\n190:       case \"-m\":\n191:         result.model = args[++i];\n192:         break;\n193:       case \"--interactive\":\n194:         result.interactive = true;\n195:         break;\n196:       case \"--dry-run\":\n197:         result.dryRun = true;\n198:         break;\n199:       case \"--no-tui\":\n200:         result.noTui = true;\n201:         break;\n202:       case \"--auto-push\":\n203:         result.autoPush = true;\n204:         break;\n205:       case \"--base-branch\":\n206:         result.baseBranch = args[++i];\n207:         break;\n208:       case \"--max-retries\":\n209:         result.maxRetries = parseInt(args[++i], 10);\n210:         break;\n211: \n212:       // --- General flags ---\n213:       case \"--force\":\n214:         result.force = true;\n215:         break;\n216:       case \"--check\":\n217:         result.checkOnly = true;\n218:         break;\n219:       case \"--version\":\n220:         result.version = args[++i];\n221:         break;\n222:       case \"--output\":\n223:       case \"-o\":\n224:         result.outputFmt = resolveOutputFormat(args[++i]);\n225:         break;\n226: \n227:       // --- Features subcommand options ---\n228:       case \"--status\":\n229:         result.status = args[++i];\n230:         break;\n231:       case \"--ready\":\n232:         result.ready = true;\n233:         break;\n234:       case \"--include-archive\":\n235:         result.includeArchive = true;\n236:         break;\n237:       case \"--title\":\n238:         result.title = args[++i];\n239:         break;\n240:       case \"--description\":\n241:       case \"--desc\":\n242:         result.description = args[++i];\n243:         break;\n244:       case \"--effort\":\n245:         result.effort = args[++i];\n246:         break;\n247:       case \"--depends-on\":\n248:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n249:         break;\n250:       case \"--fields\":\n251:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n252:         break;\n253: \n254:       // --- Positional (feature-id, title for add, etc.) ---\n255:       default:\n256:         if (!arg.startsWith(\"-\")) {\n257:           if (!result.featureId) {\n258:             result.featureId = arg;\n259:           } else if (!result.title) {\n260:             result.title = arg;\n261:           }\n262:         }\n263:         break;\n264:     }\n265:   }\n266: \n267:   return result;\n268: }\n269: \n270: // ---------------------------------------------------------------------------\n271: // Help\n272: // ---------------------------------------------------------------------------\n273: \n274: function cmdHelp(): void {\n275:   console.log(`\n276: Wombo — AI Agent Orchestration System\n277: \n278:   WOMBO COMBO! Parallel feature development with AI agents.\n279: \n280: Commands:\n281:   init           Generate wombo.json config in the current project\n282:   launch         Launch a wave of agents to implement features\n283:   resume         Resume a previously stopped wave\n284:   status         Show the status of the current wave\n285:   verify         Run build verification on completed agents\n286:   merge          Merge verified branches into the base branch\n287:   retry          Retry a failed agent\n288:   cleanup        Remove all wave worktrees and tmux sessions\n289:   features       Manage .features.yml (see below)\n290:   upgrade        Check for updates and upgrade wombo\n291:   describe       Emit JSON schema of a command (for AI agents)\n292:   help           Show this help\n293: \n294: Features Subcommands:\n295:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n296:   features add <id> <title> [options]\n297:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n298:   features set-status <id> <status>\n299:                            Change a feature's status\n300:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n301:   features archive [id]    Move done/cancelled to archive (--dry-run)\n302:   features show <id>       Show feature details\n303: \n304: Selection Options (for launch):\n305:   --top-priority N         Select top N features by priority\n306:   --quickest-wins N        Select N features with lowest effort\n307:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n308:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n309:   --features \"id1,id2\"     Select specific features by ID\n310:   --all-ready              Select all features whose dependencies are met\n311: \n312: Launch Options:\n313:   --max-concurrent N       Max agents running in parallel (default: from config)\n314:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n315:   --interactive            Use tmux TUI mode instead of headless\n316:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n317:   --auto-push              Push base branch to remote after all merges complete\n318:   --dry-run                Show what would be launched without launching\n319:   --base-branch <branch>   Base branch (default: from config)\n320:   --max-retries N          Max retries per agent (default: from config)\n321: \n322: General:\n323:   --version, -V            Print version and exit\n324:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n325:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n326:   -o <fmt>                 Alias for --output\n327:   --dry-run                Show what would happen without performing the action\n328:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n329: \n330: Upgrade Options:\n331:   --check                  Only check for updates, don't install\n332:   --version <tag>          Install a specific version (e.g., v0.1.0)\n333: \n334: Examples:\n335:   wombo init\n336:   wombo launch --quickest-wins 3\n337:   wombo launch --priority high --interactive\n338:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n339:   wombo resume\n340:   wombo status\n341:   wombo verify\n342:   wombo merge\n343:   wombo retry auth-flow\n344:   wombo cleanup\n345:   wombo features list --status ready --priority high\n346:   wombo features list --fields id,status,priority --output json\n347:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n348:   wombo features set-status my-feature in-progress\n349:   wombo features check\n350:   wombo features archive --dry-run\n351:   wombo features show my-feature\n352:   wombo describe                           # list all commands as JSON\n353:   wombo describe launch                    # describe a specific command\n354:   wombo describe features add              # describe a subcommand\n355: `);\n356: }\n357: \n358: // ---------------------------------------------------------------------------\n359: // Main\n360: // ---------------------------------------------------------------------------\n361: \n362: async function main(): Promise<void> {\n363:   checkDevModeGuard();\n364: \n365:   const PROJECT_ROOT = resolve(process.cwd());\n366:   const args = parseArgs(process.argv);\n367: \n368:   // -----------------------------------------------------------------------\n369:   // Input validation at the CLI boundary\n370:   // -----------------------------------------------------------------------\n371:   if (args.featureId) {\n372:     assertValid(validateId(args.featureId, \"feature ID\"));\n373:   }\n374:   if (args.title) {\n375:     assertValid(validateText(args.title, \"title\"));\n376:   }\n377:   if (args.description) {\n378:     assertValid(validateText(args.description, \"description\"));\n379:   }\n380:   if (args.baseBranch) {\n381:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n382:   }\n383:   if (args.effort) {\n384:     assertValid(validateDuration(args.effort, \"effort\"));\n385:   }\n386:   if (args.features) {\n387:     for (const fid of args.features) {\n388:       assertValid(validateId(fid, \"feature ID in --features\"));\n389:     }\n390:   }\n391:   if (args.dependsOn) {\n392:     for (const dep of args.dependsOn) {\n393:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n394:     }\n395:   }\n396: \n397:   // Commands that don't need config loading\n398:   if (args.command === \"--version\" || args.command === \"-V\") {\n399:     const pkgPath = resolve(import.meta.dir, \"..\", \"package.json\");\n400:     try {\n401:       const raw = readFileSync(pkgPath, \"utf-8\");\n402:       const pkg = JSON.parse(raw);\n403:       console.log(`wombo ${pkg.version}`);\n404:     } catch {\n405:       console.log(\"wombo (unknown version)\");\n406:     }\n407:     return;\n408:   }\n409: \n410:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n411:     cmdHelp();\n412:     return;\n413:   }\n414: \n415:   if (args.command === \"describe\") {\n416:     // Schema introspection: `wombo describe [command]`\n417:     if (!args.featureId) {\n418:       // No command specified — list all commands\n419:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n420:     } else {\n421:       // Describe a specific command. Handle compound names: \"features list\"\n422:       const cmdName = args.title\n423:         ? `${args.featureId} ${args.title}`\n424:         : args.featureId;\n425:       const def = findCommandDef(cmdName);\n426:       if (!def) {\n427:         console.error(`Unknown command: \"${cmdName}\"`);\n428:         console.error(\"Run 'wombo describe' to list all commands.\");\n429:         process.exit(1);\n430:         return;\n431:       }\n432:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n433:     }\n434:     return;\n435:   }\n436: \n437:   if (args.command === \"init\") {\n438:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n439:     return;\n440:   }\n441: \n442:   if (args.command === \"upgrade\") {\n443:     await cmdUpgrade({\n444:       force: args.force,\n445:       version: args.version,\n446:       checkOnly: args.checkOnly,\n447:     });\n448:     return;\n449:   }\n450: \n451:   // Everything else requires config\n452:   const config = loadConfig(PROJECT_ROOT);\n453:   validateConfig(config);\n454: \n455:   // Commands that operate on the features file — ensure it exists first\n456:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n457:   if (needsFeatures.has(args.command)) {\n458:     await ensureFeaturesFile(PROJECT_ROOT, config);\n459:   }\n460: \n461:   switch (args.command) {\n462:     case \"launch\":\n463:       await cmdLaunch({\n464:         projectRoot: PROJECT_ROOT,\n465:         config,\n466:         topPriority: args.topPriority,\n467:         quickestWins: args.quickestWins,\n468:         priority: args.priority,\n469:         difficulty: args.difficulty,\n470:         features: args.features,\n471:         allReady: args.allReady,\n472:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n473:         model: args.model,\n474:         interactive: args.interactive,\n475:         dryRun: args.dryRun,\n476:         baseBranch: args.baseBranch ?? config.baseBranch,\n477:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n478:         noTui: args.noTui,\n479:         autoPush: args.autoPush,\n480:       });\n481:       break;\n482: \n483:     case \"resume\":\n484:       await cmdResume({\n485:         projectRoot: PROJECT_ROOT,\n486:         config,\n487:         maxConcurrent: args.maxConcurrent,\n488:         model: args.model,\n489:         interactive: args.interactive,\n490:         noTui: args.noTui,\n491:         autoPush: args.autoPush,\n492:         baseBranch: args.baseBranch,\n493:         maxRetries: args.maxRetries,\n494:       });\n495:       break;\n496: \n497:     case \"status\":\n498:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n499:       break;\n500: \n501:     case \"verify\":\n502:       await cmdVerify({\n503:         projectRoot: PROJECT_ROOT,\n504:         config,\n505:         featureId: args.featureId,\n506:         model: args.model,\n507:         maxRetries: args.maxRetries,\n508:       });\n509:       break;\n510: \n511:     case \"merge\":\n512:       await cmdMerge({\n513:         projectRoot: PROJECT_ROOT,\n514:         config,\n515:         featureId: args.featureId,\n516:         autoPush: args.autoPush,\n517:         dryRun: args.dryRun,\n518:       });\n519:       break;\n520: \n521:     case \"retry\": {\n522:       if (!args.featureId) {\n523:         console.error(\"Usage: wombo retry <feature-id>\");\n524:         process.exit(1);\n525:         return;\n526:       }\n527:       await cmdRetry({\n528:         projectRoot: PROJECT_ROOT,\n529:         config,\n530:         featureId: args.featureId,\n531:         model: args.model,\n532:         interactive: args.interactive,\n533:         dryRun: args.dryRun,\n534:       });\n535:       break;\n536:     }\n537: \n538:     case \"cleanup\":\n539:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n540:       break;\n541: \n542:     case \"features\":\n543:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n544:       break;\n545: \n546:     default:\n547:       console.error(`Unknown command: ${args.command}`);\n548:       cmdHelp();\n549:       process.exit(1);\n550:       return;\n551:   }\n552: }\n553: \n554: // ---------------------------------------------------------------------------\n555: // Features Subcommand Router\n556: // ---------------------------------------------------------------------------\n557: \n558: async function handleFeaturesSubcommand(\n559:   args: CLIArgs,\n560:   projectRoot: string,\n561:   config: import(\"./config.js\").WomboConfig\n562: ): Promise<void> {\n563:   switch (args.subcommand) {\n564:     case \"list\":\n565:     case \"ls\":\n566:       await cmdFeaturesList({\n567:         projectRoot,\n568:         config,\n569:         status: args.status as FeatureStatus | undefined,\n570:         priority: args.priority,\n571:         difficulty: args.difficulty,\n572:         ready: args.ready,\n573:         includeArchive: args.includeArchive,\n574:         outputFmt: args.outputFmt,\n575:         fields: args.fields,\n576:       });\n577:       break;\n578: \n579:     case \"add\": {\n580:       if (!args.featureId || !args.title) {\n581:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n582:         process.exit(1);\n583:         return;\n584:       }\n585:       await cmdFeaturesAdd({\n586:         projectRoot,\n587:         config,\n588:         id: args.featureId,\n589:         title: args.title,\n590:         description: args.description,\n591:         priority: args.priority,\n592:         difficulty: args.difficulty,\n593:         effort: args.effort,\n594:         dependsOn: args.dependsOn,\n595:         outputFmt: args.outputFmt,\n596:         dryRun: args.dryRun,\n597:       });\n598:       break;\n599:     }\n600: \n601:     case \"set-status\": {\n602:       if (!args.featureId || !args.title) {\n603:         // title holds the second positional arg (the status value)\n604:         // If not provided via positional, check --status flag\n605:         const newStatus = args.title || args.status;\n606:         if (!args.featureId || !newStatus) {\n607:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n608:           process.exit(1);\n609:           return;\n610:         }\n611:         await cmdFeaturesSetStatus({\n612:           projectRoot,\n613:           config,\n614:           featureId: args.featureId,\n615:           newStatus,\n616:           outputFmt: args.outputFmt,\n617:           dryRun: args.dryRun,\n618:         });\n619:       } else {\n620:         await cmdFeaturesSetStatus({\n621:           projectRoot,\n622:           config,\n623:           featureId: args.featureId,\n624:           newStatus: args.title, // second positional = new status\n625:           outputFmt: args.outputFmt,\n626:           dryRun: args.dryRun,\n627:         });\n628:       }\n629:       break;\n630:     }\n631: \n632:     case \"check\":\n633:     case \"validate\":\n634:       await cmdFeaturesCheck({ projectRoot, config });\n635:       break;\n636: \n637:     case \"archive\":\n638:       await cmdFeaturesArchive({\n639:         projectRoot,\n640:         config,\n641:         featureId: args.featureId,\n642:         dryRun: args.dryRun,\n643:       });\n644:       break;\n645: \n646:     case \"show\": {\n647:       if (!args.featureId) {\n648:         console.error(\"Usage: wombo features show <feature-id>\");\n649:         process.exit(1);\n650:         return;\n651:       }\n652:       await cmdFeaturesShow({\n653:         projectRoot,\n654:         config,\n655:         featureId: args.featureId,\n656:         outputFmt: args.outputFmt,\n657:         fields: args.fields,\n658:       });\n659:       break;\n660:     }\n661: \n662:     case \"help\":\n663:     case \"--help\":\n664:     case \"-h\":\n665:       cmdHelp();\n666:       break;\n667: \n668:     default:\n669:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n670:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n671:       process.exit(1);\n672:       return;\n673:   }\n674: }\n675: \n676: // ---------------------------------------------------------------------------\n677: // Error Handlers & Entry\n678: // ---------------------------------------------------------------------------\n679: \n680: // Global error handlers — prevent silent crashes\n681: process.on(\"uncaughtException\", (err) => {\n682:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n683:   console.error(err.stack);\n684:   try {\n685:     const state = loadState(process.cwd());\n686:     if (state) saveState(process.cwd(), state);\n687:   } catch {}\n688:   process.exit(1);\n689: });\n690: \n691: process.on(\"unhandledRejection\", (reason: any) => {\n692:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n693:   if (reason?.stack) console.error(reason.stack);\n694:   try {\n695:     const state = loadState(process.cwd());\n696:     if (state) saveState(process.cwd(), state);\n697:   } catch {}\n698:   process.exit(1);\n699: });\n700: \n701: main().catch((err) => {\n702:   console.error(\"Fatal error:\", err.message);\n703:   process.exit(1);\n704: });\n\n(End of file - total 704 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo cleanup","truncated":false,"loaded":[]},"time":{"start":1773246661721,"end":1773246661726}}}}
