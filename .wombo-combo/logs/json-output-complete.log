{"type":"tool_use","timestamp":1773245128725,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda5600f0016l9s7BZsUCA3ue","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda54d650010hCqpuKgTxEH8M","type":"tool","callID":"toolu_01Qnb2BedMWtAHm4cavRvwG6","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/lib/state.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/lib/state.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * state.ts — Persistent wave state management.\n3:  *\n4:  * Responsibilities:\n5:  *   - Define the shape of .wombo-state.json\n6:  *   - Read/write state atomically\n7:  *   - Generate wave IDs\n8:  *   - Update individual agent state within a wave\n9:  */\n10: \n11: import { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export type AgentStatus =\n19:   | \"queued\"\n20:   | \"installing\"\n21:   | \"running\"\n22:   | \"completed\"\n23:   | \"verified\"\n24:   | \"failed\"\n25:   | \"merged\"\n26:   | \"retry\";\n27: \n28: export interface AgentState {\n29:   feature_id: string;\n30:   branch: string;\n31:   worktree: string;\n32:   session_id: string | null;\n33:   pid: number | null;\n34:   status: AgentStatus;\n35:   activity: string | null;\n36:   activity_updated_at: string | null;\n37:   retries: number;\n38:   max_retries: number;\n39:   started_at: string | null;\n40:   completed_at: string | null;\n41:   build_passed: boolean | null;\n42:   build_output: string | null;\n43:   error: string | null;\n44:   /** Estimated effort in milliseconds (from feature's ISO 8601 duration) */\n45:   effort_estimate_ms: number | null;\n46: }\n47: \n48: export interface WaveState {\n49:   wave_id: string;\n50:   base_branch: string;\n51:   started_at: string;\n52:   updated_at: string;\n53:   max_concurrent: number;\n54:   model: string | null;\n55:   interactive: boolean;\n56:   agents: AgentState[];\n57: }\n58: \n59: // ---------------------------------------------------------------------------\n60: // Constants\n61: // ---------------------------------------------------------------------------\n62: \n63: const STATE_FILE = \".wombo-state.json\";\n64: \n65: // ---------------------------------------------------------------------------\n66: // Wave ID Generation\n67: // ---------------------------------------------------------------------------\n68: \n69: /**\n70:  * Generate a unique wave ID based on current timestamp.\n71:  * Format: wave-YYYY-MM-DD-NNN\n72:  */\n73: export function generateWaveId(): string {\n74:   const now = new Date();\n75:   const date = now.toISOString().slice(0, 10);\n76:   const seq = String(now.getHours() * 60 + now.getMinutes()).padStart(3, \"0\");\n77:   return `wave-${date}-${seq}`;\n78: }\n79: \n80: // ---------------------------------------------------------------------------\n81: // State Path\n82: // ---------------------------------------------------------------------------\n83: \n84: function statePath(projectRoot: string): string {\n85:   return resolve(projectRoot, STATE_FILE);\n86: }\n87: \n88: // ---------------------------------------------------------------------------\n89: // Read State\n90: // ---------------------------------------------------------------------------\n91: \n92: /**\n93:  * Load the current wave state from disk. Returns null if no state file exists.\n94:  */\n95: export function loadState(projectRoot: string): WaveState | null {\n96:   const p = statePath(projectRoot);\n97:   if (!existsSync(p)) return null;\n98:   try {\n99:     const raw = readFileSync(p, \"utf-8\");\n100:     return JSON.parse(raw) as WaveState;\n101:   } catch {\n102:     return null;\n103:   }\n104: }\n105: \n106: // ---------------------------------------------------------------------------\n107: // Write State\n108: // ---------------------------------------------------------------------------\n109: \n110: /**\n111:  * Save wave state to disk atomically (write to tmp then rename).\n112:  */\n113: export function saveState(projectRoot: string, state: WaveState): void {\n114:   state.updated_at = new Date().toISOString();\n115:   const p = statePath(projectRoot);\n116:   const tmp = p + \".tmp\";\n117:   writeFileSync(tmp, JSON.stringify(state, null, 2) + \"\\n\", \"utf-8\");\n118:   renameSync(tmp, p);\n119: }\n120: \n121: // ---------------------------------------------------------------------------\n122: // State Mutations\n123: // ---------------------------------------------------------------------------\n124: \n125: /**\n126:  * Create a fresh wave state.\n127:  */\n128: export function createWaveState(opts: {\n129:   baseBranch: string;\n130:   maxConcurrent: number;\n131:   model: string | null;\n132:   interactive: boolean;\n133: }): WaveState {\n134:   return {\n135:     wave_id: generateWaveId(),\n136:     base_branch: opts.baseBranch,\n137:     started_at: new Date().toISOString(),\n138:     updated_at: new Date().toISOString(),\n139:     max_concurrent: opts.maxConcurrent,\n140:     model: opts.model,\n141:     interactive: opts.interactive,\n142:     agents: [],\n143:   };\n144: }\n145: \n146: /**\n147:  * Create an initial agent state for a feature.\n148:  */\n149: export function createAgentState(\n150:   featureId: string,\n151:   branch: string,\n152:   worktreePath: string,\n153:   maxRetries: number = 2\n154: ): AgentState {\n155:   return {\n156:     feature_id: featureId,\n157:     branch,\n158:     worktree: worktreePath,\n159:     session_id: null,\n160:     pid: null,\n161:     status: \"queued\",\n162:     activity: null,\n163:     activity_updated_at: null,\n164:     retries: 0,\n165:     max_retries: maxRetries,\n166:     started_at: null,\n167:     completed_at: null,\n168:     build_passed: null,\n169:     build_output: null,\n170:     error: null,\n171:     effort_estimate_ms: null,\n172:   };\n173: }\n174: \n175: /**\n176:  * Find an agent state by feature ID.\n177:  */\n178: export function getAgent(\n179:   state: WaveState,\n180:   featureId: string\n181: ): AgentState | undefined {\n182:   return state.agents.find((a) => a.feature_id === featureId);\n183: }\n184: \n185: /**\n186:  * Update an agent's state fields.\n187:  */\n188: export function updateAgent(\n189:   state: WaveState,\n190:   featureId: string,\n191:   updates: Partial<AgentState>\n192: ): void {\n193:   const agent = state.agents.find((a) => a.feature_id === featureId);\n194:   if (!agent) throw new Error(`Agent not found for feature: ${featureId}`);\n195:   Object.assign(agent, updates);\n196: }\n197: \n198: /**\n199:  * Get counts of agents by status.\n200:  */\n201: export function agentCounts(state: WaveState): Record<AgentStatus, number> {\n202:   const counts: Record<AgentStatus, number> = {\n203:     queued: 0,\n204:     installing: 0,\n205:     running: 0,\n206:     completed: 0,\n207:     verified: 0,\n208:     failed: 0,\n209:     merged: 0,\n210:     retry: 0,\n211:   };\n212:   for (const a of state.agents) {\n213:     counts[a.status]++;\n214:   }\n215:   return counts;\n216: }\n217: \n218: /**\n219:  * Get agents that are currently running or installing.\n220:  */\n221: export function activeAgents(state: WaveState): AgentState[] {\n222:   return state.agents.filter(\n223:     (a) => a.status === \"running\" || a.status === \"installing\"\n224:   );\n225: }\n226: \n227: /**\n228:  * Get agents that are queued and ready to be launched.\n229:  */\n230: export function queuedAgents(state: WaveState): AgentState[] {\n231:   return state.agents.filter((a) => a.status === \"queued\");\n232: }\n233: \n234: /**\n235:  * Check if the wave is fully complete (no queued, installing, running, or retry agents).\n236:  */\n237: export function isWaveComplete(state: WaveState): boolean {\n238:   return state.agents.every(\n239:     (a) =>\n240:       a.status === \"completed\" ||\n241:       a.status === \"verified\" ||\n242:       a.status === \"failed\" ||\n243:       a.status === \"merged\"\n244:   );\n245: }\n\n(End of file - total 245 lines)\n</content>","title":"src/lib/state.ts","metadata":{"preview":"/**\n * state.ts — Persistent wave state management.\n *\n * Responsibilities:\n *   - Define the shape of .wombo-state.json\n *   - Read/write state atomically\n *   - Generate wave IDs\n *   - Update individual agent state within a wave\n */\n\nimport { readFileSync, writeFileSync, existsSync, renameSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type AgentStatus =\n  | \"queued\"\n  | \"installing\"","truncated":false,"loaded":[]},"time":{"start":1773245128721,"end":1773245128725}}}}
{"type":"tool_use","timestamp":1773245128726,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda56011001VQQvtlDg4omrA2","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda54d650010hCqpuKgTxEH8M","type":"tool","callID":"toolu_017tTdd5dCqS5TTiPS9mfULF","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/lib/ui.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/lib/ui.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * ui.ts — Terminal dashboard for wave status display.\n3:  *\n4:  * Responsibilities:\n5:  *   - Render a live status table of all agents in a wave\n6:  *   - Show progress indicators, timing, retry counts\n7:  *   - Color-coded status output\n8:  *   - Summary statistics\n9:  */\n10: \n11: import type { WaveState, AgentState, AgentStatus } from \"./state.js\";\n12: import { agentCounts } from \"./state.js\";\n13: import { formatDuration, parseDurationMinutes } from \"./features.js\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // ANSI Color Helpers\n17: // ---------------------------------------------------------------------------\n18: \n19: const RESET = \"\\x1b[0m\";\n20: const BOLD = \"\\x1b[1m\";\n21: const DIM = \"\\x1b[2m\";\n22: \n23: const FG = {\n24:   red: \"\\x1b[31m\",\n25:   green: \"\\x1b[32m\",\n26:   yellow: \"\\x1b[33m\",\n27:   blue: \"\\x1b[34m\",\n28:   magenta: \"\\x1b[35m\",\n29:   cyan: \"\\x1b[36m\",\n30:   white: \"\\x1b[37m\",\n31:   gray: \"\\x1b[90m\",\n32: };\n33: \n34: // ---------------------------------------------------------------------------\n35: // Status Colors\n36: // ---------------------------------------------------------------------------\n37: \n38: const STATUS_COLORS: Record<AgentStatus, string> = {\n39:   queued: FG.gray,\n40:   installing: FG.cyan,\n41:   running: FG.blue,\n42:   completed: FG.yellow,\n43:   verified: FG.green,\n44:   failed: FG.red,\n45:   merged: FG.magenta,\n46:   retry: FG.yellow,\n47: };\n48: \n49: const STATUS_ICONS: Record<AgentStatus, string> = {\n50:   queued: \".\",\n51:   installing: \">\",\n52:   running: \"*\",\n53:   completed: \"~\",\n54:   verified: \"+\",\n55:   failed: \"!\",\n56:   merged: \"#\",\n57:   retry: \"?\",\n58: };\n59: \n60: // ---------------------------------------------------------------------------\n61: // Formatting Helpers\n62: // ---------------------------------------------------------------------------\n63: \n64: function colorize(text: string, color: string): string {\n65:   return `${color}${text}${RESET}`;\n66: }\n67: \n68: function pad(text: string, width: number): string {\n69:   if (text.length >= width) return text.slice(0, width);\n70:   return text + \" \".repeat(width - text.length);\n71: }\n72: \n73: function padLeft(text: string, width: number): string {\n74:   if (text.length >= width) return text.slice(0, width);\n75:   return \" \".repeat(width - text.length) + text;\n76: }\n77: \n78: function elapsed(startedAt: string | null): string {\n79:   if (!startedAt) return \"-\";\n80:   const start = new Date(startedAt).getTime();\n81:   const now = Date.now();\n82:   const diffMs = now - start;\n83:   const mins = Math.floor(diffMs / 60000);\n84:   if (mins < 60) return `${mins}m`;\n85:   const hours = Math.floor(mins / 60);\n86:   const remMins = mins % 60;\n87:   return `${hours}h${remMins}m`;\n88: }\n89: \n90: // ---------------------------------------------------------------------------\n91: // Table Rendering\n92: // ---------------------------------------------------------------------------\n93: \n94: /**\n95:  * Render the full wave status dashboard to stdout.\n96:  */\n97: export function renderDashboard(state: WaveState): string {\n98:   const lines: string[] = [];\n99: \n100:   // Header\n101:   lines.push(\"\");\n102:   lines.push(\n103:     `${BOLD}Wombo${RESET} ${DIM}${state.wave_id}${RESET}`\n104:   );\n105:   lines.push(\n106:     `${DIM}Base: ${state.base_branch} | Concurrency: ${state.max_concurrent} | Mode: ${state.interactive ? \"interactive\" : \"headless\"}${RESET}`\n107:   );\n108:   if (state.model) {\n109:     lines.push(`${DIM}Model: ${state.model}${RESET}`);\n110:   }\n111:   lines.push(\"\");\n112: \n113:   // Table header\n114:   const header = [\n115:     pad(\"\", 3),\n116:     pad(\"Feature\", 30),\n117:     pad(\"Status\", 12),\n118:     pad(\"Activity\", 30),\n119:     padLeft(\"Retries\", 8),\n120:     padLeft(\"Elapsed\", 8),\n121:   ].join(\" \");\n122:   lines.push(`${BOLD}${header}${RESET}`);\n123:   lines.push(\"-\".repeat(95));\n124: \n125:   // Agent rows\n126:   for (const agent of state.agents) {\n127:     const statusColor = STATUS_COLORS[agent.status];\n128:     const icon = STATUS_ICONS[agent.status];\n129: \n130:     let activityText = \"-\";\n131:     if (agent.status === \"running\" && agent.activity) {\n132:       activityText = agent.activity;\n133:     } else if (agent.status === \"installing\") {\n134:       activityText = \"setting up worktree...\";\n135:     } else if (agent.status === \"retry\") {\n136:       activityText = \"retrying with errors...\";\n137:     } else if (agent.status === \"failed\" && agent.error) {\n138:       activityText = agent.error.split(\"\\n\")[0].slice(0, 28);\n139:     } else if (agent.status === \"verified\") {\n140:       activityText = \"build passed\";\n141:     } else if (agent.status === \"merged\") {\n142:       activityText = agent.branch;\n143:     }\n144: \n145:     const row = [\n146:       colorize(pad(`[${icon}]`, 3), statusColor),\n147:       pad(agent.feature_id, 30),\n148:       colorize(pad(agent.status, 12), statusColor),\n149:       (agent.status === \"running\" ? FG.cyan : DIM) + pad(activityText, 30) + RESET,\n150:       padLeft(\n151:         agent.retries > 0 ? `${agent.retries}/${agent.max_retries}` : \"-\",\n152:         8\n153:       ),\n154:       padLeft(elapsed(agent.started_at), 8),\n155:     ].join(\" \");\n156: \n157:     lines.push(row);\n158:   }\n159: \n160:   // Summary\n161:   lines.push(\"-\".repeat(95));\n162:   const counts = agentCounts(state);\n163:   const summaryParts: string[] = [];\n164: \n165:   if (counts.queued > 0)\n166:     summaryParts.push(colorize(`${counts.queued} queued`, FG.gray));\n167:   if (counts.installing > 0)\n168:     summaryParts.push(colorize(`${counts.installing} installing`, FG.cyan));\n169:   if (counts.running > 0)\n170:     summaryParts.push(colorize(`${counts.running} running`, FG.blue));\n171:   if (counts.completed > 0)\n172:     summaryParts.push(colorize(`${counts.completed} completed`, FG.yellow));\n173:   if (counts.verified > 0)\n174:     summaryParts.push(colorize(`${counts.verified} verified`, FG.green));\n175:   if (counts.failed > 0)\n176:     summaryParts.push(colorize(`${counts.failed} failed`, FG.red));\n177:   if (counts.merged > 0)\n178:     summaryParts.push(colorize(`${counts.merged} merged`, FG.magenta));\n179:   if (counts.retry > 0)\n180:     summaryParts.push(colorize(`${counts.retry} retrying`, FG.yellow));\n181: \n182:   lines.push(summaryParts.join(\" | \"));\n183:   lines.push(\"\");\n184: \n185:   return lines.join(\"\\n\");\n186: }\n187: \n188: /**\n189:  * Print the dashboard to stdout.\n190:  */\n191: export function printDashboard(state: WaveState): void {\n192:   console.log(renderDashboard(state));\n193: }\n194: \n195: /**\n196:  * Print a single-line status update for a feature.\n197:  */\n198: export function printAgentUpdate(\n199:   agent: AgentState,\n200:   message: string\n201: ): void {\n202:   const statusColor = STATUS_COLORS[agent.status];\n203:   const icon = STATUS_ICONS[agent.status];\n204:   console.log(\n205:     `${colorize(`[${icon}]`, statusColor)} ${pad(agent.feature_id, 28)} ${message}`\n206:   );\n207: }\n208: \n209: /**\n210:  * Print a compact summary.\n211:  */\n212: export function printSummary(state: WaveState): void {\n213:   const counts = agentCounts(state);\n214:   const total = state.agents.length;\n215:   const done = counts.verified + counts.merged;\n216:   console.log(\n217:     `\\n${BOLD}Wave ${state.wave_id}${RESET}: ${done}/${total} done, ${counts.running} running, ${counts.failed} failed, ${counts.queued} queued`\n218:   );\n219: }\n220: \n221: /**\n222:  * Clear the terminal screen.\n223:  */\n224: export function clearScreen(): void {\n225:   process.stdout.write(\"\\x1b[2J\\x1b[H\");\n226: }\n227: \n228: /**\n229:  * Print a feature selection table (for launch preview).\n230:  */\n231: export function printFeatureSelection(\n232:   features: Array<{\n233:     id: string;\n234:     title: string;\n235:     priority: string;\n236:     difficulty: string;\n237:     effort: string;\n238:   }>\n239: ): void {\n240:   console.log(\"\");\n241:   console.log(`${BOLD}Selected Features (${features.length}):${RESET}`);\n242:   console.log(\"\");\n243: \n244:   const header = [\n245:     pad(\"#\", 4),\n246:     pad(\"Feature ID\", 30),\n247:     pad(\"Priority\", 10),\n248:     pad(\"Difficulty\", 12),\n249:     padLeft(\"Effort\", 8),\n250:     pad(\"Title\", 40),\n251:   ].join(\" \");\n252:   console.log(`${BOLD}${header}${RESET}`);\n253:   console.log(\"-\".repeat(108));\n254: \n255:   for (let i = 0; i < features.length; i++) {\n256:     const f = features[i];\n257:     const effortMin = parseDurationMinutes(f.effort);\n258:     const row = [\n259:       pad(`${i + 1}.`, 4),\n260:       pad(f.id, 30),\n261:       pad(f.priority, 10),\n262:       pad(f.difficulty, 12),\n263:       padLeft(formatDuration(effortMin), 8),\n264:       pad(f.title, 40),\n265:     ].join(\" \");\n266:     console.log(row);\n267:   }\n268: \n269:   console.log(\"\");\n270: }\n\n(End of file - total 270 lines)\n</content>","title":"src/lib/ui.ts","metadata":{"preview":"/**\n * ui.ts — Terminal dashboard for wave status display.\n *\n * Responsibilities:\n *   - Render a live status table of all agents in a wave\n *   - Show progress indicators, timing, retry counts\n *   - Color-coded status output\n *   - Summary statistics\n */\n\nimport type { WaveState, AgentState, AgentStatus } from \"./state.js\";\nimport { agentCounts } from \"./state.js\";\nimport { formatDuration, parseDurationMinutes } from \"./features.js\";\n\n// ---------------------------------------------------------------------------\n// ANSI Color Helpers\n// ---------------------------------------------------------------------------\n\nconst RESET = \"\\x1b[0m\";\nconst BOLD = \"\\x1b[1m\";","truncated":false,"loaded":[]},"time":{"start":1773245128722,"end":1773245128726}}}}
