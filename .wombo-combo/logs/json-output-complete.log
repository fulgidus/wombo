{"type":"tool_use","timestamp":1773245116536,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda52e52001Dmw21Lo7tQNClq","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda513b900126Jtphxg3AXvca","type":"tool","callID":"toolu_01GnErrmDPCYFnagoBFCDp8K","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/add.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/add.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/add.ts — Add a new feature to the features file.\n3:  *\n4:  * Usage:\n5:  *   wombo features add <id> --title \"Feature Title\" [--description \"...\"]\n6:  *                      [--priority medium] [--difficulty easy] [--effort PT2H]\n7:  *                      [--depends-on \"feat1,feat2\"]\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   createBlankFeature,\n15:   allFeatureIds,\n16:   type Priority,\n17:   type Difficulty,\n18: } from \"../../lib/features.js\";\n19: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface FeaturesAddOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   id: string;\n29:   title: string;\n30:   description?: string;\n31:   priority?: Priority;\n32:   difficulty?: Difficulty;\n33:   effort?: string;\n34:   dependsOn?: string[];\n35:   outputFmt?: OutputFormat;\n36:   dryRun?: boolean;\n37: }\n38: \n39: // ---------------------------------------------------------------------------\n40: // Command\n41: // ---------------------------------------------------------------------------\n42: \n43: export async function cmdFeaturesAdd(opts: FeaturesAddOptions): Promise<void> {\n44:   const { projectRoot, config } = opts;\n45:   const fmt = opts.outputFmt ?? \"text\";\n46: \n47:   if (!opts.id) {\n48:     outputError(fmt, \"Usage: wombo features add <id> --title \\\"Feature Title\\\"\");\n49:     return;\n50:   }\n51: \n52:   if (!opts.title) {\n53:     outputError(fmt, \"--title is required when adding a feature.\");\n54:     return;\n55:   }\n56: \n57:   const data = loadFeatures(projectRoot, config);\n58: \n59:   // Check for duplicate ID\n60:   const existingIds = allFeatureIds(data);\n61:   if (existingIds.includes(opts.id)) {\n62:     outputError(fmt, `Feature ID \"${opts.id}\" already exists.`);\n63:     return;\n64:   }\n65: \n66:   // Validate depends_on references\n67:   if (opts.dependsOn?.length) {\n68:     for (const dep of opts.dependsOn) {\n69:       if (!existingIds.includes(dep)) {\n70:         outputError(fmt, `Dependency \"${dep}\" does not exist in the features file.`);\n71:         return;\n72:       }\n73:     }\n74:   }\n75: \n76:   // Create the feature\n77:   const feature = createBlankFeature(opts.id, opts.title, opts.description ?? \"\", {\n78:     priority: opts.priority,\n79:     difficulty: opts.difficulty,\n80:     effort: opts.effort,\n81:   });\n82: \n83:   // Set dependencies\n84:   if (opts.dependsOn?.length) {\n85:     feature.depends_on = opts.dependsOn;\n86:   }\n87: \n88:   // Dry-run: show what would be added without writing\n89:   if (opts.dryRun) {\n90:     outputMessage(fmt, `[dry-run] Would add feature: ${opts.id} — ${opts.title}`, {\n91:       dry_run: true,\n92:       id: feature.id,\n93:       title: feature.title,\n94:       priority: feature.priority,\n95:       difficulty: feature.difficulty,\n96:       effort: feature.effort,\n97:       depends_on: feature.depends_on,\n98:     });\n99:     return;\n100:   }\n101: \n102:   // Append to features list\n103:   data.features.push(feature);\n104:   saveFeatures(projectRoot, config, data);\n105: \n106:   outputMessage(fmt, `Added feature: ${opts.id} — ${opts.title}`, {\n107:     id: feature.id,\n108:     title: feature.title,\n109:     priority: feature.priority,\n110:     difficulty: feature.difficulty,\n111:     effort: feature.effort,\n112:     depends_on: feature.depends_on,\n113:   });\n114: \n115:   if (fmt === \"text\") {\n116:     console.log(`  priority: ${feature.priority}, difficulty: ${feature.difficulty}, effort: ${feature.effort}`);\n117:     if (feature.depends_on.length > 0) {\n118:       console.log(`  depends on: ${feature.depends_on.join(\", \")}`);\n119:     }\n120:   }\n121: }\n\n(End of file - total 121 lines)\n</content>","title":"src/commands/features/add.ts","metadata":{"preview":"/**\n * features/add.ts — Add a new feature to the features file.\n *\n * Usage:\n *   wombo features add <id> --title \"Feature Title\" [--description \"...\"]\n *                      [--priority medium] [--difficulty easy] [--effort PT2H]\n *                      [--depends-on \"feat1,feat2\"]\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  createBlankFeature,\n  allFeatureIds,\n  type Priority,\n  type Difficulty,\n} from \"../../lib/features.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773245116530,"end":1773245116535}}}}
{"type":"tool_use","timestamp":1773245116537,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda53074001q1H5Ej4jS0EI6E","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda513b900126Jtphxg3AXvca","type":"tool","callID":"toolu_01PZWsfrP9xrpzrKApqiNeSL","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/set-status.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/set-status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/set-status.ts — Change a feature's status.\n3:  *\n4:  * Usage:\n5:  *   wombo features set-status <feature-id> <new-status>\n6:  *\n7:  * Valid statuses: backlog, planned, in_progress, blocked, in_review, done, cancelled\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   findFeatureById,\n15:   type FeatureStatus,\n16: } from \"../../lib/features.js\";\n17: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: const VALID_STATUSES: FeatureStatus[] = [\n24:   \"backlog\",\n25:   \"planned\",\n26:   \"in_progress\",\n27:   \"blocked\",\n28:   \"in_review\",\n29:   \"done\",\n30:   \"cancelled\",\n31: ];\n32: \n33: export interface FeaturesSetStatusOptions {\n34:   projectRoot: string;\n35:   config: WomboConfig;\n36:   featureId: string;\n37:   newStatus: string;\n38:   outputFmt?: OutputFormat;\n39:   dryRun?: boolean;\n40: }\n41: \n42: // ---------------------------------------------------------------------------\n43: // Command\n44: // ---------------------------------------------------------------------------\n45: \n46: export async function cmdFeaturesSetStatus(opts: FeaturesSetStatusOptions): Promise<void> {\n47:   const { projectRoot, config } = opts;\n48:   const fmt = opts.outputFmt ?? \"text\";\n49: \n50:   if (!opts.featureId || !opts.newStatus) {\n51:     outputError(fmt, `Usage: wombo features set-status <feature-id> <new-status>\\nValid statuses: ${VALID_STATUSES.join(\", \")}`);\n52:     return;\n53:   }\n54: \n55:   // Validate status\n56:   if (!VALID_STATUSES.includes(opts.newStatus as FeatureStatus)) {\n57:     outputError(fmt, `Invalid status: \"${opts.newStatus}\"\\nValid statuses: ${VALID_STATUSES.join(\", \")}`);\n58:     return;\n59:   }\n60: \n61:   const data = loadFeatures(projectRoot, config);\n62:   const feature = findFeatureById(data, opts.featureId);\n63: \n64:   if (!feature) {\n65:     outputError(fmt, `Feature \"${opts.featureId}\" not found.`);\n66:     return;\n67:   }\n68: \n69:   const oldStatus = feature.status;\n70:   const newStatus = opts.newStatus as FeatureStatus;\n71: \n72:   if (oldStatus === newStatus) {\n73:     outputMessage(fmt, `Feature \"${opts.featureId}\" is already in status \"${newStatus}\".`, {\n74:       id: opts.featureId,\n75:       status: newStatus,\n76:       changed: false,\n77:     });\n78:     return;\n79:   }\n80: \n81:   // Dry-run: show what would change without writing\n82:   if (opts.dryRun) {\n83:     outputMessage(fmt, `[dry-run] Would change \"${opts.featureId}\": ${oldStatus} → ${newStatus}`, {\n84:       dry_run: true,\n85:       id: opts.featureId,\n86:       old_status: oldStatus,\n87:       new_status: newStatus,\n88:       changed: false,\n89:     });\n90:     return;\n91:   }\n92: \n93:   // Apply status change\n94:   feature.status = newStatus;\n95: \n96:   // Set timestamps\n97:   if (newStatus === \"in_progress\" && !feature.started_at) {\n98:     feature.started_at = new Date().toISOString();\n99:   }\n100:   if (newStatus === \"done\" || newStatus === \"cancelled\") {\n101:     feature.ended_at = new Date().toISOString();\n102:     if (newStatus === \"done\") {\n103:       feature.completion = 100;\n104:     }\n105:   }\n106: \n107:   saveFeatures(projectRoot, config, data);\n108: \n109:   outputMessage(fmt, `Feature \"${opts.featureId}\": ${oldStatus} → ${newStatus}`, {\n110:     id: opts.featureId,\n111:     old_status: oldStatus,\n112:     new_status: newStatus,\n113:     changed: true,\n114:   });\n115: }\n\n(End of file - total 115 lines)\n</content>","title":"src/commands/features/set-status.ts","metadata":{"preview":"/**\n * features/set-status.ts — Change a feature's status.\n *\n * Usage:\n *   wombo features set-status <feature-id> <new-status>\n *\n * Valid statuses: backlog, planned, in_progress, blocked, in_review, done, cancelled\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type FeatureStatus,\n} from \"../../lib/features.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773245116533,"end":1773245116536}}}}
