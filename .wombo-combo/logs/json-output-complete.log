g })),\n  ];\n\n  output(\n    fmt,\n    {\n      ok,\n      items_checked: allItems.length,\n      errors: result.errors.length,\n      warnings: result.warnings.length,\n      issues,\n    },\n    () => {\n      console.log(`\\nChecking ${config.featuresFile} (${allItems.length} items)...\\n`);\n\n      if (result.errors.length === 0 && result.warnings.length === 0) {\n        console.log(\"  All checks passed. No issues found.\");\n        return;\n      }\n\n      if (result.errors.length > 0) {\n        console.log(`  ERRORS (${result.errors.length}):`);\n        for (const e of result.errors) {\n          console.log(`    \\x1b[31m✗\\x1b[0m ${e}`);\n        }\n        console.log(\"\");\n      }\n\n      if (result.warnings.length > 0) {\n        console.log(`  WARNINGS (${result.warnings.length}):`);\n        for (const w of result.warnings) {\n          console.log(`    \\x1b[33m⚠\\x1b[0m ${w}`);\n        }\n        console.log(\"\");\n      }\n    }\n  );\n\n  if (result.errors.length > 0) {\n    process.exit(1);\n  }\n}"},"output":"Edit applied successfully.","title":"src/commands/features/check.ts","metadata":{"diagnostics":{"/home/fulgidus/Documents/wombo-json-output-complete/src/index.ts":[{"range":{"start":{"line":415,"character":8},"end":{"line":415,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":510,"character":8},"end":{"line":510,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":535,"character":6},"end":{"line":535,"character":12}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":568,"character":8},"end":{"line":568,"character":14}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":594,"character":10},"end":{"line":594,"character":16}},"message":"Unreachable code d