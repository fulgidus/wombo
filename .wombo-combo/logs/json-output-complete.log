(const s of matching) {\n40:         console.log(`    ${s}`);\n41:       }\n42:     } catch {\n43:       console.log(\"  tmux sessions to kill: 0 (no tmux server running)\");\n44:     }\n45: \n46:     // List worktrees that would be removed\n47:     try {\n48:       const worktrees = execSync(\"git worktree list --porcelain\", {\n49:         cwd: projectRoot,\n50:         encoding: \"utf-8\",\n51:       }).trim();\n52:       const prefix = config.git.worktreePrefix;\n53:       const matching = worktrees\n54:         .split(\"\\n\")\n55:         .filter((line) => line.startsWith(\"worktree \") && line.includes(prefix))\n56:         .map((line) => line.replace(\"worktree \", \"\"));\n57:       console.log(`  worktrees to remove: ${matching.length}`);\n58:       for (const w of matching) {\n59:         console.log(`    ${w}`);\n60:       }\n61:     } catch {\n62:       console.log(\"  worktrees to remove: 0\");\n63:     }\n64: \n65:     const statePath = resolve(projectRoot, \".wombo-state.json\");\n66:     const logDir = resolve(projectRoot, \".wombo-logs\");\n67:     if (existsSync(statePath)) console.log(\"  Would remove: .wombo-state.json\");\n68:     if (existsSync(logDir)) console.log(\"  Would remove: .wombo-logs/\");\n69: \n70:     return;\n71:   }\n72: \n73:   console.log(\"\\n--- Wombo: Cleanup ---\\n\");\n74: \n75:   // Kill tmux sessions\n76:   const killed = killAllTmuxSessions(config);\n77:   console.log(`Killed ${killed} tmux session(s)`);\n78: \n79:   // Remove worktrees\n80:   const removed = cleanupAllWorktrees(projectRoot, config);\n81:   console.log(`Removed ${removed} worktree(s)`);\n82: \n83:   // List remaining feature branches\n84:   try {\n85:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n86:     const branches = execSync(`git branch --list ${branchPattern}`, {\n87:       cwd: projectRoot,\n88:       encoding: \"utf-8\",\n89:     }).trim();\n90:     if (branches) {\n91:       console.log(`\\nRemaining feature branches:\\n${branches}`);\n92:       console.log('Use \"git branch -D <branch>\" to remove manually.');\n93:     }\n94:   } catch {}\n95: \n96:   // Remove state file\n97:   const statePath = resolve(projectRoot, \".wombo-state.json\");\n98:   if (existsSync(statePath)) {\n99:     unlinkSync(statePath);\n100:     console.log(\"Removed .wombo-state.json\");\n101:   }\n102: \n103:   // Remove log directory\n104:   const logDir = resolve(projectRoot, \".wombo-logs\");\n105:   if (existsSync(logDir)) {\n106:     rmSync(logDir, { recursive: true, force: true });\n107:     console.log(\"Removed .wombo-logs/\");\n108:   }\n109: \n110:   console.log(\"\\nCleanup complete.\");\n111: }\n\n(End of file - total 111 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: wombo cleanup\n *\n * Kills tmux sessions, removes worktrees, removes state and log files.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { killAllTmuxSessions } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees } from \"../lib/worktree.js\";\n\nexport interface CleanupOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  dryRun?: boolean;\n}","truncated":false,"loaded":[]},"time":{"start":1773245121876,"end":1773245121882}}}}
