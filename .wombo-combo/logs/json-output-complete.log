{"type":"tool_use","timestamp":1773246666390,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcd3e7001kimmS7vQibPXPp","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcc5a1001opGNcEmXhUlgxR","type":"tool","callID":"toolu_01WoRLyo1K8on5n3hdJ55cur","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"text\") return \"text\";\n40:   // Check env var for agent pipelines\n41:   const env = process.env.WOMBO_OUTPUT;\n42:   if (env === \"json\") return \"json\";\n43:   return \"text\";\n44: }\n45: \n46: /**\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n48:  * In text mode, calls the provided textRenderer callback.\n49:  */\n50: export function output(\n51:   format: OutputFormat,\n52:   data: unknown,\n53:   textRenderer: () => void\n54: ): void {\n55:   if (format === \"json\") {\n56:     console.log(JSON.stringify(data));\n57:   } else {\n58:     textRenderer();\n59:   }\n60: }\n61: \n62: /**\n63:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n64:  * In text mode, outputs the message to stderr normally.\n65:  */\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n67:   if (format === \"json\") {\n68:     console.error(JSON.stringify({ error: message }));\n69:   } else {\n70:     console.error(message);\n71:   }\n72:   process.exit(exitCode);\n73: }\n74: \n75: /**\n76:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n77:  * In text mode, outputs the message to stdout normally.\n78:  */\n79: export function outputMessage(\n80:   format: OutputFormat,\n81:   message: string,\n82:   extra?: Record<string, unknown>\n83: ): void {\n84:   if (format === \"json\") {\n85:     console.log(JSON.stringify({ message, ...extra }));\n86:   } else {\n87:     console.log(message);\n88:   }\n89: }\n90: \n91: // ---------------------------------------------------------------------------\n92: // Field filtering for compact output (--fields)\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Filter an object to only include the specified fields.\n97:  * If fields is undefined/empty, returns the object unchanged.\n98:  */\n99: export function filterFields<T extends Record<string, unknown>>(\n100:   obj: T,\n101:   fields?: string[]\n102: ): Partial<T> {\n103:   if (!fields || fields.length === 0) return obj;\n104:   const result: Partial<T> = {};\n105:   for (const field of fields) {\n106:     if (field in obj) {\n107:       (result as any)[field] = (obj as any)[field];\n108:     }\n109:   }\n110:   return result;\n111: }\n112: \n113: /**\n114:  * Filter an array of objects to only include specified fields per object.\n115:  * If fields is undefined/empty, returns the array unchanged.\n116:  */\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\n118:   arr: T[],\n119:   fields?: string[]\n120: ): Partial<T>[] {\n121:   if (!fields || fields.length === 0) return arr;\n122:   return arr.map((obj) => filterFields(obj, fields));\n123: }\n124: \n125: /**\n126:  * Render a compact text table from an array of objects with selected fields.\n127:  * Used for text-mode --fields output.\n128:  */\n129: export function renderCompactTable(\n130:   items: Record<string, unknown>[],\n131:   fields: string[]\n132: ): void {\n133:   if (items.length === 0) return;\n134: \n135:   // Calculate column widths\n136:   const widths: Record<string, number> = {};\n137:   for (const field of fields) {\n138:     widths[field] = field.length;\n139:     for (const item of items) {\n140:       const val = String(item[field] ?? \"\");\n141:       widths[field] = Math.max(widths[field], val.length);\n142:     }\n143:   }\n144: \n145:   // Header\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n147:   console.log(header);\n148:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n149: \n150:   // Rows\n151:   for (const item of items) {\n152:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n153:     console.log(row);\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\";","truncated":false,"loaded":[]},"time":{"start":1773246666386,"end":1773246666389}}}}
{"type":"tool_use","timestamp":1773246667196,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcd693001N9mMoI3nYw1Amy","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcc5a1001opGNcEmXhUlgxR","type":"tool","callID":"toolu_01M7KFrjKFZ3DrWyJxL7qR7z","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/check.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/check.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/check.ts — Validate the features file for schema issues, broken deps, and orphans.\n3:  *\n4:  * Usage:\n5:  *   wombo features check\n6:  *\n7:  * Checks:\n8:  *   - Required fields present on every feature\n9:  *   - No duplicate IDs\n10:  *   - All depends_on references point to existing features\n11:  *   - No circular dependencies\n12:  *   - No orphaned subtasks (subtask IDs unique)\n13:  *   - Priority/difficulty values are valid enums\n14:  *   - Effort strings are parseable ISO 8601 durations\n15:  */\n16: \n17: import type { WomboConfig } from \"../../config.js\";\n18: import {\n19:   loadFeatures,\n20:   allFeatureIds,\n21:   parseDurationMinutes,\n22:   type Feature,\n23:   type Subtask,\n24:   type FeaturesFile,\n25:   type Priority,\n26:   type Difficulty,\n27:   type FeatureStatus,\n28: } from \"../../lib/features.js\";\n29: import { output, type OutputFormat } from \"../../lib/output.js\";\n30: \n31: // ---------------------------------------------------------------------------\n32: // Types\n33: // ---------------------------------------------------------------------------\n34: \n35: export interface FeaturesCheckOptions {\n36:   projectRoot: string;\n37:   config: WomboConfig;\n38:   outputFmt?: OutputFormat;\n39: }\n40: \n41: interface CheckResult {\n42:   errors: string[];\n43:   warnings: string[];\n44: }\n45: \n46: // ---------------------------------------------------------------------------\n47: // Validation\n48: // ---------------------------------------------------------------------------\n49: \n50: const VALID_STATUSES: FeatureStatus[] = [\n51:   \"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\",\n52: ];\n53: \n54: const VALID_PRIORITIES: Priority[] = [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"];\n55: \n56: const VALID_DIFFICULTIES: Difficulty[] = [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"];\n57: \n58: function collectAllItems(data: FeaturesFile): (Feature | Subtask)[] {\n59:   const items: (Feature | Subtask)[] = [];\n60:   const collect = (list: (Feature | Subtask)[]) => {\n61:     for (const item of list) {\n62:       items.push(item);\n63:       if (item.subtasks?.length) collect(item.subtasks);\n64:     }\n65:   };\n66:   collect(data.features ?? []);\n67:   collect(data.archive ?? []);\n68:   return items;\n69: }\n70: \n71: function checkFeatures(data: FeaturesFile): CheckResult {\n72:   const errors: string[] = [];\n73:   const warnings: string[] = [];\n74:   const allItems = collectAllItems(data);\n75:   const allIds = allItems.map((i) => i.id);\n76:   const idSet = new Set<string>();\n77: \n78:   // Check for duplicates\n79:   for (const id of allIds) {\n80:     if (idSet.has(id)) {\n81:       errors.push(`Duplicate ID: \"${id}\"`);\n82:     }\n83:     idSet.add(id);\n84:   }\n85: \n86:   // Check each item\n87:   for (const item of allItems) {\n88:     const prefix = `[${item.id}]`;\n89: \n90:     // Required fields\n91:     if (!item.id) errors.push(`${prefix} Missing required field: id`);\n92:     if (!item.title) errors.push(`${prefix} Missing required field: title`);\n93:     if (!item.status) errors.push(`${prefix} Missing required field: status`);\n94: \n95:     // Validate enum values\n96:     if (item.status && !VALID_STATUSES.includes(item.status)) {\n97:       errors.push(`${prefix} Invalid status: \"${item.status}\"`);\n98:     }\n99:     if (item.priority && !VALID_PRIORITIES.includes(item.priority)) {\n100:       errors.push(`${prefix} Invalid priority: \"${item.priority}\"`);\n101:     }\n102:     if (item.difficulty && !VALID_DIFFICULTIES.includes(item.difficulty)) {\n103:       errors.push(`${prefix} Invalid difficulty: \"${item.difficulty}\"`);\n104:     }\n105: \n106:     // Validate effort\n107:     if (item.effort) {\n108:       const minutes = parseDurationMinutes(item.effort);\n109:       if (minutes === Infinity) {\n110:         warnings.push(`${prefix} Unparseable effort duration: \"${item.effort}\"`);\n111:       }\n112:     }\n113: \n114:     // Check depends_on references\n115:     if (item.depends_on?.length) {\n116:       for (const dep of item.depends_on) {\n117:         if (!idSet.has(dep)) {\n118:           errors.push(`${prefix} Broken dependency: \"${dep}\" does not exist`);\n119:         }\n120:       }\n121:     }\n122:   }\n123: \n124:   // Check for circular dependencies (simple DFS)\n125:   const visited = new Set<string>();\n126:   const visiting = new Set<string>();\n127:   const depMap = new Map<string, string[]>();\n128:   for (const item of allItems) {\n129:     depMap.set(item.id, item.depends_on ?? []);\n130:   }\n131: \n132:   function hasCycle(id: string): boolean {\n133:     if (visiting.has(id)) return true;\n134:     if (visited.has(id)) return false;\n135:     visiting.add(id);\n136:     for (const dep of depMap.get(id) ?? []) {\n137:       if (hasCycle(dep)) {\n138:         errors.push(`Circular dependency detected involving: \"${id}\" → \"${dep}\"`);\n139:         return true;\n140:       }\n141:     }\n142:     visiting.delete(id);\n143:     visited.add(id);\n144:     return false;\n145:   }\n146: \n147:   for (const id of idSet) {\n148:     hasCycle(id);\n149:   }\n150: \n151:   // Warn about features with no effort estimate\n152:   for (const item of allItems) {\n153:     if (!item.effort || item.effort === \"PT0S\") {\n154:       warnings.push(`[${item.id}] No effort estimate`);\n155:     }\n156:   }\n157: \n158:   return { errors, warnings };\n159: }\n160: \n161: // ---------------------------------------------------------------------------\n162: // Command\n163: // ---------------------------------------------------------------------------\n164: \n165: export async function cmdFeaturesCheck(opts: FeaturesCheckOptions): Promise<void> {\n166:   const { projectRoot, config } = opts;\n167:   const fmt = opts.outputFmt ?? \"text\";\n168: \n169:   const data = loadFeatures(projectRoot, config);\n170:   const result = checkFeatures(data);\n171: \n172:   const allItems = collectAllItems(data);\n173:   const ok = result.errors.length === 0;\n174:   const issues = [\n175:     ...result.errors.map((msg) => ({ level: \"error\" as const, message: msg })),\n176:     ...result.warnings.map((msg) => ({ level: \"warning\" as const, message: msg })),\n177:   ];\n178: \n179:   output(\n180:     fmt,\n181:     {\n182:       ok,\n183:       items_checked: allItems.length,\n184:       errors: result.errors.length,\n185:       warnings: result.warnings.length,\n186:       issues,\n187:     },\n188:     () => {\n189:       console.log(`\\nChecking ${config.featuresFile} (${allItems.length} items)...\\n`);\n190: \n191:       if (result.errors.length === 0 && result.warnings.length === 0) {\n192:         console.log(\"  All checks passed. No issues found.\");\n193:         return;\n194:       }\n195: \n196:       if (result.errors.length > 0) {\n197:         console.log(`  ERRORS (${result.errors.length}):`);\n198:         for (const e of result.errors) {\n199:           console.log(`    \\x1b[31m✗\\x1b[0m ${e}`);\n200:         }\n201:         console.log(\"\");\n202:       }\n203: \n204:       if (result.warnings.length > 0) {\n205:         console.log(`  WARNINGS (${result.warnings.length}):`);\n206:         for (const w of result.warnings) {\n207:           console.log(`    \\x1b[33m⚠\\x1b[0m ${w}`);\n208:         }\n209:         console.log(\"\");\n210:       }\n211:     }\n212:   );\n213: \n214:   if (result.errors.length > 0) {\n215:     process.exit(1);\n216:   }\n217: }\n\n(End of file - total 217 lines)\n</content>","title":"src/commands/features/check.ts","metadata":{"preview":"/**\n * features/check.ts — Validate the features file for schema issues, broken deps, and orphans.\n *\n * Usage:\n *   wombo features check\n *\n * Checks:\n *   - Required fields present on every feature\n *   - No duplicate IDs\n *   - All depends_on references point to existing features\n *   - No circular dependencies\n *   - No orphaned subtasks (subtask IDs unique)\n *   - Priority/difficulty values are valid enums\n *   - Effort strings are parseable ISO 8601 durations\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  allFeatureIds,","truncated":false,"loaded":[]},"time":{"start":1773246667194,"end":1773246667195}}}}
{"type":"tool_use","timestamp":1773246668018,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcda2f001g6EPSbQqKh6XvH","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcc5a1001opGNcEmXhUlgxR","type":"tool","callID":"toolu_011DhkoRo7YcSNKBXYGDXYe6","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/archive.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/archive.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/archive.ts — Move done/cancelled features to the archive section.\n3:  *\n4:  * Usage:\n5:  *   wombo features archive              # archive all done + cancelled\n6:  *   wombo features archive <feature-id> # archive a specific feature\n7:  *   wombo features archive --dry-run    # show what would be archived\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   findFeatureById,\n15:   type Feature,\n16: } from \"../../lib/features.js\";\n17: import { output, outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: export interface FeaturesArchiveOptions {\n24:   projectRoot: string;\n25:   config: WomboConfig;\n26:   featureId?: string;\n27:   dryRun?: boolean;\n28:   outputFmt?: OutputFormat;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Command\n33: // ---------------------------------------------------------------------------\n34: \n35: export async function cmdFeaturesArchive(opts: FeaturesArchiveOptions): Promise<void> {\n36:   const { projectRoot, config } = opts;\n37:   const fmt = opts.outputFmt ?? \"text\";\n38: \n39:   const data = loadFeatures(projectRoot, config);\n40: \n41:   // Ensure archive array exists\n42:   if (!data.archive) {\n43:     data.archive = [];\n44:   }\n45: \n46:   let toArchive: Feature[];\n47: \n48:   if (opts.featureId) {\n49:     // Archive a specific feature\n50:     const idx = data.features.findIndex((f) => f.id === opts.featureId);\n51:     if (idx === -1) {\n52:       // Check if already in archive\n53:       if (data.archive.find((f) => f.id === opts.featureId)) {\n54:         outputMessage(fmt, `Feature \"${opts.featureId}\" is already in the archive.`, {\n55:           already_archived: true,\n56:           id: opts.featureId,\n57:         });\n58:         return;\n59:       }\n60:       outputError(fmt, `Feature \"${opts.featureId}\" not found.`);\n61:       return;\n62:     }\n63:     toArchive = [data.features[idx]];\n64:   } else {\n65:     // Archive all done + cancelled features\n66:     toArchive = data.features.filter(\n67:       (f) => f.status === \"done\" || f.status === \"cancelled\"\n68:     );\n69:   }\n70: \n71:   if (toArchive.length === 0) {\n72:     outputMessage(fmt, \"No features to archive.\", { archived: [], count: 0 });\n73:     return;\n74:   }\n75: \n76:   const archivedData = toArchive.map((f) => ({\n77:     id: f.id,\n78:     title: f.title,\n79:     status: f.status,\n80:   }));\n81: \n82:   if (opts.dryRun) {\n83:     output(\n84:       fmt,\n85:       {\n86:         dry_run: true,\n87:         archived: archivedData,\n88:         count: toArchive.length,\n89:       },\n90:       () => {\n91:         console.log(`\\nWould archive ${toArchive.length} feature(s):\\n`);\n92:         for (const f of toArchive) {\n93:           console.log(`  ${f.id} — ${f.title} (${f.status})`);\n94:         }\n95:       }\n96:     );\n97:     return;\n98:   }\n99: \n100:   // Move features from active to archive\n101:   const archiveIds = new Set(toArchive.map((f) => f.id));\n102:   data.features = data.features.filter((f) => !archiveIds.has(f.id));\n103:   data.archive.push(...toArchive);\n104: \n105:   saveFeatures(projectRoot, config, data);\n106: \n107:   output(\n108:     fmt,\n109:     {\n110:       archived: archivedData,\n111:       count: toArchive.length,\n112:     },\n113:     () => {\n114:       console.log(`\\nArchived ${toArchive.length} feature(s):`);\n115:       for (const f of toArchive) {\n116:         console.log(`  ${f.id} — ${f.title} (${f.status})`);\n117:       }\n118:     }\n119:   );\n120: }\n\n(End of file - total 120 lines)\n</content>","title":"src/commands/features/archive.ts","metadata":{"preview":"/**\n * features/archive.ts — Move done/cancelled features to the archive section.\n *\n * Usage:\n *   wombo features archive              # archive all done + cancelled\n *   wombo features archive <feature-id> # archive a specific feature\n *   wombo features archive --dry-run    # show what would be archived\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Feature,\n} from \"../../lib/features.js\";\nimport { output, outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773246668013,"end":1773246668016}}}}
{"type":"tool_use","timestamp":1773246668143,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcdcee0015364KtWn4W4Geg","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcc5a1001opGNcEmXhUlgxR","type":"tool","callID":"toolu_01HnaWqRqtD9ZoHzm1yuonmR","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/list.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/list.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/list.ts — List and filter features from the features file.\n3:  *\n4:  * Usage:\n5:  *   wombo features list                     # list all features\n6:  *   wombo features list --status backlog    # filter by status\n7:  *   wombo features list --priority high     # filter by priority\n8:  *   wombo features list --ready             # show only ready features\n9:  *   wombo features list --archive           # include archived features\n10:  */\n11: \n12: import type { WomboConfig } from \"../../config.js\";\n13: import {\n14:   loadFeatures,\n15:   getReadyFeatures,\n16:   featureSummary,\n17:   formatDuration,\n18:   parseDurationMinutes,\n19:   type Feature,\n20:   type FeatureStatus,\n21:   type Priority,\n22:   type Difficulty,\n23:   type FeaturesFile,\n24: } from \"../../lib/features.js\";\n25: import { output, filterFieldsArray, renderCompactTable, type OutputFormat } from \"../../lib/output.js\";\n26: \n27: // ---------------------------------------------------------------------------\n28: // Types\n29: // ---------------------------------------------------------------------------\n30: \n31: export interface FeaturesListOptions {\n32:   projectRoot: string;\n33:   config: WomboConfig;\n34:   status?: FeatureStatus;\n35:   priority?: Priority;\n36:   difficulty?: Difficulty;\n37:   ready?: boolean;\n38:   includeArchive?: boolean;\n39:   outputFmt?: OutputFormat;\n40:   fields?: string[];\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // ANSI Helpers\n45: // ---------------------------------------------------------------------------\n46: \n47: const RESET = \"\\x1b[0m\";\n48: const BOLD = \"\\x1b[1m\";\n49: const DIM = \"\\x1b[2m\";\n50: \n51: const STATUS_COLOR: Record<FeatureStatus, string> = {\n52:   backlog: \"\\x1b[37m\",     // white\n53:   planned: \"\\x1b[36m\",     // cyan\n54:   in_progress: \"\\x1b[34m\", // blue\n55:   blocked: \"\\x1b[31m\",     // red\n56:   in_review: \"\\x1b[33m\",   // yellow\n57:   done: \"\\x1b[32m\",        // green\n58:   cancelled: \"\\x1b[90m\",   // gray\n59: };\n60: \n61: // ---------------------------------------------------------------------------\n62: // Command\n63: // ---------------------------------------------------------------------------\n64: \n65: export async function cmdFeaturesList(opts: FeaturesListOptions): Promise<void> {\n66:   const { projectRoot, config } = opts;\n67:   const data = loadFeatures(projectRoot, config);\n68: \n69:   let features: Feature[] = [...data.features];\n70: \n71:   // Include archive if requested\n72:   if (opts.includeArchive && data.archive?.length) {\n73:     features = [...features, ...data.archive];\n74:   }\n75: \n76:   // Filter by status\n77:   if (opts.status) {\n78:     features = features.filter((f) => f.status === opts.status);\n79:   }\n80: \n81:   // Filter by priority\n82:   if (opts.priority) {\n83:     features = features.filter((f) => f.priority === opts.priority);\n84:   }\n85: \n86:   // Filter by difficulty\n87:   if (opts.difficulty) {\n88:     features = features.filter((f) => f.difficulty === opts.difficulty);\n89:   }\n90: \n91:   // Filter to ready-only\n92:   if (opts.ready) {\n93:     const readyFeatures = getReadyFeatures(data);\n94:     const readyIds = new Set(readyFeatures.map((f) => f.id));\n95:     features = features.filter((f) => readyIds.has(f.id));\n96:   }\n97: \n98:   if (features.length === 0) {\n99:     output(opts.outputFmt ?? \"text\", { features: [], total: 0, effort: \"0m\" }, () => {\n100:       console.log(\"No features match the given filters.\");\n101:     });\n102:     return;\n103:   }\n104: \n105:   // Group by status for display\n106:   const byStatus = new Map<FeatureStatus, Feature[]>();\n107:   for (const f of features) {\n108:     const list = byStatus.get(f.status) ?? [];\n109:     list.push(f);\n110:     byStatus.set(f.status, list);\n111:   }\n112: \n113:   // Display\n114:   const totalEffort = features.reduce(\n115:     (sum, f) => sum + parseDurationMinutes(f.effort),\n116:     0\n117:   );\n118: \n119:   const fmt = opts.outputFmt ?? \"text\";\n120: \n121:   // Build the structured data for each feature\n122:   const featureData = features.map((f) => ({\n123:     id: f.id,\n124:     title: f.title,\n125:     status: f.status,\n126:     priority: f.priority,\n127:     difficulty: f.difficulty,\n128:     effort: f.effort,\n129:     completion: f.completion,\n130:     depends_on: f.depends_on,\n131:   }));\n132: \n133:   // If --fields is specified, use compact output mode\n134:   if (opts.fields?.length) {\n135:     const filtered = filterFieldsArray(featureData, opts.fields);\n136:     output(\n137:       fmt,\n138:       { features: filtered, total: features.length, effort: formatDuration(totalEffort) },\n139:       () => {\n140:         renderCompactTable(\n141:           featureData as Record<string, unknown>[],\n142:           opts.fields!\n143:         );\n144:       }\n145:     );\n146:     return;\n147:   }\n148: \n149:   output(\n150:     fmt,\n151:     {\n152:       features: featureData,\n153:       total: features.length,\n154:       effort: formatDuration(totalEffort),\n155:     },\n156:     () => {\n157:       console.log(`\\n${BOLD}Features (${features.length} total, ~${formatDuration(totalEffort)} effort)${RESET}\\n`);\n158: \n159:       const statusOrder: FeatureStatus[] = [\n160:         \"in_progress\",\n161:         \"planned\",\n162:         \"backlog\",\n163:         \"blocked\",\n164:         \"in_review\",\n165:         \"done\",\n166:         \"cancelled\",\n167:       ];\n168: \n169:       for (const status of statusOrder) {\n170:         const group = byStatus.get(status);\n171:         if (!group?.length) continue;\n172: \n173:         const color = STATUS_COLOR[status] ?? \"\";\n174:         console.log(`  ${color}${BOLD}${status.toUpperCase()}${RESET} (${group.length})`);\n175: \n176:         for (const f of group) {\n177:           const effort = formatDuration(parseDurationMinutes(f.effort));\n178:           const deps = f.depends_on.length > 0 ? ` ${DIM}deps: ${f.depends_on.join(\", \")}${RESET}` : \"\";\n179:           const completion = f.completion > 0 ? ` ${DIM}${f.completion}%${RESET}` : \"\";\n180:           console.log(\n181:             `    ${color}${f.id}${RESET} — ${f.title} [${f.priority}/${f.difficulty}] (${effort})${completion}${deps}`\n182:           );\n183:         }\n184:         console.log(\"\");\n185:       }\n186:     }\n187:   );\n188: }\n\n(End of file - total 188 lines)\n</content>","title":"src/commands/features/list.ts","metadata":{"preview":"/**\n * features/list.ts — List and filter features from the features file.\n *\n * Usage:\n *   wombo features list                     # list all features\n *   wombo features list --status backlog    # filter by status\n *   wombo features list --priority high     # filter by priority\n *   wombo features list --ready             # show only ready features\n *   wombo features list --archive           # include archived features\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  getReadyFeatures,\n  featureSummary,\n  formatDuration,\n  parseDurationMinutes,\n  type Feature,\n  type FeatureStatus,","truncated":false,"loaded":[]},"time":{"start":1773246668138,"end":1773246668142}}}}
