{"type":"tool_use","timestamp":1773245123917,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda54bad001T8zEqmlBT5N9ml","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda5308b001MvpmkDdfkFW5X4","type":"tool","callID":"toolu_013TqsT6JBMBGyA3n7Q61R3R","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/features.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: \n23: // ---------------------------------------------------------------------------\n24: // Types\n25: // ---------------------------------------------------------------------------\n26: \n27: export interface RetryCommandOptions {\n28:   projectRoot: string;\n29:   config: WomboConfig;\n30:   featureId: string;\n31:   model?: string;\n32:   interactive: boolean;\n33:   dryRun?: boolean;\n34: }\n35: \n36: // ---------------------------------------------------------------------------\n37: // Command\n38: // ---------------------------------------------------------------------------\n39: \n40: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n41:   const { projectRoot, config } = opts;\n42: \n43:   if (!opts.featureId) {\n44:     console.error(\"Usage: wombo retry <feature-id>\");\n45:     process.exit(1);\n46:     return; // unreachable — helps TypeScript narrow\n47:   }\n48: \n49:   const state = loadState(projectRoot);\n50:   if (!state) {\n51:     console.log(\"No active wave.\");\n52:     return;\n53:   }\n54: \n55:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n56:   if (!agent) {\n57:     console.error(`Agent not found for feature: ${opts.featureId}`);\n58:     process.exit(1);\n59:     return; // unreachable — helps TypeScript narrow\n60:   }\n61: \n62:   if (agent.status !== \"failed\") {\n63:     console.error(\n64:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n65:     );\n66:     process.exit(1);\n67:     return; // unreachable — helps TypeScript narrow\n68:   }\n69: \n70:   // Dry-run: show what would be retried without doing it\n71:   if (opts.dryRun) {\n72:     console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n73:     console.log(`  Current status: ${agent.status}`);\n74:     console.log(`  Retries so far: ${agent.retries}`);\n75:     console.log(`  Worktree: ${agent.worktree}`);\n76:     console.log(`  Mode: ${opts.interactive ? \"interactive (tmux)\" : \"headless\"}`);\n77:     if (opts.model) console.log(`  Model: ${opts.model}`);\n78:     return;\n79:   }\n80: \n81:   // Reset retry count and re-run\n82:   updateAgent(state, agent.feature_id, {\n83:     status: \"queued\",\n84:     retries: 0,\n85:     error: null,\n86:     build_passed: null,\n87:     build_output: null,\n88:     completed_at: null,\n89:   });\n90:   saveState(projectRoot, state);\n91: \n92:   const data = loadFeatures(projectRoot, config);\n93:   const feature = data.features.find((f) => f.id === opts.featureId);\n94:   if (!feature) {\n95:     console.error(`Feature ${opts.featureId} not found in ${config.featuresFile}`);\n96:     process.exit(1);\n97:     return; // unreachable — helps TypeScript narrow\n98:   }\n99: \n100:   if (opts.interactive) {\n101:     const prompt = generatePrompt(feature, state.base_branch, config);\n102:     launchInteractive({\n103:       worktreePath: agent.worktree,\n104:       featureId: feature.id,\n105:       prompt,\n106:       model: opts.model,\n107:       interactive: true,\n108:       config,\n109:     });\n110: \n111:     updateAgent(state, agent.feature_id, {\n112:       status: \"running\",\n113:       started_at: new Date().toISOString(),\n114:     });\n115:     saveState(projectRoot, state);\n116:     console.log(`Retrying ${opts.featureId} in tmux session ${config.agent.tmuxPrefix}-${opts.featureId}`);\n117:   } else {\n118:     const monitor = new ProcessMonitor(projectRoot);\n119:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n120:     console.log(`Retrying ${opts.featureId} in headless mode`);\n121:   }\n122: }\n\n(End of file - total 122 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773245123908,"end":1773245123916}}}}
{"type":"tool_use","timestamp":1773245123918,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda54d46001vWn19tTPKk7dTW","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda5308b001MvpmkDdfkFW5X4","type":"tool","callID":"toolu_0191fSRtwrNLkxjtoTnMp872","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/upgrade.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/upgrade.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * upgrade.ts — Self-upgrade wombo from GitHub.\n3:  *\n4:  * Usage:\n5:  *   wombo upgrade              # Check for updates and prompt to install\n6:  *   wombo upgrade --force      # Skip confirmation prompt\n7:  *   wombo upgrade --version v0.1.0  # Install a specific version\n8:  *   wombo upgrade --check      # Only check, don't install\n9:  */\n10: \n11: import { readFileSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { createInterface } from \"node:readline\";\n14: \n15: // ---------------------------------------------------------------------------\n16: // Types\n17: // ---------------------------------------------------------------------------\n18: \n19: export interface UpgradeOptions {\n20:   force: boolean;\n21:   version?: string;\n22:   checkOnly: boolean;\n23: }\n24: \n25: // ---------------------------------------------------------------------------\n26: // Helpers\n27: // ---------------------------------------------------------------------------\n28: \n29: const REPO = \"fulgidus/wombo\";\n30: \n31: /**\n32:  * Get the locally installed version from package.json.\n33:  * Uses import.meta to find the package.json relative to this source file,\n34:  * which works whether running from local source or global install.\n35:  */\n36: function getLocalVersion(): string {\n37:   const pkgPath = resolve(import.meta.dir, \"../../package.json\");\n38:   const raw = readFileSync(pkgPath, \"utf-8\");\n39:   return JSON.parse(raw).version as string;\n40: }\n41: \n42: /**\n43:  * Fetch all v* tags from the remote GitHub repo using git ls-remote.\n44:  * Returns tags sorted by semver descending (latest first).\n45:  */\n46: async function fetchRemoteTags(): Promise<string[]> {\n47:   const proc = Bun.spawn([\"git\", \"ls-remote\", \"--tags\", `https://github.com/${REPO}.git`], {\n48:     stdout: \"pipe\",\n49:     stderr: \"pipe\",\n50:   });\n51: \n52:   const stdout = await new Response(proc.stdout).text();\n53:   const exitCode = await proc.exited;\n54: \n55:   if (exitCode !== 0) {\n56:     const stderr = await new Response(proc.stderr).text();\n57:     throw new Error(`Failed to fetch remote tags: ${stderr.trim()}`);\n58:   }\n59: \n60:   // Parse lines like: \"abc123\\trefs/tags/v0.0.1\"\n61:   const tags: string[] = [];\n62:   for (const line of stdout.split(\"\\n\")) {\n63:     const match = line.match(/refs\\/tags\\/(v\\d+\\.\\d+\\.\\d+)$/);\n64:     if (match) {\n65:       tags.push(match[1]);\n66:     }\n67:   }\n68: \n69:   // Sort descending by semver\n70:   tags.sort((a, b) => {\n71:     const pa = a.slice(1).split(\".\").map(Number);\n72:     const pb = b.slice(1).split(\".\").map(Number);\n73:     for (let i = 0; i < 3; i++) {\n74:       if (pa[i] !== pb[i]) return pb[i] - pa[i];\n75:     }\n76:     return 0;\n77:   });\n78: \n79:   return tags;\n80: }\n81: \n82: /**\n83:  * Compare two semver strings. Returns:\n84:  *   -1 if a < b\n85:  *    0 if a === b\n86:  *    1 if a > b\n87:  */\n88: function compareSemver(a: string, b: string): number {\n89:   const pa = a.replace(/^v/, \"\").split(\".\").map(Number);\n90:   const pb = b.replace(/^v/, \"\").split(\".\").map(Number);\n91:   for (let i = 0; i < 3; i++) {\n92:     if (pa[i] < pb[i]) return -1;\n93:     if (pa[i] > pb[i]) return 1;\n94:   }\n95:   return 0;\n96: }\n97: \n98: /**\n99:  * Prompt the user for yes/no confirmation.\n100:  */\n101: async function confirm(message: string): Promise<boolean> {\n102:   if (!process.stdin.isTTY) return false;\n103: \n104:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n105:   return new Promise<boolean>((resolve) => {\n106:     rl.question(`${message} [y/N] `, (answer) => {\n107:       rl.close();\n108:       resolve(answer.trim().toLowerCase() === \"y\");\n109:     });\n110:   });\n111: }\n112: \n113: // ---------------------------------------------------------------------------\n114: // Command\n115: // ---------------------------------------------------------------------------\n116: \n117: export async function cmdUpgrade(opts: UpgradeOptions): Promise<void> {\n118:   const localVersion = getLocalVersion();\n119:   console.log(`Current version: v${localVersion}`);\n120: \n121:   // If a specific version is requested, skip the check\n122:   if (opts.version) {\n123:     const targetTag = opts.version.startsWith(\"v\") ? opts.version : `v${opts.version}`;\n124:     console.log(`Requested version: ${targetTag}`);\n125: \n126:     if (compareSemver(localVersion, targetTag) === 0) {\n127:       console.log(\"Already at the requested version.\");\n128:       return;\n129:     }\n130: \n131:     if (!opts.force) {\n132:       const ok = await confirm(`Install ${targetTag}?`);\n133:       if (!ok) {\n134:         console.log(\"Upgrade cancelled.\");\n135:         return;\n136:       }\n137:     }\n138: \n139:     await installVersion(targetTag);\n140:     return;\n141:   }\n142: \n143:   // Fetch latest from GitHub\n144:   console.log(`Checking for updates from github.com/${REPO}...`);\n145: \n146:   let tags: string[];\n147:   try {\n148:     tags = await fetchRemoteTags();\n149:   } catch (err: any) {\n150:     console.error(`Failed to check for updates: ${err.message}`);\n151:     process.exit(1);\n152:     return;\n153:   }\n154: \n155:   if (tags.length === 0) {\n156:     console.error(\"No release tags found on the remote repository.\");\n157:     process.exit(1);\n158:     return;\n159:   }\n160: \n161:   const latestTag = tags[0];\n162:   const latestVersion = latestTag.slice(1); // strip 'v'\n163:   console.log(`Latest version:  ${latestTag}`);\n164: \n165:   const cmp = compareSemver(localVersion, latestVersion);\n166:   if (cmp >= 0) {\n167:     console.log(\"You are already up to date.\");\n168:     return;\n169:   }\n170: \n171:   if (opts.checkOnly) {\n172:     console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n173:     console.log(`Run 'wombo upgrade' to install.`);\n174:     return;\n175:   }\n176: \n177:   console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n178: \n179:   if (!opts.force) {\n180:     const ok = await confirm(`Upgrade to ${latestTag}?`);\n181:     if (!ok) {\n182:       console.log(\"Upgrade cancelled.\");\n183:       return;\n184:     }\n185:   }\n186: \n187:   await installVersion(latestTag);\n188: }\n189: \n190: async function installVersion(tag: string): Promise<void> {\n191:   console.log(`\\nInstalling wombo@${tag}...`);\n192: \n193:   const proc = Bun.spawn(\n194:     [\"bun\", \"install\", \"-g\", `github:${REPO}#${tag}`],\n195:     {\n196:       stdout: \"inherit\",\n197:       stderr: \"inherit\",\n198:     }\n199:   );\n200: \n201:   const exitCode = await proc.exited;\n202: \n203:   if (exitCode !== 0) {\n204:     console.error(`\\nInstallation failed (exit code ${exitCode}).`);\n205:     process.exit(1);\n206:     return;\n207:   }\n208: \n209:   console.log(`\\nSuccessfully upgraded to ${tag}.`);\n210: }\n\n(End of file - total 210 lines)\n</content>","title":"src/commands/upgrade.ts","metadata":{"preview":"/**\n * upgrade.ts — Self-upgrade wombo from GitHub.\n *\n * Usage:\n *   wombo upgrade              # Check for updates and prompt to install\n *   wombo upgrade --force      # Skip confirmation prompt\n *   wombo upgrade --version v0.1.0  # Install a specific version\n *   wombo upgrade --check      # Only check, don't install\n */\n\nimport { readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface UpgradeOptions {\n  force: boolean;","truncated":false,"loaded":[]},"time":{"start":1773245123912,"end":1773245123918}}}}
