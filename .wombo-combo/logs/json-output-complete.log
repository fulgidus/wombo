{"type":"tool_use","timestamp":1773245113773,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda520820014qwUaucTFTSw69","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda513b900126Jtphxg3AXvca","type":"tool","callID":"toolu_01V26skPhtcBKEvJjJNvfg1L","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"text\") return \"text\";\n40:   // Check env var for agent pipelines\n41:   const env = process.env.WOMBO_OUTPUT;\n42:   if (env === \"json\") return \"json\";\n43:   return \"text\";\n44: }\n45: \n46: /**\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n48:  * In text mode, calls the provided textRenderer callback.\n49:  */\n50: export function output(\n51:   format: OutputFormat,\n52:   data: unknown,\n53:   textRenderer: () => void\n54: ): void {\n55:   if (format === \"json\") {\n56:     console.log(JSON.stringify(data));\n57:   } else {\n58:     textRenderer();\n59:   }\n60: }\n61: \n62: /**\n63:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n64:  * In text mode, outputs the message to stderr normally.\n65:  */\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n67:   if (format === \"json\") {\n68:     console.error(JSON.stringify({ error: message }));\n69:   } else {\n70:     console.error(message);\n71:   }\n72:   process.exit(exitCode);\n73: }\n74: \n75: /**\n76:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n77:  * In text mode, outputs the message to stdout normally.\n78:  */\n79: export function outputMessage(\n80:   format: OutputFormat,\n81:   message: string,\n82:   extra?: Record<string, unknown>\n83: ): void {\n84:   if (format === \"json\") {\n85:     console.log(JSON.stringify({ message, ...extra }));\n86:   } else {\n87:     console.log(message);\n88:   }\n89: }\n90: \n91: // ---------------------------------------------------------------------------\n92: // Field filtering for compact output (--fields)\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Filter an object to only include the specified fields.\n97:  * If fields is undefined/empty, returns the object unchanged.\n98:  */\n99: export function filterFields<T extends Record<string, unknown>>(\n100:   obj: T,\n101:   fields?: string[]\n102: ): Partial<T> {\n103:   if (!fields || fields.length === 0) return obj;\n104:   const result: Partial<T> = {};\n105:   for (const field of fields) {\n106:     if (field in obj) {\n107:       (result as any)[field] = (obj as any)[field];\n108:     }\n109:   }\n110:   return result;\n111: }\n112: \n113: /**\n114:  * Filter an array of objects to only include specified fields per object.\n115:  * If fields is undefined/empty, returns the array unchanged.\n116:  */\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\n118:   arr: T[],\n119:   fields?: string[]\n120: ): Partial<T>[] {\n121:   if (!fields || fields.length === 0) return arr;\n122:   return arr.map((obj) => filterFields(obj, fields));\n123: }\n124: \n125: /**\n126:  * Render a compact text table from an array of objects with selected fields.\n127:  * Used for text-mode --fields output.\n128:  */\n129: export function renderCompactTable(\n130:   items: Record<string, unknown>[],\n131:   fields: string[]\n132: ): void {\n133:   if (items.length === 0) return;\n134: \n135:   // Calculate column widths\n136:   const widths: Record<string, number> = {};\n137:   for (const field of fields) {\n138:     widths[field] = field.length;\n139:     for (const item of items) {\n140:       const val = String(item[field] ?? \"\");\n141:       widths[field] = Math.max(widths[field], val.length);\n142:     }\n143:   }\n144: \n145:   // Header\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n147:   console.log(header);\n148:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n149: \n150:   // Rows\n151:   for (const item of items) {\n152:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n153:     console.log(row);\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\";","truncated":false,"loaded":[]},"time":{"start":1773245113769,"end":1773245113772}}}}
{"type":"tool_use","timestamp":1773245114693,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda52629001o4qp6YjVOF3kk5","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda513b900126Jtphxg3AXvca","type":"tool","callID":"toolu_016Xj84EZHgd1LPBwn9fFmUH","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/check.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/check.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/check.ts — Validate the features file for schema issues, broken deps, and orphans.\n3:  *\n4:  * Usage:\n5:  *   wombo features check\n6:  *\n7:  * Checks:\n8:  *   - Required fields present on every feature\n9:  *   - No duplicate IDs\n10:  *   - All depends_on references point to existing features\n11:  *   - No circular dependencies\n12:  *   - No orphaned subtasks (subtask IDs unique)\n13:  *   - Priority/difficulty values are valid enums\n14:  *   - Effort strings are parseable ISO 8601 durations\n15:  */\n16: \n17: import type { WomboConfig } from \"../../config.js\";\n18: import {\n19:   loadFeatures,\n20:   allFeatureIds,\n21:   parseDurationMinutes,\n22:   type Feature,\n23:   type Subtask,\n24:   type FeaturesFile,\n25:   type Priority,\n26:   type Difficulty,\n27:   type FeatureStatus,\n28: } from \"../../lib/features.js\";\n29: \n30: // ---------------------------------------------------------------------------\n31: // Types\n32: // ---------------------------------------------------------------------------\n33: \n34: export interface FeaturesCheckOptions {\n35:   projectRoot: string;\n36:   config: WomboConfig;\n37: }\n38: \n39: interface CheckResult {\n40:   errors: string[];\n41:   warnings: string[];\n42: }\n43: \n44: // ---------------------------------------------------------------------------\n45: // Validation\n46: // ---------------------------------------------------------------------------\n47: \n48: const VALID_STATUSES: FeatureStatus[] = [\n49:   \"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\",\n50: ];\n51: \n52: const VALID_PRIORITIES: Priority[] = [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"];\n53: \n54: const VALID_DIFFICULTIES: Difficulty[] = [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"];\n55: \n56: function collectAllItems(data: FeaturesFile): (Feature | Subtask)[] {\n57:   const items: (Feature | Subtask)[] = [];\n58:   const collect = (list: (Feature | Subtask)[]) => {\n59:     for (const item of list) {\n60:       items.push(item);\n61:       if (item.subtasks?.length) collect(item.subtasks);\n62:     }\n63:   };\n64:   collect(data.features ?? []);\n65:   collect(data.archive ?? []);\n66:   return items;\n67: }\n68: \n69: function checkFeatures(data: FeaturesFile): CheckResult {\n70:   const errors: string[] = [];\n71:   const warnings: string[] = [];\n72:   const allItems = collectAllItems(data);\n73:   const allIds = allItems.map((i) => i.id);\n74:   const idSet = new Set<string>();\n75: \n76:   // Check for duplicates\n77:   for (const id of allIds) {\n78:     if (idSet.has(id)) {\n79:       errors.push(`Duplicate ID: \"${id}\"`);\n80:     }\n81:     idSet.add(id);\n82:   }\n83: \n84:   // Check each item\n85:   for (const item of allItems) {\n86:     const prefix = `[${item.id}]`;\n87: \n88:     // Required fields\n89:     if (!item.id) errors.push(`${prefix} Missing required field: id`);\n90:     if (!item.title) errors.push(`${prefix} Missing required field: title`);\n91:     if (!item.status) errors.push(`${prefix} Missing required field: status`);\n92: \n93:     // Validate enum values\n94:     if (item.status && !VALID_STATUSES.includes(item.status)) {\n95:       errors.push(`${prefix} Invalid status: \"${item.status}\"`);\n96:     }\n97:     if (item.priority && !VALID_PRIORITIES.includes(item.priority)) {\n98:       errors.push(`${prefix} Invalid priority: \"${item.priority}\"`);\n99:     }\n100:     if (item.difficulty && !VALID_DIFFICULTIES.includes(item.difficulty)) {\n101:       errors.push(`${prefix} Invalid difficulty: \"${item.difficulty}\"`);\n102:     }\n103: \n104:     // Validate effort\n105:     if (item.effort) {\n106:       const minutes = parseDurationMinutes(item.effort);\n107:       if (minutes === Infinity) {\n108:         warnings.push(`${prefix} Unparseable effort duration: \"${item.effort}\"`);\n109:       }\n110:     }\n111: \n112:     // Check depends_on references\n113:     if (item.depends_on?.length) {\n114:       for (const dep of item.depends_on) {\n115:         if (!idSet.has(dep)) {\n116:           errors.push(`${prefix} Broken dependency: \"${dep}\" does not exist`);\n117:         }\n118:       }\n119:     }\n120:   }\n121: \n122:   // Check for circular dependencies (simple DFS)\n123:   const visited = new Set<string>();\n124:   const visiting = new Set<string>();\n125:   const depMap = new Map<string, string[]>();\n126:   for (const item of allItems) {\n127:     depMap.set(item.id, item.depends_on ?? []);\n128:   }\n129: \n130:   function hasCycle(id: string): boolean {\n131:     if (visiting.has(id)) return true;\n132:     if (visited.has(id)) return false;\n133:     visiting.add(id);\n134:     for (const dep of depMap.get(id) ?? []) {\n135:       if (hasCycle(dep)) {\n136:         errors.push(`Circular dependency detected involving: \"${id}\" → \"${dep}\"`);\n137:         return true;\n138:       }\n139:     }\n140:     visiting.delete(id);\n141:     visited.add(id);\n142:     return false;\n143:   }\n144: \n145:   for (const id of idSet) {\n146:     hasCycle(id);\n147:   }\n148: \n149:   // Warn about features with no effort estimate\n150:   for (const item of allItems) {\n151:     if (!item.effort || item.effort === \"PT0S\") {\n152:       warnings.push(`[${item.id}] No effort estimate`);\n153:     }\n154:   }\n155: \n156:   return { errors, warnings };\n157: }\n158: \n159: // ---------------------------------------------------------------------------\n160: // Command\n161: // ---------------------------------------------------------------------------\n162: \n163: export async function cmdFeaturesCheck(opts: FeaturesCheckOptions): Promise<void> {\n164:   const { projectRoot, config } = opts;\n165: \n166:   const data = loadFeatures(projectRoot, config);\n167:   const result = checkFeatures(data);\n168: \n169:   const allItems = collectAllItems(data);\n170:   console.log(`\\nChecking ${config.featuresFile} (${allItems.length} items)...\\n`);\n171: \n172:   if (result.errors.length === 0 && result.warnings.length === 0) {\n173:     console.log(\"  All checks passed. No issues found.\");\n174:     return;\n175:   }\n176: \n177:   if (result.errors.length > 0) {\n178:     console.log(`  ERRORS (${result.errors.length}):`);\n179:     for (const e of result.errors) {\n180:       console.log(`    \\x1b[31m✗\\x1b[0m ${e}`);\n181:     }\n182:     console.log(\"\");\n183:   }\n184: \n185:   if (result.warnings.length > 0) {\n186:     console.log(`  WARNINGS (${result.warnings.length}):`);\n187:     for (const w of result.warnings) {\n188:       console.log(`    \\x1b[33m⚠\\x1b[0m ${w}`);\n189:     }\n190:     console.log(\"\");\n191:   }\n192: \n193:   if (result.errors.length > 0) {\n194:     process.exit(1);\n195:   }\n196: }\n\n(End of file - total 196 lines)\n</content>","title":"src/commands/features/check.ts","metadata":{"preview":"/**\n * features/check.ts — Validate the features file for schema issues, broken deps, and orphans.\n *\n * Usage:\n *   wombo features check\n *\n * Checks:\n *   - Required fields present on every feature\n *   - No duplicate IDs\n *   - All depends_on references point to existing features\n *   - No circular dependencies\n *   - No orphaned subtasks (subtask IDs unique)\n *   - Priority/difficulty values are valid enums\n *   - Effort strings are parseable ISO 8601 durations\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  allFeatureIds,","truncated":false,"loaded":[]},"time":{"start":1773245114685,"end":1773245114692}}}}
{"type":"tool_use","timestamp":1773245114963,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda52940001mI7hlMIeWkLgxo","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda513b900126Jtphxg3AXvca","type":"tool","callID":"toolu_01JmxGnFx1wzrK4kroouATyx","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/archive.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/archive.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/archive.ts — Move done/cancelled features to the archive section.\n3:  *\n4:  * Usage:\n5:  *   wombo features archive              # archive all done + cancelled\n6:  *   wombo features archive <feature-id> # archive a specific feature\n7:  *   wombo features archive --dry-run    # show what would be archived\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   findFeatureById,\n15:   type Feature,\n16: } from \"../../lib/features.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export interface FeaturesArchiveOptions {\n23:   projectRoot: string;\n24:   config: WomboConfig;\n25:   featureId?: string;\n26:   dryRun?: boolean;\n27: }\n28: \n29: // ---------------------------------------------------------------------------\n30: // Command\n31: // ---------------------------------------------------------------------------\n32: \n33: export async function cmdFeaturesArchive(opts: FeaturesArchiveOptions): Promise<void> {\n34:   const { projectRoot, config } = opts;\n35: \n36:   const data = loadFeatures(projectRoot, config);\n37: \n38:   // Ensure archive array exists\n39:   if (!data.archive) {\n40:     data.archive = [];\n41:   }\n42: \n43:   let toArchive: Feature[];\n44: \n45:   if (opts.featureId) {\n46:     // Archive a specific feature\n47:     const idx = data.features.findIndex((f) => f.id === opts.featureId);\n48:     if (idx === -1) {\n49:       // Check if already in archive\n50:       if (data.archive.find((f) => f.id === opts.featureId)) {\n51:         console.log(`Feature \"${opts.featureId}\" is already in the archive.`);\n52:         return;\n53:       }\n54:       console.error(`Feature \"${opts.featureId}\" not found.`);\n55:       process.exit(1);\n56:       return;\n57:     }\n58:     toArchive = [data.features[idx]];\n59:   } else {\n60:     // Archive all done + cancelled features\n61:     toArchive = data.features.filter(\n62:       (f) => f.status === \"done\" || f.status === \"cancelled\"\n63:     );\n64:   }\n65: \n66:   if (toArchive.length === 0) {\n67:     console.log(\"No features to archive.\");\n68:     return;\n69:   }\n70: \n71:   if (opts.dryRun) {\n72:     console.log(`\\nWould archive ${toArchive.length} feature(s):\\n`);\n73:     for (const f of toArchive) {\n74:       console.log(`  ${f.id} — ${f.title} (${f.status})`);\n75:     }\n76:     return;\n77:   }\n78: \n79:   // Move features from active to archive\n80:   const archiveIds = new Set(toArchive.map((f) => f.id));\n81:   data.features = data.features.filter((f) => !archiveIds.has(f.id));\n82:   data.archive.push(...toArchive);\n83: \n84:   saveFeatures(projectRoot, config, data);\n85: \n86:   console.log(`\\nArchived ${toArchive.length} feature(s):`);\n87:   for (const f of toArchive) {\n88:     console.log(`  ${f.id} — ${f.title} (${f.status})`);\n89:   }\n90: }\n\n(End of file - total 90 lines)\n</content>","title":"src/commands/features/archive.ts","metadata":{"preview":"/**\n * features/archive.ts — Move done/cancelled features to the archive section.\n *\n * Usage:\n *   wombo features archive              # archive all done + cancelled\n *   wombo features archive <feature-id> # archive a specific feature\n *   wombo features archive --dry-run    # show what would be archived\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Feature,\n} from \"../../lib/features.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773245114960,"end":1773245114963}}}}
{"type":"tool_use","timestamp":1773245115429,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda52a5100143FrpRD1go2zOt","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda513b900126Jtphxg3AXvca","type":"tool","callID":"toolu_013YNeEwGTXWMsvKTztbP9Nq","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/list.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/list.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/list.ts — List and filter features from the features file.\n3:  *\n4:  * Usage:\n5:  *   wombo features list                     # list all features\n6:  *   wombo features list --status backlog    # filter by status\n7:  *   wombo features list --priority high     # filter by priority\n8:  *   wombo features list --ready             # show only ready features\n9:  *   wombo features list --archive           # include archived features\n10:  */\n11: \n12: import type { WomboConfig } from \"../../config.js\";\n13: import {\n14:   loadFeatures,\n15:   getReadyFeatures,\n16:   featureSummary,\n17:   formatDuration,\n18:   parseDurationMinutes,\n19:   type Feature,\n20:   type FeatureStatus,\n21:   type Priority,\n22:   type Difficulty,\n23:   type FeaturesFile,\n24: } from \"../../lib/features.js\";\n25: import { output, filterFieldsArray, renderCompactTable, type OutputFormat } from \"../../lib/output.js\";\n26: \n27: // ---------------------------------------------------------------------------\n28: // Types\n29: // ---------------------------------------------------------------------------\n30: \n31: export interface FeaturesListOptions {\n32:   projectRoot: string;\n33:   config: WomboConfig;\n34:   status?: FeatureStatus;\n35:   priority?: Priority;\n36:   difficulty?: Difficulty;\n37:   ready?: boolean;\n38:   includeArchive?: boolean;\n39:   outputFmt?: OutputFormat;\n40:   fields?: string[];\n41: }\n42: \n43: // ---------------------------------------------------------------------------\n44: // ANSI Helpers\n45: // ---------------------------------------------------------------------------\n46: \n47: const RESET = \"\\x1b[0m\";\n48: const BOLD = \"\\x1b[1m\";\n49: const DIM = \"\\x1b[2m\";\n50: \n51: const STATUS_COLOR: Record<FeatureStatus, string> = {\n52:   backlog: \"\\x1b[37m\",     // white\n53:   planned: \"\\x1b[36m\",     // cyan\n54:   in_progress: \"\\x1b[34m\", // blue\n55:   blocked: \"\\x1b[31m\",     // red\n56:   in_review: \"\\x1b[33m\",   // yellow\n57:   done: \"\\x1b[32m\",        // green\n58:   cancelled: \"\\x1b[90m\",   // gray\n59: };\n60: \n61: // ---------------------------------------------------------------------------\n62: // Command\n63: // ---------------------------------------------------------------------------\n64: \n65: export async function cmdFeaturesList(opts: FeaturesListOptions): Promise<void> {\n66:   const { projectRoot, config } = opts;\n67:   const data = loadFeatures(projectRoot, config);\n68: \n69:   let features: Feature[] = [...data.features];\n70: \n71:   // Include archive if requested\n72:   if (opts.includeArchive && data.archive?.length) {\n73:     features = [...features, ...data.archive];\n74:   }\n75: \n76:   // Filter by status\n77:   if (opts.status) {\n78:     features = features.filter((f) => f.status === opts.status);\n79:   }\n80: \n81:   // Filter by priority\n82:   if (opts.priority) {\n83:     features = features.filter((f) => f.priority === opts.priority);\n84:   }\n85: \n86:   // Filter by difficulty\n87:   if (opts.difficulty) {\n88:     features = features.filter((f) => f.difficulty === opts.difficulty);\n89:   }\n90: \n91:   // Filter to ready-only\n92:   if (opts.ready) {\n93:     const readyFeatures = getReadyFeatures(data);\n94:     const readyIds = new Set(readyFeatures.map((f) => f.id));\n95:     features = features.filter((f) => readyIds.has(f.id));\n96:   }\n97: \n98:   if (features.length === 0) {\n99:     output(opts.outputFmt ?? \"text\", { features: [], total: 0, effort: \"0m\" }, () => {\n100:       console.log(\"No features match the given filters.\");\n101:     });\n102:     return;\n103:   }\n104: \n105:   // Group by status for display\n106:   const byStatus = new Map<FeatureStatus, Feature[]>();\n107:   for (const f of features) {\n108:     const list = byStatus.get(f.status) ?? [];\n109:     list.push(f);\n110:     byStatus.set(f.status, list);\n111:   }\n112: \n113:   // Display\n114:   const totalEffort = features.reduce(\n115:     (sum, f) => sum + parseDurationMinutes(f.effort),\n116:     0\n117:   );\n118: \n119:   const fmt = opts.outputFmt ?? \"text\";\n120: \n121:   // Build the structured data for each feature\n122:   const featureData = features.map((f) => ({\n123:     id: f.id,\n124:     title: f.title,\n125:     status: f.status,\n126:     priority: f.priority,\n127:     difficulty: f.difficulty,\n128:     effort: f.effort,\n129:     completion: f.completion,\n130:     depends_on: f.depends_on,\n131:   }));\n132: \n133:   // If --fields is specified, use compact output mode\n134:   if (opts.fields?.length) {\n135:     const filtered = filterFieldsArray(featureData, opts.fields);\n136:     output(\n137:       fmt,\n138:       { features: filtered, total: features.length, effort: formatDuration(totalEffort) },\n139:       () => {\n140:         renderCompactTable(\n141:           featureData as Record<string, unknown>[],\n142:           opts.fields!\n143:         );\n144:       }\n145:     );\n146:     return;\n147:   }\n148: \n149:   output(\n150:     fmt,\n151:     {\n152:       features: featureData,\n153:       total: features.length,\n154:       effort: formatDuration(totalEffort),\n155:     },\n156:     () => {\n157:       console.log(`\\n${BOLD}Features (${features.length} total, ~${formatDuration(totalEffort)} effort)${RESET}\\n`);\n158: \n159:       const statusOrder: FeatureStatus[] = [\n160:         \"in_progress\",\n161:         \"planned\",\n162:         \"backlog\",\n163:         \"blocked\",\n164:         \"in_review\",\n165:         \"done\",\n166:         \"cancelled\",\n167:       ];\n168: \n169:       for (const status of statusOrder) {\n170:         const group = byStatus.get(status);\n171:         if (!group?.length) continue;\n172: \n173:         const color = STATUS_COLOR[status] ?? \"\";\n174:         console.log(`  ${color}${BOLD}${status.toUpperCase()}${RESET} (${group.length})`);\n175: \n176:         for (const f of group) {\n177:           const effort = formatDuration(parseDurationMinutes(f.effort));\n178:           const deps = f.depends_on.length > 0 ? ` ${DIM}deps: ${f.depends_on.join(\", \")}${RESET}` : \"\";\n179:           const completion = f.completion > 0 ? ` ${DIM}${f.completion}%${RESET}` : \"\";\n180:           console.log(\n181:             `    ${color}${f.id}${RESET} — ${f.title} [${f.priority}/${f.difficulty}] (${effort})${completion}${deps}`\n182:           );\n183:         }\n184:         console.log(\"\");\n185:       }\n186:     }\n187:   );\n188: }\n\n(End of file - total 188 lines)\n</content>","title":"src/commands/features/list.ts","metadata":{"preview":"/**\n * features/list.ts — List and filter features from the features file.\n *\n * Usage:\n *   wombo features list                     # list all features\n *   wombo features list --status backlog    # filter by status\n *   wombo features list --priority high     # filter by priority\n *   wombo features list --ready             # show only ready features\n *   wombo features list --archive           # include archived features\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  getReadyFeatures,\n  featureSummary,\n  formatDuration,\n  parseDurationMinutes,\n  type Feature,\n  type FeatureStatus,","truncated":false,"loaded":[]},"time":{"start":1773245115425,"end":1773245115428}}}}
{"type":"tool_use","timestamp":1773245115989,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda52c22001BgrzsFXf58ylzv","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda513b900126Jtphxg3AXvca","type":"tool","callID":"toolu_01JNHzWjfCETgKXGnZVPD358","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/show.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/show.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/show.ts — Show detailed information about a specific feature.\n3:  *\n4:  * Usage:\n5:  *   wombo features show <feature-id>\n6:  */\n7: \n8: import type { WomboConfig } from \"../../config.js\";\n9: import {\n10:   loadFeatures,\n11:   findFeatureById,\n12:   formatDuration,\n13:   parseDurationMinutes,\n14:   areDependenciesMet,\n15:   getDoneFeatureIds,\n16:   type Feature,\n17:   type Subtask,\n18: } from \"../../lib/features.js\";\n19: import { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface FeaturesShowOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   featureId: string;\n29:   outputFmt?: OutputFormat;\n30:   fields?: string[];\n31: }\n32: \n33: // ---------------------------------------------------------------------------\n34: // ANSI Helpers\n35: // ---------------------------------------------------------------------------\n36: \n37: const RESET = \"\\x1b[0m\";\n38: const BOLD = \"\\x1b[1m\";\n39: const DIM = \"\\x1b[2m\";\n40: const GREEN = \"\\x1b[32m\";\n41: const RED = \"\\x1b[31m\";\n42: const YELLOW = \"\\x1b[33m\";\n43: const CYAN = \"\\x1b[36m\";\n44: \n45: // ---------------------------------------------------------------------------\n46: // Display Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function statusColor(status: string): string {\n50:   switch (status) {\n51:     case \"done\": return GREEN;\n52:     case \"in_progress\": return CYAN;\n53:     case \"blocked\":\n54:     case \"failed\": return RED;\n55:     case \"cancelled\": return DIM;\n56:     default: return \"\";\n57:   }\n58: }\n59: \n60: function renderSubtask(st: Subtask, indent: number): void {\n61:   const pad = \"  \".repeat(indent);\n62:   const color = statusColor(st.status);\n63:   const effort = formatDuration(parseDurationMinutes(st.effort));\n64:   const completionStr = st.completion > 0 ? ` (${st.completion}%)` : \"\";\n65:   console.log(\n66:     `${pad}${color}[${st.status}]${RESET} ${st.id} — ${st.title} [${st.priority}/${st.difficulty}] (${effort})${completionStr}`\n67:   );\n68:   if (st.subtasks?.length) {\n69:     for (const sub of st.subtasks) {\n70:       renderSubtask(sub, indent + 1);\n71:     }\n72:   }\n73: }\n74: \n75: // ---------------------------------------------------------------------------\n76: // Command\n77: // ---------------------------------------------------------------------------\n78: \n79: export async function cmdFeaturesShow(opts: FeaturesShowOptions): Promise<void> {\n80:   const { projectRoot, config } = opts;\n81:   const fmt = opts.outputFmt ?? \"text\";\n82: \n83:   if (!opts.featureId) {\n84:     outputError(fmt, \"Usage: wombo features show <feature-id>\");\n85:     return;\n86:   }\n87: \n88:   const data = loadFeatures(projectRoot, config);\n89:   const feature = findFeatureById(data, opts.featureId);\n90: \n91:   if (!feature) {\n92:     outputError(fmt, `Feature \"${opts.featureId}\" not found.`);\n93:     return;\n94:   }\n95: \n96:   const doneIds = getDoneFeatureIds(data);\n97:   const depsMet = areDependenciesMet(feature, doneIds);\n98:   const effort = formatDuration(parseDurationMinutes(feature.effort));\n99: \n100:   const fullData = {\n101:     ...feature,\n102:     deps_met: depsMet,\n103:     effort_formatted: effort,\n104:   };\n105: \n106:   // If --fields is specified, emit only those fields\n107:   if (opts.fields?.length) {\n108:     const filtered = filterFields(fullData as Record<string, unknown>, opts.fields);\n109:     output(fmt, filtered, () => {\n110:       for (const [key, val] of Object.entries(filtered)) {\n111:         const display = Array.isArray(val) ? val.join(\", \") : String(val ?? \"\");\n112:         console.log(`${key}: ${display}`);\n113:       }\n114:     });\n115:     return;\n116:   }\n117: \n118:   output(\n119:     fmt,\n120:     fullData,\n121:     () => {\n122:       console.log(`\\n${BOLD}Feature: ${feature.title}${RESET}`);\n123:       console.log(`  ID:          ${feature.id}`);\n124:       console.log(`  Status:      ${statusColor(feature.status)}${feature.status}${RESET}`);\n125:       console.log(`  Priority:    ${feature.priority}`);\n126:       console.log(`  Difficulty:  ${feature.difficulty}`);\n127:       console.log(`  Effort:      ${effort}`);\n128:       console.log(`  Completion:  ${feature.completion}%`);\n129:       console.log(`  Deps met:    ${depsMet ? `${GREEN}yes${RESET}` : `${RED}no${RESET}`}`);\n130: \n131:       if (feature.started_at) {\n132:         console.log(`  Started:     ${feature.started_at}`);\n133:       }\n134:       if (feature.ended_at) {\n135:         console.log(`  Ended:       ${feature.ended_at}`);\n136:       }\n137: \n138:       if (feature.description) {\n139:         console.log(`\\n  ${BOLD}Description:${RESET}`);\n140:         for (const line of feature.description.split(\"\\n\")) {\n141:           console.log(`    ${line}`);\n142:         }\n143:       }\n144: \n145:       if (feature.depends_on.length > 0) {\n146:         console.log(`\\n  ${BOLD}Dependencies:${RESET}`);\n147:         for (const dep of feature.depends_on) {\n148:           const met = doneIds.has(dep);\n149:           const icon = met ? `${GREEN}✓${RESET}` : `${RED}✗${RESET}`;\n150:           console.log(`    ${icon} ${dep}`);\n151:         }\n152:       }\n153: \n154:       if (feature.constraints.length > 0) {\n155:         console.log(`\\n  ${BOLD}Constraints:${RESET}`);\n156:         for (const c of feature.constraints) {\n157:           console.log(`    - ${c}`);\n158:         }\n159:       }\n160: \n161:       if (feature.forbidden.length > 0) {\n162:         console.log(`\\n  ${BOLD}Forbidden:${RESET}`);\n163:         for (const f of feature.forbidden) {\n164:           console.log(`    - ${RED}${f}${RESET}`);\n165:         }\n166:       }\n167: \n168:       if (feature.references.length > 0) {\n169:         console.log(`\\n  ${BOLD}References:${RESET}`);\n170:         for (const r of feature.references) {\n171:           console.log(`    - ${DIM}${r}${RESET}`);\n172:         }\n173:       }\n174: \n175:       if (feature.notes.length > 0) {\n176:         console.log(`\\n  ${BOLD}Notes:${RESET}`);\n177:         for (const n of feature.notes) {\n178:           console.log(`    - ${n}`);\n179:         }\n180:       }\n181: \n182:       if (feature.subtasks.length > 0) {\n183:         console.log(`\\n  ${BOLD}Subtasks (${feature.subtasks.length}):${RESET}`);\n184:         for (const st of feature.subtasks) {\n185:           renderSubtask(st, 2);\n186:         }\n187:       }\n188: \n189:       console.log(\"\");\n190:     }\n191:   );\n192: }\n\n(End of file - total 192 lines)\n</content>","title":"src/commands/features/show.ts","metadata":{"preview":"/**\n * features/show.ts — Show detailed information about a specific feature.\n *\n * Usage:\n *   wombo features show <feature-id>\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  findFeatureById,\n  formatDuration,\n  parseDurationMinutes,\n  areDependenciesMet,\n  getDoneFeatureIds,\n  type Feature,\n  type Subtask,\n} from \"../../lib/features.js\";\nimport { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773245115985,"end":1773245115988}}}}
