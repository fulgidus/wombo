9:     return;\n40:   }\n41: \n42:   const toVerify = opts.featureId\n43:     ? state.agents.filter((a) => a.feature_id === opts.featureId)\n44:     : state.agents.filter((a) => a.status === \"completed\");\n45: \n46:   if (toVerify.length === 0) {\n47:     console.log(\"No agents to verify.\");\n48:     return;\n49:   }\n50: \n51:   console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n52: \n53:   const data = loadFeatures(projectRoot, config);\n54: \n55:   for (const agent of toVerify) {\n56:     const feature = data.features.find((f) => f.id === agent.feature_id);\n57:     if (!feature) continue;\n58: \n59:     await handleBuildVerification(projectRoot, state, agent, feature, config, opts.model);\n60:   }\n61: \n62:   printDashboard(state);\n63: }\n\n(End of file - total 63 lines)\n</content>","title":"src/commands/verify.ts","metadata":{"preview":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: wombo verify [feature-id]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures } from \"../lib/features.js\";\nimport { loadState, saveState } from \"../lib/state.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { handleBuildVerification } from \"./launch.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n","truncated":false,"loaded":[]},"time":{"start":1773245122572,"end":1773245122576}}}}
{"type":"tool_use","timestamp":1773245122780,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda5480d0017S4slCYW1cXGbC","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda5308b001MvpmkDdfkFW5X4","type":"tool","callID":"toolu_01MGvTo9VSagu8W7mpHvAD3u","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/merge.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/merge.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * merge.ts — Merge verified branches into the base branch.\n3:  *\n4:  * Usage: wombo merge [feature-id]\n5:  *\n6:  * Merges all verified agents (or a specific one) into the base branch.\n7:  * After merging, cleans up the worktree as best-effort.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import {\n12:   loadState,\n13:   saveState,\n14:   updateAgent,\n15: } from \"../lib/state.js\";\n16: import { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\n17: import { removeWorktree } from \"../lib/worktree.js\";\n18: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n19: \n20: // ---------------------------------------------------------------------------\n21: // Types\n22: // ---------------------------------------------------------------------------\n23: \n24: export interface MergeCommandOptions {\n25:   projectRoot: string;\n26:   config: WomboConfig;\n27:   featureId?: string;\n28:   autoPush?: boolean;\n29:   dryRun?: boolean;\n30: }\n31: \n32: // ---------------------------------------------------------------------------\n33: // Command\n34: // ---------------------------------------------------------------------------\n35: \n36: export async function cmdMerge(opts: MergeCommandOptions): Promise<void> {\n37:   const { projectRoot, config } = opts;\n38: \n39:   const state = loadState(projectRoot);\n40:   if (!state) {\n41:     console.log(\"No active wave.\");\n42:     return;\n43:   }\n44: \n45:   const toMerge = opts.featureId\n46:     ? state.agents.filter(\n47:         (a) => a.feature_id === opts.featureId && a.status === \"verified\"\n48:       )\n49:     : state.agents.filter((a) => a.status === \"verified\");\n50: \n51:   if (toMerge.length === 0) {\n52:     console.log(\"No verified agents to merge.\");\n53:     return;\n54:   }\n55: \n56:   // Dry-run: show what would be merged without merging\n57:   if (opts.dryRun) {\n58:     console.log(`\\n[dry-run] Would merge ${toMerge.length} branch(es):\\n`);\n59:     for (const agent of toMerge) {\n60:       console.log(`  ${agent.feature_id} — branch: ${agent.branch}`);\n61:     }\n62:     if (opts.autoPush) {\n63:       console.log(`\\n  Would push ${state.base_branch} to remote after merge.`);\n64:     }\n65:     return;\n66:   }\n67: \n68:   console.log(`\\nMerging ${toMerge.length} branch(es)...\\n`);\n69: \n70:   for (const agent of toMerge) {\n71:     printAgentUpdate(agent, \"merging...\");\n72:     const result = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n73: \n74:     if (result.success) {\n75:       updateAgent(state, agent.feature_id, {\n76:         status: \"merged\",\n77:       });\n78:       saveState(projectRoot, state);\n79:       printAgentUpdate(agent, `MERGED (${result.commitHash?.slice(0, 7)})`);\n80: \n81:       // Clean up worktree\n82:       try {\n83:         removeWorktree(projectRoot, agent.worktree, false);\n84:         printAgentUpdate(agent, \"worktree removed\");\n85:       } catch {\n86:         // Not critical\n87:       }\n88:     } else {\n89:       printAgentUpdate(agent, `MERGE FAILED: ${result.error}`);\n90:     }\n91:   }\n92: \n93:   // Auto-push if requested\n94:   if (opts.autoPush) {\n95:     const anyMerged = state.agents.some((a) => a.status === \"merged\");\n96:     if (anyMerged) {\n97:       await pushBaseBranch(projectRoot, state.base_branch, config);\n98:     }\n99:   }\n100: \n101:   printDashboard(state);\n102: }\n\n(End of file - total 102 lines)\n</content>","title":"src/commands/merge.ts","metadata":{"preview":"/**\n * merge.ts — Merge verified branches into the base branch.\n *\n * Usage: wombo merge [feature-id]\n *\n * Merges all verified agents (or a specific one) into the base branch.\n * After merging, cleans up the worktree as best-effort.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\nimport { removeWorktree } from \"../lib/worktree.js\";\nimport { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773245122777,"end":1773245122780}}}}
{"type":"tool_use","timestamp":1773245123508,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cdda548da0017a9Lbkl1MTtL5a","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cdda5308b001MvpmkDdfkFW5X4","type":"tool","callID":"toolu_01JYJXV2WF6fTPbbJ74k7NRk","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: wombo resume [options]\n5:  *\n6:  * Restores from .wombo-state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/features.js\";\n14: import { loadFeatures } from \"../lib/features.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   isWaveComplete,\n21:   type WaveState,\n22:   type AgentState,\n23: } from \"../lib/state.js\";\n24: import {\n25:   createWorktree,\n26:   installDeps,\n27:   worktreeReady,\n28:   log as wtLog,\n29: } from \"../lib/worktree.js\";\n30: import { generatePrompt } from \"../lib/prompt.js\";\n31: import {\n32:   launchInteractive,\n33:   isProcessRunning,\n34: } from \"../lib/launcher.js\";\n35: import { ProcessMonitor } from \"../lib/monitor.js\";\n36: import { pushBaseBranch } from \"../lib/merger.js\";\n37: import { printDashboard } from \"../lib/ui.js\";\n38: import { WomboTUI } from \"../lib/tui.js\";\n39: import {\n40:   launchSingleHeadless,\n41:   handleBuildVerification,\n42:   handleRetry,\n43:   launchNextQueued,\n44: } from \"./launch.js\";\n45: \n46: // ---------------------------------------------------------------------------\n47: // Types\n48: // ---------------------------------------------------------------------------\n49: \n50: export interface ResumeCommandOptions {\n51:   projectRoot: string;\n52:   config: WomboConfig;\n53:   maxConcurrent?: number;\n54:   model?: string;\n55:   interactive: boolean;\n56:   noTui: boolean;\n57:   autoPush: boolean;\n58:   baseBranch?: string;\n59:   maxRetries?: number;\n60: }\n61: \n62: // ---------------------------------------------------------------------------\n63: // Command\n64: // ---------------------------------------------------------------------------\n65: \n66: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n67:   const { projectRoot, config } = opts;\n68: \n69:   const state = loadState(projectRoot);\n70:   if (!state) {\n71:     console.error(\"No wave state found. Use 'wombo launch' to start a new wave.\");\n72:     process.exit(1);\n73:     return; // unreachable — helps TypeScript narrow\n74:   }\n75: \n76:   console.log(`\\n--- Wombo: Resume ${state.wave_id} ---\\n`);\n77: \n78:   // Load feature data for prompt generation\n79:   const data = loadFeatures(projectRoot, config);\n80:   const featureMap = new Map(data.features.map((f) => [f.id, f]));\n81: \n82:   // Triage agents by current state\n83:   let toRelaunch: AgentState[] = [];\n84:   let toVerify: AgentState[] = [];\n85: \n86:   for (const agent of state.agents) {\n87:     switch (agent.status) {\n88:       case \"running\":\n89:       case \"installing\":\n90:       case \"retry\":\n91:         // Was in-flight when we stopped — check if PID is still alive\n92:         if (agent.pid && isProcessRunning(agent.pid)) {\n93:           console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n94:         } else {\n95:           // Process is dead — check if worktree has meaningful changes\n96:           if (worktreeReady(agent.worktree)) {\n97:             // Worktree exists, try build verification first\n98:             console.log(`  ${agent.feature_id}: process dead, worktree exists — will verify build`);\n99:             toVerify.push(agent);\n100:           } else {\n101:             // Worktree gone or incomplete — re-launch from scratch\n102:             console.log(`  ${agent.feature_id}: process dead, no worktree — will re-launch`);\n103:             updateAgent(state, agent.feature_id, {\n104:               status: \"queued\",\n105:               pid: null,\n106:               activity: null,\n107:               session_id: null,\n108:             });\n109:             toRelaunch.push(agent);\n110:           }\n111:         }\n112:         break;\n113: \n114:       case \"queued\":\n115:         console.log(`  ${agent.feature_id}: queued — will launch`);\n116:         toRelaunch.push(agent);\n117:         break;\n118: \n119:       case \"completed\":\n120:         // Completed but not verified — verify\n121:         console.log(`  ${agent.feature_id}: completed — will verify build`);\n122:         toVerify.push(agent);\n123:         break;\n124: \n125:       case \"verified\":\n126:       case \"merged\":\n127:         console.log(`  ${agent.feature_id}: ${agent.status} — nothing to do`);\n128:         break;\n129: \n130:       case \"failed\":\n131:         console.log(`  ${agent.feature_id}: failed — skipping (use 'wombo retry' to re-run)`);\n132:         break;\n133:     }\n134:   }\n135: \n136:   saveState(projectRoot, state);\n137: \n138:   // Run build verification on agents that were mid-flight\n139:   for (const agent of toVerify) {\n140:     const feature = featureMap.get(agent.feature_id);\n141:     if (!feature) continue;\n142:     console.log(`\\n  Verifying ${agent.feature_id}...`);\n143:     try {\n144:       await handleBuildVerification(projectRoot, state, agent, feature, config, opts.model);\n145:     } catch (err: any) {\n146:       console.log(`  Verify error for ${agent.feature_id}: ${err.message}`);\n147:     }\n148: \n149:     // If build failed and retries remain, queue for re-launch\n150:     if (agent.status === \"retry\" || agent.status === \"running\") {\n151:       toRelaunch.push(agent);\n152:     }\n153:   }\n154: \n155:   // Re-launch agents\n156:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n157:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n158:   if (toLaunchNow.length === 0) {\n159:     console.log(\"\\nNo agents need (re)launching.\");\n160:     printDashboard(state);\n161:     return;\n162:   }\n163: \n164:   console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n165:   printDashboard(state);\n166: \n167:   const model = opts.model ?? state.model ?? undefined;\n168: \n169:   if (opts.interactive) {\n170:     // Interactive resume\n171:     await Promise.all(\n172:       toLaunchNow.map(async (agent) => {\n173:         const feature = featureMap.get(agent.feature_id);\n174:         if (!feature) return;\n175: \n176:         updateAgent(state, agent.feature_id, {\n177:           status: \"installing\",\n178:           started_at: new Date().toISOString(),\n179:           activity: \"resuming...\",\n180:         });\n181:         saveState(projectRoot, state);\n182: \n183:         try {\n184:           if (!worktreeReady(agent.worktree)) {\n185:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n186:             await installDeps(agent.worktree, agent.feature_id, config);\n187:           }\n188: \n189:           const prompt = generatePrompt(feature, state.base_branch, config);\n190:           const result = launchInteractive({\n191:             worktreePath: agent.worktree,\n192:             featureId: feature.id,\n193:             prompt,\n194:             model,\n195:             interactive: true,\n196:             config,\n197:           });\n198: \n199:           updateAgent(state, agent.feature_id, {\n200:             status: \"running\",\n201:             pid: result.pid,\n202:             activity: \"tmux session active\",\n203:           });\n204:           saveState(projectRoot, state);\n205:         } catch (err: any) {\n206:           updateAgent(state, agent.feature_id, {\n207:             status: \"failed\",\n208:             error: err.message,\n209:             activity: null,\n210:             completed_at: new Date().toISOString(),\n211:           });\n212:           saveState(projectRoot, state);\n213:         }\n214:       })\n215:     );\n216: \n217:     printDashboard(state);\n218:     console.log(`\\nResume complete. Use 'tmux attach -t ${config.agent.tmuxPrefix}-<id>' to check sessions.`);\n219:   } else {\n220:     // Headless resume — re-enter monitoring loop\n221:     const monitor = new ProcessMonitor(projectRoot, {\n222:       onSessionId: (featureId, sessionId) => {\n223:         updateAgent(state, featureId, { session_id: sessionId });\n224:         saveState(projectRoot, state);\n225:       },\n226:       onComplete: (featureId) => {\n227:         updateAgent(state, featureId, {\n228:           status: \"completed\",\n229:           completed_at: new Date().toISOString(),\n230:           activity: \"done\",\n231:         });\n232:         saveState(projectRoot, state);\n233:         wtLog(featureId, \"agent completed — verifying build...\");\n234: \n235:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n236:         const feature = featureMap.get(featureId)!;\n237:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n238:           .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n239:           .catch((err) => {\n240:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n241:             launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n242:           });\n243:       },\n244:       onError: (featureId, error) => {\n245:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n246:         if (agent.retries < agent.max_retries) {\n247:           updateAgent(state, featureId, {\n248:             status: \"retry\",\n249:             retries: agent.retries + 1,\n250:             error,\n251:             activity: \"retrying...\",\n252:           });\n253:           saveState(projectRoot, state);\n254:           handleRetry(projectRoot, state, agent, monitor, config, model);\n255:         } else {\n256:           updateAgent(state, featureId, {\n257:             status: \"failed\",\n258:             error,\n259:             activity: null,\n260:             completed_at: new Date().toISOString(),\n261:           });\n262:           saveState(projectRoot, state);\n263:         }\n264:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n265:       },\n266:       onActivity: (featureId, activity) => {\n267:         updateAgent(state, featureId, {\n268:           activity,\n269:           activity_updated_at: new Date().toISOString(),\n270:         });\n271:       },\n272:     });\n273: \n274:     // Handle graceful shutdown\n275:     const tuiRef = { current: null as WomboTUI | null };\n276:     process.on(\"SIGINT\", () => {\n277:       if (tuiRef.current) tuiRef.current.stop();\n278:       for (const agent of state.agents) {\n279:         if (agent.status === \"running\") {\n280:           updateAgent(state, agent.feature_id, {\n281:             activity: \"interrupted\",\n282:           });\n283:         }\n284:       }\n285:       monitor.killAll();\n286:       saveState(projectRoot, state);\n287:       console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n288:       process.exit(0);\n289:     });\n290: \n291:     await Promise.all(\n292:       toLaunchNow.map((agent) => {\n293:         const feature = featureMap.get(agent.feature_id);\n294:         if (!feature) return Promise.resolve();\n295:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n296:       })\n297:     );\n298: \n299:     // Start TUI dashboard (or skip if --no-tui)\n300:     if (!opts.noTui) {\n301:       tuiRef.current = new WomboTUI({\n302:         state,\n303:         monitor,\n304:         projectRoot,\n305:         interactive: false,\n306:         config,\n307:         onQuit: () => {\n308:           for (const agent of state.agents) {\n309:             if (agent.status === \"running\") {\n310:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n311:             }\n312:           }\n313:           monitor.killAll();\n314:           saveState(projectRoot, state);\n315:           console.log(\"State saved. Use 'wombo resume' to continue.\");\n316:           process.exit(0);\n317:         },\n318:       });\n319:       tuiRef.current.start();\n320:     } else {\n321:       console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n322:       printDashboard(state);\n323:     }\n324: \n325:     // Monitoring loop\n326:     const POLL_INTERVAL = 5000;\n327:     let dashboardCounter = 0;\n328:     while (!isWaveComplete(state)) {\n329:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n330: \n331:       for (const agent of state.agents) {\n332:         if (\n333:           agent.status === \"running\" &&\n334:           agent.pid &&\n335:           !isProcessRunning(agent.pid) &&\n336:           !monitor.isRunning(agent.feature_id)\n337:         ) {\n338:           updateAgent(state, agent.feature_id, {\n339:             status: \"completed\",\n340:             completed_at: new Date().toISOString(),\n341:             activity: \"done\",\n342:           });\n343:           saveState(projectRoot, state);\n344:           const feature = featureMap.get(agent.feature_id)!;\n345:           try {\n346:             await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n347:           } catch (err: any) {\n348:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n349:           }\n350:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n351:         }\n352:       }\n353: \n354:       saveState(projectRoot, state);\n355:       if (tuiRef.current) {\n356:         tuiRef.current.updateState(state);\n357:       } else if (opts.noTui) {\n358:         dashboardCounter++;\n359:         if (dashboardCounter % 3 === 0) {\n360:           printDashboard(state);\n361:         }\n362:       }\n363:     }\n364: \n365:     if (tuiRef.current) tuiRef.current.stop();\n366:     printDashboard(state);\n367: \n368:     // Auto-push base branch if requested\n369:     if (opts.autoPush) {\n370:       await pushBaseBranch(projectRoot, state.base_branch, config);\n371:     }\n372: \n373:     console.log(\"Wave complete.\");\n374:   }\n375: }\n\n(End of file - total 375 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: wombo resume [options]\n *\n * Restores from .wombo-state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/features.js\";\nimport { loadFeatures } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  isWaveComplete,","truncated":false,"loaded":[]},"time":{"start":1773245123498,"end":1773245123506}}}}
