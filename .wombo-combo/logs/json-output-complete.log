{"type":"tool_use","timestamp":1773246668435,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcdd6c001d4ULxy2d6N4NLr","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcc5a1001opGNcEmXhUlgxR","type":"tool","callID":"toolu_01BVfKmwnz2BTosM4EFmMcr9","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/show.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/features/show.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/show.ts — Show detailed information about a specific feature.\n3:  *\n4:  * Usage:\n5:  *   wombo features show <feature-id>\n6:  */\n7: \n8: import type { WomboConfig } from \"../../config.js\";\n9: import {\n10:   loadFeatures,\n11:   findFeatureById,\n12:   formatDuration,\n13:   parseDurationMinutes,\n14:   areDependenciesMet,\n15:   getDoneFeatureIds,\n16:   type Feature,\n17:   type Subtask,\n18: } from \"../../lib/features.js\";\n19: import { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface FeaturesShowOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   featureId: string;\n29:   outputFmt?: OutputFormat;\n30:   fields?: string[];\n31: }\n32: \n33: // ---------------------------------------------------------------------------\n34: // ANSI Helpers\n35: // ---------------------------------------------------------------------------\n36: \n37: const RESET = \"\\x1b[0m\";\n38: const BOLD = \"\\x1b[1m\";\n39: const DIM = \"\\x1b[2m\";\n40: const GREEN = \"\\x1b[32m\";\n41: const RED = \"\\x1b[31m\";\n42: const YELLOW = \"\\x1b[33m\";\n43: const CYAN = \"\\x1b[36m\";\n44: \n45: // ---------------------------------------------------------------------------\n46: // Display Helpers\n47: // ---------------------------------------------------------------------------\n48: \n49: function statusColor(status: string): string {\n50:   switch (status) {\n51:     case \"done\": return GREEN;\n52:     case \"in_progress\": return CYAN;\n53:     case \"blocked\":\n54:     case \"failed\": return RED;\n55:     case \"cancelled\": return DIM;\n56:     default: return \"\";\n57:   }\n58: }\n59: \n60: function renderSubtask(st: Subtask, indent: number): void {\n61:   const pad = \"  \".repeat(indent);\n62:   const color = statusColor(st.status);\n63:   const effort = formatDuration(parseDurationMinutes(st.effort));\n64:   const completionStr = st.completion > 0 ? ` (${st.completion}%)` : \"\";\n65:   console.log(\n66:     `${pad}${color}[${st.status}]${RESET} ${st.id} — ${st.title} [${st.priority}/${st.difficulty}] (${effort})${completionStr}`\n67:   );\n68:   if (st.subtasks?.length) {\n69:     for (const sub of st.subtasks) {\n70:       renderSubtask(sub, indent + 1);\n71:     }\n72:   }\n73: }\n74: \n75: // ---------------------------------------------------------------------------\n76: // Command\n77: // ---------------------------------------------------------------------------\n78: \n79: export async function cmdFeaturesShow(opts: FeaturesShowOptions): Promise<void> {\n80:   const { projectRoot, config } = opts;\n81:   const fmt = opts.outputFmt ?? \"text\";\n82: \n83:   if (!opts.featureId) {\n84:     outputError(fmt, \"Usage: wombo features show <feature-id>\");\n85:     return;\n86:   }\n87: \n88:   const data = loadFeatures(projectRoot, config);\n89:   const feature = findFeatureById(data, opts.featureId);\n90: \n91:   if (!feature) {\n92:     outputError(fmt, `Feature \"${opts.featureId}\" not found.`);\n93:     return;\n94:   }\n95: \n96:   const doneIds = getDoneFeatureIds(data);\n97:   const depsMet = areDependenciesMet(feature, doneIds);\n98:   const effort = formatDuration(parseDurationMinutes(feature.effort));\n99: \n100:   const fullData = {\n101:     ...feature,\n102:     deps_met: depsMet,\n103:     effort_formatted: effort,\n104:   };\n105: \n106:   // If --fields is specified, emit only those fields\n107:   if (opts.fields?.length) {\n108:     const filtered = filterFields(fullData as Record<string, unknown>, opts.fields);\n109:     output(fmt, filtered, () => {\n110:       for (const [key, val] of Object.entries(filtered)) {\n111:         const display = Array.isArray(val) ? val.join(\", \") : String(val ?? \"\");\n112:         console.log(`${key}: ${display}`);\n113:       }\n114:     });\n115:     return;\n116:   }\n117: \n118:   output(\n119:     fmt,\n120:     fullData,\n121:     () => {\n122:       console.log(`\\n${BOLD}Feature: ${feature.title}${RESET}`);\n123:       console.log(`  ID:          ${feature.id}`);\n124:       console.log(`  Status:      ${statusColor(feature.status)}${feature.status}${RESET}`);\n125:       console.log(`  Priority:    ${feature.priority}`);\n126:       console.log(`  Difficulty:  ${feature.difficulty}`);\n127:       console.log(`  Effort:      ${effort}`);\n128:       console.log(`  Completion:  ${feature.completion}%`);\n129:       console.log(`  Deps met:    ${depsMet ? `${GREEN}yes${RESET}` : `${RED}no${RESET}`}`);\n130: \n131:       if (feature.started_at) {\n132:         console.log(`  Started:     ${feature.started_at}`);\n133:       }\n134:       if (feature.ended_at) {\n135:         console.log(`  Ended:       ${feature.ended_at}`);\n136:       }\n137: \n138:       if (feature.description) {\n139:         console.log(`\\n  ${BOLD}Description:${RESET}`);\n140:         for (const line of feature.description.split(\"\\n\")) {\n141:           console.log(`    ${line}`);\n142:         }\n143:       }\n144: \n145:       if (feature.depends_on.length > 0) {\n146:         console.log(`\\n  ${BOLD}Dependencies:${RESET}`);\n147:         for (const dep of feature.depends_on) {\n148:           const met = doneIds.has(dep);\n149:           const icon = met ? `${GREEN}✓${RESET}` : `${RED}✗${RESET}`;\n150:           console.log(`    ${icon} ${dep}`);\n151:         }\n152:       }\n153: \n154:       if (feature.constraints.length > 0) {\n155:         console.log(`\\n  ${BOLD}Constraints:${RESET}`);\n156:         for (const c of feature.constraints) {\n157:           console.log(`    - ${c}`);\n158:         }\n159:       }\n160: \n161:       if (feature.forbidden.length > 0) {\n162:         console.log(`\\n  ${BOLD}Forbidden:${RESET}`);\n163:         for (const f of feature.forbidden) {\n164:           console.log(`    - ${RED}${f}${RESET}`);\n165:         }\n166:       }\n167: \n168:       if (feature.references.length > 0) {\n169:         console.log(`\\n  ${BOLD}References:${RESET}`);\n170:         for (const r of feature.references) {\n171:           console.log(`    - ${DIM}${r}${RESET}`);\n172:         }\n173:       }\n174: \n175:       if (feature.notes.length > 0) {\n176:         console.log(`\\n  ${BOLD}Notes:${RESET}`);\n177:         for (const n of feature.notes) {\n178:           console.log(`    - ${n}`);\n179:         }\n180:       }\n181: \n182:       if (feature.subtasks.length > 0) {\n183:         console.log(`\\n  ${BOLD}Subtasks (${feature.subtasks.length}):${RESET}`);\n184:         for (const st of feature.subtasks) {\n185:           renderSubtask(st, 2);\n186:         }\n187:       }\n188: \n189:       console.log(\"\");\n190:     }\n191:   );\n192: }\n\n(End of file - total 192 lines)\n</content>","title":"src/commands/features/show.ts","metadata":{"preview":"/**\n * features/show.ts — Show detailed information about a specific feature.\n *\n * Usage:\n *   wombo features show <feature-id>\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  findFeatureById,\n  formatDuration,\n  parseDurationMinutes,\n  areDependenciesMet,\n  getDoneFeatureIds,\n  type Feature,\n  type Subtask,\n} from \"../../lib/features.js\";\nimport { output, outputError, filterFields, type OutputFormat } from \"../../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773246668424,"end":1773246668434}}}}
