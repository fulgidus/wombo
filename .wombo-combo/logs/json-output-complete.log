ted.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":67,"character":4},"end":{"line":67,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":110,"character":4},"end":{"line":110,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/upgrade.ts":[{"range":{"start":{"line":169,"character":4},"end":{"line":169,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":174,"character":4},"end":{"line":174,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"},{"range":{"start":{"line":249,"character":4},"end":{"line":249,"character":10}},"message":"Unreachable code detected.","severity":4,"code":7027,"source":"typescript"}],"/home/fulgidus/Documents/wombo-json-output-complete/src/lib/state.ts":[],"/home/fulgidus/Documents/wombo-json-output-complete/src/lib/ui.ts":[]},"diff":"Index: /home/fulgidus/Documents/wombo-json-output-complete/src/commands/upgrade.ts\n===================================================================\n--- /home/fulgidus/Documents/wombo-json-output-complete/src/commands/upgrade.ts\n+++ /home/fulgidus/Documents/wombo-json-output-complete/src/commands/upgrade.ts\n@@ -227,25 +227,32 @@\n \n   await installVersion(latestTag, fmt);\n }\n \n-async function installVersion(tag: string): Promise<void> {\n-  console.log(`\\nInstalling wombo@${tag}...`);\n+async function installVersion(tag: string, fmt: OutputFormat = \"text\"): Promise<void> {\n+  if (fmt === \"text\") {\n+    console.log(`\\nInstalling wombo@${tag}...`);\n+  }\n \n   const proc = Bun.spawn(\n     [\"bun\", \"install\", \"-g\", `github:${REPO}#${tag}`],\n     {\n-      stdout: \"inherit\",\n-      stderr: \"inherit\",\n+      stdout: \"pipe\",\n+      stderr: \"pipe\",\n     }\n   );\n \n+  const stdout = await new Response(proc.stdout).text();\n+  const stderr = await new Response(proc.stderr).text();\n   const exitCode = await proc.exited;\n \n   if (exitCode !== 0) {\n-    console.error(`\\nInstallation failed (exit code ${exitCode}).`);\n-    process.exit(1);\n+    outputError(fmt, `Installation failed (exit code ${exitCode}).${stderr ? ` ${stderr.trim()}` : \"\"}`);\n     return;\n   }\n \n-  console.log(`\\nSuccessfully upgraded to ${tag}.`);\n+  outputMessage(fmt, `Successfully upgraded to ${tag}.`, {\n+    installed_version: tag,\n+    success: true,\n+    output: stdout.trim() || undefined,\n+  });\n }\n","filediff":{"file":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/upgrade.ts","before":"/**\n * upgrade.ts — Self-upgrade wombo from GitHub.\n *\n * Usage:\n *   wombo upgrade              # Check for updates and prompt to install\n *   wombo upgrade --force      # Skip confirmation prompt\n *   wombo upgrade --version v0.1.0  # Install a specific version\n *   wombo upgrade --check      # Only check, don't install\n */\n\nimport { readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface UpgradeOptions {\n  force: boolean;\n  version?: string;\n  checkOnly: boolean;\n  outputFmt?: import(\"../lib/output.js\").OutputFormat;\n}\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nconst REPO = \"fulgidus/wombo\";\n\n/**\n * Get the locally installed version from package.json.\n * Uses import.meta to find the package.json relative to this source file,\n * which works whether running from local source or global install.\n */\nfunction getLocalVersion(): string {\n  const pkgPath = resolve(import.meta.dir, \"../../package.json\");\n  const raw = readFileSync(pkgPath, \"utf-8\");\n  return JSON.parse(raw).version as string;\n}\n\n/**\n * Fetch all v* tags from the remote GitHub repo using git ls-remote.\n * Returns tags sorted by semver descending (latest first).\n */\nasync function fetchRemoteTags(): Promise<string[]> {\n  const proc = Bun.spawn([\"git\", \"ls-remote\", \"--tags\", `https://github.com/${REPO}.git`], {\n    stdout: \"pipe\",\n    stderr: \"pipe\",\n  });\n\n  const stdout = await new Response(proc.stdout).text();\n  const exitCode = await proc.exited;\n\n  if (exitCode !== 0) {\n    const stderr = await new Response(proc.stderr).text();\n    throw new Error(`Failed to fetch remote tags: ${stderr.trim()}`);\n  }\n\n  // Parse lines like: \"abc123\\trefs/tags/v0.0.1\"\n  const tags: string[] = [];\n  for (const line of stdout.split(\"\\n\")) {\n    const match = line.match(/refs\\/tags\\/(v\\d+\\.\\d+\\.\\d+)$/);\n    if (match) {\n      tags.push(match[1]);\n    }\n  }\n\n  // Sort descending by semver\n  tags.sort((a, b) => {\n    const pa = a.slice(1).split(\".\").map(Number);\n    const pb = b.slice(1).split(\".\").map(Number);\n    for (let i = 0; i < 3; i++) {\n      if (pa[i] !== pb[i]) return pb[i] - pa[i];\n    }\n    return 0;\n  });\n\n  return tags;\n}\n\n/**\n * Compare two semver strings. Returns:\n *   -1 if a < b\n *    0 if a === b\n *    1 if a > b\n */\nfunction compareSemver(a: string, b: string): number {\n  const pa = a.replace(/^v/, \"\").split(\".\").map(Number);\n  const pb = b.replace(/^v/, \"\").split(\".\").map(Number);\n  for (let i = 0; i < 3; i++) {\n    if (pa[i] < pb[i]) return -1;\n    if (pa[i] > pb[i]) return 1;\n  }\n  return 0;\n}\n\n/**\n * Prompt the user for yes/no confirmation.\n */\nasync function confirm(message: string): Promise<boolean> {\n  if (!process.stdin.isTTY) return false;\n\n  const rl = createInterface({ input: process.stdin, output: process.stdout });\n  return new Promise<boolean>((resolve) => {\n    rl.question(`${message} [y/N] `, (answer) => {\n      rl.close();\n      resolve(answer.trim().toLowerCase() === \"y\");\n    });\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Command\n// ---------------------------------------------------------------------------\n\nexport async function cmdUpgrade(opts: UpgradeOptions): Promise<void> {\n  const fmt = opts.outputFmt ?? \"text\";\n  const localVersion = getLocalVersion();\n\n  if (fmt === \"text\") {\n    console.log(`Current version: v${localVersion}`);\n  }\n\n  // If a specific version is requested, skip the check\n  if (opts.version) {\n    const targetTag = opts.version.startsWith(\"v\") ? opts.version : `v${opts.version}`;\n\n    if (fmt === \"text\") {\n      console.log(`Requested version: ${targetTag}`);\n    }\n\n    if (compareSemver(localVersion, targetTag) === 0) {\n      outputMessage(fmt, \"Already at the requested version.\", {\n        current_version: `v${localVersion}`,\n        target_version: targetTag,\n        up_to_date: true,\n      });\n      return;\n    }\n\n    if (!opts.force && fmt !== \"json\") {\n      const ok = await confirm(`Install ${targetTag}?`);\n      if (!ok) {\n        outputMessage(fmt, \"Upgrade cancelled.\", {\n          current_version: `v${localVersion}`,\n          target_version: targetTag,\n          cancelled: true,\n        });\n        return;\n      }\n    }\n\n    await installVersion(targetTag, fmt);\n    return;\n  }\n\n  // Fetch latest from GitHub\n  if (fmt === \"text\") {\n    console.log(`Checking for updates from github.com/${REPO}...`);\n  }\n\n  let tags: string[];\n  try {\n    tags = await fetchRemoteTags();\n  } catch (err: any) {\n    outputError(fmt, `Failed to check for updates: ${err.message}`);\n    return;\n  }\n\n  if (tags.length === 0) {\n    outputError(fmt, \"No release tags found on the remote repository.\");\n    return;\n  }\n\n  const latestTag = tags[0];\n  const latestVersion = latestTag.slice(1); // strip 'v'\n\n  if (fmt === \"text\") {\n    console.log(`Latest version:  ${latestTag}`);\n  }\n\n  const cmp = compareSemver(localVersion, latestVersion);\n  if (cmp >= 0) {\n    outputMessage(fmt, \"You are already up to date.\", {\n      current_version: `v${localVersion}`,\n      latest_version: latestTag,\n      up_to_date: true,\n    });\n    return;\n  }\n\n  if (opts.checkOnly) {\n    output(\n      fmt,\n      {\n        current_version: `v${localVersion}`,\n        latest_version: latestTag,\n        update_available: true,\n        up_to_date: false,\n      },\n      () => {\n        console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n        console.log(`Run 'wombo upgrade' to install.`);\n      }\n    );\n    return;\n  }\n\n  if (fmt === \"text\") {\n    console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n  }\n\n  if (!opts.force && fmt !== \"json\") {\n    const ok = await confirm(`Upgrade to ${latestTag}?`);\n    if (!ok) {\n      outputMessage(fmt, \"Upgrade cancelled.\", {\n        current_version: `v${localVersion}`,\n        latest_version: latestTag,\n        cancelled: true,\n      });\n      return;\n    }\n  }\n\n  await installVersion(latestTag, fmt);\n}\n\nasync function installVersion(tag: string): Promise<void> {\n  console.log(`\\nInstalling wombo@${tag}...`);\n\n  const proc = Bun.spawn(\n    [\"bun\", \"install\", \"-g\", `github:${REPO}#${tag}`],\n    {\n      stdout: \"inherit\",\n      stderr: \"inherit\",\n    }\n  );\n\n  const exitCode = await proc.exited;\n\n  if (exitCode !== 0) {\n    console.error(`\\nInstallation failed (exit code ${exitCode}).`);\n    process.exit(1);\n    return;\n  }\n\n  console.log(`\\nSuccessfully upgraded to ${tag}.`);\n}\n","after":"/**\n * upgrade.ts — Self-upgrade wombo from GitHub.\n *\n * Usage:\n *   wombo upgrade              # Check for updates and prompt to install\n *   wombo upgrade --force      # Skip confirmation prompt\n *   wombo upgrade --version v0.1.0  # Install a specific version\n *   wombo upgrade --check      # Only check, don't install\n */\n\nimport { readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface UpgradeOptions {\n  force: boolean;\n  version?: string;\n  checkOnly: boolean;\n  outputFmt?: import(\"../lib/output.js\").OutputFormat;\n}\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nconst REPO = \"fulgidus/wombo\";\n\n/**\n * Get the locally installed version from package.json.\n * Uses import.meta to find the package.json relative to this source file,\n * which works whether running from local source or global install.\n */\nfunction getLocalVersion(): string {\n  const pkgPath = resolve(import.meta.dir, \"../../package.json\");\n  const raw = readFileSync(pkgPath, \"utf-8\");\n  return JSON.parse(raw).version as string;\n}\n\n/**\n * Fetch all v* tags from the remote GitHub repo using git ls-remote.\n * Returns tags sorted by semver descending (latest first).\n */\nasync function fetchRemoteTags(): Promise<string[]> {\n  const proc = Bun.spawn([\"git\", \"ls-remote\", \"--tags\", `https://github.com/${REPO}.git`], {\n    stdout: \"pipe\",\n    stderr: \"pipe\",\n  });\n\n  const stdout = await new Response(proc.stdout).text();\n  const exitCode = await proc.exited;\n\n  if (exitCode !== 0) {\n    const stderr = await new Response(proc.stderr).text();\n    throw new Error(`Failed to fetch remote tags: ${stderr.trim()}`);\n  }\n\n  // Parse lines like: \"abc123\\trefs/tags/v0.0.1\"\n  const tags: string[] = [];\n  for (const line of stdout.split(\"\\n\")) {\n    const match = line.match(/refs\\/tags\\/(v\\d+\\.\\d+\\.\\d+)$/);\n    if (match) {\n      tags.push(match[1]);\n    }\n  }\n\n  // Sort descending by semver\n  tags.sort((a, b) => {\n    const pa = a.slice(1).split(\".\").map(Number);\n    const pb = b.slice(1).split(\".\").map(Number);\n    for (let i = 0; i < 3; i++) {\n      if (pa[i] !== pb[i]) return pb[i] - pa[i];\n    }\n    return 0;\n  });\n\n  return tags;\n}\n\n/**\n * Compare two semver strings. Returns:\n *   -1 if a < b\n *    0 if a === b\n *    1 if a > b\n */\nfunction compareSemver(a: string, b: string): number {\n  const pa = a.replace(/^v/, \"\").split(\".\").map(Number);\n  const pb = b.replace(/^v/, \"\").split(\".\").map(Number);\n  for (let i = 0; i < 3; i++) {\n    if (pa[i] < pb[i]) return -1;\n    if (pa[i] > pb[i]) return 1;\n  }\n  return 0;\n}\n\n/**\n * Prompt the user for yes/no confirmation.\n */\nasync function confirm(message: string): Promise<boolean> {\n  if (!process.stdin.isTTY) return false;\n\n  const rl = createInterface({ input: process.stdin, output: process.stdout });\n  return new Promise<boolean>((resolve) => {\n    rl.question(`${message} [y/N] `, (answer) => {\n      rl.close();\n      resolve(answer.trim().toLowerCase() === \"y\");\n    });\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Command\n// ---------------------------------------------------------------------------\n\nexport async function cmdUpgrade(opts: UpgradeOptions): Promise<void> {\n  const fmt = opts.outputFmt ?? \"text\";\n  const localVersion = getLocalVersion();\n\n  if (fmt === \"text\") {\n    console.log(`Current version: v${localVersion}`);\n  }\n\n  // If a specific version is requested, skip the check\n  if (opts.version) {\n    const targetTag = opts.version.startsWith(\"v\") ? opts.version : `v${opts.version}`;\n\n    if (fmt === \"text\") {\n      console.log(`Requested version: ${targetTag}`);\n    }\n\n    if (compareSemver(localVersion, targetTag) === 0) {\n      outputMessage(fmt, \"Already at the requested version.\", {\n        current_version: `v${localVersion}`,\n        target_version: targetTag,\n        up_to_date: true,\n      });\n      return;\n    }\n\n    if (!opts.force && fmt !== \"json\") {\n      const ok = await confirm(`Install ${targetTag}?`);\n      if (!ok) {\n        outputMessage(fmt, \"Upgrade cancelled.\", {\n          current_version: `v${localVersion}`,\n          target_version: targetTag,\n          cancelled: true,\n        });\n        return;\n      }\n    }\n\n    await installVersion(targetTag, fmt);\n    return;\n  }\n\n  // Fetch latest from GitHub\n  if (fmt === \"text\") {\n    console.log(`Checking for updates from github.com/${REPO}...`);\n  }\n\n  let tags: string[];\n  try {\n    tags = await fetchRemoteTags();\n  } catch (err: any) {\n    outputError(fmt, `Failed to check for updates: ${err.message}`);\n    return;\n  }\n\n  if (tags.length === 0) {\n    outputError(fmt, \"No release tags found on the remote repository.\");\n    return;\n  }\n\n  const latestTag = tags[0];\n  const latestVersion = latestTag.slice(1); // strip 'v'\n\n  if (fmt === \"text\") {\n    console.log(`Latest version:  ${latestTag}`);\n  }\n\n  const cmp = compareSemver(localVersion, latestVersion);\n  if (cmp >= 0) {\n    outputMessage(fmt, \"You are already up to date.\", {\n      current_version: `v${localVersion}`,\n      latest_version: latestTag,\n      up_to_date: true,\n    });\n    return;\n  }\n\n  if (opts.checkOnly) {\n    output(\n      fmt,\n      {\n        current_version: `v${localVersion}`,\n        latest_version: latestTag,\n        update_available: true,\n        up_to_date: false,\n      },\n      () => {\n        console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n        console.log(`Run 'wombo upgrade' to install.`);\n      }\n    );\n    return;\n  }\n\n  if (fmt === \"text\") {\n    console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n  }\n\n  if (!opts.force && fmt !== \"json\") {\n    const ok = await confirm(`Upgrade to ${latestTag}?`);\n    if (!ok) {\n      outputMessage(fmt, \"Upgrade cancelled.\", {\n        current_version: `v${localVersion}`,\n        latest_version: latestTag,\n        cancelled: true,\n      });\n      return;\n    }\n  }\n\n  await installVersion(latestTag, fmt);\n}\n\nasync function installVersion(tag: string, fmt: OutputFormat = \"text\"): Promise<void> {\n  if (fmt === \"text\") {\n    console.log(`\\nInstalling wombo@${tag}...`);\n  }\n\n  const proc = Bun.spawn(\n    [\"bun\", \"install\", \"-g\", `github:${REPO}#${tag}`],\n    {\n      stdout: \"pipe\",\n      stderr: \"pipe\",\n    }\n  );\n\n  const stdout = await new Response(proc.stdout).text();\n  const stderr = await new Response(proc.stderr).text();\n  const exitCode = await proc.exited;\n\n  if (exitCode !== 0) {\n    outputError(fmt, `Installation failed (exit code ${exitCode}).${stderr ? ` ${stderr.trim()}` : \"\"}`);\n    return;\n  }\n\n  outputMessage(fmt, `Successfully upgraded to ${tag}.`, {\n    installed_version: tag,\n    success: true,\n    output: stdout.trim() || undefined,\n  });\n}\n","additions":14,"deletions":7},"truncated":false},"time":{"start":1773245563833,"end":1773245564371}}}}
