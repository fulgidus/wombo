{"type":"tool_use","timestamp":1773246672727,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcee1e001qdLqkVgbbLWpSY","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcdeac001T9mmebPVclbhwy","type":"tool","callID":"toolu_01LhoDUcudDqrAEsURjfRAmo","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/status.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/status.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * status.ts — Show the status of the current wave.\n3:  *\n4:  * Usage: wombo status\n5:  *\n6:  * Loads the wave state, checks for dead processes, and prints a dashboard.\n7:  */\n8: \n9: import type { WomboConfig } from \"../config.js\";\n10: import { loadState, saveState, updateAgent, agentCounts } from \"../lib/state.js\";\n11: import { isProcessRunning } from \"../lib/launcher.js\";\n12: import { printDashboard } from \"../lib/ui.js\";\n13: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n14: \n15: export interface StatusOptions {\n16:   projectRoot: string;\n17:   config: WomboConfig;\n18:   outputFmt?: OutputFormat;\n19: }\n20: \n21: export async function cmdStatus(opts: StatusOptions): Promise<void> {\n22:   const fmt = opts.outputFmt ?? \"text\";\n23: \n24:   const state = loadState(opts.projectRoot);\n25:   if (!state) {\n26:     outputMessage(fmt, \"No active wave. Use 'wombo launch' to start one.\", {\n27:       active: false,\n28:     });\n29:     return;\n30:   }\n31: \n32:   // Update running agent status from process state\n33:   for (const agent of state.agents) {\n34:     if (agent.status === \"running\" && agent.pid) {\n35:       if (!isProcessRunning(agent.pid)) {\n36:         updateAgent(state, agent.feature_id, {\n37:           status: \"completed\",\n38:           completed_at: new Date().toISOString(),\n39:         });\n40:       }\n41:     }\n42:   }\n43:   saveState(opts.projectRoot, state);\n44: \n45:   const counts = agentCounts(state);\n46: \n47:   output(\n48:     fmt,\n49:     {\n50:       active: true,\n51:       wave_id: state.wave_id,\n52:       base_branch: state.base_branch,\n53:       started_at: state.started_at,\n54:       updated_at: state.updated_at,\n55:       max_concurrent: state.max_concurrent,\n56:       model: state.model,\n57:       interactive: state.interactive,\n58:       agents: state.agents.map((a) => ({\n59:         feature_id: a.feature_id,\n60:         branch: a.branch,\n61:         status: a.status,\n62:         activity: a.activity,\n63:         retries: a.retries,\n64:         max_retries: a.max_retries,\n65:         started_at: a.started_at,\n66:         completed_at: a.completed_at,\n67:         build_passed: a.build_passed,\n68:         error: a.error,\n69:       })),\n70:       counts,\n71:       total: state.agents.length,\n72:     },\n73:     () => {\n74:       printDashboard(state);\n75:     }\n76:   );\n77: }\n\n(End of file - total 77 lines)\n</content>","title":"src/commands/status.ts","metadata":{"preview":"/**\n * status.ts — Show the status of the current wave.\n *\n * Usage: wombo status\n *\n * Loads the wave state, checks for dead processes, and prints a dashboard.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadState, saveState, updateAgent, agentCounts } from \"../lib/state.js\";\nimport { isProcessRunning } from \"../lib/launcher.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n\nexport interface StatusOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  outputFmt?: OutputFormat;\n}\n","truncated":false,"loaded":[]},"time":{"start":1773246672723,"end":1773246672727}}}}
{"type":"tool_use","timestamp":1773246672850,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcef54001Ntb7PjDT5D0N3q","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcdeac001T9mmebPVclbhwy","type":"tool","callID":"toolu_015dxV8CMjGxv4MJuJ2tKiBX","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import type { WomboConfig } from \"../config.js\";\n19: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n20: import { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";\n21: import {\n22:   loadState,\n23:   saveState,\n24:   createWaveState,\n25:   createAgentState,\n26:   updateAgent,\n27:   activeAgents,\n28:   queuedAgents,\n29:   isWaveComplete,\n30:   type WaveState,\n31:   type AgentState,\n32: } from \"../lib/state.js\";\n33: import {\n34:   createWorktree,\n35:   installDeps,\n36:   featureBranchName,\n37:   worktreePath,\n38:   worktreeReady,\n39:   removeWorktree,\n40:   log as wtLog,\n41: } from \"../lib/worktree.js\";\n42: import { generatePrompt } from \"../lib/prompt.js\";\n43: import {\n44:   launchHeadless,\n45:   retryHeadless,\n46:   launchInteractive,\n47:   retryInteractive,\n48:   isProcessRunning,\n49: } from \"../lib/launcher.js\";\n50: import { ProcessMonitor } from \"../lib/monitor.js\";\n51: import { runBuild } from \"../lib/verifier.js\";\n52: import { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\n53: import {\n54:   printDashboard,\n55:   printFeatureSelection,\n56:   printAgentUpdate,\n57: } from \"../lib/ui.js\";\n58: import { WomboTUI } from \"../lib/tui.js\";\n59: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n60: \n61: // ---------------------------------------------------------------------------\n62: // Types\n63: // ---------------------------------------------------------------------------\n64: \n65: export interface LaunchCommandOptions {\n66:   projectRoot: string;\n67:   config: WomboConfig;\n68:   // Selection\n69:   topPriority?: number;\n70:   quickestWins?: number;\n71:   priority?: Priority;\n72:   difficulty?: Difficulty;\n73:   features?: string[];\n74:   allReady?: boolean;\n75:   // Launch\n76:   maxConcurrent: number;\n77:   model?: string;\n78:   interactive: boolean;\n79:   dryRun: boolean;\n80:   baseBranch: string;\n81:   maxRetries: number;\n82:   noTui: boolean;\n83:   autoPush: boolean;\n84:   // Output\n85:   outputFmt?: import(\"../lib/output.js\").OutputFormat;\n86: }\n87: \n88: // ---------------------------------------------------------------------------\n89: // Shared Helpers (exported for resume.ts and others)\n90: // ---------------------------------------------------------------------------\n91: \n92: /**\n93:  * Launch a single agent in headless mode.\n94:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n95:  */\n96: export async function launchSingleHeadless(\n97:   projectRoot: string,\n98:   state: WaveState,\n99:   agent: AgentState,\n100:   feature: Feature,\n101:   monitor: ProcessMonitor,\n102:   config: WomboConfig,\n103:   model?: string\n104: ): Promise<void> {\n105:   updateAgent(state, agent.feature_id, {\n106:     status: \"installing\",\n107:     started_at: new Date().toISOString(),\n108:     activity: \"setting up worktree...\",\n109:   });\n110:   saveState(projectRoot, state);\n111: \n112:   try {\n113:     // Skip worktree setup if already ready (resume case)\n114:     if (worktreeReady(agent.worktree)) {\n115:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n116:     } else {\n117:       // Create worktree (async — doesn't block other agents)\n118:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n119: \n120:       // Install dependencies (async)\n121:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n122:       await installDeps(agent.worktree, feature.id, config);\n123:     }\n124: \n125:     // Generate prompt\n126:     const prompt = generatePrompt(feature, state.base_branch, config);\n127: \n128:     // Launch agent\n129:     wtLog(agent.feature_id, \"launching agent...\");\n130:     const result = launchHeadless({\n131:       worktreePath: agent.worktree,\n132:       featureId: feature.id,\n133:       prompt,\n134:       model,\n135:       config,\n136:     });\n137: \n138:     updateAgent(state, agent.feature_id, {\n139:       status: \"running\",\n140:       pid: result.pid,\n141:       activity: \"starting...\",\n142:     });\n143:     saveState(projectRoot, state);\n144: \n145:     monitor.addProcess(feature.id, result.process);\n146:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n147:   } catch (err: any) {\n148:     updateAgent(state, agent.feature_id, {\n149:       status: \"failed\",\n150:       error: err.message,\n151:       activity: null,\n152:       completed_at: new Date().toISOString(),\n153:     });\n154:     saveState(projectRoot, state);\n155:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n156:   }\n157: }\n158: \n159: /**\n160:  * Handle build verification after agent completion.\n161:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n162:  *\n163:  * ASYNC — runs build and merge without blocking the event loop.\n164:  */\n165: export async function handleBuildVerification(\n166:   projectRoot: string,\n167:   state: WaveState,\n168:   agent: AgentState,\n169:   feature: Feature,\n170:   config: WomboConfig,\n171:   model?: string,\n172:   monitor?: ProcessMonitor\n173: ): Promise<void> {\n174:   try {\n175:     printAgentUpdate(agent, \"verifying build...\");\n176: \n177:     const buildResult = await runBuild(agent.worktree, config);\n178: \n179:     if (buildResult.passed) {\n180:       updateAgent(state, agent.feature_id, {\n181:         status: \"verified\",\n182:         build_passed: true,\n183:         build_output: null,\n184:       });\n185:       saveState(projectRoot, state);\n186:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n187: \n188:       // Auto-merge: merge verified branch into base immediately\n189:       printAgentUpdate(agent, \"auto-merging...\");\n190:       try {\n191:         const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n192: \n193:         if (mergeResult.success) {\n194:           updateAgent(state, agent.feature_id, {\n195:             status: \"merged\",\n196:             completed_at: new Date().toISOString(),\n197:           });\n198:           saveState(projectRoot, state);\n199:           printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n200: \n201:           // Clean up worktree after successful merge\n202:           try {\n203:             removeWorktree(projectRoot, agent.worktree, false);\n204:             printAgentUpdate(agent, \"worktree removed\");\n205:           } catch {\n206:             // Not critical — worktree cleanup is best-effort\n207:           }\n208:         } else {\n209:           // Merge failed (conflicts, etc.) — leave as verified for manual resolution\n210:           printAgentUpdate(agent, `AUTO-MERGE FAILED: ${mergeResult.error}`);\n211:         }\n212:       } catch (mergeErr: any) {\n213:         printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n214:       }\n215:     } else {\n216:       if (agent.retries < agent.max_retries) {\n217:         updateAgent(state, agent.feature_id, {\n218:           status: \"retry\",\n219:           retries: agent.retries + 1,\n220:           build_passed: false,\n221:           build_output: buildResult.errorSummary,\n222:         });\n223:         saveState(projectRoot, state);\n224:         printAgentUpdate(\n225:           agent,\n226:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n227:         );\n228: \n229:         // Retry with build errors\n230:         if (agent.session_id) {\n231:           const retryResult = retryHeadless({\n232:             worktreePath: agent.worktree,\n233:             featureId: agent.feature_id,\n234:             sessionId: agent.session_id,\n235:             buildErrors: buildResult.errorSummary,\n236:             model,\n237:             config,\n238:           });\n239: \n240:           updateAgent(state, agent.feature_id, {\n241:             status: \"running\",\n242:             pid: retryResult.pid,\n243:           });\n244:           saveState(projectRoot, state);\n245: \n246:           // Add retry process to monitor so events are tracked\n247:           if (monitor) {\n248:             monitor.addProcess(agent.feature_id, retryResult.process);\n249:           }\n250:         }\n251:       } else {\n252:         updateAgent(state, agent.feature_id, {\n253:           status: \"failed\",\n254:           build_passed: false,\n255:           build_output: buildResult.errorSummary,\n256:           error: `Build failed after ${agent.max_retries} retries`,\n257:           completed_at: new Date().toISOString(),\n258:         });\n259:         saveState(projectRoot, state);\n260:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n261:       }\n262:     }\n263:   } catch (err: any) {\n264:     // Catch-all — never let build verification crash the process\n265:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n266:     updateAgent(state, agent.feature_id, {\n267:       status: \"failed\",\n268:       error: `Build verification error: ${err.message}`,\n269:       completed_at: new Date().toISOString(),\n270:     });\n271:     saveState(projectRoot, state);\n272:   }\n273: }\n274: \n275: /**\n276:  * Handle retry of a failed agent (error-based, not build-based).\n277:  */\n278: export function handleRetry(\n279:   projectRoot: string,\n280:   state: WaveState,\n281:   agent: AgentState,\n282:   monitor: ProcessMonitor,\n283:   config: WomboConfig,\n284:   model?: string\n285: ): void {\n286:   if (!agent.session_id || !agent.error) return;\n287: \n288:   const retryResult = retryHeadless({\n289:     worktreePath: agent.worktree,\n290:     featureId: agent.feature_id,\n291:     sessionId: agent.session_id,\n292:     buildErrors: agent.error,\n293:     model,\n294:     config,\n295:   });\n296: \n297:   updateAgent(state, agent.feature_id, {\n298:     status: \"running\",\n299:     pid: retryResult.pid,\n300:   });\n301:   saveState(projectRoot, state);\n302: \n303:   monitor.addProcess(agent.feature_id, retryResult.process);\n304: }\n305: \n306: /**\n307:  * Launch the next queued agent if capacity allows.\n308:  */\n309: export function launchNextQueued(\n310:   projectRoot: string,\n311:   state: WaveState,\n312:   featureMap: Map<string, Feature>,\n313:   monitor: ProcessMonitor,\n314:   config: WomboConfig,\n315:   model?: string\n316: ): void {\n317:   const active = activeAgents(state);\n318:   const queued = queuedAgents(state);\n319: \n320:   if (active.length < state.max_concurrent && queued.length > 0) {\n321:     const next = queued[0];\n322:     const feature = featureMap.get(next.feature_id);\n323:     if (feature) {\n324:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n325:     }\n326:   }\n327: }\n328: \n329: // ---------------------------------------------------------------------------\n330: // Headless Wave Launch\n331: // ---------------------------------------------------------------------------\n332: \n333: async function launchWaveHeadless(\n334:   projectRoot: string,\n335:   state: WaveState,\n336:   features: Feature[],\n337:   opts: LaunchCommandOptions\n338: ): Promise<void> {\n339:   const { config, model } = opts;\n340:   const featureMap = new Map(features.map((f) => [f.id, f]));\n341: \n342:   const monitor = new ProcessMonitor(projectRoot, {\n343:     onSessionId: (featureId, sessionId) => {\n344:       updateAgent(state, featureId, { session_id: sessionId });\n345:       saveState(projectRoot, state);\n346:     },\n347:     onComplete: (featureId) => {\n348:       updateAgent(state, featureId, {\n349:         status: \"completed\",\n350:         completed_at: new Date().toISOString(),\n351:       });\n352:       saveState(projectRoot, state);\n353: \n354:       // Run build verification — fire-and-forget\n355:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n356:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n357:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n358:         .catch((err) => {\n359:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n360:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n361:         });\n362:     },\n363:     onError: (featureId, error) => {\n364:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n365:       if (agent.retries < agent.max_retries) {\n366:         updateAgent(state, featureId, {\n367:           status: \"retry\",\n368:           retries: agent.retries + 1,\n369:           error,\n370:         });\n371:         saveState(projectRoot, state);\n372: \n373:         // Retry\n374:         handleRetry(projectRoot, state, agent, monitor, config, model);\n375:       } else {\n376:         updateAgent(state, featureId, {\n377:           status: \"failed\",\n378:           error,\n379:           completed_at: new Date().toISOString(),\n380:         });\n381:         saveState(projectRoot, state);\n382:       }\n383: \n384:       // Try to launch next queued agent\n385:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n386:     },\n387:     onOutput: (_featureId, _data) => {\n388:       // Raw output — logged to file by ProcessMonitor\n389:     },\n390:     onActivity: (featureId, activity) => {\n391:       updateAgent(state, featureId, {\n392:         activity,\n393:         activity_updated_at: new Date().toISOString(),\n394:       });\n395:       // Don't save to disk on every activity — too frequent.\n396:     },\n397:   });\n398: \n399:   // Create the TUI — it will auto-refresh and show activity from the monitor\n400:   const tuiRef = { current: null as WomboTUI | null };\n401:   const startTUI = () => {\n402:     tuiRef.current = new WomboTUI({\n403:       state,\n404:       monitor,\n405:       projectRoot,\n406:       interactive: false,\n407:       config,\n408:       onQuit: () => {\n409:         // Same as SIGINT — save state and exit\n410:         for (const agent of state.agents) {\n411:           if (agent.status === \"running\") {\n412:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n413:           }\n414:         }\n415:         monitor.killAll();\n416:         saveState(projectRoot, state);\n417:         console.log(\"State saved. Use 'wombo resume' to continue.\");\n418:         process.exit(0);\n419:       },\n420:     });\n421:     tuiRef.current.start();\n422:   };\n423: \n424:   // Handle graceful shutdown\n425:   process.on(\"SIGINT\", () => {\n426:     if (tuiRef.current) tuiRef.current.stop();\n427:     for (const agent of state.agents) {\n428:       if (agent.status === \"running\") {\n429:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n430:       }\n431:     }\n432:     monitor.killAll();\n433:     saveState(projectRoot, state);\n434:     console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n435:     process.exit(0);\n436:   });\n437: \n438:   // Launch initial batch — set up worktrees in parallel\n439:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n440:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n441: \n442:   await Promise.all(\n443:     tolaunch.map((agent) =>\n444:       launchSingleHeadless(\n445:         projectRoot,\n446:         state,\n447:         agent,\n448:         featureMap.get(agent.feature_id)!,\n449:         monitor,\n450:         config,\n451:         model\n452:       )\n453:     )\n454:   );\n455: \n456:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n457: \n458:   // Start the TUI dashboard (or skip if --no-tui)\n459:   if (opts.noTui) {\n460:     console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n461:     printDashboard(state);\n462:   } else {\n463:     console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n464:     startTUI();\n465:   }\n466: \n467:   // Background monitoring loop — checks for dead processes and launches queued\n468:   const POLL_INTERVAL = 5000;\n469:   let dashboardCounter = 0;\n470:   while (!isWaveComplete(state)) {\n471:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n472: \n473:     // Check for completed processes that weren't caught by event handlers\n474:     for (const agent of state.agents) {\n475:       if (\n476:         agent.status === \"running\" &&\n477:         agent.pid &&\n478:         !isProcessRunning(agent.pid) &&\n479:         !monitor.isRunning(agent.feature_id)\n480:       ) {\n481:         // Process exited but we didn't get a callback\n482:         updateAgent(state, agent.feature_id, {\n483:           status: \"completed\",\n484:           completed_at: new Date().toISOString(),\n485:           activity: \"done\",\n486:         });\n487:         saveState(projectRoot, state);\n488:         try {\n489:           await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n490:         } catch (err: any) {\n491:           wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n492:         }\n493:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n494:       }\n495:     }\n496: \n497:     // Persist state periodically\n498:     saveState(projectRoot, state);\n499: \n500:     // Update TUI state reference (or print dashboard in --no-tui mode)\n501:     if (tuiRef.current) {\n502:       tuiRef.current.updateState(state);\n503:     } else if (opts.noTui) {\n504:       dashboardCounter++;\n505:       if (dashboardCounter % 3 === 0) {\n506:         printDashboard(state);\n507: \n508:         // Auto-push base branch if requested\n509:         if (opts.autoPush) {\n510:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n511:           if (anyMerged) {\n512:             await pushBaseBranch(projectRoot, state.base_branch, config);\n513:           } else {\n514:             console.log(\"No branches were merged — skipping push.\");\n515:           }\n516:         }\n517:       }\n518:     }\n519:   }\n520: \n521:   // Wave complete — tear down TUI and show final summary\n522:   if (tuiRef.current) tuiRef.current.stop();\n523:   printDashboard(state);\n524: \n525:   // Auto-push base branch if requested\n526:   if (opts.autoPush) {\n527:     await pushBaseBranch(projectRoot, state.base_branch, config);\n528:   }\n529: \n530:   console.log(\"Wave complete.\");\n531: }\n532: \n533: // ---------------------------------------------------------------------------\n534: // Interactive Wave Launch\n535: // ---------------------------------------------------------------------------\n536: \n537: async function launchWaveInteractive(\n538:   projectRoot: string,\n539:   state: WaveState,\n540:   features: Feature[],\n541:   opts: LaunchCommandOptions\n542: ): Promise<void> {\n543:   const { config, model } = opts;\n544:   const featureMap = new Map(features.map((f) => [f.id, f]));\n545: \n546:   // Show dashboard immediately\n547:   printDashboard(state);\n548: \n549:   // Launch initial batch in tmux — parallelize setup\n550:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n551:   console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n552: \n553:   await Promise.all(\n554:     tolaunch.map(async (agent) => {\n555:       updateAgent(state, agent.feature_id, {\n556:         status: \"installing\",\n557:         started_at: new Date().toISOString(),\n558:         activity: \"setting up worktree...\",\n559:       });\n560:       saveState(projectRoot, state);\n561: \n562:       try {\n563:         if (worktreeReady(agent.worktree)) {\n564:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n565:         } else {\n566:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n567:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n568:           await installDeps(agent.worktree, agent.feature_id, config);\n569:         }\n570: \n571:         const prompt = generatePrompt(\n572:           featureMap.get(agent.feature_id)!,\n573:           state.base_branch,\n574:           config\n575:         );\n576: \n577:         wtLog(agent.feature_id, \"launching tmux session...\");\n578:         const result = launchInteractive({\n579:           worktreePath: agent.worktree,\n580:           featureId: agent.feature_id,\n581:           prompt,\n582:           model,\n583:           interactive: true,\n584:           config,\n585:         });\n586: \n587:         updateAgent(state, agent.feature_id, {\n588:           status: \"running\",\n589:           pid: result.pid,\n590:           activity: \"tmux session active\",\n591:         });\n592:         saveState(projectRoot, state);\n593:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n594:       } catch (err: any) {\n595:         updateAgent(state, agent.feature_id, {\n596:           status: \"failed\",\n597:           error: err.message,\n598:           activity: null,\n599:           completed_at: new Date().toISOString(),\n600:         });\n601:         saveState(projectRoot, state);\n602:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n603:       }\n604:     })\n605:   );\n606: \n607:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n608:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n609:   console.log(\"  tmux ls                                                  # list sessions\");\n610:   console.log(\"  wombo status                                             # check status\");\n611:   console.log(\"  wombo verify                                             # verify builds\");\n612:   console.log(\"  wombo merge                                              # merge verified\");\n613:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n614: \n615:   printDashboard(state);\n616: }\n617: \n618: // ---------------------------------------------------------------------------\n619: // Main Command\n620: // ---------------------------------------------------------------------------\n621: \n622: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n623:   const { projectRoot, config } = opts;\n624:   const fmt = opts.outputFmt ?? \"text\";\n625: \n626:   if (fmt === \"text\") {\n627:     console.log(\"\\n--- Wombo: Launch ---\\n\");\n628:   }\n629: \n630:   // Load features\n631:   const data = loadFeatures(projectRoot, config);\n632: \n633:   // Build selection options\n634:   const selOpts: SelectionOptions = {};\n635:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n636:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n637:   if (opts.priority) selOpts.priority = opts.priority;\n638:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n639:   if (opts.features) selOpts.featureIds = opts.features;\n640:   if (opts.allReady) selOpts.allReady = true;\n641: \n642:   // Select features\n643:   const selected = selectFeatures(data, selOpts);\n644: \n645:   if (selected.length === 0) {\n646:     outputError(\n647:       fmt,\n648:       \"No features matched the selection criteria. Use --all-ready to see all available.\"\n649:     );\n650:     return;\n651:   }\n652: \n653:   // Show selection\n654:   const selectedData = selected.map((f) => ({\n655:     id: f.id,\n656:     title: f.title,\n657:     priority: f.priority,\n658:     difficulty: f.difficulty,\n659:     effort: f.effort,\n660:   }));\n661: \n662:   if (opts.dryRun) {\n663:     output(\n664:       fmt,\n665:       {\n666:         dry_run: true,\n667:         selected: selectedData,\n668:         count: selected.length,\n669:         max_concurrent: opts.maxConcurrent,\n670:         base_branch: opts.baseBranch,\n671:         interactive: opts.interactive,\n672:         model: opts.model ?? null,\n673:       },\n674:       () => {\n675:         printFeatureSelection(selectedData);\n676:         console.log(\"Dry run — not launching agents.\");\n677:       }\n678:     );\n679:     return;\n680:   }\n681: \n682:   if (fmt === \"text\") {\n683:     printFeatureSelection(selectedData);\n684:   }\n685: \n686:   // Create wave state\n687:   const state = createWaveState({\n688:     baseBranch: opts.baseBranch,\n689:     maxConcurrent: opts.maxConcurrent,\n690:     model: opts.model ?? null,\n691:     interactive: opts.interactive,\n692:   });\n693: \n694:   // Create agent entries for all selected features\n695:   for (const feature of selected) {\n696:     const branch = featureBranchName(feature.id, config);\n697:     const wtPath = worktreePath(projectRoot, feature.id, config);\n698:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n699:     // Set effort estimate from feature spec\n700:     const effortMinutes = parseDurationMinutes(feature.effort);\n701:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n702:     state.agents.push(agent);\n703:   }\n704: \n705:   saveState(projectRoot, state);\n706: \n707:   if (fmt === \"json\") {\n708:     // In JSON mode, emit the wave state and return — long-running monitoring\n709:     // is not suitable for JSON consumers. They should poll `wombo status --output json`.\n710:     console.log(JSON.stringify({\n711:       wave_id: state.wave_id,\n712:       selected: selectedData,\n713:       count: selected.length,\n714:       max_concurrent: opts.maxConcurrent,\n715:       base_branch: opts.baseBranch,\n716:       interactive: opts.interactive,\n717:       model: opts.model ?? null,\n718:       message: \"Wave created. Use 'wombo status --output json' to monitor progress.\",\n719:     }));\n720:     // Still launch agents but skip TUI/dashboard output\n721:   } else {\n722:     console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n723:   }\n724: \n725:   // Launch agents up to max_concurrent\n726:   if (opts.interactive) {\n727:     await launchWaveInteractive(projectRoot, state, selected, opts);\n728:   } else {\n729:     await launchWaveHeadless(projectRoot, state, selected, opts);\n730:   }\n731: }\n\n(End of file - total 731 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\nimport { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773246672840,"end":1773246672847}}}}
{"type":"tool_use","timestamp":1773246673655,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcefca001zbm9kA2GseKB6B","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcdeac001T9mmebPVclbhwy","type":"tool","callID":"toolu_01LQWC3DXmmrQCCThusbtk2y","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/cleanup.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/cleanup.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * cleanup.ts — Remove all wave-related resources.\n3:  *\n4:  * Usage: wombo cleanup\n5:  *\n6:  * Kills tmux sessions, removes worktrees, removes state and log files.\n7:  */\n8: \n9: import { existsSync, unlinkSync, rmSync } from \"node:fs\";\n10: import { execSync } from \"node:child_process\";\n11: import { resolve } from \"node:path\";\n12: import type { WomboConfig } from \"../config.js\";\n13: import { killAllTmuxSessions } from \"../lib/launcher.js\";\n14: import { cleanupAllWorktrees } from \"../lib/worktree.js\";\n15: import { output, type OutputFormat } from \"../lib/output.js\";\n16: \n17: export interface CleanupOptions {\n18:   projectRoot: string;\n19:   config: WomboConfig;\n20:   dryRun?: boolean;\n21:   outputFmt?: OutputFormat;\n22: }\n23: \n24: export async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n25:   const { projectRoot, config } = opts;\n26:   const fmt = opts.outputFmt ?? \"text\";\n27: \n28:   // Dry-run: show what would be cleaned up without doing it\n29:   if (opts.dryRun) {\n30:     let tmuxSessions: string[] = [];\n31:     let worktrees: string[] = [];\n32: \n33:     // List tmux sessions that would be killed\n34:     try {\n35:       const sessions = execSync(\"tmux list-sessions -F '#{session_name}'\", {\n36:         encoding: \"utf-8\",\n37:       }).trim();\n38:       const prefix = config.agent.tmuxPrefix;\n39:       tmuxSessions = sessions\n40:         .split(\"\\n\")\n41:         .filter((s) => s.startsWith(prefix));\n42:     } catch {\n43:       // no tmux server running\n44:     }\n45: \n46:     // List worktrees that would be removed\n47:     try {\n48:       const worktreeOutput = execSync(\"git worktree list --porcelain\", {\n49:         cwd: projectRoot,\n50:         encoding: \"utf-8\",\n51:       }).trim();\n52:       const prefix = config.git.worktreePrefix;\n53:       worktrees = worktreeOutput\n54:         .split(\"\\n\")\n55:         .filter((line) => line.startsWith(\"worktree \") && line.includes(prefix))\n56:         .map((line) => line.replace(\"worktree \", \"\"));\n57:     } catch {\n58:       // no worktrees\n59:     }\n60: \n61:     const statePath = resolve(projectRoot, \".wombo-state.json\");\n62:     const logDir = resolve(projectRoot, \".wombo-logs\");\n63:     const filesToRemove: string[] = [];\n64:     if (existsSync(statePath)) filesToRemove.push(\".wombo-state.json\");\n65:     if (existsSync(logDir)) filesToRemove.push(\".wombo-logs/\");\n66: \n67:     output(\n68:       fmt,\n69:       {\n70:         dry_run: true,\n71:         tmux_sessions: tmuxSessions,\n72:         tmux_sessions_count: tmuxSessions.length,\n73:         worktrees,\n74:         worktrees_count: worktrees.length,\n75:         files: filesToRemove,\n76:       },\n77:       () => {\n78:         console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n79: \n80:         console.log(`  tmux sessions to kill: ${tmuxSessions.length}`);\n81:         for (const s of tmuxSessions) {\n82:           console.log(`    ${s}`);\n83:         }\n84: \n85:         console.log(`  worktrees to remove: ${worktrees.length}`);\n86:         for (const w of worktrees) {\n87:           console.log(`    ${w}`);\n88:         }\n89: \n90:         if (existsSync(statePath)) console.log(\"  Would remove: .wombo-state.json\");\n91:         if (existsSync(logDir)) console.log(\"  Would remove: .wombo-logs/\");\n92:       }\n93:     );\n94:     return;\n95:   }\n96: \n97:   if (fmt === \"text\") {\n98:     console.log(\"\\n--- Wombo: Cleanup ---\\n\");\n99:   }\n100: \n101:   // Kill tmux sessions\n102:   const killed = killAllTmuxSessions(config);\n103:   if (fmt === \"text\") {\n104:     console.log(`Killed ${killed} tmux session(s)`);\n105:   }\n106: \n107:   // Remove worktrees\n108:   const removed = cleanupAllWorktrees(projectRoot, config);\n109:   if (fmt === \"text\") {\n110:     console.log(`Removed ${removed} worktree(s)`);\n111:   }\n112: \n113:   // List remaining feature branches\n114:   let remainingBranches: string[] = [];\n115:   try {\n116:     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n117:     const branches = execSync(`git branch --list ${branchPattern}`, {\n118:       cwd: projectRoot,\n119:       encoding: \"utf-8\",\n120:     }).trim();\n121:     if (branches) {\n122:       remainingBranches = branches.split(\"\\n\").map((b) => b.trim());\n123:       if (fmt === \"text\") {\n124:         console.log(`\\nRemaining feature branches:\\n${branches}`);\n125:         console.log('Use \"git branch -D <branch>\" to remove manually.');\n126:       }\n127:     }\n128:   } catch {}\n129: \n130:   // Remove state file\n131:   const statePath = resolve(projectRoot, \".wombo-state.json\");\n132:   let stateRemoved = false;\n133:   if (existsSync(statePath)) {\n134:     unlinkSync(statePath);\n135:     stateRemoved = true;\n136:     if (fmt === \"text\") {\n137:       console.log(\"Removed .wombo-state.json\");\n138:     }\n139:   }\n140: \n141:   // Remove log directory\n142:   const logDir = resolve(projectRoot, \".wombo-logs\");\n143:   let logsRemoved = false;\n144:   if (existsSync(logDir)) {\n145:     rmSync(logDir, { recursive: true, force: true });\n146:     logsRemoved = true;\n147:     if (fmt === \"text\") {\n148:       console.log(\"Removed .wombo-logs/\");\n149:     }\n150:   }\n151: \n152:   output(\n153:     fmt,\n154:     {\n155:       tmux_sessions_killed: killed,\n156:       worktrees_removed: removed,\n157:       state_removed: stateRemoved,\n158:       logs_removed: logsRemoved,\n159:       remaining_branches: remainingBranches,\n160:     },\n161:     () => {\n162:       console.log(\"\\nCleanup complete.\");\n163:     }\n164:   );\n165: }\n\n(End of file - total 165 lines)\n</content>","title":"src/commands/cleanup.ts","metadata":{"preview":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: wombo cleanup\n *\n * Kills tmux sessions, removes worktrees, removes state and log files.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { killAllTmuxSessions } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees } from \"../lib/worktree.js\";\nimport { output, type OutputFormat } from \"../lib/output.js\";\n\nexport interface CleanupOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  dryRun?: boolean;","truncated":false,"loaded":[]},"time":{"start":1773246673652,"end":1773246673654}}}}
{"type":"tool_use","timestamp":1773246673859,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcf34f001GOtUIaVH67jpUW","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcdeac001T9mmebPVclbhwy","type":"tool","callID":"toolu_01WgyJ9yGYW7Ty57EQPDmM6A","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/verify.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/verify.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * verify.ts — Run build verification on completed agents.\n3:  *\n4:  * Usage: wombo verify [feature-id]\n5:  *\n6:  * Runs the build command in each completed agent's worktree. If a specific\n7:  * feature-id is given, verifies only that agent. Otherwise verifies all\n8:  * agents with status \"completed\".\n9:  */\n10: \n11: import type { WomboConfig } from \"../config.js\";\n12: import { loadFeatures } from \"../lib/features.js\";\n13: import { loadState, saveState } from \"../lib/state.js\";\n14: import { printDashboard } from \"../lib/ui.js\";\n15: import { handleBuildVerification } from \"./launch.js\";\n16: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export interface VerifyCommandOptions {\n23:   projectRoot: string;\n24:   config: WomboConfig;\n25:   featureId?: string;\n26:   model?: string;\n27:   maxRetries?: number;\n28:   outputFmt?: OutputFormat;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Command\n33: // ---------------------------------------------------------------------------\n34: \n35: export async function cmdVerify(opts: VerifyCommandOptions): Promise<void> {\n36:   const { projectRoot, config } = opts;\n37:   const fmt = opts.outputFmt ?? \"text\";\n38: \n39:   const state = loadState(projectRoot);\n40:   if (!state) {\n41:     outputMessage(fmt, \"No active wave.\", { active: false });\n42:     return;\n43:   }\n44: \n45:   const toVerify = opts.featureId\n46:     ? state.agents.filter((a) => a.feature_id === opts.featureId)\n47:     : state.agents.filter((a) => a.status === \"completed\");\n48: \n49:   if (toVerify.length === 0) {\n50:     outputMessage(fmt, \"No agents to verify.\", {\n51:       verified: [],\n52:       count: 0,\n53:     });\n54:     return;\n55:   }\n56: \n57:   if (fmt === \"text\") {\n58:     console.log(`\\nVerifying ${toVerify.length} agent(s)...\\n`);\n59:   }\n60: \n61:   const data = loadFeatures(projectRoot, config);\n62: \n63:   for (const agent of toVerify) {\n64:     const feature = data.features.find((f) => f.id === agent.feature_id);\n65:     if (!feature) continue;\n66: \n67:     await handleBuildVerification(projectRoot, state, agent, feature, config, opts.model);\n68:   }\n69: \n70:   const results = toVerify.map((a) => ({\n71:     feature_id: a.feature_id,\n72:     status: a.status,\n73:     build_passed: a.build_passed,\n74:     error: a.error,\n75:   }));\n76: \n77:   output(\n78:     fmt,\n79:     {\n80:       verified: results,\n81:       count: results.length,\n82:       wave_id: state.wave_id,\n83:     },\n84:     () => {\n85:       printDashboard(state);\n86:     }\n87:   );\n88: }\n\n(End of file - total 88 lines)\n</content>","title":"src/commands/verify.ts","metadata":{"preview":"/**\n * verify.ts — Run build verification on completed agents.\n *\n * Usage: wombo verify [feature-id]\n *\n * Runs the build command in each completed agent's worktree. If a specific\n * feature-id is given, verifies only that agent. Otherwise verifies all\n * agents with status \"completed\".\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures } from \"../lib/features.js\";\nimport { loadState, saveState } from \"../lib/state.js\";\nimport { printDashboard } from \"../lib/ui.js\";\nimport { handleBuildVerification } from \"./launch.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773246673851,"end":1773246673857}}}}
{"type":"tool_use","timestamp":1773246674263,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcf3be001EFJRAaJy26VKNA","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcdeac001T9mmebPVclbhwy","type":"tool","callID":"toolu_01Cx72ELeFjais9iZHe8zHXj","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/merge.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/merge.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * merge.ts — Merge verified branches into the base branch.\n3:  *\n4:  * Usage: wombo merge [feature-id]\n5:  *\n6:  * Merges all verified agents (or a specific one) into the base branch.\n7:  * After merging, cleans up the worktree as best-effort.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import {\n12:   loadState,\n13:   saveState,\n14:   updateAgent,\n15: } from \"../lib/state.js\";\n16: import { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\n17: import { removeWorktree } from \"../lib/worktree.js\";\n18: import { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\n19: import { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface MergeCommandOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   featureId?: string;\n29:   autoPush?: boolean;\n30:   dryRun?: boolean;\n31:   outputFmt?: OutputFormat;\n32: }\n33: \n34: // ---------------------------------------------------------------------------\n35: // Command\n36: // ---------------------------------------------------------------------------\n37: \n38: export async function cmdMerge(opts: MergeCommandOptions): Promise<void> {\n39:   const { projectRoot, config } = opts;\n40:   const fmt = opts.outputFmt ?? \"text\";\n41: \n42:   const state = loadState(projectRoot);\n43:   if (!state) {\n44:     outputMessage(fmt, \"No active wave.\", { active: false });\n45:     return;\n46:   }\n47: \n48:   const toMerge = opts.featureId\n49:     ? state.agents.filter(\n50:         (a) => a.feature_id === opts.featureId && a.status === \"verified\"\n51:       )\n52:     : state.agents.filter((a) => a.status === \"verified\");\n53: \n54:   if (toMerge.length === 0) {\n55:     outputMessage(fmt, \"No verified agents to merge.\", {\n56:       merged: [],\n57:       count: 0,\n58:     });\n59:     return;\n60:   }\n61: \n62:   // Dry-run: show what would be merged without merging\n63:   if (opts.dryRun) {\n64:     const dryRunData = toMerge.map((a) => ({\n65:       feature_id: a.feature_id,\n66:       branch: a.branch,\n67:     }));\n68: \n69:     output(\n70:       fmt,\n71:       {\n72:         dry_run: true,\n73:         merged: dryRunData,\n74:         count: toMerge.length,\n75:         auto_push: opts.autoPush ?? false,\n76:         base_branch: state.base_branch,\n77:       },\n78:       () => {\n79:         console.log(`\\n[dry-run] Would merge ${toMerge.length} branch(es):\\n`);\n80:         for (const agent of toMerge) {\n81:           console.log(`  ${agent.feature_id} — branch: ${agent.branch}`);\n82:         }\n83:         if (opts.autoPush) {\n84:           console.log(`\\n  Would push ${state.base_branch} to remote after merge.`);\n85:         }\n86:       }\n87:     );\n88:     return;\n89:   }\n90: \n91:   if (fmt === \"text\") {\n92:     console.log(`\\nMerging ${toMerge.length} branch(es)...\\n`);\n93:   }\n94: \n95:   const mergeResults: Array<{\n96:     feature_id: string;\n97:     branch: string;\n98:     success: boolean;\n99:     commit_hash?: string;\n100:     error?: string;\n101:   }> = [];\n102: \n103:   for (const agent of toMerge) {\n104:     if (fmt === \"text\") {\n105:       printAgentUpdate(agent, \"merging...\");\n106:     }\n107:     const result = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n108: \n109:     if (result.success) {\n110:       updateAgent(state, agent.feature_id, {\n111:         status: \"merged\",\n112:       });\n113:       saveState(projectRoot, state);\n114: \n115:       mergeResults.push({\n116:         feature_id: agent.feature_id,\n117:         branch: agent.branch,\n118:         success: true,\n119:         commit_hash: result.commitHash ?? undefined,\n120:       });\n121: \n122:       if (fmt === \"text\") {\n123:         printAgentUpdate(agent, `MERGED (${result.commitHash?.slice(0, 7)})`);\n124:       }\n125: \n126:       // Clean up worktree\n127:       try {\n128:         removeWorktree(projectRoot, agent.worktree, false);\n129:         if (fmt === \"text\") {\n130:           printAgentUpdate(agent, \"worktree removed\");\n131:         }\n132:       } catch {\n133:         // Not critical\n134:       }\n135:     } else {\n136:       mergeResults.push({\n137:         feature_id: agent.feature_id,\n138:         branch: agent.branch,\n139:         success: false,\n140:         error: result.error ?? undefined,\n141:       });\n142: \n143:       if (fmt === \"text\") {\n144:         printAgentUpdate(agent, `MERGE FAILED: ${result.error}`);\n145:       }\n146:     }\n147:   }\n148: \n149:   // Auto-push if requested\n150:   let pushed = false;\n151:   if (opts.autoPush) {\n152:     const anyMerged = state.agents.some((a) => a.status === \"merged\");\n153:     if (anyMerged) {\n154:       await pushBaseBranch(projectRoot, state.base_branch, config);\n155:       pushed = true;\n156:     }\n157:   }\n158: \n159:   output(\n160:     fmt,\n161:     {\n162:       merged: mergeResults,\n163:       count: mergeResults.filter((r) => r.success).length,\n164:       failed: mergeResults.filter((r) => !r.success).length,\n165:       wave_id: state.wave_id,\n166:       pushed,\n167:     },\n168:     () => {\n169:       printDashboard(state);\n170:     }\n171:   );\n172: }\n\n(End of file - total 172 lines)\n</content>","title":"src/commands/merge.ts","metadata":{"preview":"/**\n * merge.ts — Merge verified branches into the base branch.\n *\n * Usage: wombo merge [feature-id]\n *\n * Merges all verified agents (or a specific one) into the base branch.\n * After merging, cleans up the worktree as best-effort.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\nimport { removeWorktree } from \"../lib/worktree.js\";\nimport { printDashboard, printAgentUpdate } from \"../lib/ui.js\";\nimport { output, outputMessage, type OutputFormat } from \"../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773246674260,"end":1773246674262}}}}
{"type":"tool_use","timestamp":1773246674670,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcf5c8001A3qQIPlqDxuU2h","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcdeac001T9mmebPVclbhwy","type":"tool","callID":"toolu_01BVoNrSVNs2B1ncMHgwMGDp","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: wombo resume [options]\n5:  *\n6:  * Restores from .wombo-state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/features.js\";\n14: import { loadFeatures } from \"../lib/features.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   isWaveComplete,\n21:   type WaveState,\n22:   type AgentState,\n23: } from \"../lib/state.js\";\n24: import {\n25:   createWorktree,\n26:   installDeps,\n27:   worktreeReady,\n28:   log as wtLog,\n29: } from \"../lib/worktree.js\";\n30: import { generatePrompt } from \"../lib/prompt.js\";\n31: import {\n32:   launchInteractive,\n33:   isProcessRunning,\n34: } from \"../lib/launcher.js\";\n35: import { ProcessMonitor } from \"../lib/monitor.js\";\n36: import { pushBaseBranch } from \"../lib/merger.js\";\n37: import { printDashboard } from \"../lib/ui.js\";\n38: import { WomboTUI } from \"../lib/tui.js\";\n39: import {\n40:   launchSingleHeadless,\n41:   handleBuildVerification,\n42:   handleRetry,\n43:   launchNextQueued,\n44: } from \"./launch.js\";\n45: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n46: \n47: // ---------------------------------------------------------------------------\n48: // Types\n49: // ---------------------------------------------------------------------------\n50: \n51: export interface ResumeCommandOptions {\n52:   projectRoot: string;\n53:   config: WomboConfig;\n54:   maxConcurrent?: number;\n55:   model?: string;\n56:   interactive: boolean;\n57:   noTui: boolean;\n58:   autoPush: boolean;\n59:   baseBranch?: string;\n60:   maxRetries?: number;\n61:   outputFmt?: import(\"../lib/output.js\").OutputFormat;\n62: }\n63: \n64: // ---------------------------------------------------------------------------\n65: // Command\n66: // ---------------------------------------------------------------------------\n67: \n68: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n69:   const { projectRoot, config } = opts;\n70:   const fmt = opts.outputFmt ?? \"text\";\n71: \n72:   const state = loadState(projectRoot);\n73:   if (!state) {\n74:     outputError(fmt, \"No wave state found. Use 'wombo launch' to start a new wave.\");\n75:     return; // unreachable — helps TypeScript narrow\n76:   }\n77: \n78:   if (fmt === \"text\") {\n79:     console.log(`\\n--- Wombo: Resume ${state.wave_id} ---\\n`);\n80:   }\n81: \n82:   // Load feature data for prompt generation\n83:   const data = loadFeatures(projectRoot, config);\n84:   const featureMap = new Map(data.features.map((f) => [f.id, f]));\n85: \n86:   // Triage agents by current state\n87:   let toRelaunch: AgentState[] = [];\n88:   let toVerify: AgentState[] = [];\n89: \n90:   for (const agent of state.agents) {\n91:     switch (agent.status) {\n92:       case \"running\":\n93:       case \"installing\":\n94:       case \"retry\":\n95:         // Was in-flight when we stopped — check if PID is still alive\n96:         if (agent.pid && isProcessRunning(agent.pid)) {\n97:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n98:         } else {\n99:           // Process is dead — check if worktree has meaningful changes\n100:           if (worktreeReady(agent.worktree)) {\n101:             // Worktree exists, try build verification first\n102:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, worktree exists — will verify build`);\n103:             toVerify.push(agent);\n104:           } else {\n105:             // Worktree gone or incomplete — re-launch from scratch\n106:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, no worktree — will re-launch`);\n107:             updateAgent(state, agent.feature_id, {\n108:               status: \"queued\",\n109:               pid: null,\n110:               activity: null,\n111:               session_id: null,\n112:             });\n113:             toRelaunch.push(agent);\n114:           }\n115:         }\n116:         break;\n117: \n118:       case \"queued\":\n119:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: queued — will launch`);\n120:         toRelaunch.push(agent);\n121:         break;\n122: \n123:       case \"completed\":\n124:         // Completed but not verified — verify\n125:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: completed — will verify build`);\n126:         toVerify.push(agent);\n127:         break;\n128: \n129:       case \"verified\":\n130:       case \"merged\":\n131:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: ${agent.status} — nothing to do`);\n132:         break;\n133: \n134:       case \"failed\":\n135:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed — skipping (use 'wombo retry' to re-run)`);\n136:         break;\n137:     }\n138:   }\n139: \n140:   saveState(projectRoot, state);\n141: \n142:   // Run build verification on agents that were mid-flight\n143:   for (const agent of toVerify) {\n144:     const feature = featureMap.get(agent.feature_id);\n145:     if (!feature) continue;\n146:     if (fmt === \"text\") console.log(`\\n  Verifying ${agent.feature_id}...`);\n147:     try {\n148:       await handleBuildVerification(projectRoot, state, agent, feature, config, opts.model);\n149:     } catch (err: any) {\n150:       if (fmt === \"text\") console.log(`  Verify error for ${agent.feature_id}: ${err.message}`);\n151:     }\n152: \n153:     // If build failed and retries remain, queue for re-launch\n154:     if (agent.status === \"retry\" || agent.status === \"running\") {\n155:       toRelaunch.push(agent);\n156:     }\n157:   }\n158: \n159:   // Re-launch agents\n160:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n161:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n162:   if (toLaunchNow.length === 0) {\n163:     if (fmt === \"json\") {\n164:       console.log(JSON.stringify({\n165:         wave_id: state.wave_id,\n166:         relaunched: 0,\n167:         verified: toVerify.length,\n168:         agents: state.agents.map((a) => ({\n169:           feature_id: a.feature_id,\n170:           status: a.status,\n171:         })),\n172:         message: \"No agents need (re)launching.\",\n173:       }));\n174:     } else {\n175:       console.log(\"\\nNo agents need (re)launching.\");\n176:       printDashboard(state);\n177:     }\n178:     return;\n179:   }\n180: \n181:   if (fmt === \"text\") {\n182:     console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n183:     printDashboard(state);\n184:   }\n185: \n186:   const model = opts.model ?? state.model ?? undefined;\n187: \n188:   if (opts.interactive) {\n189:     // Interactive resume\n190:     await Promise.all(\n191:       toLaunchNow.map(async (agent) => {\n192:         const feature = featureMap.get(agent.feature_id);\n193:         if (!feature) return;\n194: \n195:         updateAgent(state, agent.feature_id, {\n196:           status: \"installing\",\n197:           started_at: new Date().toISOString(),\n198:           activity: \"resuming...\",\n199:         });\n200:         saveState(projectRoot, state);\n201: \n202:         try {\n203:           if (!worktreeReady(agent.worktree)) {\n204:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n205:             await installDeps(agent.worktree, agent.feature_id, config);\n206:           }\n207: \n208:           const prompt = generatePrompt(feature, state.base_branch, config);\n209:           const result = launchInteractive({\n210:             worktreePath: agent.worktree,\n211:             featureId: feature.id,\n212:             prompt,\n213:             model,\n214:             interactive: true,\n215:             config,\n216:           });\n217: \n218:           updateAgent(state, agent.feature_id, {\n219:             status: \"running\",\n220:             pid: result.pid,\n221:             activity: \"tmux session active\",\n222:           });\n223:           saveState(projectRoot, state);\n224:         } catch (err: any) {\n225:           updateAgent(state, agent.feature_id, {\n226:             status: \"failed\",\n227:             error: err.message,\n228:             activity: null,\n229:             completed_at: new Date().toISOString(),\n230:           });\n231:           saveState(projectRoot, state);\n232:         }\n233:       })\n234:     );\n235: \n236:     if (fmt === \"json\") {\n237:       console.log(JSON.stringify({\n238:         wave_id: state.wave_id,\n239:         relaunched: toLaunchNow.length,\n240:         mode: \"interactive\",\n241:         agents: state.agents.map((a) => ({\n242:           feature_id: a.feature_id,\n243:           status: a.status,\n244:         })),\n245:         message: \"Resume complete.\",\n246:       }));\n247:     } else {\n248:       printDashboard(state);\n249:       console.log(`\\nResume complete. Use 'tmux attach -t ${config.agent.tmuxPrefix}-<id>' to check sessions.`);\n250:     }\n251:   } else {\n252:     // Headless resume — re-enter monitoring loop\n253:     const monitor = new ProcessMonitor(projectRoot, {\n254:       onSessionId: (featureId, sessionId) => {\n255:         updateAgent(state, featureId, { session_id: sessionId });\n256:         saveState(projectRoot, state);\n257:       },\n258:       onComplete: (featureId) => {\n259:         updateAgent(state, featureId, {\n260:           status: \"completed\",\n261:           completed_at: new Date().toISOString(),\n262:           activity: \"done\",\n263:         });\n264:         saveState(projectRoot, state);\n265:         wtLog(featureId, \"agent completed — verifying build...\");\n266: \n267:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n268:         const feature = featureMap.get(featureId)!;\n269:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n270:           .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n271:           .catch((err) => {\n272:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n273:             launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n274:           });\n275:       },\n276:       onError: (featureId, error) => {\n277:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n278:         if (agent.retries < agent.max_retries) {\n279:           updateAgent(state, featureId, {\n280:             status: \"retry\",\n281:             retries: agent.retries + 1,\n282:             error,\n283:             activity: \"retrying...\",\n284:           });\n285:           saveState(projectRoot, state);\n286:           handleRetry(projectRoot, state, agent, monitor, config, model);\n287:         } else {\n288:           updateAgent(state, featureId, {\n289:             status: \"failed\",\n290:             error,\n291:             activity: null,\n292:             completed_at: new Date().toISOString(),\n293:           });\n294:           saveState(projectRoot, state);\n295:         }\n296:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n297:       },\n298:       onActivity: (featureId, activity) => {\n299:         updateAgent(state, featureId, {\n300:           activity,\n301:           activity_updated_at: new Date().toISOString(),\n302:         });\n303:       },\n304:     });\n305: \n306:     // Handle graceful shutdown\n307:     const tuiRef = { current: null as WomboTUI | null };\n308:     process.on(\"SIGINT\", () => {\n309:       if (tuiRef.current) tuiRef.current.stop();\n310:       for (const agent of state.agents) {\n311:         if (agent.status === \"running\") {\n312:           updateAgent(state, agent.feature_id, {\n313:             activity: \"interrupted\",\n314:           });\n315:         }\n316:       }\n317:       monitor.killAll();\n318:       saveState(projectRoot, state);\n319:       console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n320:       process.exit(0);\n321:     });\n322: \n323:     await Promise.all(\n324:       toLaunchNow.map((agent) => {\n325:         const feature = featureMap.get(agent.feature_id);\n326:         if (!feature) return Promise.resolve();\n327:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n328:       })\n329:     );\n330: \n331:     // Start TUI dashboard (or skip if --no-tui)\n332:     if (!opts.noTui) {\n333:       tuiRef.current = new WomboTUI({\n334:         state,\n335:         monitor,\n336:         projectRoot,\n337:         interactive: false,\n338:         config,\n339:         onQuit: () => {\n340:           for (const agent of state.agents) {\n341:             if (agent.status === \"running\") {\n342:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n343:             }\n344:           }\n345:           monitor.killAll();\n346:           saveState(projectRoot, state);\n347:           console.log(\"State saved. Use 'wombo resume' to continue.\");\n348:           process.exit(0);\n349:         },\n350:       });\n351:       tuiRef.current.start();\n352:     } else {\n353:       console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n354:       printDashboard(state);\n355:     }\n356: \n357:     // Monitoring loop\n358:     const POLL_INTERVAL = 5000;\n359:     let dashboardCounter = 0;\n360:     while (!isWaveComplete(state)) {\n361:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n362: \n363:       for (const agent of state.agents) {\n364:         if (\n365:           agent.status === \"running\" &&\n366:           agent.pid &&\n367:           !isProcessRunning(agent.pid) &&\n368:           !monitor.isRunning(agent.feature_id)\n369:         ) {\n370:           updateAgent(state, agent.feature_id, {\n371:             status: \"completed\",\n372:             completed_at: new Date().toISOString(),\n373:             activity: \"done\",\n374:           });\n375:           saveState(projectRoot, state);\n376:           const feature = featureMap.get(agent.feature_id)!;\n377:           try {\n378:             await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n379:           } catch (err: any) {\n380:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n381:           }\n382:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n383:         }\n384:       }\n385: \n386:       saveState(projectRoot, state);\n387:       if (tuiRef.current) {\n388:         tuiRef.current.updateState(state);\n389:       } else if (opts.noTui) {\n390:         dashboardCounter++;\n391:         if (dashboardCounter % 3 === 0) {\n392:           printDashboard(state);\n393:         }\n394:       }\n395:     }\n396: \n397:     if (tuiRef.current) tuiRef.current.stop();\n398:     printDashboard(state);\n399: \n400:     // Auto-push base branch if requested\n401:     if (opts.autoPush) {\n402:       await pushBaseBranch(projectRoot, state.base_branch, config);\n403:     }\n404: \n405:     console.log(\"Wave complete.\");\n406:   }\n407: }\n\n(End of file - total 407 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: wombo resume [options]\n *\n * Restores from .wombo-state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/features.js\";\nimport { loadFeatures } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  isWaveComplete,","truncated":false,"loaded":[]},"time":{"start":1773246674667,"end":1773246674670}}}}
{"type":"tool_use","timestamp":1773246675096,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddbcf6ec001reamwFqtYZBZ9B","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddbcdeac001T9mmebPVclbhwy","type":"tool","callID":"toolu_0146qESytbVjpVxkt1nCzpXi","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/retry.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/retry.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * retry.ts — Retry a specific failed agent.\n3:  *\n4:  * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n5:  *\n6:  * Resets the agent's retry count and re-launches it. Can launch in either\n7:  * headless mode (default) or interactive (tmux) mode.\n8:  */\n9: \n10: import type { WomboConfig } from \"../config.js\";\n11: import { loadFeatures, type Feature } from \"../lib/features.js\";\n12: import {\n13:   loadState,\n14:   saveState,\n15:   updateAgent,\n16: } from \"../lib/state.js\";\n17: import { worktreeReady } from \"../lib/worktree.js\";\n18: import { generatePrompt } from \"../lib/prompt.js\";\n19: import { launchInteractive } from \"../lib/launcher.js\";\n20: import { ProcessMonitor } from \"../lib/monitor.js\";\n21: import { launchSingleHeadless } from \"./launch.js\";\n22: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n23: \n24: // ---------------------------------------------------------------------------\n25: // Types\n26: // ---------------------------------------------------------------------------\n27: \n28: export interface RetryCommandOptions {\n29:   projectRoot: string;\n30:   config: WomboConfig;\n31:   featureId: string;\n32:   model?: string;\n33:   interactive: boolean;\n34:   dryRun?: boolean;\n35:   outputFmt?: OutputFormat;\n36: }\n37: \n38: // ---------------------------------------------------------------------------\n39: // Command\n40: // ---------------------------------------------------------------------------\n41: \n42: export async function cmdRetry(opts: RetryCommandOptions): Promise<void> {\n43:   const { projectRoot, config } = opts;\n44:   const fmt = opts.outputFmt ?? \"text\";\n45: \n46:   if (!opts.featureId) {\n47:     outputError(fmt, \"Usage: wombo retry <feature-id>\");\n48:     return; // unreachable — helps TypeScript narrow\n49:   }\n50: \n51:   const state = loadState(projectRoot);\n52:   if (!state) {\n53:     outputMessage(fmt, \"No active wave.\", { active: false });\n54:     return;\n55:   }\n56: \n57:   const agent = state.agents.find((a) => a.feature_id === opts.featureId);\n58:   if (!agent) {\n59:     outputError(fmt, `Agent not found for feature: ${opts.featureId}`);\n60:     return; // unreachable — helps TypeScript narrow\n61:   }\n62: \n63:   if (agent.status !== \"failed\") {\n64:     outputError(\n65:       fmt,\n66:       `Agent ${opts.featureId} is not in failed state (current: ${agent.status})`\n67:     );\n68:     return; // unreachable — helps TypeScript narrow\n69:   }\n70: \n71:   // Dry-run: show what would be retried without doing it\n72:   if (opts.dryRun) {\n73:     output(\n74:       fmt,\n75:       {\n76:         dry_run: true,\n77:         feature_id: opts.featureId,\n78:         status: agent.status,\n79:         retries: agent.retries,\n80:         worktree: agent.worktree,\n81:         mode: opts.interactive ? \"interactive\" : \"headless\",\n82:         model: opts.model ?? null,\n83:       },\n84:       () => {\n85:         console.log(`\\n[dry-run] Would retry agent: ${opts.featureId}`);\n86:         console.log(`  Current status: ${agent.status}`);\n87:         console.log(`  Retries so far: ${agent.retries}`);\n88:         console.log(`  Worktree: ${agent.worktree}`);\n89:         console.log(`  Mode: ${opts.interactive ? \"interactive (tmux)\" : \"headless\"}`);\n90:         if (opts.model) console.log(`  Model: ${opts.model}`);\n91:       }\n92:     );\n93:     return;\n94:   }\n95: \n96:   // Reset retry count and re-run\n97:   updateAgent(state, agent.feature_id, {\n98:     status: \"queued\",\n99:     retries: 0,\n100:     error: null,\n101:     build_passed: null,\n102:     build_output: null,\n103:     completed_at: null,\n104:   });\n105:   saveState(projectRoot, state);\n106: \n107:   const data = loadFeatures(projectRoot, config);\n108:   const feature = data.features.find((f) => f.id === opts.featureId);\n109:   if (!feature) {\n110:     outputError(fmt, `Feature ${opts.featureId} not found in ${config.featuresFile}`);\n111:     return; // unreachable — helps TypeScript narrow\n112:   }\n113: \n114:   if (opts.interactive) {\n115:     const prompt = generatePrompt(feature, state.base_branch, config);\n116:     launchInteractive({\n117:       worktreePath: agent.worktree,\n118:       featureId: feature.id,\n119:       prompt,\n120:       model: opts.model,\n121:       interactive: true,\n122:       config,\n123:     });\n124: \n125:     updateAgent(state, agent.feature_id, {\n126:       status: \"running\",\n127:       started_at: new Date().toISOString(),\n128:     });\n129:     saveState(projectRoot, state);\n130: \n131:     outputMessage(\n132:       fmt,\n133:       `Retrying ${opts.featureId} in tmux session ${config.agent.tmuxPrefix}-${opts.featureId}`,\n134:       {\n135:         feature_id: opts.featureId,\n136:         mode: \"interactive\",\n137:         status: \"running\",\n138:         session: `${config.agent.tmuxPrefix}-${opts.featureId}`,\n139:       }\n140:     );\n141:   } else {\n142:     const monitor = new ProcessMonitor(projectRoot);\n143:     await launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, opts.model);\n144: \n145:     outputMessage(\n146:       fmt,\n147:       `Retrying ${opts.featureId} in headless mode`,\n148:       {\n149:         feature_id: opts.featureId,\n150:         mode: \"headless\",\n151:         status: agent.status,\n152:       }\n153:     );\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/commands/retry.ts","metadata":{"preview":"/**\n * retry.ts — Retry a specific failed agent.\n *\n * Usage: wombo retry <feature-id> [--interactive] [--model <model>]\n *\n * Resets the agent's retry count and re-launches it. Can launch in either\n * headless mode (default) or interactive (tmux) mode.\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport { loadFeatures, type Feature } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n} from \"../lib/state.js\";\nimport { worktreeReady } from \"../lib/worktree.js\";\nimport { generatePrompt } from \"../lib/prompt.js\";\nimport { launchInteractive } from \"../lib/launcher.js\";\nimport { ProcessMonitor } from \"../lib/monitor.js\";","truncated":false,"loaded":[]},"time":{"start":1773246675088,"end":1773246675095}}}}
