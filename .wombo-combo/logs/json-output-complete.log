{"type":"tool_use","timestamp":1773245545559,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cddabbb44002vxWnXSQUQ5dkL6","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cddabaef2001NrDVKyirokkNQJ","type":"tool","callID":"toolu_01VQiNRHxXFLdCNmdQGUV7yq","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/upgrade.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/upgrade.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * upgrade.ts — Self-upgrade wombo from GitHub.\n3:  *\n4:  * Usage:\n5:  *   wombo upgrade              # Check for updates and prompt to install\n6:  *   wombo upgrade --force      # Skip confirmation prompt\n7:  *   wombo upgrade --version v0.1.0  # Install a specific version\n8:  *   wombo upgrade --check      # Only check, don't install\n9:  */\n10: \n11: import { readFileSync } from \"node:fs\";\n12: import { resolve } from \"node:path\";\n13: import { createInterface } from \"node:readline\";\n14: import { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export interface UpgradeOptions {\n21:   force: boolean;\n22:   version?: string;\n23:   checkOnly: boolean;\n24:   outputFmt?: import(\"../lib/output.js\").OutputFormat;\n25: }\n26: \n27: // ---------------------------------------------------------------------------\n28: // Helpers\n29: // ---------------------------------------------------------------------------\n30: \n31: const REPO = \"fulgidus/wombo\";\n32: \n33: /**\n34:  * Get the locally installed version from package.json.\n35:  * Uses import.meta to find the package.json relative to this source file,\n36:  * which works whether running from local source or global install.\n37:  */\n38: function getLocalVersion(): string {\n39:   const pkgPath = resolve(import.meta.dir, \"../../package.json\");\n40:   const raw = readFileSync(pkgPath, \"utf-8\");\n41:   return JSON.parse(raw).version as string;\n42: }\n43: \n44: /**\n45:  * Fetch all v* tags from the remote GitHub repo using git ls-remote.\n46:  * Returns tags sorted by semver descending (latest first).\n47:  */\n48: async function fetchRemoteTags(): Promise<string[]> {\n49:   const proc = Bun.spawn([\"git\", \"ls-remote\", \"--tags\", `https://github.com/${REPO}.git`], {\n50:     stdout: \"pipe\",\n51:     stderr: \"pipe\",\n52:   });\n53: \n54:   const stdout = await new Response(proc.stdout).text();\n55:   const exitCode = await proc.exited;\n56: \n57:   if (exitCode !== 0) {\n58:     const stderr = await new Response(proc.stderr).text();\n59:     throw new Error(`Failed to fetch remote tags: ${stderr.trim()}`);\n60:   }\n61: \n62:   // Parse lines like: \"abc123\\trefs/tags/v0.0.1\"\n63:   const tags: string[] = [];\n64:   for (const line of stdout.split(\"\\n\")) {\n65:     const match = line.match(/refs\\/tags\\/(v\\d+\\.\\d+\\.\\d+)$/);\n66:     if (match) {\n67:       tags.push(match[1]);\n68:     }\n69:   }\n70: \n71:   // Sort descending by semver\n72:   tags.sort((a, b) => {\n73:     const pa = a.slice(1).split(\".\").map(Number);\n74:     const pb = b.slice(1).split(\".\").map(Number);\n75:     for (let i = 0; i < 3; i++) {\n76:       if (pa[i] !== pb[i]) return pb[i] - pa[i];\n77:     }\n78:     return 0;\n79:   });\n80: \n81:   return tags;\n82: }\n83: \n84: /**\n85:  * Compare two semver strings. Returns:\n86:  *   -1 if a < b\n87:  *    0 if a === b\n88:  *    1 if a > b\n89:  */\n90: function compareSemver(a: string, b: string): number {\n91:   const pa = a.replace(/^v/, \"\").split(\".\").map(Number);\n92:   const pb = b.replace(/^v/, \"\").split(\".\").map(Number);\n93:   for (let i = 0; i < 3; i++) {\n94:     if (pa[i] < pb[i]) return -1;\n95:     if (pa[i] > pb[i]) return 1;\n96:   }\n97:   return 0;\n98: }\n99: \n100: /**\n101:  * Prompt the user for yes/no confirmation.\n102:  */\n103: async function confirm(message: string): Promise<boolean> {\n104:   if (!process.stdin.isTTY) return false;\n105: \n106:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n107:   return new Promise<boolean>((resolve) => {\n108:     rl.question(`${message} [y/N] `, (answer) => {\n109:       rl.close();\n110:       resolve(answer.trim().toLowerCase() === \"y\");\n111:     });\n112:   });\n113: }\n114: \n115: // ---------------------------------------------------------------------------\n116: // Command\n117: // ---------------------------------------------------------------------------\n118: \n119: export async function cmdUpgrade(opts: UpgradeOptions): Promise<void> {\n120:   const fmt = opts.outputFmt ?? \"text\";\n121:   const localVersion = getLocalVersion();\n122: \n123:   if (fmt === \"text\") {\n124:     console.log(`Current version: v${localVersion}`);\n125:   }\n126: \n127:   // If a specific version is requested, skip the check\n128:   if (opts.version) {\n129:     const targetTag = opts.version.startsWith(\"v\") ? opts.version : `v${opts.version}`;\n130: \n131:     if (fmt === \"text\") {\n132:       console.log(`Requested version: ${targetTag}`);\n133:     }\n134: \n135:     if (compareSemver(localVersion, targetTag) === 0) {\n136:       outputMessage(fmt, \"Already at the requested version.\", {\n137:         current_version: `v${localVersion}`,\n138:         target_version: targetTag,\n139:         up_to_date: true,\n140:       });\n141:       return;\n142:     }\n143: \n144:     if (!opts.force && fmt !== \"json\") {\n145:       const ok = await confirm(`Install ${targetTag}?`);\n146:       if (!ok) {\n147:         outputMessage(fmt, \"Upgrade cancelled.\", {\n148:           current_version: `v${localVersion}`,\n149:           target_version: targetTag,\n150:           cancelled: true,\n151:         });\n152:         return;\n153:       }\n154:     }\n155: \n156:     await installVersion(targetTag, fmt);\n157:     return;\n158:   }\n159: \n160:   // Fetch latest from GitHub\n161:   if (fmt === \"text\") {\n162:     console.log(`Checking for updates from github.com/${REPO}...`);\n163:   }\n164: \n165:   let tags: string[];\n166:   try {\n167:     tags = await fetchRemoteTags();\n168:   } catch (err: any) {\n169:     outputError(fmt, `Failed to check for updates: ${err.message}`);\n170:     return;\n171:   }\n172: \n173:   if (tags.length === 0) {\n174:     outputError(fmt, \"No release tags found on the remote repository.\");\n175:     return;\n176:   }\n177: \n178:   const latestTag = tags[0];\n179:   const latestVersion = latestTag.slice(1); // strip 'v'\n180: \n181:   if (fmt === \"text\") {\n182:     console.log(`Latest version:  ${latestTag}`);\n183:   }\n184: \n185:   const cmp = compareSemver(localVersion, latestVersion);\n186:   if (cmp >= 0) {\n187:     outputMessage(fmt, \"You are already up to date.\", {\n188:       current_version: `v${localVersion}`,\n189:       latest_version: latestTag,\n190:       up_to_date: true,\n191:     });\n192:     return;\n193:   }\n194: \n195:   if (opts.checkOnly) {\n196:     output(\n197:       fmt,\n198:       {\n199:         current_version: `v${localVersion}`,\n200:         latest_version: latestTag,\n201:         update_available: true,\n202:         up_to_date: false,\n203:       },\n204:       () => {\n205:         console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n206:         console.log(`Run 'wombo upgrade' to install.`);\n207:       }\n208:     );\n209:     return;\n210:   }\n211: \n212:   if (fmt === \"text\") {\n213:     console.log(`\\nUpdate available: v${localVersion} → ${latestTag}`);\n214:   }\n215: \n216:   if (!opts.force && fmt !== \"json\") {\n217:     const ok = await confirm(`Upgrade to ${latestTag}?`);\n218:     if (!ok) {\n219:       outputMessage(fmt, \"Upgrade cancelled.\", {\n220:         current_version: `v${localVersion}`,\n221:         latest_version: latestTag,\n222:         cancelled: true,\n223:       });\n224:       return;\n225:     }\n226:   }\n227: \n228:   await installVersion(latestTag, fmt);\n229: }\n230: \n231: async function installVersion(tag: string): Promise<void> {\n232:   console.log(`\\nInstalling wombo@${tag}...`);\n233: \n234:   const proc = Bun.spawn(\n235:     [\"bun\", \"install\", \"-g\", `github:${REPO}#${tag}`],\n236:     {\n237:       stdout: \"inherit\",\n238:       stderr: \"inherit\",\n239:     }\n240:   );\n241: \n242:   const exitCode = await proc.exited;\n243: \n244:   if (exitCode !== 0) {\n245:     console.error(`\\nInstallation failed (exit code ${exitCode}).`);\n246:     process.exit(1);\n247:     return;\n248:   }\n249: \n250:   console.log(`\\nSuccessfully upgraded to ${tag}.`);\n251: }\n\n(End of file - total 251 lines)\n</content>","title":"src/commands/upgrade.ts","metadata":{"preview":"/**\n * upgrade.ts — Self-upgrade wombo from GitHub.\n *\n * Usage:\n *   wombo upgrade              # Check for updates and prompt to install\n *   wombo upgrade --force      # Skip confirmation prompt\n *   wombo upgrade --version v0.1.0  # Install a specific version\n *   wombo upgrade --check      # Only check, don't install\n */\n\nimport { readFileSync } from \"node:fs\";\nimport { resolve } from \"node:path\";\nimport { createInterface } from \"node:readline\";\nimport { output, outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface UpgradeOptions {","truncated":false,"loaded":[]},"time":{"start":1773245545553,"end":1773245545558}}}}
{"type":"tool_use","timestamp":1773245546409,"sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","part":{"id":"prt_cddabbc520010Kn76RL9QwF6q1","sessionID":"ses_3225b067cffelwLK8Sy8mv6BSq","messageID":"msg_cddabaef2001NrDVKyirokkNQJ","type":"tool","callID":"toolu_012qSbG9zuJSd8Q56CZRtAE3","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo cleanup\n21:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n22:  *   wombo features add <id> <title> [options]\n23:  *   wombo features set-status <feature-id> <status>\n24:  *   wombo features check\n25:  *   wombo features archive [feature-id] [--dry-run]\n26:  *   wombo features show <feature-id>\n27:  *   wombo help\n28:  */\n29: \n30: import { resolve } from \"node:path\";\n31: import { existsSync, readFileSync } from \"node:fs\";\n32: import { loadConfig, validateConfig } from \"./config.js\";\n33: import { loadState, saveState } from \"./lib/state.js\";\n34: \n35: // ---------------------------------------------------------------------------\n36: // Dev-mode guard: warn if running the global binary inside the wombo repo\n37: // ---------------------------------------------------------------------------\n38: \n39: function checkDevModeGuard(): void {\n40:   const cwd = process.cwd();\n41:   const pkgPath = resolve(cwd, \"package.json\");\n42: \n43:   // Are we inside the wombo repo?\n44:   if (!existsSync(pkgPath)) return;\n45: \n46:   let pkgName: string | undefined;\n47:   try {\n48:     const raw = readFileSync(pkgPath, \"utf-8\");\n49:     pkgName = JSON.parse(raw).name;\n50:   } catch {\n51:     return;\n52:   }\n53:   if (pkgName !== \"wombo\") return;\n54: \n55:   // We're in the wombo repo. Is the source being run from a different location?\n56:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n57:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n58:   // we're running the globally installed binary.\n59:   const sourceDir = resolve(import.meta.dir);\n60:   const projectSrc = resolve(cwd, \"src\");\n61: \n62:   if (!sourceDir.startsWith(projectSrc)) {\n63:     console.warn(\n64:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n65:       \"inside the wombo repo.\\n\" +\n66:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n67:       \"  See AGENTS.md for details.\\n\"\n68:     );\n69:   }\n70: }\n71: \n72: import { cmdInit } from \"./commands/init.js\";\n73: import { cmdLaunch } from \"./commands/launch.js\";\n74: import { cmdResume } from \"./commands/resume.js\";\n75: import { cmdStatus } from \"./commands/status.js\";\n76: import { cmdVerify } from \"./commands/verify.js\";\n77: import { cmdMerge } from \"./commands/merge.js\";\n78: import { cmdRetry } from \"./commands/retry.js\";\n79: import { cmdCleanup } from \"./commands/cleanup.js\";\n80: import { cmdUpgrade } from \"./commands/upgrade.js\";\n81: import { cmdFeaturesList } from \"./commands/features/list.js\";\n82: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n83: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n84: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n85: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n86: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n87: \n88: import { ensureFeaturesFile } from \"./lib/features.js\";\n89: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n90: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n91: import { validateId, validateText, validateBranchName, validateDuration, assertValid } from \"./lib/validate.js\";\n92: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n93: \n94: // ---------------------------------------------------------------------------\n95: // Types\n96: // ---------------------------------------------------------------------------\n97: \n98: interface CLIArgs {\n99:   command: string;\n100:   subcommand?: string;\n101:   // Selection options (launch)\n102:   topPriority?: number;\n103:   quickestWins?: number;\n104:   priority?: Priority;\n105:   difficulty?: Difficulty;\n106:   features?: string[];\n107:   allReady?: boolean;\n108:   // Launch / runtime options\n109:   maxConcurrent?: number;\n110:   model?: string;\n111:   interactive: boolean;\n112:   dryRun: boolean;\n113:   baseBranch?: string;\n114:   maxRetries?: number;\n115:   noTui: boolean;\n116:   autoPush: boolean;\n117:   // General\n118:   featureId?: string;\n119:   force: boolean;\n120:   // Output format\n121:   outputFmt: OutputFormat;\n122:   // Upgrade options\n123:   checkOnly: boolean;\n124:   version?: string;\n125:   // Features subcommand extras\n126:   status?: string;\n127:   ready?: boolean;\n128:   includeArchive?: boolean;\n129:   title?: string;\n130:   description?: string;\n131:   effort?: string;\n132:   dependsOn?: string[];\n133:   // Compact output\n134:   fields?: string[];\n135: }\n136: \n137: // ---------------------------------------------------------------------------\n138: // Arg Parsing\n139: // ---------------------------------------------------------------------------\n140: \n141: function parseArgs(argv: string[]): CLIArgs {\n142:   const args = argv.slice(2); // skip 'bun' and script path\n143:   const result: CLIArgs = {\n144:     command: args[0] || \"help\",\n145:     interactive: false,\n146:     dryRun: false,\n147:     noTui: false,\n148:     autoPush: false,\n149:     force: false,\n150:     checkOnly: false,\n151:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n152:   };\n153: \n154:   // If the first arg is \"features\", treat the second positional as the subcommand\n155:   let startIdx = 1;\n156:   if (result.command === \"features\") {\n157:     result.subcommand = args[1] || \"list\";\n158:     startIdx = 2;\n159:   }\n160: \n161:   for (let i = startIdx; i < args.length; i++) {\n162:     const arg = args[i];\n163:     switch (arg) {\n164:       // --- Selection options ---\n165:       case \"--top-priority\":\n166:         result.topPriority = parseInt(args[++i], 10);\n167:         break;\n168:       case \"--quickest-wins\":\n169:         result.quickestWins = parseInt(args[++i], 10);\n170:         break;\n171:       case \"--priority\":\n172:         result.priority = args[++i] as Priority;\n173:         break;\n174:       case \"--difficulty\":\n175:         result.difficulty = args[++i] as Difficulty;\n176:         break;\n177:       case \"--features\":\n178:         result.features = args[++i].split(\",\").map((s) => s.trim());\n179:         break;\n180:       case \"--all-ready\":\n181:         result.allReady = true;\n182:         break;\n183: \n184:       // --- Launch / runtime options ---\n185:       case \"--max-concurrent\":\n186:         result.maxConcurrent = parseInt(args[++i], 10);\n187:         break;\n188:       case \"--model\":\n189:       case \"-m\":\n190:         result.model = args[++i];\n191:         break;\n192:       case \"--interactive\":\n193:         result.interactive = true;\n194:         break;\n195:       case \"--dry-run\":\n196:         result.dryRun = true;\n197:         break;\n198:       case \"--no-tui\":\n199:         result.noTui = true;\n200:         break;\n201:       case \"--auto-push\":\n202:         result.autoPush = true;\n203:         break;\n204:       case \"--base-branch\":\n205:         result.baseBranch = args[++i];\n206:         break;\n207:       case \"--max-retries\":\n208:         result.maxRetries = parseInt(args[++i], 10);\n209:         break;\n210: \n211:       // --- General flags ---\n212:       case \"--force\":\n213:         result.force = true;\n214:         break;\n215:       case \"--check\":\n216:         result.checkOnly = true;\n217:         break;\n218:       case \"--version\":\n219:         result.version = args[++i];\n220:         break;\n221:       case \"--output\":\n222:       case \"-o\":\n223:         result.outputFmt = resolveOutputFormat(args[++i]);\n224:         break;\n225: \n226:       // --- Features subcommand options ---\n227:       case \"--status\":\n228:         result.status = args[++i];\n229:         break;\n230:       case \"--ready\":\n231:         result.ready = true;\n232:         break;\n233:       case \"--include-archive\":\n234:         result.includeArchive = true;\n235:         break;\n236:       case \"--title\":\n237:         result.title = args[++i];\n238:         break;\n239:       case \"--description\":\n240:       case \"--desc\":\n241:         result.description = args[++i];\n242:         break;\n243:       case \"--effort\":\n244:         result.effort = args[++i];\n245:         break;\n246:       case \"--depends-on\":\n247:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n248:         break;\n249:       case \"--fields\":\n250:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n251:         break;\n252: \n253:       // --- Positional (feature-id, title for add, etc.) ---\n254:       default:\n255:         if (!arg.startsWith(\"-\")) {\n256:           if (!result.featureId) {\n257:             result.featureId = arg;\n258:           } else if (!result.title) {\n259:             result.title = arg;\n260:           }\n261:         }\n262:         break;\n263:     }\n264:   }\n265: \n266:   return result;\n267: }\n268: \n269: // ---------------------------------------------------------------------------\n270: // Help\n271: // ---------------------------------------------------------------------------\n272: \n273: function cmdHelp(): void {\n274:   console.log(`\n275: Wombo — AI Agent Orchestration System\n276: \n277:   WOMBO COMBO! Parallel feature development with AI agents.\n278: \n279: Commands:\n280:   init           Generate wombo.json config in the current project\n281:   launch         Launch a wave of agents to implement features\n282:   resume         Resume a previously stopped wave\n283:   status         Show the status of the current wave\n284:   verify         Run build verification on completed agents\n285:   merge          Merge verified branches into the base branch\n286:   retry          Retry a failed agent\n287:   cleanup        Remove all wave worktrees and tmux sessions\n288:   features       Manage .features.yml (see below)\n289:   upgrade        Check for updates and upgrade wombo\n290:   describe       Emit JSON schema of a command (for AI agents)\n291:   help           Show this help\n292: \n293: Features Subcommands:\n294:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n295:   features add <id> <title> [options]\n296:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n297:   features set-status <id> <status>\n298:                            Change a feature's status\n299:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n300:   features archive [id]    Move done/cancelled to archive (--dry-run)\n301:   features show <id>       Show feature details\n302: \n303: Selection Options (for launch):\n304:   --top-priority N         Select top N features by priority\n305:   --quickest-wins N        Select N features with lowest effort\n306:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n307:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n308:   --features \"id1,id2\"     Select specific features by ID\n309:   --all-ready              Select all features whose dependencies are met\n310: \n311: Launch Options:\n312:   --max-concurrent N       Max agents running in parallel (default: from config)\n313:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n314:   --interactive            Use tmux TUI mode instead of headless\n315:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n316:   --auto-push              Push base branch to remote after all merges complete\n317:   --dry-run                Show what would be launched without launching\n318:   --base-branch <branch>   Base branch (default: from config)\n319:   --max-retries N          Max retries per agent (default: from config)\n320: \n321: General:\n322:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n323:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n324:   -o <fmt>                 Alias for --output\n325:   --dry-run                Show what would happen without performing the action\n326:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n327: \n328: Upgrade Options:\n329:   --check                  Only check for updates, don't install\n330:   --version <tag>          Install a specific version (e.g., v0.1.0)\n331: \n332: Examples:\n333:   wombo init\n334:   wombo launch --quickest-wins 3\n335:   wombo launch --priority high --interactive\n336:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n337:   wombo resume\n338:   wombo status\n339:   wombo verify\n340:   wombo merge\n341:   wombo retry auth-flow\n342:   wombo cleanup\n343:   wombo features list --status ready --priority high\n344:   wombo features list --fields id,status,priority --output json\n345:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n346:   wombo features set-status my-feature in-progress\n347:   wombo features check\n348:   wombo features archive --dry-run\n349:   wombo features show my-feature\n350:   wombo describe                           # list all commands as JSON\n351:   wombo describe launch                    # describe a specific command\n352:   wombo describe features add              # describe a subcommand\n353: `);\n354: }\n355: \n356: // ---------------------------------------------------------------------------\n357: // Main\n358: // ---------------------------------------------------------------------------\n359: \n360: async function main(): Promise<void> {\n361:   checkDevModeGuard();\n362: \n363:   const PROJECT_ROOT = resolve(process.cwd());\n364:   const args = parseArgs(process.argv);\n365: \n366:   // -----------------------------------------------------------------------\n367:   // Input validation at the CLI boundary\n368:   // -----------------------------------------------------------------------\n369:   if (args.featureId) {\n370:     assertValid(validateId(args.featureId, \"feature ID\"));\n371:   }\n372:   if (args.title) {\n373:     assertValid(validateText(args.title, \"title\"));\n374:   }\n375:   if (args.description) {\n376:     assertValid(validateText(args.description, \"description\"));\n377:   }\n378:   if (args.baseBranch) {\n379:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n380:   }\n381:   if (args.effort) {\n382:     assertValid(validateDuration(args.effort, \"effort\"));\n383:   }\n384:   if (args.features) {\n385:     for (const fid of args.features) {\n386:       assertValid(validateId(fid, \"feature ID in --features\"));\n387:     }\n388:   }\n389:   if (args.dependsOn) {\n390:     for (const dep of args.dependsOn) {\n391:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n392:     }\n393:   }\n394: \n395:   // Commands that don't need config loading\n396:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n397:     cmdHelp();\n398:     return;\n399:   }\n400: \n401:   if (args.command === \"describe\") {\n402:     // Schema introspection: `wombo describe [command]`\n403:     if (!args.featureId) {\n404:       // No command specified — list all commands\n405:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n406:     } else {\n407:       // Describe a specific command. Handle compound names: \"features list\"\n408:       const cmdName = args.title\n409:         ? `${args.featureId} ${args.title}`\n410:         : args.featureId;\n411:       const def = findCommandDef(cmdName);\n412:       if (!def) {\n413:         console.error(`Unknown command: \"${cmdName}\"`);\n414:         console.error(\"Run 'wombo describe' to list all commands.\");\n415:         process.exit(1);\n416:         return;\n417:       }\n418:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n419:     }\n420:     return;\n421:   }\n422: \n423:   if (args.command === \"init\") {\n424:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n425:     return;\n426:   }\n427: \n428:   if (args.command === \"upgrade\") {\n429:     await cmdUpgrade({\n430:       force: args.force,\n431:       version: args.version,\n432:       checkOnly: args.checkOnly,\n433:     });\n434:     return;\n435:   }\n436: \n437:   // Everything else requires config\n438:   const config = loadConfig(PROJECT_ROOT);\n439:   validateConfig(config);\n440: \n441:   // Commands that operate on the features file — ensure it exists first\n442:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n443:   if (needsFeatures.has(args.command)) {\n444:     await ensureFeaturesFile(PROJECT_ROOT, config);\n445:   }\n446: \n447:   switch (args.command) {\n448:     case \"launch\":\n449:       await cmdLaunch({\n450:         projectRoot: PROJECT_ROOT,\n451:         config,\n452:         topPriority: args.topPriority,\n453:         quickestWins: args.quickestWins,\n454:         priority: args.priority,\n455:         difficulty: args.difficulty,\n456:         features: args.features,\n457:         allReady: args.allReady,\n458:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n459:         model: args.model,\n460:         interactive: args.interactive,\n461:         dryRun: args.dryRun,\n462:         baseBranch: args.baseBranch ?? config.baseBranch,\n463:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n464:         noTui: args.noTui,\n465:         autoPush: args.autoPush,\n466:       });\n467:       break;\n468: \n469:     case \"resume\":\n470:       await cmdResume({\n471:         projectRoot: PROJECT_ROOT,\n472:         config,\n473:         maxConcurrent: args.maxConcurrent,\n474:         model: args.model,\n475:         interactive: args.interactive,\n476:         noTui: args.noTui,\n477:         autoPush: args.autoPush,\n478:         baseBranch: args.baseBranch,\n479:         maxRetries: args.maxRetries,\n480:       });\n481:       break;\n482: \n483:     case \"status\":\n484:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n485:       break;\n486: \n487:     case \"verify\":\n488:       await cmdVerify({\n489:         projectRoot: PROJECT_ROOT,\n490:         config,\n491:         featureId: args.featureId,\n492:         model: args.model,\n493:         maxRetries: args.maxRetries,\n494:       });\n495:       break;\n496: \n497:     case \"merge\":\n498:       await cmdMerge({\n499:         projectRoot: PROJECT_ROOT,\n500:         config,\n501:         featureId: args.featureId,\n502:         autoPush: args.autoPush,\n503:         dryRun: args.dryRun,\n504:       });\n505:       break;\n506: \n507:     case \"retry\": {\n508:       if (!args.featureId) {\n509:         console.error(\"Usage: wombo retry <feature-id>\");\n510:         process.exit(1);\n511:         return;\n512:       }\n513:       await cmdRetry({\n514:         projectRoot: PROJECT_ROOT,\n515:         config,\n516:         featureId: args.featureId,\n517:         model: args.model,\n518:         interactive: args.interactive,\n519:         dryRun: args.dryRun,\n520:       });\n521:       break;\n522:     }\n523: \n524:     case \"cleanup\":\n525:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n526:       break;\n527: \n528:     case \"features\":\n529:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n530:       break;\n531: \n532:     default:\n533:       console.error(`Unknown command: ${args.command}`);\n534:       cmdHelp();\n535:       process.exit(1);\n536:       return;\n537:   }\n538: }\n539: \n540: // ---------------------------------------------------------------------------\n541: // Features Subcommand Router\n542: // ---------------------------------------------------------------------------\n543: \n544: async function handleFeaturesSubcommand(\n545:   args: CLIArgs,\n546:   projectRoot: string,\n547:   config: import(\"./config.js\").WomboConfig\n548: ): Promise<void> {\n549:   switch (args.subcommand) {\n550:     case \"list\":\n551:     case \"ls\":\n552:       await cmdFeaturesList({\n553:         projectRoot,\n554:         config,\n555:         status: args.status as FeatureStatus | undefined,\n556:         priority: args.priority,\n557:         difficulty: args.difficulty,\n558:         ready: args.ready,\n559:         includeArchive: args.includeArchive,\n560:         outputFmt: args.outputFmt,\n561:         fields: args.fields,\n562:       });\n563:       break;\n564: \n565:     case \"add\": {\n566:       if (!args.featureId || !args.title) {\n567:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n568:         process.exit(1);\n569:         return;\n570:       }\n571:       await cmdFeaturesAdd({\n572:         projectRoot,\n573:         config,\n574:         id: args.featureId,\n575:         title: args.title,\n576:         description: args.description,\n577:         priority: args.priority,\n578:         difficulty: args.difficulty,\n579:         effort: args.effort,\n580:         dependsOn: args.dependsOn,\n581:         outputFmt: args.outputFmt,\n582:         dryRun: args.dryRun,\n583:       });\n584:       break;\n585:     }\n586: \n587:     case \"set-status\": {\n588:       if (!args.featureId || !args.title) {\n589:         // title holds the second positional arg (the status value)\n590:         // If not provided via positional, check --status flag\n591:         const newStatus = args.title || args.status;\n592:         if (!args.featureId || !newStatus) {\n593:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n594:           process.exit(1);\n595:           return;\n596:         }\n597:         await cmdFeaturesSetStatus({\n598:           projectRoot,\n599:           config,\n600:           featureId: args.featureId,\n601:           newStatus,\n602:           outputFmt: args.outputFmt,\n603:           dryRun: args.dryRun,\n604:         });\n605:       } else {\n606:         await cmdFeaturesSetStatus({\n607:           projectRoot,\n608:           config,\n609:           featureId: args.featureId,\n610:           newStatus: args.title, // second positional = new status\n611:           outputFmt: args.outputFmt,\n612:           dryRun: args.dryRun,\n613:         });\n614:       }\n615:       break;\n616:     }\n617: \n618:     case \"check\":\n619:     case \"validate\":\n620:       await cmdFeaturesCheck({ projectRoot, config, outputFmt: args.outputFmt });\n621:       break;\n622: \n623:     case \"archive\":\n624:       await cmdFeaturesArchive({\n625:         projectRoot,\n626:         config,\n627:         featureId: args.featureId,\n628:         dryRun: args.dryRun,\n629:         outputFmt: args.outputFmt,\n630:       });\n631:       break;\n632: \n633:     case \"show\": {\n634:       if (!args.featureId) {\n635:         console.error(\"Usage: wombo features show <feature-id>\");\n636:         process.exit(1);\n637:         return;\n638:       }\n639:       await cmdFeaturesShow({\n640:         projectRoot,\n641:         config,\n642:         featureId: args.featureId,\n643:         outputFmt: args.outputFmt,\n644:         fields: args.fields,\n645:       });\n646:       break;\n647:     }\n648: \n649:     case \"help\":\n650:     case \"--help\":\n651:     case \"-h\":\n652:       cmdHelp();\n653:       break;\n654: \n655:     default:\n656:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n657:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n658:       process.exit(1);\n659:       return;\n660:   }\n661: }\n662: \n663: // ---------------------------------------------------------------------------\n664: // Error Handlers & Entry\n665: // ---------------------------------------------------------------------------\n666: \n667: // Global error handlers — prevent silent crashes\n668: process.on(\"uncaughtException\", (err) => {\n669:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n670:   console.error(err.stack);\n671:   try {\n672:     const state = loadState(process.cwd());\n673:     if (state) saveState(process.cwd(), state);\n674:   } catch {}\n675:   process.exit(1);\n676: });\n677: \n678: process.on(\"unhandledRejection\", (reason: any) => {\n679:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n680:   if (reason?.stack) console.error(reason.stack);\n681:   try {\n682:     const state = loadState(process.cwd());\n683:     if (state) saveState(process.cwd(), state);\n684:   } catch {}\n685:   process.exit(1);\n686: });\n687: \n688: main().catch((err) => {\n689:   console.error(\"Fatal error:\", err.message);\n690:   process.exit(1);\n691: });\n\n(End of file - total 691 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo cleanup","truncated":false,"loaded":[]},"time":{"start":1773245546403,"end":1773245546408}}}}
