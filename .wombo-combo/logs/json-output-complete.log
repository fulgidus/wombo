{"type":"tool_use","timestamp":1773246955545,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddc13dc800144sU2EshHqZdMN","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddc12d1700102FZYMvsmWbkC1","type":"tool","callID":"toolu_01XWokCjumVDLf3qZFSNeNpJ","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/launch.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/launch.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * launch.ts — Launch a wave of agents.\n3:  *\n4:  * Usage: wombo launch [selection options] [launch options]\n5:  *\n6:  * This is the primary entry point for starting a new wave. It selects features\n7:  * from the features file, creates a wave state, sets up worktrees, and launches\n8:  * agent processes (either headless or interactive via tmux).\n9:  *\n10:  * IMPORTANT: This file also exports shared helper functions that are reused\n11:  * by resume.ts and other commands:\n12:  *   - launchSingleHeadless\n13:  *   - handleBuildVerification\n14:  *   - handleRetry\n15:  *   - launchNextQueued\n16:  */\n17: \n18: import type { WomboConfig } from \"../config.js\";\n19: import type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\n20: import { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";\n21: import {\n22:   loadState,\n23:   saveState,\n24:   createWaveState,\n25:   createAgentState,\n26:   updateAgent,\n27:   activeAgents,\n28:   queuedAgents,\n29:   isWaveComplete,\n30:   type WaveState,\n31:   type AgentState,\n32: } from \"../lib/state.js\";\n33: import {\n34:   createWorktree,\n35:   installDeps,\n36:   featureBranchName,\n37:   worktreePath,\n38:   worktreeReady,\n39:   removeWorktree,\n40:   log as wtLog,\n41: } from \"../lib/worktree.js\";\n42: import { generatePrompt } from \"../lib/prompt.js\";\n43: import {\n44:   launchHeadless,\n45:   retryHeadless,\n46:   launchInteractive,\n47:   retryInteractive,\n48:   isProcessRunning,\n49: } from \"../lib/launcher.js\";\n50: import { ProcessMonitor } from \"../lib/monitor.js\";\n51: import { runBuild } from \"../lib/verifier.js\";\n52: import { mergeBranch, pushBaseBranch } from \"../lib/merger.js\";\n53: import {\n54:   printDashboard,\n55:   printFeatureSelection,\n56:   printAgentUpdate,\n57: } from \"../lib/ui.js\";\n58: import { WomboTUI } from \"../lib/tui.js\";\n59: import { output, outputError, type OutputFormat } from \"../lib/output.js\";\n60: \n61: // ---------------------------------------------------------------------------\n62: // Types\n63: // ---------------------------------------------------------------------------\n64: \n65: export interface LaunchCommandOptions {\n66:   projectRoot: string;\n67:   config: WomboConfig;\n68:   // Selection\n69:   topPriority?: number;\n70:   quickestWins?: number;\n71:   priority?: Priority;\n72:   difficulty?: Difficulty;\n73:   features?: string[];\n74:   allReady?: boolean;\n75:   // Launch\n76:   maxConcurrent: number;\n77:   model?: string;\n78:   interactive: boolean;\n79:   dryRun: boolean;\n80:   baseBranch: string;\n81:   maxRetries: number;\n82:   noTui: boolean;\n83:   autoPush: boolean;\n84:   // Output\n85:   outputFmt?: import(\"../lib/output.js\").OutputFormat;\n86: }\n87: \n88: // ---------------------------------------------------------------------------\n89: // Shared Helpers (exported for resume.ts and others)\n90: // ---------------------------------------------------------------------------\n91: \n92: /**\n93:  * Launch a single agent in headless mode.\n94:  * Sets up worktree, installs deps, generates prompt, launches agent process.\n95:  */\n96: export async function launchSingleHeadless(\n97:   projectRoot: string,\n98:   state: WaveState,\n99:   agent: AgentState,\n100:   feature: Feature,\n101:   monitor: ProcessMonitor,\n102:   config: WomboConfig,\n103:   model?: string\n104: ): Promise<void> {\n105:   updateAgent(state, agent.feature_id, {\n106:     status: \"installing\",\n107:     started_at: new Date().toISOString(),\n108:     activity: \"setting up worktree...\",\n109:   });\n110:   saveState(projectRoot, state);\n111: \n112:   try {\n113:     // Skip worktree setup if already ready (resume case)\n114:     if (worktreeReady(agent.worktree)) {\n115:       wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n116:     } else {\n117:       // Create worktree (async — doesn't block other agents)\n118:       await createWorktree(projectRoot, feature.id, state.base_branch, config);\n119: \n120:       // Install dependencies (async)\n121:       updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n122:       await installDeps(agent.worktree, feature.id, config);\n123:     }\n124: \n125:     // Generate prompt\n126:     const prompt = generatePrompt(feature, state.base_branch, config);\n127: \n128:     // Launch agent\n129:     wtLog(agent.feature_id, \"launching agent...\");\n130:     const result = launchHeadless({\n131:       worktreePath: agent.worktree,\n132:       featureId: feature.id,\n133:       prompt,\n134:       model,\n135:       config,\n136:     });\n137: \n138:     updateAgent(state, agent.feature_id, {\n139:       status: \"running\",\n140:       pid: result.pid,\n141:       activity: \"starting...\",\n142:     });\n143:     saveState(projectRoot, state);\n144: \n145:     monitor.addProcess(feature.id, result.process);\n146:     wtLog(agent.feature_id, `running (PID: ${result.pid})`);\n147:   } catch (err: any) {\n148:     updateAgent(state, agent.feature_id, {\n149:       status: \"failed\",\n150:       error: err.message,\n151:       activity: null,\n152:       completed_at: new Date().toISOString(),\n153:     });\n154:     saveState(projectRoot, state);\n155:     wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n156:   }\n157: }\n158: \n159: /**\n160:  * Handle build verification after agent completion.\n161:  * Runs build, auto-merges on pass, retries on failure if retries remain.\n162:  *\n163:  * ASYNC — runs build and merge without blocking the event loop.\n164:  */\n165: export async function handleBuildVerification(\n166:   projectRoot: string,\n167:   state: WaveState,\n168:   agent: AgentState,\n169:   feature: Feature,\n170:   config: WomboConfig,\n171:   model?: string,\n172:   monitor?: ProcessMonitor\n173: ): Promise<void> {\n174:   try {\n175:     printAgentUpdate(agent, \"verifying build...\");\n176: \n177:     const buildResult = await runBuild(agent.worktree, config);\n178: \n179:     if (buildResult.passed) {\n180:       updateAgent(state, agent.feature_id, {\n181:         status: \"verified\",\n182:         build_passed: true,\n183:         build_output: null,\n184:       });\n185:       saveState(projectRoot, state);\n186:       printAgentUpdate(agent, `BUILD PASSED (${Math.round(buildResult.durationMs / 1000)}s)`);\n187: \n188:       // Auto-merge: merge verified branch into base immediately\n189:       printAgentUpdate(agent, \"auto-merging...\");\n190:       try {\n191:         const mergeResult = await mergeBranch(projectRoot, agent.branch, state.base_branch, config);\n192: \n193:         if (mergeResult.success) {\n194:           updateAgent(state, agent.feature_id, {\n195:             status: \"merged\",\n196:             completed_at: new Date().toISOString(),\n197:           });\n198:           saveState(projectRoot, state);\n199:           printAgentUpdate(agent, `MERGED (${mergeResult.commitHash?.slice(0, 7)})`);\n200: \n201:           // Clean up worktree after successful merge\n202:           try {\n203:             removeWorktree(projectRoot, agent.worktree, false);\n204:             printAgentUpdate(agent, \"worktree removed\");\n205:           } catch {\n206:             // Not critical — worktree cleanup is best-effort\n207:           }\n208:         } else {\n209:           // Merge failed (conflicts, etc.) — leave as verified for manual resolution\n210:           printAgentUpdate(agent, `AUTO-MERGE FAILED: ${mergeResult.error}`);\n211:         }\n212:       } catch (mergeErr: any) {\n213:         printAgentUpdate(agent, `AUTO-MERGE ERROR: ${mergeErr.message?.slice(0, 100)}`);\n214:       }\n215:     } else {\n216:       if (agent.retries < agent.max_retries) {\n217:         updateAgent(state, agent.feature_id, {\n218:           status: \"retry\",\n219:           retries: agent.retries + 1,\n220:           build_passed: false,\n221:           build_output: buildResult.errorSummary,\n222:         });\n223:         saveState(projectRoot, state);\n224:         printAgentUpdate(\n225:           agent,\n226:           `BUILD FAILED — retrying (${agent.retries}/${agent.max_retries})`\n227:         );\n228: \n229:         // Retry with build errors\n230:         if (agent.session_id) {\n231:           const retryResult = retryHeadless({\n232:             worktreePath: agent.worktree,\n233:             featureId: agent.feature_id,\n234:             sessionId: agent.session_id,\n235:             buildErrors: buildResult.errorSummary,\n236:             model,\n237:             config,\n238:           });\n239: \n240:           updateAgent(state, agent.feature_id, {\n241:             status: \"running\",\n242:             pid: retryResult.pid,\n243:           });\n244:           saveState(projectRoot, state);\n245: \n246:           // Add retry process to monitor so events are tracked\n247:           if (monitor) {\n248:             monitor.addProcess(agent.feature_id, retryResult.process);\n249:           }\n250:         }\n251:       } else {\n252:         updateAgent(state, agent.feature_id, {\n253:           status: \"failed\",\n254:           build_passed: false,\n255:           build_output: buildResult.errorSummary,\n256:           error: `Build failed after ${agent.max_retries} retries`,\n257:           completed_at: new Date().toISOString(),\n258:         });\n259:         saveState(projectRoot, state);\n260:         printAgentUpdate(agent, \"BUILD FAILED — max retries reached\");\n261:       }\n262:     }\n263:   } catch (err: any) {\n264:     // Catch-all — never let build verification crash the process\n265:     printAgentUpdate(agent, `VERIFY ERROR: ${err.message?.slice(0, 100)}`);\n266:     updateAgent(state, agent.feature_id, {\n267:       status: \"failed\",\n268:       error: `Build verification error: ${err.message}`,\n269:       completed_at: new Date().toISOString(),\n270:     });\n271:     saveState(projectRoot, state);\n272:   }\n273: }\n274: \n275: /**\n276:  * Handle retry of a failed agent (error-based, not build-based).\n277:  */\n278: export function handleRetry(\n279:   projectRoot: string,\n280:   state: WaveState,\n281:   agent: AgentState,\n282:   monitor: ProcessMonitor,\n283:   config: WomboConfig,\n284:   model?: string\n285: ): void {\n286:   if (!agent.session_id || !agent.error) return;\n287: \n288:   const retryResult = retryHeadless({\n289:     worktreePath: agent.worktree,\n290:     featureId: agent.feature_id,\n291:     sessionId: agent.session_id,\n292:     buildErrors: agent.error,\n293:     model,\n294:     config,\n295:   });\n296: \n297:   updateAgent(state, agent.feature_id, {\n298:     status: \"running\",\n299:     pid: retryResult.pid,\n300:   });\n301:   saveState(projectRoot, state);\n302: \n303:   monitor.addProcess(agent.feature_id, retryResult.process);\n304: }\n305: \n306: /**\n307:  * Launch the next queued agent if capacity allows.\n308:  */\n309: export function launchNextQueued(\n310:   projectRoot: string,\n311:   state: WaveState,\n312:   featureMap: Map<string, Feature>,\n313:   monitor: ProcessMonitor,\n314:   config: WomboConfig,\n315:   model?: string\n316: ): void {\n317:   const active = activeAgents(state);\n318:   const queued = queuedAgents(state);\n319: \n320:   if (active.length < state.max_concurrent && queued.length > 0) {\n321:     const next = queued[0];\n322:     const feature = featureMap.get(next.feature_id);\n323:     if (feature) {\n324:       launchSingleHeadless(projectRoot, state, next, feature, monitor, config, model);\n325:     }\n326:   }\n327: }\n328: \n329: // ---------------------------------------------------------------------------\n330: // Headless Wave Launch\n331: // ---------------------------------------------------------------------------\n332: \n333: async function launchWaveHeadless(\n334:   projectRoot: string,\n335:   state: WaveState,\n336:   features: Feature[],\n337:   opts: LaunchCommandOptions\n338: ): Promise<void> {\n339:   const { config, model } = opts;\n340:   const fmt = opts.outputFmt ?? \"text\";\n341:   const featureMap = new Map(features.map((f) => [f.id, f]));\n342: \n343:   const monitor = new ProcessMonitor(projectRoot, {\n344:     onSessionId: (featureId, sessionId) => {\n345:       updateAgent(state, featureId, { session_id: sessionId });\n346:       saveState(projectRoot, state);\n347:     },\n348:     onComplete: (featureId) => {\n349:       updateAgent(state, featureId, {\n350:         status: \"completed\",\n351:         completed_at: new Date().toISOString(),\n352:       });\n353:       saveState(projectRoot, state);\n354: \n355:       // Run build verification — fire-and-forget\n356:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n357:       handleBuildVerification(projectRoot, state, agent, featureMap.get(featureId)!, config, model, monitor)\n358:         .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n359:         .catch((err) => {\n360:           wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n361:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n362:         });\n363:     },\n364:     onError: (featureId, error) => {\n365:       const agent = state.agents.find((a) => a.feature_id === featureId)!;\n366:       if (agent.retries < agent.max_retries) {\n367:         updateAgent(state, featureId, {\n368:           status: \"retry\",\n369:           retries: agent.retries + 1,\n370:           error,\n371:         });\n372:         saveState(projectRoot, state);\n373: \n374:         // Retry\n375:         handleRetry(projectRoot, state, agent, monitor, config, model);\n376:       } else {\n377:         updateAgent(state, featureId, {\n378:           status: \"failed\",\n379:           error,\n380:           completed_at: new Date().toISOString(),\n381:         });\n382:         saveState(projectRoot, state);\n383:       }\n384: \n385:       // Try to launch next queued agent\n386:       launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n387:     },\n388:     onOutput: (_featureId, _data) => {\n389:       // Raw output — logged to file by ProcessMonitor\n390:     },\n391:     onActivity: (featureId, activity) => {\n392:       updateAgent(state, featureId, {\n393:         activity,\n394:         activity_updated_at: new Date().toISOString(),\n395:       });\n396:       // Don't save to disk on every activity — too frequent.\n397:     },\n398:   });\n399: \n400:   // Create the TUI — it will auto-refresh and show activity from the monitor\n401:   const tuiRef = { current: null as WomboTUI | null };\n402:   const startTUI = () => {\n403:     tuiRef.current = new WomboTUI({\n404:       state,\n405:       monitor,\n406:       projectRoot,\n407:       interactive: false,\n408:       config,\n409:       onQuit: () => {\n410:         // Same as SIGINT — save state and exit\n411:         for (const agent of state.agents) {\n412:           if (agent.status === \"running\") {\n413:             updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n414:           }\n415:         }\n416:         monitor.killAll();\n417:         saveState(projectRoot, state);\n418:         if (fmt === \"text\") console.log(\"State saved. Use 'wombo resume' to continue.\");\n419:         process.exit(0);\n420:       },\n421:     });\n422:     tuiRef.current.start();\n423:   };\n424: \n425:   // Handle graceful shutdown\n426:   process.on(\"SIGINT\", () => {\n427:     if (tuiRef.current) tuiRef.current.stop();\n428:     for (const agent of state.agents) {\n429:       if (agent.status === \"running\") {\n430:         updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n431:       }\n432:     }\n433:     monitor.killAll();\n434:     saveState(projectRoot, state);\n435:     if (fmt === \"text\") console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n436:     process.exit(0);\n437:   });\n438: \n439:   // Launch initial batch — set up worktrees in parallel\n440:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n441:   if (fmt === \"text\") {\n442:     console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n443:   }\n444: \n445:   await Promise.all(\n446:     tolaunch.map((agent) =>\n447:       launchSingleHeadless(\n448:         projectRoot,\n449:         state,\n450:         agent,\n451:         featureMap.get(agent.feature_id)!,\n452:         monitor,\n453:         config,\n454:         model\n455:       )\n456:     )\n457:   );\n458: \n459:   const launched = state.agents.filter((a) => a.status === \"running\").length;\n460: \n461:   // Start the TUI dashboard (or skip if --no-tui)\n462:   if (opts.noTui) {\n463:     if (fmt === \"text\") {\n464:       console.log(`${launched} agent(s) running. (--no-tui mode, dashboard prints every 15s)\\n`);\n465:       printDashboard(state);\n466:     }\n467:   } else {\n468:     if (fmt === \"text\") {\n469:       console.log(`${launched} agent(s) running. Launching TUI...\\n`);\n470:     }\n471:     startTUI();\n472:   }\n473: \n474:   // Background monitoring loop — checks for dead processes and launches queued\n475:   const POLL_INTERVAL = 5000;\n476:   let dashboardCounter = 0;\n477:   while (!isWaveComplete(state)) {\n478:     await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n479: \n480:     // Check for completed processes that weren't caught by event handlers\n481:     for (const agent of state.agents) {\n482:       if (\n483:         agent.status === \"running\" &&\n484:         agent.pid &&\n485:         !isProcessRunning(agent.pid) &&\n486:         !monitor.isRunning(agent.feature_id)\n487:       ) {\n488:         // Process exited but we didn't get a callback\n489:         updateAgent(state, agent.feature_id, {\n490:           status: \"completed\",\n491:           completed_at: new Date().toISOString(),\n492:           activity: \"done\",\n493:         });\n494:         saveState(projectRoot, state);\n495:         try {\n496:           await handleBuildVerification(projectRoot, state, agent, featureMap.get(agent.feature_id)!, config, model, monitor);\n497:         } catch (err: any) {\n498:           wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n499:         }\n500:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n501:       }\n502:     }\n503: \n504:     // Persist state periodically\n505:     saveState(projectRoot, state);\n506: \n507:     // Update TUI state reference (or print dashboard in --no-tui mode)\n508:     if (tuiRef.current) {\n509:       tuiRef.current.updateState(state);\n510:     } else if (opts.noTui && fmt === \"text\") {\n511:       dashboardCounter++;\n512:       if (dashboardCounter % 3 === 0) {\n513:         printDashboard(state);\n514: \n515:         // Auto-push base branch if requested\n516:         if (opts.autoPush) {\n517:           const anyMerged = state.agents.some((a) => a.status === \"merged\");\n518:           if (anyMerged) {\n519:             await pushBaseBranch(projectRoot, state.base_branch, config);\n520:           } else {\n521:             console.log(\"No branches were merged — skipping push.\");\n522:           }\n523:         }\n524:       }\n525:     }\n526:   }\n527: \n528:   // Wave complete — tear down TUI and show final summary\n529:   if (tuiRef.current) tuiRef.current.stop();\n530:   if (fmt === \"text\") {\n531:     printDashboard(state);\n532:   }\n533: \n534:   // Auto-push base branch if requested\n535:   if (opts.autoPush) {\n536:     await pushBaseBranch(projectRoot, state.base_branch, config);\n537:   }\n538: \n539:   if (fmt === \"text\") {\n540:     console.log(\"Wave complete.\");\n541:   }\n542: }\n543: \n544: // ---------------------------------------------------------------------------\n545: // Interactive Wave Launch\n546: // ---------------------------------------------------------------------------\n547: \n548: async function launchWaveInteractive(\n549:   projectRoot: string,\n550:   state: WaveState,\n551:   features: Feature[],\n552:   opts: LaunchCommandOptions\n553: ): Promise<void> {\n554:   const { config, model } = opts;\n555:   const fmt = opts.outputFmt ?? \"text\";\n556:   const featureMap = new Map(features.map((f) => [f.id, f]));\n557: \n558:   // Show dashboard immediately\n559:   if (fmt === \"text\") {\n560:     printDashboard(state);\n561:   }\n562: \n563:   // Launch initial batch in tmux — parallelize setup\n564:   const tolaunch = queuedAgents(state).slice(0, opts.maxConcurrent);\n565:   if (fmt === \"text\") {\n566:     console.log(`Setting up ${tolaunch.length} agent(s) in parallel...\\n`);\n567:   }\n568: \n569:   await Promise.all(\n570:     tolaunch.map(async (agent) => {\n571:       updateAgent(state, agent.feature_id, {\n572:         status: \"installing\",\n573:         started_at: new Date().toISOString(),\n574:         activity: \"setting up worktree...\",\n575:       });\n576:       saveState(projectRoot, state);\n577: \n578:       try {\n579:         if (worktreeReady(agent.worktree)) {\n580:           wtLog(agent.feature_id, \"worktree already exists, skipping setup\");\n581:         } else {\n582:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n583:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n584:           await installDeps(agent.worktree, agent.feature_id, config);\n585:         }\n586: \n587:         const prompt = generatePrompt(\n588:           featureMap.get(agent.feature_id)!,\n589:           state.base_branch,\n590:           config\n591:         );\n592: \n593:         wtLog(agent.feature_id, \"launching tmux session...\");\n594:         const result = launchInteractive({\n595:           worktreePath: agent.worktree,\n596:           featureId: agent.feature_id,\n597:           prompt,\n598:           model,\n599:           interactive: true,\n600:           config,\n601:         });\n602: \n603:         updateAgent(state, agent.feature_id, {\n604:           status: \"running\",\n605:           pid: result.pid,\n606:           activity: \"tmux session active\",\n607:         });\n608:         saveState(projectRoot, state);\n609:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n610:       } catch (err: any) {\n611:         updateAgent(state, agent.feature_id, {\n612:           status: \"failed\",\n613:           error: err.message,\n614:           activity: null,\n615:           completed_at: new Date().toISOString(),\n616:         });\n617:         saveState(projectRoot, state);\n618:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n619:       }\n620:     })\n621:   );\n622: \n623:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n624:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n625:   console.log(\"  tmux ls                                                  # list sessions\");\n626:   console.log(\"  wombo status                                             # check status\");\n627:   console.log(\"  wombo verify                                             # verify builds\");\n628:   console.log(\"  wombo merge                                              # merge verified\");\n629:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n630: \n631:   printDashboard(state);\n632: }\n633: \n634: // ---------------------------------------------------------------------------\n635: // Main Command\n636: // ---------------------------------------------------------------------------\n637: \n638: export async function cmdLaunch(opts: LaunchCommandOptions): Promise<void> {\n639:   const { projectRoot, config } = opts;\n640:   const fmt = opts.outputFmt ?? \"text\";\n641: \n642:   if (fmt === \"text\") {\n643:     console.log(\"\\n--- Wombo: Launch ---\\n\");\n644:   }\n645: \n646:   // Load features\n647:   const data = loadFeatures(projectRoot, config);\n648: \n649:   // Build selection options\n650:   const selOpts: SelectionOptions = {};\n651:   if (opts.topPriority) selOpts.topPriority = opts.topPriority;\n652:   if (opts.quickestWins) selOpts.quickestWins = opts.quickestWins;\n653:   if (opts.priority) selOpts.priority = opts.priority;\n654:   if (opts.difficulty) selOpts.difficulty = opts.difficulty;\n655:   if (opts.features) selOpts.featureIds = opts.features;\n656:   if (opts.allReady) selOpts.allReady = true;\n657: \n658:   // Select features\n659:   const selected = selectFeatures(data, selOpts);\n660: \n661:   if (selected.length === 0) {\n662:     outputError(\n663:       fmt,\n664:       \"No features matched the selection criteria. Use --all-ready to see all available.\"\n665:     );\n666:     return;\n667:   }\n668: \n669:   // Show selection\n670:   const selectedData = selected.map((f) => ({\n671:     id: f.id,\n672:     title: f.title,\n673:     priority: f.priority,\n674:     difficulty: f.difficulty,\n675:     effort: f.effort,\n676:   }));\n677: \n678:   if (opts.dryRun) {\n679:     output(\n680:       fmt,\n681:       {\n682:         dry_run: true,\n683:         selected: selectedData,\n684:         count: selected.length,\n685:         max_concurrent: opts.maxConcurrent,\n686:         base_branch: opts.baseBranch,\n687:         interactive: opts.interactive,\n688:         model: opts.model ?? null,\n689:       },\n690:       () => {\n691:         printFeatureSelection(selectedData);\n692:         console.log(\"Dry run — not launching agents.\");\n693:       }\n694:     );\n695:     return;\n696:   }\n697: \n698:   if (fmt === \"text\") {\n699:     printFeatureSelection(selectedData);\n700:   }\n701: \n702:   // Create wave state\n703:   const state = createWaveState({\n704:     baseBranch: opts.baseBranch,\n705:     maxConcurrent: opts.maxConcurrent,\n706:     model: opts.model ?? null,\n707:     interactive: opts.interactive,\n708:   });\n709: \n710:   // Create agent entries for all selected features\n711:   for (const feature of selected) {\n712:     const branch = featureBranchName(feature.id, config);\n713:     const wtPath = worktreePath(projectRoot, feature.id, config);\n714:     const agent = createAgentState(feature.id, branch, wtPath, opts.maxRetries);\n715:     // Set effort estimate from feature spec\n716:     const effortMinutes = parseDurationMinutes(feature.effort);\n717:     agent.effort_estimate_ms = effortMinutes === Infinity ? null : effortMinutes * 60 * 1000;\n718:     state.agents.push(agent);\n719:   }\n720: \n721:   saveState(projectRoot, state);\n722: \n723:   if (fmt === \"json\") {\n724:     // In JSON mode, emit the wave state and return — long-running monitoring\n725:     // is not suitable for JSON consumers. They should poll `wombo status --output json`.\n726:     console.log(JSON.stringify({\n727:       wave_id: state.wave_id,\n728:       selected: selectedData,\n729:       count: selected.length,\n730:       max_concurrent: opts.maxConcurrent,\n731:       base_branch: opts.baseBranch,\n732:       interactive: opts.interactive,\n733:       model: opts.model ?? null,\n734:       message: \"Wave created. Use 'wombo status --output json' to monitor progress.\",\n735:     }));\n736:     // Still launch agents but skip TUI/dashboard output\n737:   } else {\n738:     console.log(`Wave ${state.wave_id} created with ${selected.length} agents.`);\n739:   }\n740: \n741:   // Launch agents up to max_concurrent\n742:   if (opts.interactive) {\n743:     await launchWaveInteractive(projectRoot, state, selected, opts);\n744:   } else {\n745:     await launchWaveHeadless(projectRoot, state, selected, opts);\n746:   }\n747: }\n\n(End of file - total 747 lines)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"/**\n * launch.ts — Launch a wave of agents.\n *\n * Usage: wombo launch [selection options] [launch options]\n *\n * This is the primary entry point for starting a new wave. It selects features\n * from the features file, creates a wave state, sets up worktrees, and launches\n * agent processes (either headless or interactive via tmux).\n *\n * IMPORTANT: This file also exports shared helper functions that are reused\n * by resume.ts and other commands:\n *   - launchSingleHeadless\n *   - handleBuildVerification\n *   - handleRetry\n *   - launchNextQueued\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature, SelectionOptions, Priority, Difficulty } from \"../lib/features.js\";\nimport { loadFeatures, selectFeatures, parseDurationMinutes } from \"../lib/features.js\";","truncated":false,"loaded":[]},"time":{"start":1773246955537,"end":1773246955540}}}}
{"type":"tool_use","timestamp":1773246955770,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddc14011001ZBvDPiSKIrQ5FM","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddc12d1700102FZYMvsmWbkC1","type":"tool","callID":"toolu_01QSw3E7UsJWFEFu5rjZczW5","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/resume.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/commands/resume.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * resume.ts — Resume a previously stopped wave.\n3:  *\n4:  * Usage: wombo resume [options]\n5:  *\n6:  * Restores from .wombo-state.json:\n7:  *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n8:  *   - Agents in \"queued\" → launch them\n9:  *   - Agents in terminal states (verified/failed/merged) → leave alone\n10:  */\n11: \n12: import type { WomboConfig } from \"../config.js\";\n13: import type { Feature } from \"../lib/features.js\";\n14: import { loadFeatures } from \"../lib/features.js\";\n15: import {\n16:   loadState,\n17:   saveState,\n18:   updateAgent,\n19:   queuedAgents,\n20:   isWaveComplete,\n21:   type WaveState,\n22:   type AgentState,\n23: } from \"../lib/state.js\";\n24: import {\n25:   createWorktree,\n26:   installDeps,\n27:   worktreeReady,\n28:   log as wtLog,\n29: } from \"../lib/worktree.js\";\n30: import { generatePrompt } from \"../lib/prompt.js\";\n31: import {\n32:   launchInteractive,\n33:   isProcessRunning,\n34: } from \"../lib/launcher.js\";\n35: import { ProcessMonitor } from \"../lib/monitor.js\";\n36: import { pushBaseBranch } from \"../lib/merger.js\";\n37: import { printDashboard } from \"../lib/ui.js\";\n38: import { WomboTUI } from \"../lib/tui.js\";\n39: import {\n40:   launchSingleHeadless,\n41:   handleBuildVerification,\n42:   handleRetry,\n43:   launchNextQueued,\n44: } from \"./launch.js\";\n45: import { outputError, outputMessage, type OutputFormat } from \"../lib/output.js\";\n46: \n47: // ---------------------------------------------------------------------------\n48: // Types\n49: // ---------------------------------------------------------------------------\n50: \n51: export interface ResumeCommandOptions {\n52:   projectRoot: string;\n53:   config: WomboConfig;\n54:   maxConcurrent?: number;\n55:   model?: string;\n56:   interactive: boolean;\n57:   noTui: boolean;\n58:   autoPush: boolean;\n59:   baseBranch?: string;\n60:   maxRetries?: number;\n61:   outputFmt?: import(\"../lib/output.js\").OutputFormat;\n62: }\n63: \n64: // ---------------------------------------------------------------------------\n65: // Command\n66: // ---------------------------------------------------------------------------\n67: \n68: export async function cmdResume(opts: ResumeCommandOptions): Promise<void> {\n69:   const { projectRoot, config } = opts;\n70:   const fmt = opts.outputFmt ?? \"text\";\n71: \n72:   const state = loadState(projectRoot);\n73:   if (!state) {\n74:     outputError(fmt, \"No wave state found. Use 'wombo launch' to start a new wave.\");\n75:     return; // unreachable — helps TypeScript narrow\n76:   }\n77: \n78:   if (fmt === \"text\") {\n79:     console.log(`\\n--- Wombo: Resume ${state.wave_id} ---\\n`);\n80:   }\n81: \n82:   // Load feature data for prompt generation\n83:   const data = loadFeatures(projectRoot, config);\n84:   const featureMap = new Map(data.features.map((f) => [f.id, f]));\n85: \n86:   // Triage agents by current state\n87:   let toRelaunch: AgentState[] = [];\n88:   let toVerify: AgentState[] = [];\n89: \n90:   for (const agent of state.agents) {\n91:     switch (agent.status) {\n92:       case \"running\":\n93:       case \"installing\":\n94:       case \"retry\":\n95:         // Was in-flight when we stopped — check if PID is still alive\n96:         if (agent.pid && isProcessRunning(agent.pid)) {\n97:           if (fmt === \"text\") console.log(`  ${agent.feature_id}: still running (PID ${agent.pid}), leaving alone`);\n98:         } else {\n99:           // Process is dead — check if worktree has meaningful changes\n100:           if (worktreeReady(agent.worktree)) {\n101:             // Worktree exists, try build verification first\n102:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, worktree exists — will verify build`);\n103:             toVerify.push(agent);\n104:           } else {\n105:             // Worktree gone or incomplete — re-launch from scratch\n106:             if (fmt === \"text\") console.log(`  ${agent.feature_id}: process dead, no worktree — will re-launch`);\n107:             updateAgent(state, agent.feature_id, {\n108:               status: \"queued\",\n109:               pid: null,\n110:               activity: null,\n111:               session_id: null,\n112:             });\n113:             toRelaunch.push(agent);\n114:           }\n115:         }\n116:         break;\n117: \n118:       case \"queued\":\n119:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: queued — will launch`);\n120:         toRelaunch.push(agent);\n121:         break;\n122: \n123:       case \"completed\":\n124:         // Completed but not verified — verify\n125:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: completed — will verify build`);\n126:         toVerify.push(agent);\n127:         break;\n128: \n129:       case \"verified\":\n130:       case \"merged\":\n131:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: ${agent.status} — nothing to do`);\n132:         break;\n133: \n134:       case \"failed\":\n135:         if (fmt === \"text\") console.log(`  ${agent.feature_id}: failed — skipping (use 'wombo retry' to re-run)`);\n136:         break;\n137:     }\n138:   }\n139: \n140:   saveState(projectRoot, state);\n141: \n142:   // Run build verification on agents that were mid-flight\n143:   for (const agent of toVerify) {\n144:     const feature = featureMap.get(agent.feature_id);\n145:     if (!feature) continue;\n146:     if (fmt === \"text\") console.log(`\\n  Verifying ${agent.feature_id}...`);\n147:     try {\n148:       await handleBuildVerification(projectRoot, state, agent, feature, config, opts.model);\n149:     } catch (err: any) {\n150:       if (fmt === \"text\") console.log(`  Verify error for ${agent.feature_id}: ${err.message}`);\n151:     }\n152: \n153:     // If build failed and retries remain, queue for re-launch\n154:     if (agent.status === \"retry\" || agent.status === \"running\") {\n155:       toRelaunch.push(agent);\n156:     }\n157:   }\n158: \n159:   // Re-launch agents\n160:   const maxConcurrent = opts.maxConcurrent ?? state.max_concurrent;\n161:   const toLaunchNow = toRelaunch.slice(0, maxConcurrent);\n162:   if (toLaunchNow.length === 0) {\n163:     if (fmt === \"json\") {\n164:       console.log(JSON.stringify({\n165:         wave_id: state.wave_id,\n166:         relaunched: 0,\n167:         verified: toVerify.length,\n168:         agents: state.agents.map((a) => ({\n169:           feature_id: a.feature_id,\n170:           status: a.status,\n171:         })),\n172:         message: \"No agents need (re)launching.\",\n173:       }));\n174:     } else {\n175:       console.log(\"\\nNo agents need (re)launching.\");\n176:       printDashboard(state);\n177:     }\n178:     return;\n179:   }\n180: \n181:   if (fmt === \"text\") {\n182:     console.log(`\\nRe-launching ${toLaunchNow.length} agent(s)...\\n`);\n183:     printDashboard(state);\n184:   }\n185: \n186:   const model = opts.model ?? state.model ?? undefined;\n187: \n188:   if (opts.interactive) {\n189:     // Interactive resume\n190:     await Promise.all(\n191:       toLaunchNow.map(async (agent) => {\n192:         const feature = featureMap.get(agent.feature_id);\n193:         if (!feature) return;\n194: \n195:         updateAgent(state, agent.feature_id, {\n196:           status: \"installing\",\n197:           started_at: new Date().toISOString(),\n198:           activity: \"resuming...\",\n199:         });\n200:         saveState(projectRoot, state);\n201: \n202:         try {\n203:           if (!worktreeReady(agent.worktree)) {\n204:             await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n205:             await installDeps(agent.worktree, agent.feature_id, config);\n206:           }\n207: \n208:           const prompt = generatePrompt(feature, state.base_branch, config);\n209:           const result = launchInteractive({\n210:             worktreePath: agent.worktree,\n211:             featureId: feature.id,\n212:             prompt,\n213:             model,\n214:             interactive: true,\n215:             config,\n216:           });\n217: \n218:           updateAgent(state, agent.feature_id, {\n219:             status: \"running\",\n220:             pid: result.pid,\n221:             activity: \"tmux session active\",\n222:           });\n223:           saveState(projectRoot, state);\n224:         } catch (err: any) {\n225:           updateAgent(state, agent.feature_id, {\n226:             status: \"failed\",\n227:             error: err.message,\n228:             activity: null,\n229:             completed_at: new Date().toISOString(),\n230:           });\n231:           saveState(projectRoot, state);\n232:         }\n233:       })\n234:     );\n235: \n236:     if (fmt === \"json\") {\n237:       console.log(JSON.stringify({\n238:         wave_id: state.wave_id,\n239:         relaunched: toLaunchNow.length,\n240:         mode: \"interactive\",\n241:         agents: state.agents.map((a) => ({\n242:           feature_id: a.feature_id,\n243:           status: a.status,\n244:         })),\n245:         message: \"Resume complete.\",\n246:       }));\n247:     } else {\n248:       printDashboard(state);\n249:       console.log(`\\nResume complete. Use 'tmux attach -t ${config.agent.tmuxPrefix}-<id>' to check sessions.`);\n250:     }\n251:   } else {\n252:     // Headless resume — re-enter monitoring loop\n253:     const monitor = new ProcessMonitor(projectRoot, {\n254:       onSessionId: (featureId, sessionId) => {\n255:         updateAgent(state, featureId, { session_id: sessionId });\n256:         saveState(projectRoot, state);\n257:       },\n258:       onComplete: (featureId) => {\n259:         updateAgent(state, featureId, {\n260:           status: \"completed\",\n261:           completed_at: new Date().toISOString(),\n262:           activity: \"done\",\n263:         });\n264:         saveState(projectRoot, state);\n265:         wtLog(featureId, \"agent completed — verifying build...\");\n266: \n267:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n268:         const feature = featureMap.get(featureId)!;\n269:         handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor)\n270:           .then(() => launchNextQueued(projectRoot, state, featureMap, monitor, config, model))\n271:           .catch((err) => {\n272:             wtLog(featureId, `BUILD VERIFICATION UNHANDLED ERROR: ${err.message}`);\n273:             launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n274:           });\n275:       },\n276:       onError: (featureId, error) => {\n277:         const agent = state.agents.find((a) => a.feature_id === featureId)!;\n278:         if (agent.retries < agent.max_retries) {\n279:           updateAgent(state, featureId, {\n280:             status: \"retry\",\n281:             retries: agent.retries + 1,\n282:             error,\n283:             activity: \"retrying...\",\n284:           });\n285:           saveState(projectRoot, state);\n286:           handleRetry(projectRoot, state, agent, monitor, config, model);\n287:         } else {\n288:           updateAgent(state, featureId, {\n289:             status: \"failed\",\n290:             error,\n291:             activity: null,\n292:             completed_at: new Date().toISOString(),\n293:           });\n294:           saveState(projectRoot, state);\n295:         }\n296:         launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n297:       },\n298:       onActivity: (featureId, activity) => {\n299:         updateAgent(state, featureId, {\n300:           activity,\n301:           activity_updated_at: new Date().toISOString(),\n302:         });\n303:       },\n304:     });\n305: \n306:     // Handle graceful shutdown\n307:     const tuiRef = { current: null as WomboTUI | null };\n308:     process.on(\"SIGINT\", () => {\n309:       if (tuiRef.current) tuiRef.current.stop();\n310:       for (const agent of state.agents) {\n311:         if (agent.status === \"running\") {\n312:           updateAgent(state, agent.feature_id, {\n313:             activity: \"interrupted\",\n314:           });\n315:         }\n316:       }\n317:       monitor.killAll();\n318:       saveState(projectRoot, state);\n319:       console.log(\"\\nState saved. Use 'wombo resume' to continue.\");\n320:       process.exit(0);\n321:     });\n322: \n323:     await Promise.all(\n324:       toLaunchNow.map((agent) => {\n325:         const feature = featureMap.get(agent.feature_id);\n326:         if (!feature) return Promise.resolve();\n327:         return launchSingleHeadless(projectRoot, state, agent, feature, monitor, config, model);\n328:       })\n329:     );\n330: \n331:     // Start TUI dashboard (or skip if --no-tui)\n332:     if (!opts.noTui) {\n333:       tuiRef.current = new WomboTUI({\n334:         state,\n335:         monitor,\n336:         projectRoot,\n337:         interactive: false,\n338:         config,\n339:         onQuit: () => {\n340:           for (const agent of state.agents) {\n341:             if (agent.status === \"running\") {\n342:               updateAgent(state, agent.feature_id, { activity: \"interrupted\" });\n343:             }\n344:           }\n345:           monitor.killAll();\n346:           saveState(projectRoot, state);\n347:           console.log(\"State saved. Use 'wombo resume' to continue.\");\n348:           process.exit(0);\n349:         },\n350:       });\n351:       tuiRef.current.start();\n352:     } else {\n353:       console.log(\"(--no-tui mode, dashboard prints every 15s)\\n\");\n354:       printDashboard(state);\n355:     }\n356: \n357:     // Monitoring loop\n358:     const POLL_INTERVAL = 5000;\n359:     let dashboardCounter = 0;\n360:     while (!isWaveComplete(state)) {\n361:       await new Promise((r) => setTimeout(r, POLL_INTERVAL));\n362: \n363:       for (const agent of state.agents) {\n364:         if (\n365:           agent.status === \"running\" &&\n366:           agent.pid &&\n367:           !isProcessRunning(agent.pid) &&\n368:           !monitor.isRunning(agent.feature_id)\n369:         ) {\n370:           updateAgent(state, agent.feature_id, {\n371:             status: \"completed\",\n372:             completed_at: new Date().toISOString(),\n373:             activity: \"done\",\n374:           });\n375:           saveState(projectRoot, state);\n376:           const feature = featureMap.get(agent.feature_id)!;\n377:           try {\n378:             await handleBuildVerification(projectRoot, state, agent, feature, config, model, monitor);\n379:           } catch (err: any) {\n380:             wtLog(agent.feature_id, `POLL VERIFY ERROR: ${err.message}`);\n381:           }\n382:           launchNextQueued(projectRoot, state, featureMap, monitor, config, model);\n383:         }\n384:       }\n385: \n386:       saveState(projectRoot, state);\n387:       if (tuiRef.current) {\n388:         tuiRef.current.updateState(state);\n389:       } else if (opts.noTui) {\n390:         dashboardCounter++;\n391:         if (dashboardCounter % 3 === 0) {\n392:           printDashboard(state);\n393:         }\n394:       }\n395:     }\n396: \n397:     if (tuiRef.current) tuiRef.current.stop();\n398:     printDashboard(state);\n399: \n400:     // Auto-push base branch if requested\n401:     if (opts.autoPush) {\n402:       await pushBaseBranch(projectRoot, state.base_branch, config);\n403:     }\n404: \n405:     console.log(\"Wave complete.\");\n406:   }\n407: }\n\n(End of file - total 407 lines)\n</content>","title":"src/commands/resume.ts","metadata":{"preview":"/**\n * resume.ts — Resume a previously stopped wave.\n *\n * Usage: wombo resume [options]\n *\n * Restores from .wombo-state.json:\n *   - Agents in \"running\"/\"installing\" whose PID is dead → re-check or re-launch\n *   - Agents in \"queued\" → launch them\n *   - Agents in terminal states (verified/failed/merged) → leave alone\n */\n\nimport type { WomboConfig } from \"../config.js\";\nimport type { Feature } from \"../lib/features.js\";\nimport { loadFeatures } from \"../lib/features.js\";\nimport {\n  loadState,\n  saveState,\n  updateAgent,\n  queuedAgents,\n  isWaveComplete,","truncated":false,"loaded":[]},"time":{"start":1773246955762,"end":1773246955769}}}}
{"type":"tool_use","timestamp":1773246955862,"sessionID":"ses_3224353feffeqylOxitWfk83Ra","part":{"id":"prt_cddc140f6001LxGa7ut8Nd2HfA","sessionID":"ses_3224353feffeqylOxitWfk83Ra","messageID":"msg_cddc12d1700102FZYMvsmWbkC1","type":"tool","callID":"toolu_01VyM23833ohwv6mPB2wXuNw","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-json-output-complete/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wombo-json-output-complete/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"text\") return \"text\";\n40:   // Check env var for agent pipelines\n41:   const env = process.env.WOMBO_OUTPUT;\n42:   if (env === \"json\") return \"json\";\n43:   return \"text\";\n44: }\n45: \n46: /**\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n48:  * In text mode, calls the provided textRenderer callback.\n49:  */\n50: export function output(\n51:   format: OutputFormat,\n52:   data: unknown,\n53:   textRenderer: () => void\n54: ): void {\n55:   if (format === \"json\") {\n56:     console.log(JSON.stringify(data));\n57:   } else {\n58:     textRenderer();\n59:   }\n60: }\n61: \n62: /**\n63:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n64:  * In text mode, outputs the message to stderr normally.\n65:  */\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n67:   if (format === \"json\") {\n68:     console.error(JSON.stringify({ error: message }));\n69:   } else {\n70:     console.error(message);\n71:   }\n72:   process.exit(exitCode);\n73: }\n74: \n75: /**\n76:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n77:  * In text mode, outputs the message to stdout normally.\n78:  */\n79: export function outputMessage(\n80:   format: OutputFormat,\n81:   message: string,\n82:   extra?: Record<string, unknown>\n83: ): void {\n84:   if (format === \"json\") {\n85:     console.log(JSON.stringify({ message, ...extra }));\n86:   } else {\n87:     console.log(message);\n88:   }\n89: }\n90: \n91: // ---------------------------------------------------------------------------\n92: // Field filtering for compact output (--fields)\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Filter an object to only include the specified fields.\n97:  * If fields is undefined/empty, returns the object unchanged.\n98:  */\n99: export function filterFields<T extends Record<string, unknown>>(\n100:   obj: T,\n101:   fields?: string[]\n102: ): Partial<T> {\n103:   if (!fields || fields.length === 0) return obj;\n104:   const result: Partial<T> = {};\n105:   for (const field of fields) {\n106:     if (field in obj) {\n107:       (result as any)[field] = (obj as any)[field];\n108:     }\n109:   }\n110:   return result;\n111: }\n112: \n113: /**\n114:  * Filter an array of objects to only include specified fields per object.\n115:  * If fields is undefined/empty, returns the array unchanged.\n116:  */\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\n118:   arr: T[],\n119:   fields?: string[]\n120: ): Partial<T>[] {\n121:   if (!fields || fields.length === 0) return arr;\n122:   return arr.map((obj) => filterFields(obj, fields));\n123: }\n124: \n125: /**\n126:  * Render a compact text table from an array of objects with selected fields.\n127:  * Used for text-mode --fields output.\n128:  */\n129: export function renderCompactTable(\n130:   items: Record<string, unknown>[],\n131:   fields: string[]\n132: ): void {\n133:   if (items.length === 0) return;\n134: \n135:   // Calculate column widths\n136:   const widths: Record<string, number> = {};\n137:   for (const field of fields) {\n138:     widths[field] = field.length;\n139:     for (const item of items) {\n140:       const val = String(item[field] ?? \"\");\n141:       widths[field] = Math.max(widths[field], val.length);\n142:     }\n143:   }\n144: \n145:   // Header\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n147:   console.log(header);\n148:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n149: \n150:   // Rows\n151:   for (const item of items) {\n152:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n153:     console.log(row);\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\";","truncated":false,"loaded":[]},"time":{"start":1773246955859,"end":1773246955861}}}}
