} else {\n577:           await createWorktree(projectRoot, agent.feature_id, state.base_branch, config);\n578:           updateAgent(state, agent.feature_id, { activity: \"installing deps...\" });\n579:           await installDeps(agent.worktree, agent.feature_id, config);\n580:         }\n581: \n582:         const prompt = generatePrompt(\n583:           featureMap.get(agent.feature_id)!,\n584:           state.base_branch,\n585:           config\n586:         );\n587: \n588:         wtLog(agent.feature_id, \"launching tmux session...\");\n589:         const result = launchInteractive({\n590:           worktreePath: agent.worktree,\n591:           featureId: agent.feature_id,\n592:           prompt,\n593:           model,\n594:           interactive: true,\n595:           config,\n596:         });\n597: \n598:         updateAgent(state, agent.feature_id, {\n599:           status: \"running\",\n600:           pid: result.pid,\n601:           activity: \"tmux session active\",\n602:         });\n603:         saveState(projectRoot, state);\n604:         wtLog(agent.feature_id, `tmux session: ${config.agent.tmuxPrefix}-${agent.feature_id}`);\n605:       } catch (err: any) {\n606:         updateAgent(state, agent.feature_id, {\n607:           status: \"failed\",\n608:           error: err.message,\n609:           activity: null,\n610:           completed_at: new Date().toISOString(),\n611:         });\n612:         saveState(projectRoot, state);\n613:         wtLog(agent.feature_id, `SETUP FAILED: ${err.message.split(\"\\n\")[0]}`);\n614:       }\n615:     })\n616:   );\n617: \n618:   console.log(\"\\nInteractive sessions launched. Use these commands:\");\n619:   console.log(`  tmux attach -t ${config.agent.tmuxPrefix}-<feature-id>   # attach to a session`);\n620:   console.log(\"  tmux ls                                                  # list sessions\");\n621:   console.log(\"  wombo status                                             # check status\");\n622:   console.log(\"  wombo verify                                             # verify builds\");\n623:   console.log(\"  wombo merge                                              # merge verified\");\n624:   console.log(\"  wombo cleanup                                            # remove worktrees\");\n625: \n626:   printDashboard(state);\n\n(Showing lines 537-626 of 742. Use offset=627 to continue.)\n</content>","title":"src/commands/launch.ts","metadata":{"preview":"  }\n\n  if (fmt === \"text\") {\n    console.log(\"Wave complete.\");\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Interactive Wave Launch\n// ---------------------------------------------------------------------------\n\nasync function launchWaveInteractive(\n  projectRoot: string,\n  state: WaveState,\n  features: Feature[],\n  opts: LaunchCommandOptions\n): Promise<void> {\n  const { config, model } = opts;\n  const featureMap = new Map(features.map((f) => [f.id, f]));\n","truncated":true,"loaded":[]},"time":{"start":1773246902922,"end":1773246902927}}}}
