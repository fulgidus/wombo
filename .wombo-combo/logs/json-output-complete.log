bo-state.json\");\n+        if (existsSync(logDir)) console.log(\"  Would remove: .wombo-logs/\");\n+      }\n+    );\n     return;\n   }\n \n-  console.log(\"\\n--- Wombo: Cleanup ---\\n\");\n+  if (fmt === \"text\") {\n+    console.log(\"\\n--- Wombo: Cleanup ---\\n\");\n+  }\n \n   // Kill tmux sessions\n   const killed = killAllTmuxSessions(config);\n-  console.log(`Killed ${killed} tmux session(s)`);\n+  if (fmt === \"text\") {\n+    console.log(`Killed ${killed} tmux session(s)`);\n+  }\n \n   // Remove worktrees\n   const removed = cleanupAllWorktrees(projectRoot, config);\n-  console.log(`Removed ${removed} worktree(s)`);\n+  if (fmt === \"text\") {\n+    console.log(`Removed ${removed} worktree(s)`);\n+  }\n \n   // List remaining feature branches\n+  let remainingBranches: string[] = [];\n   try {\n     const branchPattern = `\"${config.git.branchPrefix}*\"`;\n     const branches = execSync(`git branch --list ${branchPattern}`, {\n       cwd: projectRoot,\n       encoding: \"utf-8\",\n     }).trim();\n     if (branches) {\n-      console.log(`\\nRemaining feature branches:\\n${branches}`);\n-      console.log('Use \"git branch -D <branch>\" to remove manually.');\n+      remainingBranches = branches.split(\"\\n\").map((b) => b.trim());\n+      if (fmt === \"text\") {\n+        console.log(`\\nRemaining feature branches:\\n${branches}`);\n+        console.log('Use \"git branch -D <branch>\" to remove manually.');\n+      }\n     }\n   } catch {}\n \n   // Remove state file\n   const statePath = resolve(projectRoot, \".wombo-state.json\");\n+  let stateRemoved = false;\n   if (existsSync(statePath)) {\n     unlinkSync(statePath);\n-    console.log(\"Removed .wombo-state.json\");\n+    stateRemoved = true;\n+    if (fmt === \"text\") {\n+      console.log(\"Removed .wombo-state.json\");\n+    }\n   }\n \n   // Remove log directory\n   const logDir = resolve(projectRoot, \".wombo-logs\");\n+  let logsRemoved = false;\n   if (existsSync(logDir)) {\n     rmSync(logDir, { recursive: true, force: true });\n-    console.log(\"Removed .wombo-logs/\");\n+    logsRemoved = true;\n+    if (fmt === \"text\") {\n+      console.log(\"Removed .wombo-logs/\");\n+    }\n   }\n \n-  console.log(\"\\nCleanup complete.\");\n+  output(\n+    fmt,\n+    {\n+      tmux_sessions_killed: killed,\n+      worktrees_removed: removed,\n+      state_removed: stateRemoved,\n+      logs_removed: logsRemoved,\n+      remaining_branches: remainingBranches,\n+    },\n+    () => {\n+      console.log(\"\\nCleanup complete.\");\n+    }\n+  );\n }\n","filediff":{"file":"/home/fulgidus/Documents/wombo-json-output-complete/src/commands/cleanup.ts","before":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: wombo cleanup\n *\n * Kills tmux sessions, removes worktrees, removes state and log files.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { killAllTmuxSessions } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees } from \"../lib/worktree.js\";\n\nexport interface CleanupOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  dryRun?: boolean;\n}\n\nexport async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n\n  // Dry-run: show what would be cleaned up without doing it\n  if (opts.dryRun) {\n    console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n\n    // List tmux sessions that would be killed\n    try {\n      const sessions = execSync(\"tmux list-sessions -F '#{session_name}'\", {\n        encoding: \"utf-8\",\n      }).trim();\n      const prefix = config.agent.tmuxPrefix;\n      const matching = sessions\n        .split(\"\\n\")\n        .filter((s) => s.startsWith(prefix));\n      console.log(`  tmux sessions to kill: ${matching.length}`);\n      for (const s of matching) {\n        console.log(`    ${s}`);\n      }\n    } catch {\n      console.log(\"  tmux sessions to kill: 0 (no tmux server running)\");\n    }\n\n    // List worktrees that would be removed\n    try {\n      const worktrees = execSync(\"git worktree list --porcelain\", {\n        cwd: projectRoot,\n        encoding: \"utf-8\",\n      }).trim();\n      const prefix = config.git.worktreePrefix;\n      const matching = worktrees\n        .split(\"\\n\")\n        .filter((line) => line.startsWith(\"worktree \") && line.includes(prefix))\n        .map((line) => line.replace(\"worktree \", \"\"));\n      console.log(`  worktrees to remove: ${matching.length}`);\n      for (const w of matching) {\n        console.log(`    ${w}`);\n      }\n    } catch {\n      console.log(\"  worktrees to remove: 0\");\n    }\n\n    const statePath = resolve(projectRoot, \".wombo-state.json\");\n    const logDir = resolve(projectRoot, \".wombo-logs\");\n    if (existsSync(statePath)) console.log(\"  Would remove: .wombo-state.json\");\n    if (existsSync(logDir)) console.log(\"  Would remove: .wombo-logs/\");\n\n    return;\n  }\n\n  console.log(\"\\n--- Wombo: Cleanup ---\\n\");\n\n  // Kill tmux sessions\n  const killed = killAllTmuxSessions(config);\n  console.log(`Killed ${killed} tmux session(s)`);\n\n  // Remove worktrees\n  const removed = cleanupAllWorktrees(projectRoot, config);\n  console.log(`Removed ${removed} worktree(s)`);\n\n  // List remaining feature branches\n  try {\n    const branchPattern = `\"${config.git.branchPrefix}*\"`;\n    const branches = execSync(`git branch --list ${branchPattern}`, {\n      cwd: projectRoot,\n      encoding: \"utf-8\",\n    }).trim();\n    if (branches) {\n      console.log(`\\nRemaining feature branches:\\n${branches}`);\n      console.log('Use \"git branch -D <branch>\" to remove manually.');\n    }\n  } catch {}\n\n  // Remove state file\n  const statePath = resolve(projectRoot, \".wombo-state.json\");\n  if (existsSync(statePath)) {\n    unlinkSync(statePath);\n    console.log(\"Removed .wombo-state.json\");\n  }\n\n  // Remove log directory\n  const logDir = resolve(projectRoot, \".wombo-logs\");\n  if (existsSync(logDir)) {\n    rmSync(logDir, { recursive: true, force: true });\n    console.log(\"Removed .wombo-logs/\");\n  }\n\n  console.log(\"\\nCleanup complete.\");\n}\n","after":"/**\n * cleanup.ts — Remove all wave-related resources.\n *\n * Usage: wombo cleanup\n *\n * Kills tmux sessions, removes worktrees, removes state and log files.\n */\n\nimport { existsSync, unlinkSync, rmSync } from \"node:fs\";\nimport { execSync } from \"node:child_process\";\nimport { resolve } from \"node:path\";\nimport type { WomboConfig } from \"../config.js\";\nimport { killAllTmuxSessions } from \"../lib/launcher.js\";\nimport { cleanupAllWorktrees } from \"../lib/worktree.js\";\nimport { output, type OutputFormat } from \"../lib/output.js\";\n\nexport interface CleanupOptions {\n  projectRoot: string;\n  config: WomboConfig;\n  dryRun?: boolean;\n  outputFmt?: OutputFormat;\n}\n\nexport async function cmdCleanup(opts: CleanupOptions): Promise<void> {\n  const { projectRoot, config } = opts;\n  const fmt = opts.outputFmt ?? \"text\";\n\n  // Dry-run: show what would be cleaned up without doing it\n  if (opts.dryRun) {\n    let tmuxSessions: string[] = [];\n    let worktrees: string[] = [];\n\n    // List tmux sessions that would be killed\n    try {\n      const sessions = execSync(\"tmux list-sessions -F '#{session_name}'\", {\n        encoding: \"utf-8\",\n      }).trim();\n      const prefix = config.agent.tmuxPrefix;\n      tmuxSessions = sessions\n        .split(\"\\n\")\n        .filter((s) => s.startsWith(prefix));\n    } catch {\n      // no tmux server running\n    }\n\n    // List worktrees that would be removed\n    try {\n      const worktreeOutput = execSync(\"git worktree list --porcelain\", {\n        cwd: projectRoot,\n        encoding: \"utf-8\",\n      }).trim();\n      const prefix = config.git.worktreePrefix;\n      worktrees = worktreeOutput\n        .split(\"\\n\")\n        .filter((line) => line.startsWith(\"worktree \") && line.includes(prefix))\n        .map((line) => line.replace(\"worktree \", \"\"));\n    } catch {\n      // no worktrees\n    }\n\n    const statePath = resolve(projectRoot, \".wombo-state.json\");\n    const logDir = resolve(projectRoot, \".wombo-logs\");\n    const filesToRemove: string[] = [];\n    if (existsSync(statePath)) filesToRemove.push(\".wombo-state.json\");\n    if (existsSync(logDir)) filesToRemove.push(\".wombo-logs/\");\n\n    output(\n      fmt,\n      {\n        dry_run: true,\n        tmux_sessions: tmuxSessions,\n        tmux_sessions_count: tmuxSessions.length,\n        worktrees,\n        worktrees_count: worktrees.length,\n        files: filesToRemove,\n      },\n      () => {\n        console.log(\"\\n[dry-run] Would perform the following cleanup:\\n\");\n\n        console.log(`  tmux sessions to kill: ${tmuxSessions.length}`);\n        for (const s of tmuxSessions) {\n          console.log(`    ${s}`);\n        }\n\n        console.log(`  worktrees to remove: ${worktrees.length}`);\n        for (const w of worktrees) {\n          console.log(`    ${w}`);\n        }\n\n        if (existsSync(statePath)) console.log(\"  Would remove: .wombo-state.json\");\n        if (existsSync(logDir)) console.log(\"  Would remove: .wombo-logs/\");\n      }\n    );\n    return;\n  }\n\n  if (fmt === \"text\") {\n    console.log(\"\\n--- Wombo: Cleanup ---\\n\");\n  }\n\n  // Kill tmux sessions\n  const killed = killAllTmuxSessions(config);\n  if (fmt === \"text\") {\n    console.log(`Killed ${killed} tmux session(s)`);\n  }\n\n  // Remove worktrees\n  const removed = cleanupAllWorktrees(projectRoot, config);\n  if (fmt === \"text\") {\n    console.log(`Removed ${removed} worktree(s)`);\n  }\n\n  // List remaining feature branches\n  let remainingBranches: string[] = [];\n  try {\n    const branchPattern = `\"${config.git.branchPrefix}*\"`;\n    const branches = execSync(`git branch --list ${branchPattern}`, {\n      cwd: projectRoot,\n      encoding: \"utf-8\",\n    }).trim();\n    if (branches) {\n      remainingBranches = branches.split(\"\\n\").map((b) => b.trim());\n      if (fmt === \"text\") {\n        console.log(`\\nRemaining feature branches:\\n${branches}`);\n        console.log('Use \"git branch -D <branch>\" to remove manually.');\n      }\n    }\n  } catch {}\n\n  // Remove state file\n  const statePath = resolve(projectRoot, \".wombo-state.json\");\n  let stateRemoved = false;\n  if (existsSync(statePath)) {\n    unlinkSync(statePath);\n    stateRemoved = true;\n    if (fmt === \"text\") {\n      console.log(\"Removed .wombo-state.json\");\n    }\n  }\n\n  // Remove log directory\n  const logDir = resolve(projectRoot, \".wombo-logs\");\n  let logsRemoved = false;\n  if (existsSync(logDir)) {\n    rmSync(logDir, { recursive: true, force: true });\n    logsRemoved = true;\n    if (fmt === \"text\") {\n      console.log(\"Removed .wombo-logs/\");\n    }\n  }\n\n  output(\n    fmt,\n    {\n      tmux_sessions_killed: killed,\n      worktrees_removed: removed,\n      state_removed: stateRemoved,\n      logs_removed: logsRemoved,\n      remaining_branches: remainingBranches,\n    },\n    () => {\n      console.log(\"\\nCleanup complete.\");\n    }\n  );\n}\n","additions":78,"deletions":24},"truncated":false},"time":{"start":1773245348910,"end":1773245351924}}}}
