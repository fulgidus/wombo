{"type":"tool_use","timestamp":1773246681946,"sessionID":"ses_322435403ffe4OOvT8TwP2P2VN","part":{"id":"prt_cddbd11b8001XdXcZF2Q3oW2Xx","sessionID":"ses_322435403ffe4OOvT8TwP2P2VN","messageID":"msg_cddbd00c8001vQO4U5SNkISAvV","type":"tool","callID":"toolu_01SCY8R6ea6ca5BRodfLFQP7","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/index.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/index.ts</path>\n<type>file</type>\n<content>1: #!/usr/bin/env bun\n2: /**\n3:  * index.ts — CLI entry point for the Wombo agent orchestration system.\n4:  *\n5:  * Usage:\n6:  *   wombo init\n7:  *   wombo launch --top-priority 3\n8:  *   wombo launch --quickest-wins 5\n9:  *   wombo launch --priority high\n10:  *   wombo launch --difficulty easy\n11:  *   wombo launch --features \"feat-a,feat-b\"\n12:  *   wombo launch --all-ready\n13:  *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n14:  *   wombo launch ... --interactive\n15:  *   wombo resume\n16:  *   wombo status\n17:  *   wombo verify [feature-id]\n18:  *   wombo merge [feature-id]\n19:  *   wombo retry <feature-id>\n20:  *   wombo cleanup\n21:  *   wombo features list [--status <s>] [--priority <p>] [--difficulty <d>] [--ready] [--include-archive]\n22:  *   wombo features add <id> <title> [options]\n23:  *   wombo features set-status <feature-id> <status>\n24:  *   wombo features check\n25:  *   wombo features archive [feature-id] [--dry-run]\n26:  *   wombo features show <feature-id>\n27:  *   wombo help\n28:  */\n29: \n30: import { resolve } from \"node:path\";\n31: import { existsSync, readFileSync } from \"node:fs\";\n32: import { loadConfig, validateConfig } from \"./config.js\";\n33: import { loadState, saveState } from \"./lib/state.js\";\n34: \n35: // ---------------------------------------------------------------------------\n36: // Dev-mode guard: warn if running the global binary inside the wombo repo\n37: // ---------------------------------------------------------------------------\n38: \n39: function checkDevModeGuard(): void {\n40:   const cwd = process.cwd();\n41:   const pkgPath = resolve(cwd, \"package.json\");\n42: \n43:   // Are we inside the wombo repo?\n44:   if (!existsSync(pkgPath)) return;\n45: \n46:   let pkgName: string | undefined;\n47:   try {\n48:     const raw = readFileSync(pkgPath, \"utf-8\");\n49:     pkgName = JSON.parse(raw).name;\n50:   } catch {\n51:     return;\n52:   }\n53:   if (pkgName !== \"wombo\") return;\n54: \n55:   // We're in the wombo repo. Is the source being run from a different location?\n56:   // import.meta.dir = directory of THIS file (index.ts). If it's under cwd,\n57:   // we're running local source (bun dev). If it's elsewhere (e.g. ~/.bun/install),\n58:   // we're running the globally installed binary.\n59:   const sourceDir = resolve(import.meta.dir);\n60:   const projectSrc = resolve(cwd, \"src\");\n61: \n62:   if (!sourceDir.startsWith(projectSrc)) {\n63:     console.warn(\n64:       \"\\x1b[33m[WARNING]\\x1b[0m You are running the globally installed wombo binary \" +\n65:       \"inside the wombo repo.\\n\" +\n66:       \"  Use \\x1b[1mbun dev <command>\\x1b[0m instead to run from local source.\\n\" +\n67:       \"  See AGENTS.md for details.\\n\"\n68:     );\n69:   }\n70: }\n71: \n72: import { cmdInit } from \"./commands/init.js\";\n73: import { cmdLaunch } from \"./commands/launch.js\";\n74: import { cmdResume } from \"./commands/resume.js\";\n75: import { cmdStatus } from \"./commands/status.js\";\n76: import { cmdVerify } from \"./commands/verify.js\";\n77: import { cmdMerge } from \"./commands/merge.js\";\n78: import { cmdRetry } from \"./commands/retry.js\";\n79: import { cmdCleanup } from \"./commands/cleanup.js\";\n80: import { cmdUpgrade } from \"./commands/upgrade.js\";\n81: import { cmdFeaturesList } from \"./commands/features/list.js\";\n82: import { cmdFeaturesAdd } from \"./commands/features/add.js\";\n83: import { cmdFeaturesSetStatus } from \"./commands/features/set-status.js\";\n84: import { cmdFeaturesCheck } from \"./commands/features/check.js\";\n85: import { cmdFeaturesArchive } from \"./commands/features/archive.js\";\n86: import { cmdFeaturesShow } from \"./commands/features/show.js\";\n87: \n88: import { ensureFeaturesFile, VALID_PRIORITIES, VALID_DIFFICULTIES } from \"./lib/features.js\";\n89: import type { Priority, Difficulty, FeatureStatus } from \"./lib/features.js\";\n90: import { resolveOutputFormat, type OutputFormat } from \"./lib/output.js\";\n91: import { validateId, validateText, validateBranchName, validateDuration, validateEnum, assertValid } from \"./lib/validate.js\";\n92: import { findCommandDef, commandToSchema, allCommandSchemas } from \"./lib/schema.js\";\n93: \n94: // ---------------------------------------------------------------------------\n95: // Types\n96: // ---------------------------------------------------------------------------\n97: \n98: interface CLIArgs {\n99:   command: string;\n100:   subcommand?: string;\n101:   // Selection options (launch)\n102:   topPriority?: number;\n103:   quickestWins?: number;\n104:   priority?: Priority;\n105:   difficulty?: Difficulty;\n106:   features?: string[];\n107:   allReady?: boolean;\n108:   // Launch / runtime options\n109:   maxConcurrent?: number;\n110:   model?: string;\n111:   interactive: boolean;\n112:   dryRun: boolean;\n113:   baseBranch?: string;\n114:   maxRetries?: number;\n115:   noTui: boolean;\n116:   autoPush: boolean;\n117:   // General\n118:   featureId?: string;\n119:   force: boolean;\n120:   // Output format\n121:   outputFmt: OutputFormat;\n122:   // Upgrade options\n123:   checkOnly: boolean;\n124:   version?: string;\n125:   // Features subcommand extras\n126:   status?: string;\n127:   ready?: boolean;\n128:   includeArchive?: boolean;\n129:   title?: string;\n130:   description?: string;\n131:   effort?: string;\n132:   dependsOn?: string[];\n133:   // Compact output\n134:   fields?: string[];\n135: }\n136: \n137: // ---------------------------------------------------------------------------\n138: // Arg Parsing\n139: // ---------------------------------------------------------------------------\n140: \n141: function parseArgs(argv: string[]): CLIArgs {\n142:   const args = argv.slice(2); // skip 'bun' and script path\n143:   const result: CLIArgs = {\n144:     command: args[0] || \"help\",\n145:     interactive: false,\n146:     dryRun: false,\n147:     noTui: false,\n148:     autoPush: false,\n149:     force: false,\n150:     checkOnly: false,\n151:     outputFmt: resolveOutputFormat(undefined), // auto-detect until --output overrides\n152:   };\n153: \n154:   // If the first arg is \"features\", treat the second positional as the subcommand\n155:   let startIdx = 1;\n156:   if (result.command === \"features\") {\n157:     result.subcommand = args[1] || \"list\";\n158:     startIdx = 2;\n159:   }\n160: \n161:   for (let i = startIdx; i < args.length; i++) {\n162:     const arg = args[i];\n163:     switch (arg) {\n164:       // --- Selection options ---\n165:       case \"--top-priority\":\n166:         result.topPriority = parseInt(args[++i], 10);\n167:         break;\n168:       case \"--quickest-wins\":\n169:         result.quickestWins = parseInt(args[++i], 10);\n170:         break;\n171:       case \"--priority\":\n172:         result.priority = args[++i] as Priority;\n173:         break;\n174:       case \"--difficulty\":\n175:         result.difficulty = args[++i] as Difficulty;\n176:         break;\n177:       case \"--features\":\n178:         result.features = args[++i].split(\",\").map((s) => s.trim());\n179:         break;\n180:       case \"--all-ready\":\n181:         result.allReady = true;\n182:         break;\n183: \n184:       // --- Launch / runtime options ---\n185:       case \"--max-concurrent\":\n186:         result.maxConcurrent = parseInt(args[++i], 10);\n187:         break;\n188:       case \"--model\":\n189:       case \"-m\":\n190:         result.model = args[++i];\n191:         break;\n192:       case \"--interactive\":\n193:         result.interactive = true;\n194:         break;\n195:       case \"--dry-run\":\n196:         result.dryRun = true;\n197:         break;\n198:       case \"--no-tui\":\n199:         result.noTui = true;\n200:         break;\n201:       case \"--auto-push\":\n202:         result.autoPush = true;\n203:         break;\n204:       case \"--base-branch\":\n205:         result.baseBranch = args[++i];\n206:         break;\n207:       case \"--max-retries\":\n208:         result.maxRetries = parseInt(args[++i], 10);\n209:         break;\n210: \n211:       // --- General flags ---\n212:       case \"--force\":\n213:         result.force = true;\n214:         break;\n215:       case \"--check\":\n216:         result.checkOnly = true;\n217:         break;\n218:       case \"--version\":\n219:         result.version = args[++i];\n220:         break;\n221:       case \"--output\":\n222:       case \"-o\":\n223:         result.outputFmt = resolveOutputFormat(args[++i]);\n224:         break;\n225: \n226:       // --- Features subcommand options ---\n227:       case \"--status\":\n228:         result.status = args[++i];\n229:         break;\n230:       case \"--ready\":\n231:         result.ready = true;\n232:         break;\n233:       case \"--include-archive\":\n234:         result.includeArchive = true;\n235:         break;\n236:       case \"--title\":\n237:         result.title = args[++i];\n238:         break;\n239:       case \"--description\":\n240:       case \"--desc\":\n241:         result.description = args[++i];\n242:         break;\n243:       case \"--effort\":\n244:         result.effort = args[++i];\n245:         break;\n246:       case \"--depends-on\":\n247:         result.dependsOn = args[++i].split(\",\").map((s) => s.trim());\n248:         break;\n249:       case \"--fields\":\n250:         result.fields = args[++i].split(\",\").map((s) => s.trim());\n251:         break;\n252: \n253:       // --- Positional (feature-id, title for add, etc.) ---\n254:       default:\n255:         if (!arg.startsWith(\"-\")) {\n256:           if (!result.featureId) {\n257:             result.featureId = arg;\n258:           } else if (!result.title) {\n259:             result.title = arg;\n260:           }\n261:         }\n262:         break;\n263:     }\n264:   }\n265: \n266:   return result;\n267: }\n268: \n269: // ---------------------------------------------------------------------------\n270: // Help\n271: // ---------------------------------------------------------------------------\n272: \n273: function cmdHelp(): void {\n274:   console.log(`\n275: Wombo — AI Agent Orchestration System\n276: \n277:   WOMBO COMBO! Parallel feature development with AI agents.\n278: \n279: Commands:\n280:   init           Generate wombo.json config in the current project\n281:   launch         Launch a wave of agents to implement features\n282:   resume         Resume a previously stopped wave\n283:   status         Show the status of the current wave\n284:   verify         Run build verification on completed agents\n285:   merge          Merge verified branches into the base branch\n286:   retry          Retry a failed agent\n287:   cleanup        Remove all wave worktrees and tmux sessions\n288:   features       Manage .features.yml (see below)\n289:   upgrade        Check for updates and upgrade wombo\n290:   describe       Emit JSON schema of a command (for AI agents)\n291:   help           Show this help\n292: \n293: Features Subcommands:\n294:   features list            List features (--status, --priority, --difficulty, --ready, --include-archive)\n295:   features add <id> <title> [options]\n296:                            Add a new feature (--desc, --priority, --difficulty, --effort, --depends-on)\n297:   features set-status <id> <status>\n298:                            Change a feature's status\n299:   features check           Validate .features.yml (schema, deps, duplicates, cycles)\n300:   features archive [id]    Move done/cancelled to archive (--dry-run)\n301:   features show <id>       Show feature details\n302: \n303: Selection Options (for launch):\n304:   --top-priority N         Select top N features by priority\n305:   --quickest-wins N        Select N features with lowest effort\n306:   --priority <level>       Filter by priority (critical/high/medium/low/wishlist)\n307:   --difficulty <level>     Filter by difficulty (trivial/easy/medium/hard/very_hard)\n308:   --features \"id1,id2\"     Select specific features by ID\n309:   --all-ready              Select all features whose dependencies are met\n310: \n311: Launch Options:\n312:   --max-concurrent N       Max agents running in parallel (default: from config)\n313:   --model <model>          Model to use (e.g., \"anthropic/claude-sonnet-4-20250514\")\n314:   --interactive            Use tmux TUI mode instead of headless\n315:   --no-tui                 Headless mode without neo-blessed TUI (periodic console dashboard)\n316:   --auto-push              Push base branch to remote after all merges complete\n317:   --dry-run                Show what would be launched without launching\n318:   --base-branch <branch>   Base branch (default: from config)\n319:   --max-retries N          Max retries per agent (default: from config)\n320: \n321: General:\n322:   --force                  Force overwrite (e.g., for init) / skip prompts (e.g., for upgrade)\n323:   --output <fmt>           Output format: text (default on TTY) or json (default when piped)\n324:   -o <fmt>                 Alias for --output\n325:   --dry-run                Show what would happen without performing the action\n326:   --fields <list>          Comma-separated fields to include (e.g., id,status,priority)\n327: \n328: Upgrade Options:\n329:   --check                  Only check for updates, don't install\n330:   --version <tag>          Install a specific version (e.g., v0.1.0)\n331: \n332: Examples:\n333:   wombo init\n334:   wombo launch --quickest-wins 3\n335:   wombo launch --priority high --interactive\n336:   wombo launch --features \"auth-flow,search-api\" --max-concurrent 2\n337:   wombo resume\n338:   wombo status\n339:   wombo verify\n340:   wombo merge\n341:   wombo retry auth-flow\n342:   wombo cleanup\n343:   wombo features list --status ready --priority high\n344:   wombo features list --fields id,status,priority --output json\n345:   wombo features add my-feature \"My Cool Feature\" --priority high --difficulty easy\n346:   wombo features set-status my-feature in-progress\n347:   wombo features check\n348:   wombo features archive --dry-run\n349:   wombo features show my-feature\n350:   wombo describe                           # list all commands as JSON\n351:   wombo describe launch                    # describe a specific command\n352:   wombo describe features add              # describe a subcommand\n353: `);\n354: }\n355: \n356: // ---------------------------------------------------------------------------\n357: // Main\n358: // ---------------------------------------------------------------------------\n359: \n360: async function main(): Promise<void> {\n361:   checkDevModeGuard();\n362: \n363:   const PROJECT_ROOT = resolve(process.cwd());\n364:   const args = parseArgs(process.argv);\n365: \n366:   // -----------------------------------------------------------------------\n367:   // Input validation at the CLI boundary\n368:   // -----------------------------------------------------------------------\n369:   if (args.featureId) {\n370:     assertValid(validateId(args.featureId, \"feature ID\"));\n371:   }\n372:   if (args.title) {\n373:     assertValid(validateText(args.title, \"title\"));\n374:   }\n375:   if (args.description) {\n376:     assertValid(validateText(args.description, \"description\"));\n377:   }\n378:   if (args.baseBranch) {\n379:     assertValid(validateBranchName(args.baseBranch, \"base branch\"));\n380:   }\n381:   if (args.effort) {\n382:     assertValid(validateDuration(args.effort, \"effort\"));\n383:   }\n384:   if (args.priority) {\n385:     assertValid(validateEnum(args.priority, VALID_PRIORITIES, \"--priority\"));\n386:   }\n387:   if (args.difficulty) {\n388:     assertValid(validateEnum(args.difficulty, VALID_DIFFICULTIES, \"--difficulty\"));\n389:   }\n390:   if (args.features) {\n391:     for (const fid of args.features) {\n392:       assertValid(validateId(fid, \"feature ID in --features\"));\n393:     }\n394:   }\n395:   if (args.dependsOn) {\n396:     for (const dep of args.dependsOn) {\n397:       assertValid(validateId(dep, \"dependency ID in --depends-on\"));\n398:     }\n399:   }\n400: \n401:   // Commands that don't need config loading\n402:   if (args.command === \"help\" || args.command === \"--help\" || args.command === \"-h\") {\n403:     cmdHelp();\n404:     return;\n405:   }\n406: \n407:   if (args.command === \"describe\") {\n408:     // Schema introspection: `wombo describe [command]`\n409:     if (!args.featureId) {\n410:       // No command specified — list all commands\n411:       console.log(JSON.stringify(allCommandSchemas(), null, 2));\n412:     } else {\n413:       // Describe a specific command. Handle compound names: \"features list\"\n414:       const cmdName = args.title\n415:         ? `${args.featureId} ${args.title}`\n416:         : args.featureId;\n417:       const def = findCommandDef(cmdName);\n418:       if (!def) {\n419:         console.error(`Unknown command: \"${cmdName}\"`);\n420:         console.error(\"Run 'wombo describe' to list all commands.\");\n421:         process.exit(1);\n422:         return;\n423:       }\n424:       console.log(JSON.stringify(commandToSchema(def), null, 2));\n425:     }\n426:     return;\n427:   }\n428: \n429:   if (args.command === \"init\") {\n430:     await cmdInit({ projectRoot: PROJECT_ROOT, force: args.force });\n431:     return;\n432:   }\n433: \n434:   if (args.command === \"upgrade\") {\n435:     await cmdUpgrade({\n436:       force: args.force,\n437:       version: args.version,\n438:       checkOnly: args.checkOnly,\n439:     });\n440:     return;\n441:   }\n442: \n443:   // Everything else requires config\n444:   const config = loadConfig(PROJECT_ROOT);\n445:   validateConfig(config);\n446: \n447:   // Commands that operate on the features file — ensure it exists first\n448:   const needsFeatures = new Set([\"launch\", \"resume\", \"verify\", \"retry\", \"features\"]);\n449:   if (needsFeatures.has(args.command)) {\n450:     await ensureFeaturesFile(PROJECT_ROOT, config);\n451:   }\n452: \n453:   switch (args.command) {\n454:     case \"launch\":\n455:       await cmdLaunch({\n456:         projectRoot: PROJECT_ROOT,\n457:         config,\n458:         topPriority: args.topPriority,\n459:         quickestWins: args.quickestWins,\n460:         priority: args.priority,\n461:         difficulty: args.difficulty,\n462:         features: args.features,\n463:         allReady: args.allReady,\n464:         maxConcurrent: args.maxConcurrent ?? config.defaults.maxConcurrent,\n465:         model: args.model,\n466:         interactive: args.interactive,\n467:         dryRun: args.dryRun,\n468:         baseBranch: args.baseBranch ?? config.baseBranch,\n469:         maxRetries: args.maxRetries ?? config.defaults.maxRetries,\n470:         noTui: args.noTui,\n471:         autoPush: args.autoPush,\n472:       });\n473:       break;\n474: \n475:     case \"resume\":\n476:       await cmdResume({\n477:         projectRoot: PROJECT_ROOT,\n478:         config,\n479:         maxConcurrent: args.maxConcurrent,\n480:         model: args.model,\n481:         interactive: args.interactive,\n482:         noTui: args.noTui,\n483:         autoPush: args.autoPush,\n484:         baseBranch: args.baseBranch,\n485:         maxRetries: args.maxRetries,\n486:       });\n487:       break;\n488: \n489:     case \"status\":\n490:       await cmdStatus({ projectRoot: PROJECT_ROOT, config });\n491:       break;\n492: \n493:     case \"verify\":\n494:       await cmdVerify({\n495:         projectRoot: PROJECT_ROOT,\n496:         config,\n497:         featureId: args.featureId,\n498:         model: args.model,\n499:         maxRetries: args.maxRetries,\n500:       });\n501:       break;\n502: \n503:     case \"merge\":\n504:       await cmdMerge({\n505:         projectRoot: PROJECT_ROOT,\n506:         config,\n507:         featureId: args.featureId,\n508:         autoPush: args.autoPush,\n509:         dryRun: args.dryRun,\n510:       });\n511:       break;\n512: \n513:     case \"retry\": {\n514:       if (!args.featureId) {\n515:         console.error(\"Usage: wombo retry <feature-id>\");\n516:         process.exit(1);\n517:         return;\n518:       }\n519:       await cmdRetry({\n520:         projectRoot: PROJECT_ROOT,\n521:         config,\n522:         featureId: args.featureId,\n523:         model: args.model,\n524:         interactive: args.interactive,\n525:         dryRun: args.dryRun,\n526:       });\n527:       break;\n528:     }\n529: \n530:     case \"cleanup\":\n531:       await cmdCleanup({ projectRoot: PROJECT_ROOT, config, dryRun: args.dryRun });\n532:       break;\n533: \n534:     case \"features\":\n535:       await handleFeaturesSubcommand(args, PROJECT_ROOT, config);\n536:       break;\n537: \n538:     default:\n539:       console.error(`Unknown command: ${args.command}`);\n540:       cmdHelp();\n541:       process.exit(1);\n542:       return;\n543:   }\n544: }\n545: \n546: // ---------------------------------------------------------------------------\n547: // Features Subcommand Router\n548: // ---------------------------------------------------------------------------\n549: \n550: async function handleFeaturesSubcommand(\n551:   args: CLIArgs,\n552:   projectRoot: string,\n553:   config: import(\"./config.js\").WomboConfig\n554: ): Promise<void> {\n555:   switch (args.subcommand) {\n556:     case \"list\":\n557:     case \"ls\":\n558:       await cmdFeaturesList({\n559:         projectRoot,\n560:         config,\n561:         status: args.status as FeatureStatus | undefined,\n562:         priority: args.priority,\n563:         difficulty: args.difficulty,\n564:         ready: args.ready,\n565:         includeArchive: args.includeArchive,\n566:         outputFmt: args.outputFmt,\n567:         fields: args.fields,\n568:       });\n569:       break;\n570: \n571:     case \"add\": {\n572:       if (!args.featureId || !args.title) {\n573:         console.error(\"Usage: wombo features add <id> <title> [--desc <desc>] [--priority <p>] [--difficulty <d>] [--effort <e>] [--depends-on <ids>]\");\n574:         process.exit(1);\n575:         return;\n576:       }\n577:       await cmdFeaturesAdd({\n578:         projectRoot,\n579:         config,\n580:         id: args.featureId,\n581:         title: args.title,\n582:         description: args.description,\n583:         priority: args.priority,\n584:         difficulty: args.difficulty,\n585:         effort: args.effort,\n586:         dependsOn: args.dependsOn,\n587:         outputFmt: args.outputFmt,\n588:         dryRun: args.dryRun,\n589:       });\n590:       break;\n591:     }\n592: \n593:     case \"set-status\": {\n594:       if (!args.featureId || !args.title) {\n595:         // title holds the second positional arg (the status value)\n596:         // If not provided via positional, check --status flag\n597:         const newStatus = args.title || args.status;\n598:         if (!args.featureId || !newStatus) {\n599:           console.error(\"Usage: wombo features set-status <feature-id> <status>\");\n600:           process.exit(1);\n601:           return;\n602:         }\n603:         await cmdFeaturesSetStatus({\n604:           projectRoot,\n605:           config,\n606:           featureId: args.featureId,\n607:           newStatus,\n608:           outputFmt: args.outputFmt,\n609:           dryRun: args.dryRun,\n610:         });\n611:       } else {\n612:         await cmdFeaturesSetStatus({\n613:           projectRoot,\n614:           config,\n615:           featureId: args.featureId,\n616:           newStatus: args.title, // second positional = new status\n617:           outputFmt: args.outputFmt,\n618:           dryRun: args.dryRun,\n619:         });\n620:       }\n621:       break;\n622:     }\n623: \n624:     case \"check\":\n625:     case \"validate\":\n626:       await cmdFeaturesCheck({ projectRoot, config });\n627:       break;\n628: \n629:     case \"archive\":\n630:       await cmdFeaturesArchive({\n631:         projectRoot,\n632:         config,\n633:         featureId: args.featureId,\n634:         dryRun: args.dryRun,\n635:         outputFmt: args.outputFmt,\n636:       });\n637:       break;\n638: \n639:     case \"show\": {\n640:       if (!args.featureId) {\n641:         console.error(\"Usage: wombo features show <feature-id>\");\n642:         process.exit(1);\n643:         return;\n644:       }\n645:       await cmdFeaturesShow({\n646:         projectRoot,\n647:         config,\n648:         featureId: args.featureId,\n649:         outputFmt: args.outputFmt,\n650:         fields: args.fields,\n651:       });\n652:       break;\n653:     }\n654: \n655:     case \"help\":\n656:     case \"--help\":\n657:     case \"-h\":\n658:       cmdHelp();\n659:       break;\n660: \n661:     default:\n662:       console.error(`Unknown features subcommand: ${args.subcommand}`);\n663:       console.error(\"Run 'wombo features help' or 'wombo help' for usage.\");\n664:       process.exit(1);\n665:       return;\n666:   }\n667: }\n668: \n669: // ---------------------------------------------------------------------------\n670: // Error Handlers & Entry\n671: // ---------------------------------------------------------------------------\n672: \n673: // Global error handlers — prevent silent crashes\n674: process.on(\"uncaughtException\", (err) => {\n675:   console.error(`\\n[FATAL] Uncaught exception: ${err.message}`);\n676:   console.error(err.stack);\n677:   try {\n678:     const state = loadState(process.cwd());\n679:     if (state) saveState(process.cwd(), state);\n680:   } catch {}\n681:   process.exit(1);\n682: });\n683: \n684: process.on(\"unhandledRejection\", (reason: any) => {\n685:   console.error(`\\n[FATAL] Unhandled rejection: ${reason?.message || reason}`);\n686:   if (reason?.stack) console.error(reason.stack);\n687:   try {\n688:     const state = loadState(process.cwd());\n689:     if (state) saveState(process.cwd(), state);\n690:   } catch {}\n691:   process.exit(1);\n692: });\n693: \n694: main().catch((err) => {\n695:   console.error(\"Fatal error:\", err.message);\n696:   process.exit(1);\n697: });\n\n(End of file - total 697 lines)\n</content>","title":"src/index.ts","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * index.ts — CLI entry point for the Wombo agent orchestration system.\n *\n * Usage:\n *   wombo init\n *   wombo launch --top-priority 3\n *   wombo launch --quickest-wins 5\n *   wombo launch --priority high\n *   wombo launch --difficulty easy\n *   wombo launch --features \"feat-a,feat-b\"\n *   wombo launch --all-ready\n *   wombo launch ... --max-concurrent 3 --model \"anthropic/claude-sonnet-4-20250514\"\n *   wombo launch ... --interactive\n *   wombo resume\n *   wombo status\n *   wombo verify [feature-id]\n *   wombo merge [feature-id]\n *   wombo retry <feature-id>\n *   wombo cleanup","truncated":false,"loaded":[]},"time":{"start":1773246681942,"end":1773246681945}}}}
