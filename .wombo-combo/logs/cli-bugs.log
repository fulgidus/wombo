{"type":"tool_use","timestamp":1773245122780,"sessionID":"ses_3225b056affeIKEEihnMYwMnTu","part":{"id":"prt_cdda54678001i92uq3vf1oLDpW","sessionID":"ses_3225b056affeIKEEihnMYwMnTu","messageID":"msg_cdda53521001UuGUukGjwCgh80","type":"tool","callID":"toolu_01WtDWk29TgAZn3N1TQbnTAQ","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/add.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/add.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/add.ts — Add a new feature to the features file.\n3:  *\n4:  * Usage:\n5:  *   wombo features add <id> --title \"Feature Title\" [--description \"...\"]\n6:  *                      [--priority medium] [--difficulty easy] [--effort PT2H]\n7:  *                      [--depends-on \"feat1,feat2\"]\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   createBlankFeature,\n15:   allFeatureIds,\n16:   type Priority,\n17:   type Difficulty,\n18: } from \"../../lib/features.js\";\n19: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface FeaturesAddOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   id: string;\n29:   title: string;\n30:   description?: string;\n31:   priority?: Priority;\n32:   difficulty?: Difficulty;\n33:   effort?: string;\n34:   dependsOn?: string[];\n35:   outputFmt?: OutputFormat;\n36:   dryRun?: boolean;\n37: }\n38: \n39: // ---------------------------------------------------------------------------\n40: // Command\n41: // ---------------------------------------------------------------------------\n42: \n43: export async function cmdFeaturesAdd(opts: FeaturesAddOptions): Promise<void> {\n44:   const { projectRoot, config } = opts;\n45:   const fmt = opts.outputFmt ?? \"text\";\n46: \n47:   if (!opts.id) {\n48:     outputError(fmt, \"Usage: wombo features add <id> --title \\\"Feature Title\\\"\");\n49:     return;\n50:   }\n51: \n52:   if (!opts.title) {\n53:     outputError(fmt, \"--title is required when adding a feature.\");\n54:     return;\n55:   }\n56: \n57:   const data = loadFeatures(projectRoot, config);\n58: \n59:   // Check for duplicate ID\n60:   const existingIds = allFeatureIds(data);\n61:   if (existingIds.includes(opts.id)) {\n62:     outputError(fmt, `Feature ID \"${opts.id}\" already exists.`);\n63:     return;\n64:   }\n65: \n66:   // Validate depends_on references\n67:   if (opts.dependsOn?.length) {\n68:     for (const dep of opts.dependsOn) {\n69:       if (!existingIds.includes(dep)) {\n70:         outputError(fmt, `Dependency \"${dep}\" does not exist in the features file.`);\n71:         return;\n72:       }\n73:     }\n74:   }\n75: \n76:   // Create the feature\n77:   const feature = createBlankFeature(opts.id, opts.title, opts.description ?? \"\", {\n78:     priority: opts.priority,\n79:     difficulty: opts.difficulty,\n80:     effort: opts.effort,\n81:   });\n82: \n83:   // Set dependencies\n84:   if (opts.dependsOn?.length) {\n85:     feature.depends_on = opts.dependsOn;\n86:   }\n87: \n88:   // Dry-run: show what would be added without writing\n89:   if (opts.dryRun) {\n90:     outputMessage(fmt, `[dry-run] Would add feature: ${opts.id} — ${opts.title}`, {\n91:       dry_run: true,\n92:       id: feature.id,\n93:       title: feature.title,\n94:       priority: feature.priority,\n95:       difficulty: feature.difficulty,\n96:       effort: feature.effort,\n97:       depends_on: feature.depends_on,\n98:     });\n99:     return;\n100:   }\n101: \n102:   // Append to features list\n103:   data.features.push(feature);\n104:   saveFeatures(projectRoot, config, data);\n105: \n106:   outputMessage(fmt, `Added feature: ${opts.id} — ${opts.title}`, {\n107:     id: feature.id,\n108:     title: feature.title,\n109:     priority: feature.priority,\n110:     difficulty: feature.difficulty,\n111:     effort: feature.effort,\n112:     depends_on: feature.depends_on,\n113:   });\n114: \n115:   if (fmt === \"text\") {\n116:     console.log(`  priority: ${feature.priority}, difficulty: ${feature.difficulty}, effort: ${feature.effort}`);\n117:     if (feature.depends_on.length > 0) {\n118:       console.log(`  depends on: ${feature.depends_on.join(\", \")}`);\n119:     }\n120:   }\n121: }\n\n(End of file - total 121 lines)\n</content>","title":"src/commands/features/add.ts","metadata":{"preview":"/**\n * features/add.ts — Add a new feature to the features file.\n *\n * Usage:\n *   wombo features add <id> --title \"Feature Title\" [--description \"...\"]\n *                      [--priority medium] [--difficulty easy] [--effort PT2H]\n *                      [--depends-on \"feat1,feat2\"]\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  createBlankFeature,\n  allFeatureIds,\n  type Priority,\n  type Difficulty,\n} from \"../../lib/features.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773245122776,"end":1773245122779}}}}
{"type":"tool_use","timestamp":1773245123199,"sessionID":"ses_3225b056affeIKEEihnMYwMnTu","part":{"id":"prt_cdda548d9001dTGQS5789GLkcO","sessionID":"ses_3225b056affeIKEEihnMYwMnTu","messageID":"msg_cdda53521001UuGUukGjwCgh80","type":"tool","callID":"toolu_0191iRdRZfng6iEvgZ26ju9H","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/archive.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/archive.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/archive.ts — Move done/cancelled features to the archive section.\n3:  *\n4:  * Usage:\n5:  *   wombo features archive              # archive all done + cancelled\n6:  *   wombo features archive <feature-id> # archive a specific feature\n7:  *   wombo features archive --dry-run    # show what would be archived\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   findFeatureById,\n15:   type Feature,\n16: } from \"../../lib/features.js\";\n17: \n18: // ---------------------------------------------------------------------------\n19: // Types\n20: // ---------------------------------------------------------------------------\n21: \n22: export interface FeaturesArchiveOptions {\n23:   projectRoot: string;\n24:   config: WomboConfig;\n25:   featureId?: string;\n26:   dryRun?: boolean;\n27: }\n28: \n29: // ---------------------------------------------------------------------------\n30: // Command\n31: // ---------------------------------------------------------------------------\n32: \n33: export async function cmdFeaturesArchive(opts: FeaturesArchiveOptions): Promise<void> {\n34:   const { projectRoot, config } = opts;\n35: \n36:   const data = loadFeatures(projectRoot, config);\n37: \n38:   // Ensure archive array exists\n39:   if (!data.archive) {\n40:     data.archive = [];\n41:   }\n42: \n43:   let toArchive: Feature[];\n44: \n45:   if (opts.featureId) {\n46:     // Archive a specific feature\n47:     const idx = data.features.findIndex((f) => f.id === opts.featureId);\n48:     if (idx === -1) {\n49:       // Check if already in archive\n50:       if (data.archive.find((f) => f.id === opts.featureId)) {\n51:         console.log(`Feature \"${opts.featureId}\" is already in the archive.`);\n52:         return;\n53:       }\n54:       console.error(`Feature \"${opts.featureId}\" not found.`);\n55:       process.exit(1);\n56:       return;\n57:     }\n58:     toArchive = [data.features[idx]];\n59:   } else {\n60:     // Archive all done + cancelled features\n61:     toArchive = data.features.filter(\n62:       (f) => f.status === \"done\" || f.status === \"cancelled\"\n63:     );\n64:   }\n65: \n66:   if (toArchive.length === 0) {\n67:     console.log(\"No features to archive.\");\n68:     return;\n69:   }\n70: \n71:   if (opts.dryRun) {\n72:     console.log(`\\nWould archive ${toArchive.length} feature(s):\\n`);\n73:     for (const f of toArchive) {\n74:       console.log(`  ${f.id} — ${f.title} (${f.status})`);\n75:     }\n76:     return;\n77:   }\n78: \n79:   // Move features from active to archive\n80:   const archiveIds = new Set(toArchive.map((f) => f.id));\n81:   data.features = data.features.filter((f) => !archiveIds.has(f.id));\n82:   data.archive.push(...toArchive);\n83: \n84:   saveFeatures(projectRoot, config, data);\n85: \n86:   console.log(`\\nArchived ${toArchive.length} feature(s):`);\n87:   for (const f of toArchive) {\n88:     console.log(`  ${f.id} — ${f.title} (${f.status})`);\n89:   }\n90: }\n\n(End of file - total 90 lines)\n</content>","title":"src/commands/features/archive.ts","metadata":{"preview":"/**\n * features/archive.ts — Move done/cancelled features to the archive section.\n *\n * Usage:\n *   wombo features archive              # archive all done + cancelled\n *   wombo features archive <feature-id> # archive a specific feature\n *   wombo features archive --dry-run    # show what would be archived\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Feature,\n} from \"../../lib/features.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------","truncated":false,"loaded":[]},"time":{"start":1773245123196,"end":1773245123199}}}}
{"type":"tool_use","timestamp":1773245123598,"sessionID":"ses_3225b056affeIKEEihnMYwMnTu","part":{"id":"prt_cdda54a7d001W7C5ox36D4Ulvq","sessionID":"ses_3225b056affeIKEEihnMYwMnTu","messageID":"msg_cdda53521001UuGUukGjwCgh80","type":"tool","callID":"toolu_01NZQfCdqrMpmn2rYtFuFjy7","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/lib/validate.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/lib/validate.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * validate.ts — Input validation / hardening for agent-ready CLI.\n3:  *\n4:  * All user/agent-supplied inputs pass through these validators at the CLI\n5:  * boundary. This prevents hallucinated inputs from corrupting state.\n6:  *\n7:  * Rules:\n8:  *   - Feature IDs: kebab-case only, no path traversals, no query params\n9:  *   - Branch names: no control chars, no \"..\", no spaces\n10:  *   - Free-text (titles, descriptions): no control chars except \\n \\t\n11:  *   - Effort strings: ISO 8601 duration pattern only\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Patterns\n16: // ---------------------------------------------------------------------------\n17: \n18: /** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\n19: const ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n20: \n21: /** Control characters below space, excluding \\t (0x09) and \\n (0x0a) */\n22: const CONTROL_CHARS = /[\\x00-\\x08\\x0b\\x0c\\x0e-\\x1f\\x7f]/;\n23: \n24: /** Path traversal sequences */\n25: const PATH_TRAVERSAL = /\\.\\.\\//;\n26: \n27: /** Embedded query params or fragments */\n28: const QUERY_FRAGMENT = /[?#]/;\n29: \n30: /** Percent-encoded sequences (indicates double-encoding risk) */\n31: const PERCENT_ENCODED = /%[0-9a-fA-F]{2}/;\n32: \n33: /** ISO 8601 duration: P[nY][nM][nD][T[nH][nM][nS]] */\n34: const DURATION_PATTERN = /^P(?:\\d+Y)?(?:\\d+M)?(?:\\d+D)?(?:T(?:\\d+H)?(?:\\d+M)?(?:\\d+S)?)?$/;\n35: \n36: // ---------------------------------------------------------------------------\n37: // Result type\n38: // ---------------------------------------------------------------------------\n39: \n40: export interface ValidationResult {\n41:   valid: boolean;\n42:   error?: string;\n43: }\n44: \n45: function ok(): ValidationResult {\n46:   return { valid: true };\n47: }\n48: \n49: function fail(error: string): ValidationResult {\n50:   return { valid: false, error };\n51: }\n52: \n53: // ---------------------------------------------------------------------------\n54: // Validators\n55: // ---------------------------------------------------------------------------\n56: \n57: /**\n58:  * Validate a feature or subtask ID.\n59:  * Must be kebab-case, no traversals, no query params, no encoded chars.\n60:  */\n61: export function validateId(value: string, label: string = \"ID\"): ValidationResult {\n62:   if (!value || value.length === 0) {\n63:     return fail(`${label} must not be empty.`);\n64:   }\n65: \n66:   if (CONTROL_CHARS.test(value)) {\n67:     return fail(`${label} contains control characters.`);\n68:   }\n69: \n70:   if (PATH_TRAVERSAL.test(value)) {\n71:     return fail(`${label} contains path traversal sequence \"../\".`);\n72:   }\n73: \n74:   if (QUERY_FRAGMENT.test(value)) {\n75:     return fail(`${label} contains query/fragment characters (? or #).`);\n76:   }\n77: \n78:   if (PERCENT_ENCODED.test(value)) {\n79:     return fail(`${label} contains percent-encoded characters — possible double-encoding.`);\n80:   }\n81: \n82:   if (!ID_PATTERN.test(value)) {\n83:     return fail(\n84:       `${label} \"${value}\" is invalid. IDs must be kebab-case ` +\n85:       `(lowercase letters, digits, hyphens), 1–128 characters, starting with a letter or digit.`\n86:     );\n87:   }\n88: \n89:   return ok();\n90: }\n91: \n92: /**\n93:  * Validate free-text input (titles, descriptions, notes).\n94:  * Rejects control chars except \\t and \\n.\n95:  */\n96: export function validateText(value: string, label: string = \"text\"): ValidationResult {\n97:   if (CONTROL_CHARS.test(value)) {\n98:     return fail(`${label} contains control characters (non-printable bytes).`);\n99:   }\n100:   return ok();\n101: }\n102: \n103: /**\n104:  * Validate a branch name.\n105:  * No control chars, no \"..\", no spaces, no ~, ^, :, \\, ?, *, [\n106:  */\n107: export function validateBranchName(value: string, label: string = \"branch name\"): ValidationResult {\n108:   if (!value || value.length === 0) {\n109:     return fail(`${label} must not be empty.`);\n110:   }\n111: \n112:   if (CONTROL_CHARS.test(value)) {\n113:     return fail(`${label} contains control characters.`);\n114:   }\n115: \n116:   if (/\\.\\./.test(value)) {\n117:     return fail(`${label} contains \"..\" which is not allowed in git branch names.`);\n118:   }\n119: \n120:   if (/[ ~^:\\\\?*\\[]/.test(value)) {\n121:     return fail(`${label} contains characters not allowed in git branch names.`);\n122:   }\n123: \n124:   return ok();\n125: }\n126: \n127: /**\n128:  * Validate an ISO 8601 duration string.\n129:  */\n130: export function validateDuration(value: string, label: string = \"effort\"): ValidationResult {\n131:   if (!value || value.length === 0) {\n132:     return fail(`${label} must not be empty.`);\n133:   }\n134: \n135:   if (!DURATION_PATTERN.test(value)) {\n136:     return fail(\n137:       `${label} \"${value}\" is not a valid ISO 8601 duration. ` +\n138:       `Expected format: P[nY][nM][nD][T[nH][nM][nS]] (e.g., \"PT2H\", \"P1D\", \"P1DT4H30M\").`\n139:     );\n140:   }\n141: \n142:   return ok();\n143: }\n144: \n145: /**\n146:  * Validate a status value against the allowed set.\n147:  */\n148: export function validateEnum(\n149:   value: string,\n150:   allowed: readonly string[],\n151:   label: string = \"value\"\n152: ): ValidationResult {\n153:   if (!allowed.includes(value)) {\n154:     return fail(`${label} \"${value}\" is not valid. Allowed values: ${allowed.join(\", \")}`);\n155:   }\n156:   return ok();\n157: }\n158: \n159: // ---------------------------------------------------------------------------\n160: // Convenience: validate and exit on failure\n161: // ---------------------------------------------------------------------------\n162: \n163: /**\n164:  * Run a validation and exit with error message if invalid.\n165:  * For use at the CLI boundary.\n166:  */\n167: export function assertValid(result: ValidationResult): void {\n168:   if (!result.valid) {\n169:     console.error(`Validation error: ${result.error}`);\n170:     process.exit(1);\n171:   }\n172: }\n\n(End of file - total 172 lines)\n</content>","title":"src/lib/validate.ts","metadata":{"preview":"/**\n * validate.ts — Input validation / hardening for agent-ready CLI.\n *\n * All user/agent-supplied inputs pass through these validators at the CLI\n * boundary. This prevents hallucinated inputs from corrupting state.\n *\n * Rules:\n *   - Feature IDs: kebab-case only, no path traversals, no query params\n *   - Branch names: no control chars, no \"..\", no spaces\n *   - Free-text (titles, descriptions): no control chars except \\n \\t\n *   - Effort strings: ISO 8601 duration pattern only\n */\n\n// ---------------------------------------------------------------------------\n// Patterns\n// ---------------------------------------------------------------------------\n\n/** Valid feature/subtask ID: lowercase alphanumeric + hyphens, 1-128 chars */\nconst ID_PATTERN = /^[a-z0-9][a-z0-9-]{0,127}$/;\n","truncated":false,"loaded":[]},"time":{"start":1773245123595,"end":1773245123598}}}}
{"type":"text","timestamp":1773245123910,"sessionID":"ses_3225b056affeIKEEihnMYwMnTu","part":{"id":"prt_cdda543c4001ejer64bSnZUdTd","sessionID":"ses_3225b056affeIKEEihnMYwMnTu","messageID":"msg_cdda53521001UuGUukGjwCgh80","type":"text","text":"Now let me read the specific files for each bug:","time":{"start":1773245123910,"end":1773245123910}}}
{"type":"tool_use","timestamp":1773245123914,"sessionID":"ses_3225b056affeIKEEihnMYwMnTu","part":{"id":"prt_cdda54c0b001UN0ALB7mN9d2Pa","sessionID":"ses_3225b056affeIKEEihnMYwMnTu","messageID":"msg_cdda53521001UuGUukGjwCgh80","type":"tool","callID":"toolu_014e85AP57bkFQk33GdvvTUo","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/lib/schema.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/lib/schema.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * schema.ts — Declarative command/flag registry for schema introspection.\n3:  *\n4:  * Every command and flag is described in a single registry. This registry is\n5:  * the source of truth for:\n6:  *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n7:  *   2. Future help text generation\n8:  *\n9:  * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n10:  * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n11:  * features check` should eventually catch it.\n12:  */\n13: \n14: // ---------------------------------------------------------------------------\n15: // Types\n16: // ---------------------------------------------------------------------------\n17: \n18: export interface FlagDef {\n19:   /** Primary flag name, e.g. \"--dry-run\" */\n20:   name: string;\n21:   /** Short alias, e.g. \"-o\" */\n22:   alias?: string;\n23:   /** Description shown in help / schema */\n24:   description: string;\n25:   /** Type of the value: \"boolean\" flags take no value, others consume next arg */\n26:   type: \"string\" | \"number\" | \"boolean\" | \"string[]\";\n27:   /** Default value (undefined = required or absent) */\n28:   default?: unknown;\n29:   /** For enum-like flags, the set of allowed values */\n30:   enum?: readonly string[];\n31:   /** If true, this flag is required */\n32:   required?: boolean;\n33: }\n34: \n35: export interface PositionalDef {\n36:   /** Name used in usage strings, e.g. \"feature-id\" */\n37:   name: string;\n38:   description: string;\n39:   required?: boolean;\n40: }\n41: \n42: export interface CommandDef {\n43:   /** Command name as typed by the user, e.g. \"launch\" or \"features list\" */\n44:   name: string;\n45:   /** One-line summary */\n46:   summary: string;\n47:   /** Longer description */\n48:   description?: string;\n49:   /** Positional arguments */\n50:   positionals: PositionalDef[];\n51:   /** Named flags */\n52:   flags: FlagDef[];\n53:   /** Whether this command mutates state (used for dry-run indication) */\n54:   mutating: boolean;\n55:   /** Whether this command supports --dry-run */\n56:   supportsDryRun: boolean;\n57:   /** Subcommands (for \"features\" parent) */\n58:   subcommands?: CommandDef[];\n59: }\n60: \n61: // ---------------------------------------------------------------------------\n62: // Global flags (available on every command)\n63: // ---------------------------------------------------------------------------\n64: \n65: const GLOBAL_FLAGS: FlagDef[] = [\n66:   {\n67:     name: \"--output\",\n68:     alias: \"-o\",\n69:     description: \"Output format: text (default) or json\",\n70:     type: \"string\",\n71:     default: \"text\",\n72:     enum: [\"text\", \"json\"],\n73:   },\n74:   {\n75:     name: \"--force\",\n76:     description: \"Force overwrite / skip safety prompts\",\n77:     type: \"boolean\",\n78:     default: false,\n79:   },\n80: ];\n81: \n82: // ---------------------------------------------------------------------------\n83: // Command Registry\n84: // ---------------------------------------------------------------------------\n85: \n86: export const COMMAND_REGISTRY: CommandDef[] = [\n87:   // --- init ---------------------------------------------------------------\n88:   {\n89:     name: \"init\",\n90:     summary: \"Generate wombo.json config in the current project\",\n91:     description:\n92:       \"Interactive guided setup that walks through every config section. \" +\n93:       \"Creates wombo.json and .features.yml from template.\",\n94:     positionals: [],\n95:     flags: [\n96:       {\n97:         name: \"--force\",\n98:         description: \"Overwrite existing config files\",\n99:         type: \"boolean\",\n100:         default: false,\n101:       },\n102:       {\n103:         name: \"--dry-run\",\n104:         description: \"Show what would be created without writing files\",\n105:         type: \"boolean\",\n106:         default: false,\n107:       },\n108:     ],\n109:     mutating: true,\n110:     supportsDryRun: true,\n111:   },\n112: \n113:   // --- launch -------------------------------------------------------------\n114:   {\n115:     name: \"launch\",\n116:     summary: \"Launch a wave of agents to implement features\",\n117:     description:\n118:       \"Select features from .features.yml, create worktrees, and spawn agents. \" +\n119:       \"Supports multiple selection strategies.\",\n120:     positionals: [],\n121:     flags: [\n122:       { name: \"--top-priority\", description: \"Select top N features by priority\", type: \"number\" },\n123:       { name: \"--quickest-wins\", description: \"Select N features with lowest effort\", type: \"number\" },\n124:       { name: \"--priority\", description: \"Filter by priority level\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n125:       { name: \"--difficulty\", description: \"Filter by difficulty level\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n126:       { name: \"--features\", description: \"Select specific features by comma-separated IDs\", type: \"string\" },\n127:       { name: \"--all-ready\", description: \"Select all features whose dependencies are met\", type: \"boolean\", default: false },\n128:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n129:       { name: \"--model\", alias: \"-m\", description: \"Model to use (e.g., anthropic/claude-sonnet-4-20250514)\", type: \"string\" },\n130:       { name: \"--interactive\", description: \"Use tmux TUI mode instead of headless\", type: \"boolean\", default: false },\n131:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n132:       { name: \"--auto-push\", description: \"Push base branch to remote after all merges\", type: \"boolean\", default: false },\n133:       { name: \"--dry-run\", description: \"Show what would be launched without launching\", type: \"boolean\", default: false },\n134:       { name: \"--base-branch\", description: \"Base branch (default: from config)\", type: \"string\" },\n135:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n136:     ],\n137:     mutating: true,\n138:     supportsDryRun: true,\n139:   },\n140: \n141:   // --- resume -------------------------------------------------------------\n142:   {\n143:     name: \"resume\",\n144:     summary: \"Resume a previously stopped wave\",\n145:     positionals: [],\n146:     flags: [\n147:       { name: \"--max-concurrent\", description: \"Max agents running in parallel\", type: \"number\" },\n148:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n149:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n150:       { name: \"--no-tui\", description: \"Headless mode without neo-blessed TUI\", type: \"boolean\", default: false },\n151:       { name: \"--auto-push\", description: \"Push base branch to remote after merges\", type: \"boolean\", default: false },\n152:       { name: \"--base-branch\", description: \"Base branch override\", type: \"string\" },\n153:       { name: \"--max-retries\", description: \"Max retries per agent\", type: \"number\" },\n154:     ],\n155:     mutating: true,\n156:     supportsDryRun: false,\n157:   },\n158: \n159:   // --- status -------------------------------------------------------------\n160:   {\n161:     name: \"status\",\n162:     summary: \"Show the status of the current wave\",\n163:     positionals: [],\n164:     flags: [],\n165:     mutating: false,\n166:     supportsDryRun: false,\n167:   },\n168: \n169:   // --- verify -------------------------------------------------------------\n170:   {\n171:     name: \"verify\",\n172:     summary: \"Run build verification on completed agents\",\n173:     positionals: [\n174:       { name: \"feature-id\", description: \"Specific feature to verify (optional)\", required: false },\n175:     ],\n176:     flags: [\n177:       { name: \"--model\", alias: \"-m\", description: \"Model to use for verification\", type: \"string\" },\n178:       { name: \"--max-retries\", description: \"Max retries\", type: \"number\" },\n179:     ],\n180:     mutating: true,\n181:     supportsDryRun: false,\n182:   },\n183: \n184:   // --- merge --------------------------------------------------------------\n185:   {\n186:     name: \"merge\",\n187:     summary: \"Merge verified branches into the base branch\",\n188:     positionals: [\n189:       { name: \"feature-id\", description: \"Specific feature to merge (optional)\", required: false },\n190:     ],\n191:     flags: [\n192:       { name: \"--auto-push\", description: \"Push base branch to remote after merge\", type: \"boolean\", default: false },\n193:       { name: \"--dry-run\", description: \"Show what would be merged without merging\", type: \"boolean\", default: false },\n194:     ],\n195:     mutating: true,\n196:     supportsDryRun: true,\n197:   },\n198: \n199:   // --- retry --------------------------------------------------------------\n200:   {\n201:     name: \"retry\",\n202:     summary: \"Retry a failed agent\",\n203:     positionals: [\n204:       { name: \"feature-id\", description: \"Feature ID of the failed agent\", required: true },\n205:     ],\n206:     flags: [\n207:       { name: \"--model\", alias: \"-m\", description: \"Model to use\", type: \"string\" },\n208:       { name: \"--interactive\", description: \"Use tmux TUI mode\", type: \"boolean\", default: false },\n209:       { name: \"--dry-run\", description: \"Show what would be retried without retrying\", type: \"boolean\", default: false },\n210:     ],\n211:     mutating: true,\n212:     supportsDryRun: true,\n213:   },\n214: \n215:   // --- cleanup ------------------------------------------------------------\n216:   {\n217:     name: \"cleanup\",\n218:     summary: \"Remove all wave worktrees and tmux sessions\",\n219:     description: \"Kills tmux sessions, removes worktrees, removes state and log files.\",\n220:     positionals: [],\n221:     flags: [\n222:       { name: \"--dry-run\", description: \"Show what would be cleaned up without removing\", type: \"boolean\", default: false },\n223:     ],\n224:     mutating: true,\n225:     supportsDryRun: true,\n226:   },\n227: \n228:   // --- upgrade ------------------------------------------------------------\n229:   {\n230:     name: \"upgrade\",\n231:     summary: \"Check for updates and upgrade wombo\",\n232:     positionals: [],\n233:     flags: [\n234:       { name: \"--check\", description: \"Only check for updates, don't install\", type: \"boolean\", default: false },\n235:       { name: \"--version\", description: \"Install a specific version (e.g., v0.1.0)\", type: \"string\" },\n236:       { name: \"--force\", description: \"Force reinstall even if up to date\", type: \"boolean\", default: false },\n237:     ],\n238:     mutating: true,\n239:     supportsDryRun: false,\n240:   },\n241: \n242:   // --- features (parent with subcommands) ---------------------------------\n243:   {\n244:     name: \"features\",\n245:     summary: \"Manage .features.yml\",\n246:     positionals: [],\n247:     flags: [],\n248:     mutating: false,\n249:     supportsDryRun: false,\n250:     subcommands: [\n251:       {\n252:         name: \"features list\",\n253:         summary: \"List features with optional filtering\",\n254:         positionals: [],\n255:         flags: [\n256:           { name: \"--status\", description: \"Filter by status\", type: \"string\", enum: [\"backlog\", \"planned\", \"in_progress\", \"blocked\", \"in_review\", \"done\", \"cancelled\"] },\n257:           { name: \"--priority\", description: \"Filter by priority\", type: \"string\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n258:           { name: \"--difficulty\", description: \"Filter by difficulty\", type: \"string\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n259:           { name: \"--ready\", description: \"Show only ready features (backlog + deps met)\", type: \"boolean\", default: false },\n260:           { name: \"--include-archive\", description: \"Include archived features\", type: \"boolean\", default: false },\n261:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n262:         ],\n263:         mutating: false,\n264:         supportsDryRun: false,\n265:       },\n266:       {\n267:         name: \"features add\",\n268:         summary: \"Add a new feature\",\n269:         positionals: [\n270:           { name: \"id\", description: \"Feature ID (kebab-case)\", required: true },\n271:           { name: \"title\", description: \"Feature title\", required: true },\n272:         ],\n273:         flags: [\n274:           { name: \"--description\", alias: \"--desc\", description: \"Feature description\", type: \"string\" },\n275:           { name: \"--priority\", description: \"Priority level\", type: \"string\", default: \"medium\", enum: [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] },\n276:           { name: \"--difficulty\", description: \"Difficulty level\", type: \"string\", default: \"medium\", enum: [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] },\n277:           { name: \"--effort\", description: \"Effort estimate (ISO 8601 duration, e.g. PT2H)\", type: \"string\", default: \"PT1H\" },\n278:           { name: \"--depends-on\", description: \"Comma-separated dependency IDs\", type: \"string\" },\n279:           { name: \"--dry-run\", description: \"Show what would be added without writing\", type: \"boolean\", default: false },\n280:         ],\n281:         mutating: true,\n282:         supportsDryRun: true,\n283:       },\n284:       {\n285:         name: \"features set-status\",\n286:         summary: \"Change a feature's status\",\n287:         positionals: [\n288:           { name: \"feature-id\", description: \"Feature ID to update\", required: true },\n289:           { name: \"status\", description: \"New status value\", required: true },\n290:         ],\n291:         flags: [\n292:           { name: \"--dry-run\", description: \"Show what would change without writing\", type: \"boolean\", default: false },\n293:         ],\n294:         mutating: true,\n295:         supportsDryRun: true,\n296:       },\n297:       {\n298:         name: \"features check\",\n299:         summary: \"Validate .features.yml (schema, deps, duplicates, cycles)\",\n300:         positionals: [],\n301:         flags: [],\n302:         mutating: false,\n303:         supportsDryRun: false,\n304:       },\n305:       {\n306:         name: \"features archive\",\n307:         summary: \"Move done/cancelled features to archive section\",\n308:         positionals: [\n309:           { name: \"feature-id\", description: \"Specific feature to archive (optional)\", required: false },\n310:         ],\n311:         flags: [\n312:           { name: \"--dry-run\", description: \"Show what would be archived without moving\", type: \"boolean\", default: false },\n313:         ],\n314:         mutating: true,\n315:         supportsDryRun: true,\n316:       },\n317:       {\n318:         name: \"features show\",\n319:         summary: \"Show detailed information about a specific feature\",\n320:         positionals: [\n321:           { name: \"feature-id\", description: \"Feature ID to display\", required: true },\n322:         ],\n323:         flags: [\n324:           { name: \"--fields\", description: \"Comma-separated list of fields to include in output\", type: \"string\" },\n325:         ],\n326:         mutating: false,\n327:         supportsDryRun: false,\n328:       },\n329:     ],\n330:   },\n331: \n332:   // --- help ---------------------------------------------------------------\n333:   {\n334:     name: \"help\",\n335:     summary: \"Show help text\",\n336:     positionals: [],\n337:     flags: [],\n338:     mutating: false,\n339:     supportsDryRun: false,\n340:   },\n341: \n342:   // --- describe -----------------------------------------------------------\n343:   {\n344:     name: \"describe\",\n345:     summary: \"Emit JSON schema of a command's arguments and flags\",\n346:     description:\n347:       \"Machine-readable introspection for AI agents. Outputs the accepted \" +\n348:       \"positionals, flags, types, defaults, and constraints for a command.\",\n349:     positionals: [\n350:       { name: \"command\", description: \"Command to describe (e.g. 'launch', 'features add')\", required: false },\n351:     ],\n352:     flags: [],\n353:     mutating: false,\n354:     supportsDryRun: false,\n355:   },\n356: ];\n357: \n358: // ---------------------------------------------------------------------------\n359: // Lookup helpers\n360: // ---------------------------------------------------------------------------\n361: \n362: /**\n363:  * Find a command definition by name. Supports compound names like \"features list\".\n364:  */\n365: export function findCommandDef(name: string): CommandDef | undefined {\n366:   // Try direct match first\n367:   const direct = COMMAND_REGISTRY.find((c) => c.name === name);\n368:   if (direct) return direct;\n369: \n370:   // Try compound: \"features list\" -> look in features subcommands\n371:   const parts = name.split(/\\s+/);\n372:   if (parts.length === 2) {\n373:     const parent = COMMAND_REGISTRY.find((c) => c.name === parts[0]);\n374:     if (parent?.subcommands) {\n375:       return parent.subcommands.find((sc) => sc.name === name || sc.name === parts[1]);\n376:     }\n377:   }\n378: \n379:   return undefined;\n380: }\n381: \n382: /**\n383:  * Produce the JSON schema object for a command, suitable for agent consumption.\n384:  */\n385: export function commandToSchema(cmd: CommandDef): Record<string, unknown> {\n386:   const schema: Record<string, unknown> = {\n387:     command: cmd.name,\n388:     summary: cmd.summary,\n389:     mutating: cmd.mutating,\n390:     supports_dry_run: cmd.supportsDryRun,\n391:   };\n392: \n393:   if (cmd.description) {\n394:     schema.description = cmd.description;\n395:   }\n396: \n397:   if (cmd.positionals.length > 0) {\n398:     schema.positionals = cmd.positionals.map((p) => ({\n399:       name: p.name,\n400:       description: p.description,\n401:       required: p.required ?? false,\n402:     }));\n403:   }\n404: \n405:   const allFlags = [...cmd.flags, ...GLOBAL_FLAGS];\n406:   schema.flags = allFlags.map((f) => {\n407:     const entry: Record<string, unknown> = {\n408:       name: f.name,\n409:       type: f.type,\n410:       description: f.description,\n411:     };\n412:     if (f.alias) entry.alias = f.alias;\n413:     if (f.default !== undefined) entry.default = f.default;\n414:     if (f.enum) entry.enum = f.enum;\n415:     if (f.required) entry.required = true;\n416:     return entry;\n417:   });\n418: \n419:   if (cmd.subcommands?.length) {\n420:     schema.subcommands = cmd.subcommands.map((sc) => sc.name);\n421:   }\n422: \n423:   return schema;\n424: }\n425: \n426: /**\n427:  * Produce a listing of all commands (for `wombo describe` with no args).\n428:  */\n429: export function allCommandSchemas(): Record<string, unknown> {\n430:   const commands: Record<string, unknown>[] = [];\n431: \n432:   for (const cmd of COMMAND_REGISTRY) {\n433:     const entry: Record<string, unknown> = {\n434:       name: cmd.name,\n435:       summary: cmd.summary,\n436:       mutating: cmd.mutating,\n437:       supports_dry_run: cmd.supportsDryRun,\n438:     };\n439:     if (cmd.subcommands) {\n440:       entry.subcommands = cmd.subcommands.map((sc) => ({\n441:         name: sc.name,\n442:         summary: sc.summary,\n443:         mutating: sc.mutating,\n444:         supports_dry_run: sc.supportsDryRun,\n445:       }));\n446:     }\n447:     commands.push(entry);\n448:   }\n449: \n450:   return {\n451:     tool: \"wombo\",\n452:     version: \"0.0.2\",\n453:     global_flags: GLOBAL_FLAGS.map((f) => ({\n454:       name: f.name,\n455:       alias: f.alias,\n456:       type: f.type,\n457:       description: f.description,\n458:       default: f.default,\n459:     })),\n460:     commands,\n461:   };\n462: }\n\n(End of file - total 462 lines)\n</content>","title":"src/lib/schema.ts","metadata":{"preview":"/**\n * schema.ts — Declarative command/flag registry for schema introspection.\n *\n * Every command and flag is described in a single registry. This registry is\n * the source of truth for:\n *   1. `wombo describe <command>` — emits a JSON schema of accepted args\n *   2. Future help text generation\n *\n * The registry is NOT used for actual arg parsing (that's still the hand-rolled\n * switch in index.ts), but the two must stay in sync. If they drift, `wombo\n * features check` should eventually catch it.\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface FlagDef {\n  /** Primary flag name, e.g. \"--dry-run\" */\n  name: string;","truncated":false,"loaded":[]},"time":{"start":1773245123908,"end":1773245123913}}}}
