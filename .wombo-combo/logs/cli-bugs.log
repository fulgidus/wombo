{"type":"tool_use","timestamp":1773246675922,"sessionID":"ses_322435403ffe4OOvT8TwP2P2VN","part":{"id":"prt_cddbcfb50001HOO7tpAOzATbVv","sessionID":"ses_322435403ffe4OOvT8TwP2P2VN","messageID":"msg_cddbcee3c001PKVP1GxtvAR169","type":"tool","callID":"toolu_01BXenCRadHpSLFvq92TtvwG","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/add.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/add.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/add.ts — Add a new feature to the features file.\n3:  *\n4:  * Usage:\n5:  *   wombo features add <id> --title \"Feature Title\" [--description \"...\"]\n6:  *                      [--priority medium] [--difficulty easy] [--effort PT2H]\n7:  *                      [--depends-on \"feat1,feat2\"]\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   createBlankFeature,\n15:   allFeatureIds,\n16:   type Priority,\n17:   type Difficulty,\n18: } from \"../../lib/features.js\";\n19: import { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n20: \n21: // ---------------------------------------------------------------------------\n22: // Types\n23: // ---------------------------------------------------------------------------\n24: \n25: export interface FeaturesAddOptions {\n26:   projectRoot: string;\n27:   config: WomboConfig;\n28:   id: string;\n29:   title: string;\n30:   description?: string;\n31:   priority?: Priority;\n32:   difficulty?: Difficulty;\n33:   effort?: string;\n34:   dependsOn?: string[];\n35:   outputFmt?: OutputFormat;\n36:   dryRun?: boolean;\n37: }\n38: \n39: // ---------------------------------------------------------------------------\n40: // Command\n41: // ---------------------------------------------------------------------------\n42: \n43: export async function cmdFeaturesAdd(opts: FeaturesAddOptions): Promise<void> {\n44:   const { projectRoot, config } = opts;\n45:   const fmt = opts.outputFmt ?? \"text\";\n46: \n47:   if (!opts.id) {\n48:     outputError(fmt, \"Usage: wombo features add <id> --title \\\"Feature Title\\\"\");\n49:     return;\n50:   }\n51: \n52:   if (!opts.title) {\n53:     outputError(fmt, \"--title is required when adding a feature.\");\n54:     return;\n55:   }\n56: \n57:   const data = loadFeatures(projectRoot, config);\n58: \n59:   // Check for duplicate ID\n60:   const existingIds = allFeatureIds(data);\n61:   if (existingIds.includes(opts.id)) {\n62:     outputError(fmt, `Feature ID \"${opts.id}\" already exists.`);\n63:     return;\n64:   }\n65: \n66:   // Validate depends_on references\n67:   if (opts.dependsOn?.length) {\n68:     for (const dep of opts.dependsOn) {\n69:       if (!existingIds.includes(dep)) {\n70:         outputError(fmt, `Dependency \"${dep}\" does not exist in the features file.`);\n71:         return;\n72:       }\n73:     }\n74:   }\n75: \n76:   // Create the feature\n77:   const feature = createBlankFeature(opts.id, opts.title, opts.description ?? \"\", {\n78:     priority: opts.priority,\n79:     difficulty: opts.difficulty,\n80:     effort: opts.effort,\n81:   });\n82: \n83:   // Set dependencies\n84:   if (opts.dependsOn?.length) {\n85:     feature.depends_on = opts.dependsOn;\n86:   }\n87: \n88:   // Dry-run: show what would be added without writing\n89:   if (opts.dryRun) {\n90:     outputMessage(fmt, `[dry-run] Would add feature: ${opts.id} — ${opts.title}`, {\n91:       dry_run: true,\n92:       id: feature.id,\n93:       title: feature.title,\n94:       priority: feature.priority,\n95:       difficulty: feature.difficulty,\n96:       effort: feature.effort,\n97:       depends_on: feature.depends_on,\n98:     });\n99:     return;\n100:   }\n101: \n102:   // Append to features list\n103:   data.features.push(feature);\n104:   saveFeatures(projectRoot, config, data);\n105: \n106:   outputMessage(fmt, `Added feature: ${opts.id} — ${opts.title}`, {\n107:     id: feature.id,\n108:     title: feature.title,\n109:     priority: feature.priority,\n110:     difficulty: feature.difficulty,\n111:     effort: feature.effort,\n112:     depends_on: feature.depends_on,\n113:   });\n114: \n115:   if (fmt === \"text\") {\n116:     console.log(`  priority: ${feature.priority}, difficulty: ${feature.difficulty}, effort: ${feature.effort}`);\n117:     if (feature.depends_on.length > 0) {\n118:       console.log(`  depends on: ${feature.depends_on.join(\", \")}`);\n119:     }\n120:   }\n121: }\n\n(End of file - total 121 lines)\n</content>","title":"src/commands/features/add.ts","metadata":{"preview":"/**\n * features/add.ts — Add a new feature to the features file.\n *\n * Usage:\n *   wombo features add <id> --title \"Feature Title\" [--description \"...\"]\n *                      [--priority medium] [--difficulty easy] [--effort PT2H]\n *                      [--depends-on \"feat1,feat2\"]\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  createBlankFeature,\n  allFeatureIds,\n  type Priority,\n  type Difficulty,\n} from \"../../lib/features.js\";\nimport { outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n","truncated":false,"loaded":[]},"time":{"start":1773246675905,"end":1773246675921}}}}
{"type":"tool_use","timestamp":1773246676209,"sessionID":"ses_322435403ffe4OOvT8TwP2P2VN","part":{"id":"prt_cddbcfbc4001yUfVO9bVtvOdTC","sessionID":"ses_322435403ffe4OOvT8TwP2P2VN","messageID":"msg_cddbcee3c001PKVP1GxtvAR169","type":"tool","callID":"toolu_01DnxH7t5GCnY6Yo22PPHJPQ","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/lib/features.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/lib/features.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features.ts — Parse features YAML and provide feature selection/filtering.\n3:  *\n4:  * Responsibilities:\n5:  *   - Load and parse the features file with full type safety\n6:  *   - Parse ISO 8601 durations into comparable minutes\n7:  *   - Filter features by status, priority, difficulty, dependency readiness\n8:  *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n9:  *   - Resolve dependency graphs to determine which features are ready to start\n10:  *   - Write-back capability for feature management commands\n11:  */\n12: \n13: import { readFileSync, writeFileSync, existsSync } from \"node:fs\";\n14: import { resolve, dirname, join } from \"node:path\";\n15: import { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\n16: import { createInterface } from \"node:readline\";\n17: import type { WomboConfig } from \"../config.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Template path (resolved relative to this source file)\n21: // ---------------------------------------------------------------------------\n22: \n23: export const FEATURES_TEMPLATE_PATH = join(dirname(import.meta.dir), \"templates\", \".features.yml\");\n24: \n25: // ---------------------------------------------------------------------------\n26: // Types\n27: // ---------------------------------------------------------------------------\n28: \n29: export type FeatureStatus =\n30:   | \"backlog\"\n31:   | \"planned\"\n32:   | \"in_progress\"\n33:   | \"blocked\"\n34:   | \"in_review\"\n35:   | \"done\"\n36:   | \"cancelled\";\n37: \n38: export type Priority = \"critical\" | \"high\" | \"medium\" | \"low\" | \"wishlist\";\n39: \n40: export type Difficulty = \"trivial\" | \"easy\" | \"medium\" | \"hard\" | \"very_hard\";\n41: \n42: /** Allowed priority values (for validation at CLI boundary) */\n43: export const VALID_PRIORITIES: readonly Priority[] = [\"critical\", \"high\", \"medium\", \"low\", \"wishlist\"] as const;\n44: \n45: /** Allowed difficulty values (for validation at CLI boundary) */\n46: export const VALID_DIFFICULTIES: readonly Difficulty[] = [\"trivial\", \"easy\", \"medium\", \"hard\", \"very_hard\"] as const;\n47: \n48: export interface Subtask {\n49:   id: string;\n50:   title: string;\n51:   description: string;\n52:   status: FeatureStatus;\n53:   completion: number;\n54:   difficulty: Difficulty;\n55:   priority: Priority;\n56:   depends_on: string[];\n57:   effort: string;\n58:   started_at: string | null;\n59:   ended_at: string | null;\n60:   constraints: string[];\n61:   forbidden: string[];\n62:   references: string[];\n63:   notes: string[];\n64:   subtasks: Subtask[];\n65: }\n66: \n67: export interface Feature {\n68:   id: string;\n69:   title: string;\n70:   description: string;\n71:   status: FeatureStatus;\n72:   completion: number;\n73:   difficulty: Difficulty;\n74:   priority: Priority;\n75:   depends_on: string[];\n76:   effort: string;\n77:   started_at: string | null;\n78:   ended_at: string | null;\n79:   constraints: string[];\n80:   forbidden: string[];\n81:   references: string[];\n82:   notes: string[];\n83:   subtasks: Subtask[];\n84: }\n85: \n86: export interface FeaturesFile {\n87:   version: string;\n88:   meta: {\n89:     created_at: string;\n90:     updated_at: string;\n91:     project: string;\n92:     generator: string;\n93:     maintainer: string;\n94:   };\n95:   features: Feature[];\n96:   archive: Feature[];\n97: }\n98: \n99: // Priority ordering (lower = more important)\n100: const PRIORITY_ORDER: Record<Priority, number> = {\n101:   critical: 0,\n102:   high: 1,\n103:   medium: 2,\n104:   low: 3,\n105:   wishlist: 4,\n106: };\n107: \n108: // Difficulty ordering (lower = easier)\n109: const DIFFICULTY_ORDER: Record<Difficulty, number> = {\n110:   trivial: 0,\n111:   easy: 1,\n112:   medium: 2,\n113:   hard: 3,\n114:   very_hard: 4,\n115: };\n116: \n117: // ---------------------------------------------------------------------------\n118: // ISO 8601 Duration Parser\n119: // ---------------------------------------------------------------------------\n120: \n121: /**\n122:  * Parse an ISO 8601 duration string into total minutes.\n123:  * Supports: P[nD][T[nH][nM][nS]]\n124:  * Examples: PT1H -> 60, PT30M -> 30, P1D -> 1440, P2DT4H -> 3360, PT1H30M -> 90\n125:  */\n126: export function parseDurationMinutes(iso: string): number {\n127:   const match = iso.match(\n128:     /^P(?:(\\d+)D)?(?:T(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?)?$/\n129:   );\n130:   if (!match) return Infinity; // unparseable -> sort to end\n131:   const days = parseInt(match[1] || \"0\", 10);\n132:   const hours = parseInt(match[2] || \"0\", 10);\n133:   const minutes = parseInt(match[3] || \"0\", 10);\n134:   const seconds = parseInt(match[4] || \"0\", 10);\n135:   return days * 24 * 60 + hours * 60 + minutes + Math.ceil(seconds / 60);\n136: }\n137: \n138: /**\n139:  * Format minutes into a human-readable string.\n140:  */\n141: export function formatDuration(minutes: number): string {\n142:   if (minutes === Infinity) return \"unknown\";\n143:   if (minutes < 60) return `${minutes}m`;\n144:   const h = Math.floor(minutes / 60);\n145:   const m = minutes % 60;\n146:   if (h >= 24) {\n147:     const d = Math.floor(h / 24);\n148:     const rh = h % 24;\n149:     if (rh === 0 && m === 0) return `${d}d`;\n150:     if (m === 0) return `${d}d ${rh}h`;\n151:     return `${d}d ${rh}h ${m}m`;\n152:   }\n153:   return m === 0 ? `${h}h` : `${h}h ${m}m`;\n154: }\n155: \n156: // ---------------------------------------------------------------------------\n157: // Features File Existence Guard\n158: // ---------------------------------------------------------------------------\n159: \n160: /**\n161:  * Prompt the user with a yes/no question via stdin.\n162:  */\n163: function promptYesNo(question: string): Promise<boolean> {\n164:   const rl = createInterface({ input: process.stdin, output: process.stdout });\n165:   return new Promise((resolve) => {\n166:     rl.question(question, (answer) => {\n167:       rl.close();\n168:       resolve(answer.trim().toLowerCase().startsWith(\"y\"));\n169:     });\n170:   });\n171: }\n172: \n173: /**\n174:  * Ensure the features file exists before any command that needs it.\n175:  * If the file is missing, prompt the user to generate one from the template.\n176:  */\n177: export async function ensureFeaturesFile(\n178:   projectRoot: string,\n179:   config: WomboConfig\n180: ): Promise<void> {\n181:   const filePath = resolve(projectRoot, config.featuresFile);\n182: \n183:   if (existsSync(filePath)) return;\n184: \n185:   console.log(`\\nFeatures file not found: ${config.featuresFile}`);\n186: \n187:   const generate = await promptYesNo(\n188:     \"Generate a new features file from template? (y/N): \"\n189:   );\n190: \n191:   if (!generate) {\n192:     console.error(\n193:       `Cannot proceed without a features file. Create one manually or run again and accept the prompt.`\n194:     );\n195:     process.exit(1);\n196:   }\n197: \n198:   // Read template, update timestamps, write to project root\n199:   const template = readFileSync(FEATURES_TEMPLATE_PATH, \"utf-8\");\n200:   const now = new Date().toISOString();\n201:   const content = template\n202:     .replace(/created_at:\\s*\".*?\"/, `created_at: \"${now}\"`)\n203:     .replace(/updated_at:\\s*\".*?\"/, `updated_at: \"${now}\"`);\n204: \n205:   writeFileSync(filePath, content, \"utf-8\");\n206:   console.log(`Created ${config.featuresFile} from template.\\n`);\n207: }\n208: \n209: // ---------------------------------------------------------------------------\n210: // Loader\n211: // ---------------------------------------------------------------------------\n212: \n213: /**\n214:  * Load and parse the features YAML file from the project root.\n215:  * Uses config.featuresFile for the file path.\n216:  *\n217:  * Handles two error cases gracefully:\n218:  *   - Corrupted/malformed YAML → wraps the parser error with a friendly message\n219:  *   - Valid YAML but invalid schema (e.g. `features: not-an-array`) → clear schema error\n220:  */\n221: export function loadFeatures(\n222:   projectRoot: string,\n223:   config: WomboConfig\n224: ): FeaturesFile {\n225:   const filePath = resolve(projectRoot, config.featuresFile);\n226:   const raw = readFileSync(filePath, \"utf-8\");\n227: \n228:   // --- Parse raw YAML (may throw on malformed YAML) ---\n229:   let parsed: unknown;\n230:   try {\n231:     parsed = parseYaml(raw);\n232:   } catch (err: unknown) {\n233:     const reason = err instanceof Error ? err.message : String(err);\n234:     console.error(`Failed to parse ${config.featuresFile}: ${reason}`);\n235:     process.exit(1);\n236:   }\n237: \n238:   // --- Schema validation: ensure parsed result has the expected shape ---\n239:   if (parsed == null || typeof parsed !== \"object\") {\n240:     console.error(\n241:       `Invalid ${config.featuresFile}: expected a YAML mapping at the top level, ` +\n242:       `but got ${parsed === null ? \"null\" : typeof parsed}.`\n243:     );\n244:     process.exit(1);\n245:   }\n246: \n247:   const data = parsed as Record<string, unknown>;\n248: \n249:   if (data.features != null && !Array.isArray(data.features)) {\n250:     console.error(\n251:       `Invalid ${config.featuresFile}: \"features\" must be a list (array), ` +\n252:       `but got ${typeof data.features}. Check your YAML structure.`\n253:     );\n254:     process.exit(1);\n255:   }\n256: \n257:   if (data.archive != null && !Array.isArray(data.archive)) {\n258:     console.error(\n259:       `Invalid ${config.featuresFile}: \"archive\" must be a list (array), ` +\n260:       `but got ${typeof data.archive}. Check your YAML structure.`\n261:     );\n262:     process.exit(1);\n263:   }\n264: \n265:   const result = parsed as FeaturesFile;\n266: \n267:   // Normalize: ensure top-level arrays are never null/undefined (YAML parses\n268:   // empty keys as null).\n269:   result.features = result.features ?? [];\n270:   result.archive = result.archive ?? [];\n271: \n272:   for (const f of [...result.features, ...result.archive]) {\n273:     normalizeFeature(f);\n274:   }\n275: \n276:   return result;\n277: }\n278: \n279: /**\n280:  * Save the features file back to disk (for management commands).\n281:  */\n282: export function saveFeatures(\n283:   projectRoot: string,\n284:   config: WomboConfig,\n285:   data: FeaturesFile\n286: ): void {\n287:   const filePath = resolve(projectRoot, config.featuresFile);\n288:   data.meta.updated_at = new Date().toISOString();\n289:   const yaml = stringifyYaml(data, {\n290:     lineWidth: 120,\n291:     defaultKeyType: \"PLAIN\",\n292:     defaultStringType: \"PLAIN\",\n293:   });\n294:   writeFileSync(filePath, yaml, \"utf-8\");\n295: }\n296: \n297: function normalizeFeature(f: Feature | Subtask): void {\n298:   f.depends_on = f.depends_on ?? [];\n299:   f.constraints = f.constraints ?? [];\n300:   f.forbidden = f.forbidden ?? [];\n301:   f.references = f.references ?? [];\n302:   f.notes = f.notes ?? [];\n303:   f.subtasks = f.subtasks ?? [];\n304:   for (const s of f.subtasks) {\n305:     normalizeFeature(s);\n306:   }\n307: }\n308: \n309: // ---------------------------------------------------------------------------\n310: // Dependency Resolution\n311: // ---------------------------------------------------------------------------\n312: \n313: /**\n314:  * Get all feature IDs that are done (status === \"done\" or completion === 100).\n315:  */\n316: function getDoneIds(features: Feature[], archive: Feature[]): Set<string> {\n317:   const done = new Set<string>();\n318:   const collectDone = (items: (Feature | Subtask)[]) => {\n319:     for (const item of items) {\n320:       if (item.status === \"done\" || item.completion === 100) {\n321:         done.add(item.id);\n322:       }\n323:       if (item.subtasks?.length) {\n324:         collectDone(item.subtasks);\n325:       }\n326:     }\n327:   };\n328:   collectDone(features);\n329:   collectDone(archive);\n330:   return done;\n331: }\n332: \n333: /**\n334:  * Check if a feature's dependencies are all satisfied.\n335:  */\n336: export function areDependenciesMet(\n337:   feature: Feature,\n338:   doneIds: Set<string>\n339: ): boolean {\n340:   return feature.depends_on.every((dep) => doneIds.has(dep));\n341: }\n342: \n343: /**\n344:  * Get all features that are ready to start (backlog + deps met).\n345:  */\n346: export function getReadyFeatures(data: FeaturesFile): Feature[] {\n347:   const doneIds = getDoneIds(data.features, data.archive);\n348:   return data.features.filter(\n349:     (f) =>\n350:       f.status === \"backlog\" &&\n351:       f.completion === 0 &&\n352:       areDependenciesMet(f, doneIds)\n353:   );\n354: }\n355: \n356: /**\n357:  * Get done IDs (exported for use in selection error messages).\n358:  */\n359: export function getDoneFeatureIds(data: FeaturesFile): Set<string> {\n360:   return getDoneIds(data.features, data.archive);\n361: }\n362: \n363: // ---------------------------------------------------------------------------\n364: // Selection Strategies\n365: // ---------------------------------------------------------------------------\n366: \n367: export interface SelectionOptions {\n368:   /** Select top N by priority (highest priority first, then lowest effort) */\n369:   topPriority?: number;\n370:   /** Select N quickest wins (lowest effort first) */\n371:   quickestWins?: number;\n372:   /** Select all features matching this priority level */\n373:   priority?: Priority;\n374:   /** Select all features matching this difficulty level */\n375:   difficulty?: Difficulty;\n376:   /** Select specific feature IDs (comma-separated) */\n377:   featureIds?: string[];\n378:   /** Select all ready features */\n379:   allReady?: boolean;\n380: }\n381: \n382: /**\n383:  * Select features based on the given strategy.\n384:  * Always filters to only ready features (backlog + deps met) first.\n385:  */\n386: export function selectFeatures(\n387:   data: FeaturesFile,\n388:   options: SelectionOptions\n389: ): Feature[] {\n390:   const ready = getReadyFeatures(data);\n391: \n392:   if (options.allReady) {\n393:     return sortByPriorityThenEffort(ready);\n394:   }\n395: \n396:   if (options.featureIds?.length) {\n397:     const idSet = new Set(options.featureIds);\n398:     const selected = ready.filter((f) => idSet.has(f.id));\n399:     const missing = options.featureIds.filter(\n400:       (id) => !selected.find((f) => f.id === id)\n401:     );\n402:     if (missing.length) {\n403:       const allIds = data.features.map((f) => f.id);\n404:       const doneIds = getDoneIds(data.features, data.archive);\n405:       for (const m of missing) {\n406:         if (!allIds.includes(m)) {\n407:           console.error(`  Feature \"${m}\" does not exist in the features file`);\n408:         } else {\n409:           const feat = data.features.find((f) => f.id === m)!;\n410:           console.error(\n411:             `  Feature \"${m}\" is not ready (status: ${feat.status}, deps met: ${areDependenciesMet(feat, doneIds)})`\n412:           );\n413:         }\n414:       }\n415:     }\n416:     return sortByPriorityThenEffort(selected);\n417:   }\n418: \n419:   if (options.priority) {\n420:     return sortByPriorityThenEffort(\n421:       ready.filter((f) => f.priority === options.priority)\n422:     );\n423:   }\n424: \n425:   if (options.difficulty) {\n426:     return sortByEffort(ready.filter((f) => f.difficulty === options.difficulty));\n427:   }\n428: \n429:   if (options.topPriority) {\n430:     return sortByPriorityThenEffort(ready).slice(0, options.topPriority);\n431:   }\n432: \n433:   if (options.quickestWins) {\n434:     return sortByEffort(ready).slice(0, options.quickestWins);\n435:   }\n436: \n437:   // Default: return all ready, sorted by priority\n438:   return sortByPriorityThenEffort(ready);\n439: }\n440: \n441: // ---------------------------------------------------------------------------\n442: // Sorting Helpers\n443: // ---------------------------------------------------------------------------\n444: \n445: function sortByPriorityThenEffort(features: Feature[]): Feature[] {\n446:   return [...features].sort((a, b) => {\n447:     const pDiff = PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority];\n448:     if (pDiff !== 0) return pDiff;\n449:     return parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort);\n450:   });\n451: }\n452: \n453: function sortByEffort(features: Feature[]): Feature[] {\n454:   return [...features].sort(\n455:     (a, b) => parseDurationMinutes(a.effort) - parseDurationMinutes(b.effort)\n456:   );\n457: }\n458: \n459: // ---------------------------------------------------------------------------\n460: // Utility Exports\n461: // ---------------------------------------------------------------------------\n462: \n463: export { PRIORITY_ORDER, DIFFICULTY_ORDER };\n464: \n465: /**\n466:  * Get a compact summary of a feature for display.\n467:  */\n468: export function featureSummary(f: Feature): string {\n469:   const effort = formatDuration(parseDurationMinutes(f.effort));\n470:   return `[${f.priority}/${f.difficulty}] ${f.id} -- ${f.title} (${effort})`;\n471: }\n472: \n473: /**\n474:  * Recursively search a list of features (and their subtasks) for a matching ID.\n475:  */\n476: function findInList(features: Feature[], id: string): Feature | undefined {\n477:   for (const f of features) {\n478:     if (f.id === id) return f;\n479:     if (f.subtasks?.length) {\n480:       const found = findInList(f.subtasks, id);\n481:       if (found) return found;\n482:     }\n483:   }\n484:   return undefined;\n485: }\n486: \n487: /**\n488:  * Find a feature or subtask by ID across active features, their subtasks\n489:  * (recursively), and the archive list.\n490:  */\n491: export function findFeatureById(\n492:   data: FeaturesFile,\n493:   id: string\n494: ): Feature | undefined {\n495:   return (\n496:     findInList(data.features, id) ??\n497:     (data.archive ? findInList(data.archive, id) : undefined)\n498:   );\n499: }\n500: \n501: /**\n502:  * Create a blank feature with all required fields initialized.\n503:  */\n504: export function createBlankFeature(\n505:   id: string,\n506:   title: string,\n507:   description: string = \"\",\n508:   opts?: {\n509:     priority?: Priority;\n510:     difficulty?: Difficulty;\n511:     effort?: string;\n512:   }\n513: ): Feature {\n514:   return {\n515:     id,\n516:     title,\n517:     description,\n518:     status: \"backlog\",\n519:     completion: 0,\n520:     difficulty: opts?.difficulty ?? \"medium\",\n521:     priority: opts?.priority ?? \"medium\",\n522:     depends_on: [],\n523:     effort: opts?.effort ?? \"PT1H\",\n524:     started_at: null,\n525:     ended_at: null,\n526:     constraints: [],\n527:     forbidden: [],\n528:     references: [],\n529:     notes: [],\n530:     subtasks: [],\n531:   };\n532: }\n533: \n534: /**\n535:  * Get all feature IDs (active + archive), useful for validation.\n536:  */\n537: export function allFeatureIds(data: FeaturesFile): string[] {\n538:   const ids: string[] = [];\n539:   const collect = (items: (Feature | Subtask)[]) => {\n540:     for (const item of items) {\n541:       ids.push(item.id);\n542:       if (item.subtasks?.length) collect(item.subtasks);\n543:     }\n544:   };\n545:   collect(data.features);\n546:   collect(data.archive ?? []);\n547:   return ids;\n548: }\n\n(End of file - total 548 lines)\n</content>","title":"src/lib/features.ts","metadata":{"preview":"/**\n * features.ts — Parse features YAML and provide feature selection/filtering.\n *\n * Responsibilities:\n *   - Load and parse the features file with full type safety\n *   - Parse ISO 8601 durations into comparable minutes\n *   - Filter features by status, priority, difficulty, dependency readiness\n *   - Select features by various strategies (top-priority, quickest-wins, etc.)\n *   - Resolve dependency graphs to determine which features are ready to start\n *   - Write-back capability for feature management commands\n */\n\nimport { readFileSync, writeFileSync, existsSync } from \"node:fs\";\nimport { resolve, dirname, join } from \"node:path\";\nimport { parse as parseYaml, stringify as stringifyYaml } from \"yaml\";\nimport { createInterface } from \"node:readline\";\nimport type { WomboConfig } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Template path (resolved relative to this source file)","truncated":false,"loaded":[]},"time":{"start":1773246676202,"end":1773246676207}}}}
{"type":"tool_use","timestamp":1773246676643,"sessionID":"ses_322435403ffe4OOvT8TwP2P2VN","part":{"id":"prt_cddbcfcec001ruA1mM4Xp37tqm","sessionID":"ses_322435403ffe4OOvT8TwP2P2VN","messageID":"msg_cddbcee3c001PKVP1GxtvAR169","type":"tool","callID":"toolu_01CygELLuKrcugy3ufuuTUxx","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/archive.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/commands/features/archive.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * features/archive.ts — Move done/cancelled features to the archive section.\n3:  *\n4:  * Usage:\n5:  *   wombo features archive              # archive all done + cancelled\n6:  *   wombo features archive <feature-id> # archive a specific feature\n7:  *   wombo features archive --dry-run    # show what would be archived\n8:  */\n9: \n10: import type { WomboConfig } from \"../../config.js\";\n11: import {\n12:   loadFeatures,\n13:   saveFeatures,\n14:   findFeatureById,\n15:   type Feature,\n16: } from \"../../lib/features.js\";\n17: import { output, outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n18: \n19: // ---------------------------------------------------------------------------\n20: // Types\n21: // ---------------------------------------------------------------------------\n22: \n23: export interface FeaturesArchiveOptions {\n24:   projectRoot: string;\n25:   config: WomboConfig;\n26:   featureId?: string;\n27:   dryRun?: boolean;\n28:   outputFmt?: OutputFormat;\n29: }\n30: \n31: // ---------------------------------------------------------------------------\n32: // Command\n33: // ---------------------------------------------------------------------------\n34: \n35: export async function cmdFeaturesArchive(opts: FeaturesArchiveOptions): Promise<void> {\n36:   const { projectRoot, config } = opts;\n37:   const fmt = opts.outputFmt ?? \"text\";\n38: \n39:   const data = loadFeatures(projectRoot, config);\n40: \n41:   // Ensure archive array exists\n42:   if (!data.archive) {\n43:     data.archive = [];\n44:   }\n45: \n46:   let toArchive: Feature[];\n47: \n48:   if (opts.featureId) {\n49:     // Archive a specific feature\n50:     const idx = data.features.findIndex((f) => f.id === opts.featureId);\n51:     if (idx === -1) {\n52:       // Check if already in archive\n53:       if (data.archive.find((f) => f.id === opts.featureId)) {\n54:         outputMessage(fmt, `Feature \"${opts.featureId}\" is already in the archive.`);\n55:         return;\n56:       }\n57:       outputError(fmt, `Feature \"${opts.featureId}\" not found.`);\n58:       return;\n59:     }\n60:     toArchive = [data.features[idx]];\n61:   } else {\n62:     // Archive all done + cancelled features\n63:     toArchive = data.features.filter(\n64:       (f) => f.status === \"done\" || f.status === \"cancelled\"\n65:     );\n66:   }\n67: \n68:   if (toArchive.length === 0) {\n69:     outputMessage(fmt, \"No features to archive.\");\n70:     return;\n71:   }\n72: \n73:   if (opts.dryRun) {\n74:     const archived = toArchive.map((f) => ({ id: f.id, title: f.title, status: f.status }));\n75:     output(fmt, { dry_run: true, would_archive: archived }, () => {\n76:       console.log(`\\nWould archive ${toArchive.length} feature(s):\\n`);\n77:       for (const f of toArchive) {\n78:         console.log(`  ${f.id} — ${f.title} (${f.status})`);\n79:       }\n80:     });\n81:     return;\n82:   }\n83: \n84:   // Move features from active to archive\n85:   const archiveIds = new Set(toArchive.map((f) => f.id));\n86:   data.features = data.features.filter((f) => !archiveIds.has(f.id));\n87:   data.archive.push(...toArchive);\n88: \n89:   saveFeatures(projectRoot, config, data);\n90: \n91:   const archived = toArchive.map((f) => ({ id: f.id, title: f.title, status: f.status }));\n92:   output(fmt, { archived, count: archived.length }, () => {\n93:     console.log(`\\nArchived ${toArchive.length} feature(s):`);\n94:     for (const f of toArchive) {\n95:       console.log(`  ${f.id} — ${f.title} (${f.status})`);\n96:     }\n97:   });\n98: }\n\n(End of file - total 98 lines)\n</content>","title":"src/commands/features/archive.ts","metadata":{"preview":"/**\n * features/archive.ts — Move done/cancelled features to the archive section.\n *\n * Usage:\n *   wombo features archive              # archive all done + cancelled\n *   wombo features archive <feature-id> # archive a specific feature\n *   wombo features archive --dry-run    # show what would be archived\n */\n\nimport type { WomboConfig } from \"../../config.js\";\nimport {\n  loadFeatures,\n  saveFeatures,\n  findFeatureById,\n  type Feature,\n} from \"../../lib/features.js\";\nimport { output, outputError, outputMessage, type OutputFormat } from \"../../lib/output.js\";\n\n// ---------------------------------------------------------------------------\n// Types","truncated":false,"loaded":[]},"time":{"start":1773246676638,"end":1773246676642}}}}
{"type":"tool_use","timestamp":1773246677141,"sessionID":"ses_322435403ffe4OOvT8TwP2P2VN","part":{"id":"prt_cddbcff51001rXFm39HT1Z4wH8","sessionID":"ses_322435403ffe4OOvT8TwP2P2VN","messageID":"msg_cddbcee3c001PKVP1GxtvAR169","type":"tool","callID":"toolu_01RoEBcZiZ1rk3q5gxmtMnLK","tool":"read","state":{"status":"completed","input":{"filePath":"/home/fulgidus/Documents/wombo-cli-bugs/src/lib/output.ts"},"output":"<path>/home/fulgidus/Documents/wombo-cli-bugs/src/lib/output.ts</path>\n<type>file</type>\n<content>1: /**\n2:  * output.ts — Shared output helpers for agent-ready CLI.\n3:  *\n4:  * Provides a centralized way for commands to emit structured data that\n5:  * renders as human-readable text on TTY or as JSON when --output json\n6:  * is specified (or when stdout is not a TTY).\n7:  *\n8:  * Usage in commands:\n9:  *   import { output, OutputFormat } from \"../lib/output.js\";\n10:  *\n11:  *   // At the end of a command:\n12:  *   output(format, data);           // emits JSON or human text\n13:  *   outputError(format, message);   // emits error in the right format\n14:  */\n15: \n16: // ---------------------------------------------------------------------------\n17: // Types\n18: // ---------------------------------------------------------------------------\n19: \n20: export type OutputFormat = \"text\" | \"json\";\n21: \n22: // ---------------------------------------------------------------------------\n23: // Helpers\n24: // ---------------------------------------------------------------------------\n25: \n26: /**\n27:  * Determine the output format. Priority:\n28:  *   1. Explicit --output flag value\n29:  *   2. WOMBO_OUTPUT env var (for agent pipelines)\n30:  *   3. Default to \"text\"\n31:  *\n32:  * Note: We intentionally do NOT auto-detect based on TTY. Many legitimate\n33:  * use cases (bun dev, piped to less/grep, CI) have non-TTY stdout but still\n34:  * want human output. Agents should explicitly pass --output json or set\n35:  * WOMBO_OUTPUT=json.\n36:  */\n37: export function resolveOutputFormat(explicit?: string): OutputFormat {\n38:   if (explicit === \"json\") return \"json\";\n39:   if (explicit === \"text\") return \"text\";\n40:   // Check env var for agent pipelines\n41:   const env = process.env.WOMBO_OUTPUT;\n42:   if (env === \"json\") return \"json\";\n43:   return \"text\";\n44: }\n45: \n46: /**\n47:  * Emit structured data. In JSON mode, outputs a single JSON line to stdout.\n48:  * In text mode, calls the provided textRenderer callback.\n49:  */\n50: export function output(\n51:   format: OutputFormat,\n52:   data: unknown,\n53:   textRenderer: () => void\n54: ): void {\n55:   if (format === \"json\") {\n56:     console.log(JSON.stringify(data));\n57:   } else {\n58:     textRenderer();\n59:   }\n60: }\n61: \n62: /**\n63:  * Emit an error. In JSON mode, outputs {\"error\": message} to stderr.\n64:  * In text mode, outputs the message to stderr normally.\n65:  */\n66: export function outputError(format: OutputFormat, message: string, exitCode: number = 1): never {\n67:   if (format === \"json\") {\n68:     console.error(JSON.stringify({ error: message }));\n69:   } else {\n70:     console.error(message);\n71:   }\n72:   process.exit(exitCode);\n73: }\n74: \n75: /**\n76:  * Emit a success/info message. In JSON mode, outputs {\"message\": msg, ...extra}.\n77:  * In text mode, outputs the message to stdout normally.\n78:  */\n79: export function outputMessage(\n80:   format: OutputFormat,\n81:   message: string,\n82:   extra?: Record<string, unknown>\n83: ): void {\n84:   if (format === \"json\") {\n85:     console.log(JSON.stringify({ message, ...extra }));\n86:   } else {\n87:     console.log(message);\n88:   }\n89: }\n90: \n91: // ---------------------------------------------------------------------------\n92: // Field filtering for compact output (--fields)\n93: // ---------------------------------------------------------------------------\n94: \n95: /**\n96:  * Filter an object to only include the specified fields.\n97:  * If fields is undefined/empty, returns the object unchanged.\n98:  */\n99: export function filterFields<T extends Record<string, unknown>>(\n100:   obj: T,\n101:   fields?: string[]\n102: ): Partial<T> {\n103:   if (!fields || fields.length === 0) return obj;\n104:   const result: Partial<T> = {};\n105:   for (const field of fields) {\n106:     if (field in obj) {\n107:       (result as any)[field] = (obj as any)[field];\n108:     }\n109:   }\n110:   return result;\n111: }\n112: \n113: /**\n114:  * Filter an array of objects to only include specified fields per object.\n115:  * If fields is undefined/empty, returns the array unchanged.\n116:  */\n117: export function filterFieldsArray<T extends Record<string, unknown>>(\n118:   arr: T[],\n119:   fields?: string[]\n120: ): Partial<T>[] {\n121:   if (!fields || fields.length === 0) return arr;\n122:   return arr.map((obj) => filterFields(obj, fields));\n123: }\n124: \n125: /**\n126:  * Render a compact text table from an array of objects with selected fields.\n127:  * Used for text-mode --fields output.\n128:  */\n129: export function renderCompactTable(\n130:   items: Record<string, unknown>[],\n131:   fields: string[]\n132: ): void {\n133:   if (items.length === 0) return;\n134: \n135:   // Calculate column widths\n136:   const widths: Record<string, number> = {};\n137:   for (const field of fields) {\n138:     widths[field] = field.length;\n139:     for (const item of items) {\n140:       const val = String(item[field] ?? \"\");\n141:       widths[field] = Math.max(widths[field], val.length);\n142:     }\n143:   }\n144: \n145:   // Header\n146:   const header = fields.map((f) => f.padEnd(widths[f])).join(\"  \");\n147:   console.log(header);\n148:   console.log(fields.map((f) => \"─\".repeat(widths[f])).join(\"  \"));\n149: \n150:   // Rows\n151:   for (const item of items) {\n152:     const row = fields.map((f) => String(item[f] ?? \"\").padEnd(widths[f])).join(\"  \");\n153:     console.log(row);\n154:   }\n155: }\n\n(End of file - total 155 lines)\n</content>","title":"src/lib/output.ts","metadata":{"preview":"/**\n * output.ts — Shared output helpers for agent-ready CLI.\n *\n * Provides a centralized way for commands to emit structured data that\n * renders as human-readable text on TTY or as JSON when --output json\n * is specified (or when stdout is not a TTY).\n *\n * Usage in commands:\n *   import { output, OutputFormat } from \"../lib/output.js\";\n *\n *   // At the end of a command:\n *   output(format, data);           // emits JSON or human text\n *   outputError(format, message);   // emits error in the right format\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type OutputFormat = \"text\" | \"json\";","truncated":false,"loaded":[]},"time":{"start":1773246677137,"end":1773246677140}}}}
